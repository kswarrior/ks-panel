<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KS Panel Logo</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #000;
            font-family: 'Arial', sans-serif;
        }
        .logo-container {
            text-align: center;
        }
        .logo-svg {
            width: 300px;
            height: 300px;
            fill: #00FFFF;
        }
        .card {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            display: inline-block;
        }
    </style>
</head>
<body>
    <div class="logo-container">
        <svg class="logo-svg" viewBox="0 0 100 100">
            <!-- Replace with your high-quality SVG logo -->
            <circle cx="50" cy="50" r="40" stroke="#00FFFF" stroke-width="3" fill="none"/>
        </svg>
        <div class="card">
            <h1>KS Panel</h1>
            <p>Welcome to the ultimate gaming control panel.</p>
        </div>
    </div>
</body>
</html>
