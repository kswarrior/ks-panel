# Database Configuration
# Protocols: sqlite, postgres, mysql
# Default: sqlite://storage/kspanel.sqlite

# SQLite (Recommended for small setups)
DB_URL=sqlite://storage/kspanel.sqlite

# PostgreSQL
# DB_URL=postgres://ksuser:kspanelpassword@localhost:5432/kspanel

# MySQL / MariaDB
# DB_URL=mysql://ksuser:kspanelpassword@localhost:3306/kspanel

# Session Secret (Generate a strong one)
SESSION_SECRET=kspanel-session-secret-random-string
