<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %> - Login</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

<style>
  :root {
    --accent-color: #3b82f6;
    --glass-bg: rgba(10, 10, 10, 0.4);
    --glass-border: rgba(255, 255, 255, 0.05);
    --glass-blur: 24px;
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
                url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && theme.backgrounds.login) || "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" %>');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    background-attachment: fixed;
    color: #f8fafc;
    overflow-x: hidden;
  }

  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
  }

  .input-field {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .input-field:focus {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--accent-color);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-slide-up {
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
</head>

<body class="flex items-center justify-center min-h-screen p-4">

<div class="w-full max-w-[420px] animate-slide-up">
  <div class="glass rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
    <!-- Subtle Gradient Glows -->
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-blue-500/10 blur-[100px] rounded-full"></div>
    <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full"></div>

    <div class="relative z-10">
      <div class="mb-10 text-center">
        <img src="<%= logo %>" class="w-20 h-20 mx-auto mb-6 object-contain drop-shadow-2xl rounded-2xl" alt="Logo" onerror="this.src='/assets/logo.webp'">
        <h1 class="text-3xl font-extrabold tracking-tight text-white mb-1"><%= name %></h1>
        <p class="text-neutral-400 text-sm font-medium italic opacity-80 mb-4">Welcome back</p>
        <p class="text-neutral-500 text-xs font-semibold tracking-wide uppercase"><%= req.translations.login_description || 'Identify yourself to continue' %></p>
      </div>

      <form id="login-form" class="space-y-6" onsubmit="event.preventDefault(); submitForm();">
        <div class="space-y-2">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] ml-1">Email or Username</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-neutral-500 group-focus-within:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <input class="input-field w-full pl-12 pr-5 py-4 rounded-2xl text-white placeholder-neutral-600 focus:outline-none text-sm"
                   placeholder="Username or Email"
                   id="username"
                   autocomplete="username"
                   required>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] ml-1">Security Key</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-neutral-500 group-focus-within:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <input class="input-field w-full pl-12 pr-5 py-4 rounded-2xl text-white placeholder-neutral-600 focus:outline-none text-sm"
                   placeholder="••••••••••••"
                   id="password"
                   name="password"
                   type="password"
                   autocomplete="current-password"
                   required>
          </div>
        </div>

        <div class="flex items-center justify-between text-xs pt-1">
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" id="remember-me" class="w-4 h-4 rounded border-white/10 bg-white/5 text-blue-500 focus:ring-0 focus:ring-offset-0 transition-colors cursor-pointer">
            <span class="text-neutral-500 group-hover:text-neutral-300 transition-colors">Remember me</span>
          </label>
          <a href="/auth/reset-password" class="text-blue-400 hover:text-blue-300 font-bold transition-colors">Recovery</a>
        </div>

        <button type="submit" class="w-full bg-white text-black font-bold py-4 rounded-2xl hover:bg-neutral-200 active:scale-[0.98] transition-all shadow-xl shadow-white/5">
          Sign In
        </button>
      </form>

      <div class="mt-10 text-center">
        <p class="text-neutral-500 text-xs font-medium">
          Need an account?
          <a href="/register" class="text-white font-bold hover:underline ml-1">Create one</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
async function submitForm() {
  const username = document.getElementById("username").value.trim();
  const password = document.getElementById("password").value.trim();

  if (username === "" || password === "") {
    return;
  }

  const encodedUsername = encodeURIComponent(username);
  const encodedPassword = encodeURIComponent(password);

  document.location.href = `/auth/login?username=${encodedUsername}&password=${encodedPassword}`;
}
</script>

</body>
</html>
