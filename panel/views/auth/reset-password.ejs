<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %> - Reset Password</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

<style>
  :root {
    --accent-color: #3b82f6;
    --glass-bg: rgba(10, 10, 10, 0.4);
    --glass-border: rgba(255, 255, 255, 0.05);
    --glass-blur: 24px;
  }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
                url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && theme.backgrounds.login) || "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" %>');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    background-attachment: fixed;
    color: #f8fafc;
    overflow-x: hidden;
  }

  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
  }

  .input-field {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .input-field:focus {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--accent-color);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-slide-up {
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
</head>

<body class="flex items-center justify-center min-h-screen p-4">

<div class="w-full max-w-[420px] animate-slide-up">
  <div class="glass rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
    <!-- Subtle Gradient Glows -->
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-amber-500/10 blur-[100px] rounded-full"></div>
    <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-orange-500/10 blur-[100px] rounded-full"></div>

    <div class="relative z-10">
      <div class="mb-10 text-center">
        <img src="<%= logo %>" class="w-20 h-20 mx-auto mb-6 object-contain drop-shadow-2xl rounded-2xl" alt="Logo" onerror="this.src='/assets/logo.webp'">
        <h1 class="text-3xl font-extrabold tracking-tight text-white mb-1"><%= name %></h1>
        <p class="text-neutral-400 text-sm font-medium italic opacity-80 mb-4">Reset Password</p>
        <p class="text-neutral-500 text-xs font-semibold tracking-wide uppercase">Enter your email to receive a link</p>
      </div>

      <form action="/auth/reset-password" method="POST" class="space-y-6">
        <div class="space-y-2">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] ml-1">Email Link</label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-neutral-500 group-focus-within:text-amber-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <input class="input-field w-full pl-12 pr-5 py-4 rounded-2xl text-white placeholder-neutral-600 focus:outline-none text-sm"
                   placeholder="you@example.com"
                   id="email"
                   name="email"
                   type="email"
                   required>
          </div>
        </div>

        <button type="submit" class="w-full bg-white text-black font-bold py-4 rounded-2xl hover:bg-neutral-200 active:scale-[0.98] transition-all shadow-xl shadow-white/5 mt-2">
          Send Reset Link
        </button>

        <% if (req.query.msg && req.query.msg === 'PasswordSent') { %>
          <div class="mt-4 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl">
            <p class="text-emerald-400 text-xs font-bold text-center italic">Instructions sent. Check your inbox.</p>
          </div>
        <% } %>

        <% if (req.query.err && req.query.err === 'EmailNotFound') { %>
          <div class="mt-4 p-4 bg-red-500/10 border border-red-500/20 rounded-2xl">
            <p class="text-red-400 text-xs font-bold text-center italic">Email not found. Try again.</p>
          </div>
        <% } %>
      </form>

      <div class="mt-10 text-center">
        <p class="text-neutral-500 text-xs font-medium">
          Remembered it?
          <a href="/login" class="text-white font-bold hover:underline ml-1">Go back</a>
        </p>
      </div>
    </div>
  </div>
</div>

</body>
</html>
