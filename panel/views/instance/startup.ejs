<%- include('components/template') %>
<main id="content" class="min-h-screen">
    <!-- Header Section -->
    <div class="bg-transparent">
        <div class="flex flex-col sm:flex-row sm:items-center px-4 sm:px-8 pt-4 sm:pt-6">
            <div class="flex-auto">
                <h1 class="text-lg sm:text-xl font-semibold leading-6 text-white tracking-tight">Manage Instance</h1>
                <p class="mt-1 tracking-tight text-sm text-neutral-400">
                    View, update, and manage an instance on the KS Panel.
                </p>
            </div>
        </div>
    </div>

    <%- include('components/instance') %>

    <!-- Main Card Container -->
    <div class="p-4 sm:p-6 lg:p-8 bg-transparent shadow-2xl border border-white/5 rounded-2xl overflow-hidden w-full max-w-5xl mx-auto card mt-4 sm:mt-6 backdrop-blur-sm">
        
        <!-- Responsive Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
            
            <!-- Left Column: Instance Startup Settings -->
            <div class="space-y-6">
                <div class="flex items-center gap-2 mb-4">
                    <div class="w-1 h-6 bg-gradient-to-b from-white/40 to-transparent rounded-full"></div>
                    <h2 class="text-base sm:text-lg font-medium text-white tracking-tight">Instance Startup Settings</h2>
                </div>

                <!-- Image Selection -->
                <div class="group">
                    <% if (instance.AltImages && instance.AltImages.length > 0) { %>
                        <label class="text-neutral-400 text-sm tracking-wide mb-2 block font-medium">Docker Image</label>
                        
                        <div class="relative">
                            <select id="image" class="w-full appearance-none rounded-xl text-sm mt-2 mb-3 transition-all duration-300 px-4 py-3 border border-neutral-700/50 bg-neutral-800/80 text-white focus:ring-2 focus:ring-white/10 focus:border-neutral-500 hover:bg-neutral-700/80 shadow-lg backdrop-blur-sm">
                                <% instance.AltImages.forEach(function(altImage) { %>
                                    <option value="<%= altImage %>" <%= instance.currentimage === altImage ? 'selected' : '' %>><%= altImage %></option>
                                <% }); %>
                            </select>
                            <!-- Custom dropdown arrow -->
                            <div class="absolute right-4 top-1/2 transform -translate-y-1/2 pointer-events-none text-neutral-400">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </div>
                        </div>

                        <button id="save-image" class="w-full sm:w-auto mt-2 rounded-xl <%= theme['button-color'] %> px-4 py-2.5 text-center text-sm font-medium shadow-lg transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 touch-manipulation">
                            <span class="flex items-center justify-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <%= req.translations.save %>
                            </span>
                        </button>
                    <% } else { %>
                        <div class="flex items-center gap-3 p-4 rounded-xl bg-neutral-800/50 border border-neutral-700/30">
                            <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <p class="text-neutral-400 text-sm">No alternative images available</p>
                        </div>
                    <% } %>
                </div>

                <% 
                    const envObject = {};
                    if (instance.Env) {
                        instance.Env.forEach(function(item) {
                            const [key, value] = item.split('=');
                            envObject[key] = value;
                        });
                    }
                %>

                <!-- Environment Variables -->
                <% if (instance.templateData && instance.templateData.Variables) { %>
                    <div class="space-y-4 mt-6">
                        <div class="flex items-center gap-2 mb-2">
                            <div class="w-1 h-4 bg-gradient-to-b from-white/30 to-transparent rounded-full"></div>
                            <h3 class="text-neutral-300 text-sm font-medium tracking-wide">Environment Variables</h3>
                        </div>
                        
                        <% Object.keys(instance.templateData.Variables).forEach(function(variableName) { %>
                            <% const variable = instance.templateData.Variables[variableName]; %>
                            <div class="variable-group p-4 rounded-xl bg-neutral-800/30 border border-white/5 hover:border-white/10 transition-all duration-300 hover:bg-neutral-800/50">
                                <label class="text-neutral-300 text-sm tracking-wide mb-2 block font-medium flex items-center gap-2">
                                    <svg class="w-3.5 h-3.5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                                    </svg>
                                    <%= variable.name || variableName %>
                                </label>
                                
                                <div class="flex flex-col sm:flex-row gap-3">
                                    <input 
                                        type="<%= variable.type || 'text' %>" 
                                        id="variable-<%= variableName %>" 
                                        value="<%= envObject[variableName] || '' %>" 
                                        class="flex-1 rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm transition-all duration-300 px-4 py-3 border border-white/10 bg-neutral-700/30 hover:bg-neutral-700/50 placeholder:text-white/20 backdrop-blur-sm"
                                        placeholder="Enter value..."
                                    >
                                    <button 
                                        id="save-variable-<%= variableName %>" 
                                        class="w-full sm:w-auto rounded-xl <%= theme['button-color'] %> px-4 py-2.5 text-center text-sm font-medium shadow-lg transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 whitespace-nowrap touch-manipulation"
                                    >
                                        <%= req.translations.save %>
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>


                <!-- Help Section -->
                <div class="mt-6 p-4 rounded-xl bg-neutral-800/20 border border-white/5">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-neutral-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <h4 class="text-neutral-300 text-sm font-medium mb-1">Need Help?</h4>
                            <p class="text-neutral-500 text-xs leading-relaxed">
                                Changes to startup settings require an instance restart to take effect. Make sure to save your work before applying changes.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // Image save functionality with loading state
    document.getElementById('save-image').addEventListener('click', function(e) {
        const btn = e.currentTarget;
        const originalContent = btn.innerHTML;
        
        // Add loading state
        btn.innerHTML = '<span class="flex items-center justify-center gap-2"><svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Saving...</span>';
        btn.disabled = true;
        
        const image = document.getElementById('image').value;
        const userId = '<%= req.user.userId %>';
        const instanceId = '<%= instance.Id %>';
        
        setTimeout(() => {
            window.location.href = `/instances/startup/changeimage/${instanceId}?image=${encodeURIComponent(image)}&user=${encodeURIComponent(userId)}`;
        }, 300);
    });

    <% if (instance.templateData && instance.templateData.Variables) { %>
        <% Object.keys(instance.templateData.Variables).forEach(function(variableName) { %>
            document.getElementById('save-variable-<%= variableName %>').addEventListener('click', function(e) {
                const btn = e.currentTarget;
                const originalText = btn.textContent;
                
                // Add loading state
                btn.innerHTML = '<svg class="animate-spin w-4 h-4 mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
                btn.disabled = true;
                
                const value = document.getElementById('variable-<%= variableName %>').value;
                const userId = '<%= req.user.userId %>';
                const instanceId = '<%= instance.Id %>';
                
                fetch(`/instances/startup/changevariable/${instanceId}?variable=<%= variableName %>&value=${encodeURIComponent(value)}&user=${encodeURIComponent(userId)}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                }).then(response => response.json())
                  .then(data => {
                      if (data.success) {
                          // Success state
                          btn.innerHTML = '<svg class="w-4 h-4 mx-auto text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
                          setTimeout(() => {
                              btn.textContent = originalText;
                              btn.disabled = false;
                          }, 1500);
                      } else {
                          throw new Error('Failed to update');
                      }
                  })
                  .catch(err => {
                      btn.textContent = 'Error';
                      btn.classList.add('bg-red-600');
                      setTimeout(() => {
                          btn.textContent = originalText;
                          btn.classList.remove('bg-red-600');
                          btn.disabled = false;
                      }, 2000);
                  });
            });
        <% }); %>
    <% } %>

    // Add smooth transitions for mobile touch feedback
    document.querySelectorAll('button, select, input').forEach(el => {
        el.addEventListener('touchstart', function() {
            this.style.transform = 'scale(0.98)';
        });
        el.addEventListener('touchend', function() {
            this.style.transform = '';
        });
    });
</script>

<style>
    /* Mobile-first responsive enhancements */
    @media (max-width: 640px) {
        .card {
            margin-left: 0.5rem;
            margin-right: 0.5rem;
            border-radius: 1rem;
        }
        
        /* Ensure touch targets are at least 44px */
        button, select, input {
            min-height: 44px;
        }
        
        /* Better spacing on small screens */
        .variable-group {
            padding: 1rem;
        }
    }
    
    /* Tablet optimizations */
    @media (min-width: 641px) and (max-width: 1024px) {
        .card {
            max-width: 100%;
            margin-left: 1rem;
            margin-right: 1rem;
        }
    }
    
    /* Desktop enhancements */
    @media (min-width: 1025px) {
        .card {
            backdrop-filter: blur(8px);
        }
    }
    
    /* Smooth scrolling */
    html {
        scroll-behavior: smooth;
    }
    
    /* Custom scrollbar for webkit browsers */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    ::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
    }
    
    ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.3);
    }
    
    /* Prevent text selection on buttons for better mobile UX */
    button {
        user-select: none;
        -webkit-user-select: none;
        -webkit-tap-highlight-color: transparent;
    }
    
    /* Focus visible for accessibility */
    *:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.3);
        outline-offset: 2px;
    }
</style>

<%- include('../components/footer') %>
