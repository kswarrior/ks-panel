<%- include('components/template') %>
<main id="content">
   <!-- Header Section -->
   <div class="bg-transparent">
      <div class="flex flex-col sm:flex-row sm:items-center px-4 sm:px-8 pt-4 pb-2 gap-2">
         <div class="flex-auto">
            <h1 class="text-lg sm:text-base font-medium leading-6 text-white">Manage Instance</h1>
            <p class="mt-1 tracking-tight text-xs sm:text-sm text-neutral-500">View, update and manage an instance on the KS Panel.</p>
         </div>
      </div>
   </div>

   <%- include('components/instance') %>

   <!-- Main Card Container -->
   <div class="px-3 sm:px-6 lg:px-8 pb-8">
      <div class="p-4 sm:p-6 lg:p-10 bg-transparent shadow-xl border border-white/5 rounded-xl overflow-hidden w-full max-w-3xl mx-auto card">
         
         <!-- Responsive Grid Layout -->
         <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
            
            <!-- Left Column: Settings -->
            <div class="w-full lg:w-1/2 flex flex-col gap-6">
               <div>
                  <h2 class="text-base sm:text-md font-medium text-white tracking-tight mb-4">Settings</h2>
                  
                  <!-- Name Input Section -->
                  <div class="space-y-4">
                     <div>
                        <label class="block text-neutral-400 text-xs sm:text-sm tracking-tight mb-2">Instance Name</label>
                        <input 
                           id="name" 
                           placeholder="My Server" 
                           value="<%= instance.Name %>" 
                           class="w-full rounded-xl focus:ring-transparent focus:border-transparent text-white text-sm mt-2 mb-6 transition hover:bg-white/5 px-4 py-2 border-white/5 bg-neutral-600/20 placeholder:text-white/20 text-white border border-black/10"
                        >
                     </div>
                     
                     <button 
                        id="save" 
                        class="w-full sm:w-auto block rounded-xl <%= theme['button-color'] %> px-3 py-2 text-center text-sm font-medium shadow-lg transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
                     >
                        Save
                     </button>
                  </div>
               </div>

               <!-- Reinstall Section -->
               <div class="mt-5 pt-4 border-t border-white/5">
                  <div>
                     <label class="block text-neutral-400 text-xs sm:text-sm tracking-tight mb-2" for="reinstall">Reinstall server</label>
                     <button 
                        id="reinstall" 
                        name="reinstall" 
                        class="w-full sm:w-auto block rounded-xl bg-red-600 px-3 py-2 text-center text-sm font-medium text-white shadow-lg hover:bg-red-500 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 mt-2" 
                        onclick="reinstall()"
                     >
                        Reinstall
                     </button>
                  </div>
               </div>
            </div>

            <!-- Right Column: Status/Info -->
            <div class="w-full lg:w-1/2 flex flex-col gap-6 lg:border-l lg:border-white/5 lg:pl-8">
               <!-- Instance Quick Stats -->
               <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                  <h3 class="text-sm font-medium text-white mb-3">Instance Status</h3>
                  <div class="space-y-2 text-xs sm:text-sm">
                     <div class="flex justify-between">
                        <span class="text-neutral-400">ID:</span>
                        <span class="text-white font-mono"><%= req.params.id %></span>
                     </div>
                     <div class="flex justify-between">
                        <span class="text-neutral-400">Status:</span>
                        <span class="text-emerald-400">Active</span>
                     </div>
                  </div>
               </div>

               <!-- Help Text -->
               <div class="bg-neutral-800/30 rounded-xl p-4 border border-white/5">
                  <h3 class="text-sm font-medium text-white mb-2">Quick Tips</h3>
                  <ul class="text-xs text-neutral-400 space-y-1 list-disc list-inside">
                     <li>Use meaningful names for easy identification</li>
                     <li>Reinstalling cannot be undone</li>
                     <li>Settings auto-save on confirmation</li>
                  </ul>
               </div>
            </div>
         </div>
      </div>
   </div>
</main>

<script>
    document.getElementById('save').addEventListener('click', function() {
        const name = document.getElementById('name').value;
        window.location.href = '/instance/<%= req.params.id %>/change/name/' + name;
    });

    async function reinstall() {
        const instanceId = '<%= req.params.id %>';
        
        if (!confirm('Are you sure you want to reinstall this server? All data will be lost.')) {
            return;
        }

        const loadingPopup = document.getElementById('loadingPopup');
        loadingPopup.classList.add('active');
        document.getElementById('loadingBar').style.width = '0%';
        document.getElementById('loadingMessage').textContent = 'Initializing...';

        try {
            const response = await fetch(`/instance/reinstall/${instanceId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            let progress = 0;
            const interval = setInterval(() => {
                if (progress < 90) {
                    progress += 10;
                    document.getElementById('loadingBar').style.width = `${progress}%`;
                    document.getElementById('loadingMessage').textContent = `Reinstalling server... ${progress}%`;
                } else {
                    clearInterval(interval);
                }
            }, 200);

            if (response.ok) {
                setTimeout(() => {
                    document.getElementById('loadingBar').style.width = '100%';
                    document.getElementById('loadingMessage').textContent = 'Server reinstalled successfully!';
                    setTimeout(() => {
                        loadingPopup.classList.remove('active');
                        window.location.href = `/instance/${instanceId}/settings`;
                    }, 1000);
                }, 2000);
            } else {
                alert('Error reinstalling server: ' + response.statusText);
                loadingPopup.classList.remove('active');
            }
        } catch (error) {
            console.error('Error during POST request:', error);
            alert('An error occurred.');
            loadingPopup.classList.remove('active');
        }
    }
</script>

<%- include('../components/footer') %>

<!-- Popup for loading -->
<div id="loadingPopup" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
   <div class="bg-white rounded-xl p-8 max-w-md w-full transform scale-95 transition-transform duration-300 mx-4">
       <h2 class="text-2xl font-medium mb-4 text-neutral-800">Reinstalling Server</h2>
       <div class="mb-4">
           <div class="w-full bg-neutral-200 rounded-full h-2.5">
               <div id="loadingBar" class="bg-neutral-400 h-2.5 rounded-full" style="width: 0%"></div>
           </div>
       </div>
       <p id="loadingMessage" class="text-center text-neutral-600">Initializing...</p>
   </div>
</div>

<style>
   #loadingPopup {
       display: none;
       opacity: 0;
       pointer-events: none;
       transition: opacity 0.3s, transform 0.3s;
   }
   
   #loadingPopup.active {
       display: flex;
       opacity: 1;
       pointer-events: auto;
   }
   
   #loadingPopup .bg-white {
       transform: scale(0.95);
       transition: transform 0.3s;
   }
   
   #loadingPopup.active .bg-white {
       transform: scale(1);
   }
   
   #loadingBar {
       transition: width 0.4s;
   }
   
   /* Mobile optimizations */
   @media (max-width: 640px) {
      .card {
         border-radius: 1rem;
      }
   }
   
   /* Ensure buttons are touch-friendly */
   button {
      min-height: 44px;
      touch-action: manipulation;
   }
   
   input, button {
      transition: all 0.2s ease-in-out;
   }
</style>
