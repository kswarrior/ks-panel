<%- include('../components/template') %>
<main id="content">
   <div class="bg-transparent">
      <div class="flex flex-col sm:flex-row sm:items-center px-4 sm:px-8 pt-4 gap-2">
         <div class="flex-auto">
            <h1 class="text-base font-medium leading-6 text-white">Manage Instance</h1>
            <p class="mt-1 tracking-tight text-sm text-neutral-500">View, update and manage an instance on the KS Panel.</p>
         </div>
         <% let query = req.query.path ? '?path=' + req.query.path : ''; %>
      </div>
  </div>
   <%- include('../components/instance') %>
   
   <div class="px-3 sm:px-6 lg:px-8 pb-8">
      <div class="p-4 sm:p-6 lg:p-10 bg-transparent shadow-xl border border-white/5 rounded-xl overflow-hidden w-full max-w-3xl mx-auto card">
         
         <!-- Responsive Layout: Stack on mobile, side-by-side on desktop -->
         <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
            
            <!-- Left Column: FTP Details -->
            <div class="w-full lg:w-1/2 flex flex-col gap-4">
               <h2 class="text-md font-medium text-white tracking-tight mb-2">FTP Details</h2>
               
               <!-- Server Address -->
               <div class="w-full">
                  <label class="block text-neutral-400 text-sm tracking-tight mb-2">Server Address</label>
                  <div 
                     onclick="navigator.clipboard.writeText(`ftp://<%- loginData.host %>:<%- loginData.port %>`)" 
                     class="w-full rounded-xl focus:ring-transparent focus:border-transparent text-white text-sm mt-2 mb-4 transition hover:bg-white/5 px-4 py-2 flex bg-neutral-600/20 placeholder:text-white/20 border border-black/10 cursor-pointer group relative overflow-hidden"
                  >
                     <span class="truncate">ftp://<%- loginData.host %>:<%- loginData.port %></span>
                     <svg class="w-4 h-4 ml-auto text-neutral-500 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                     </svg>
                  </div>
               </div>

               <!-- Username -->
               <div class="w-full">
                  <label class="block text-neutral-400 text-sm tracking-tight mb-2">Username</label>
                  <div 
                     onclick="navigator.clipboard.writeText('<%- loginData.username %>');" 
                     class="w-full rounded-xl focus:ring-transparent focus:border-transparent text-white text-sm mt-2 mb-4 transition hover:bg-white/5 px-4 py-2 flex bg-neutral-600/20 placeholder:text-white/20 border border-black/10 cursor-pointer group relative overflow-hidden"
                  >
                     <span id="usernameText" class="truncate"><%- loginData.username %></span>
                     <svg class="w-4 h-4 ml-auto text-neutral-500 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                     </svg>
                  </div>
               </div>

               <!-- Password with Blur Effect -->
               <div class="w-full">
                  <label class="block text-neutral-400 text-sm tracking-tight mb-2">Password</label>
                  <div 
                     onclick="navigator.clipboard.writeText('<%- loginData.password %>');" 
                     class="w-full rounded-xl focus:ring-transparent focus:border-transparent text-white text-sm mt-2 mb-4 transition hover:bg-white/5 px-4 py-2 flex bg-neutral-600/20 placeholder:text-white/20 border border-black/10 cursor-pointer group relative overflow-hidden"
                  >
                     <span 
                        id="passwordText" 
                        style="filter: blur(5px); transition: filter 0.2s ease;" 
                        onmouseover="this.style.filter = 'none';" 
                        onmouseout="this.style.filter = 'blur(5px)';"
                        class="truncate select-none"
                     ><%- loginData.password %></span>
                     <svg class="w-4 h-4 ml-auto text-neutral-500 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                     </svg>
                  </div>
               </div>

               <!-- Connect Button -->
               <button 
                  class="w-full sm:w-auto block mt-4 rounded-xl <%= theme['button-color'] %> px-3 py-2 text-center text-sm font-medium shadow-lg transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" 
                  onclick="loginToWinSCP()"
               >
                  Connect via your FTP client
               </button>
               
               <script>
                  function loginToWinSCP() {
                      const username = "<%- loginData.username %>";
                      const password = "<%- loginData.password %>";
                      const hostname = "<%- loginData.host %>";
                      const port = "<%- loginData.port %>";
          
                      const winscpUrl = `ftp://${username}:${password}@${hostname}:${port}`;
                      window.location.href = winscpUrl;
                  }
              </script>
            </div>

            <!-- Right Column: Connection Guide -->
            <div class="w-full lg:w-1/2 flex flex-col gap-4 lg:border-l lg:border-white/5 lg:pl-8 pt-6 lg:pt-0 border-t lg:border-t-0 border-white/5">
               <h2 class="text-md font-medium text-white tracking-tight mb-2">Connection Guide</h2>
               
               <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                  <h3 class="text-sm font-medium text-white mb-3">Quick Connect</h3>
                  <p class="text-xs text-neutral-400 mb-3">Click the button below to open your default FTP client automatically with pre-filled credentials.</p>
                  <div class="flex items-center gap-2 text-xs text-neutral-500">
                     <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                     </svg>
                     <span>Requires FTP client installed (FileZilla, WinSCP, etc.)</span>
                  </div>
               </div>

               <div class="bg-neutral-800/30 rounded-xl p-4 border border-white/5">
                  <h3 class="text-sm font-medium text-white mb-2">Manual Setup</h3>
                  <ul class="text-xs text-neutral-400 space-y-2">
                     <li class="flex items-start gap-2">
                        <span class="text-neutral-500 mt-0.5">1.</span>
                        <span>Open your preferred FTP client</span>
                     </li>
                     <li class="flex items-start gap-2">
                        <span class="text-neutral-500 mt-0.5">2.</span>
                        <span>Enter the server address and port shown on the left</span>
                     </li>
                     <li class="flex items-start gap-2">
                        <span class="text-neutral-500 mt-0.5">3.</span>
                        <span>Use the provided username and password</span>
                     </li>
                     <li class="flex items-start gap-2">
                        <span class="text-neutral-500 mt-0.5">4.</span>
                        <span>Click any field to copy to clipboard</span>
                     </li>
                  </ul>
               </div>

               <div class="bg-white/5 rounded-xl p-4 border border-white/5">
                  <h3 class="text-sm font-medium text-white mb-2">Security Note</h3>
                  <p class="text-xs text-neutral-400">Password is blurred by default. Hover to reveal. Click any credential field to copy instantly to clipboard.</p>
               </div>
            </div>
         </div>
      </div>
   </div>
</main>

<%- include('../components/footer') %>

<style>
   /* Preserve original blur transition */
   #passwordText {
      filter: blur(5px);
      transition: filter 0.2s ease;
   }
   
   /* Custom scrollbar */
   ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
   }
   
   ::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.1);
   }
   
   ::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.2);
      border-radius: 4px;
   }
   
   ::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.3);
   }
   
   /* Touch device optimizations */
   @media (max-width: 640px) {
      .card {
         border-radius: 1rem;
      }
   }
   
   /* Prevent text selection on click-to-copy elements */
   .cursor-pointer span {
      user-select: all;
      -webkit-user-select: all;
   }
   
   /* Ensure buttons are touch-friendly */
   button {
      min-height: 44px;
      touch-action: manipulation;
   }
   
   /* Smooth transitions */
   input, button, div {
      transition: all 0.2s ease-in-out;
   }
   
   /* Truncate long text */
   .truncate {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
   }
</style>
