<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    /* ============================================
       INSTANCE MANAGER - MATCHED TO LIST PAGE (white/opacity theme + rounded-2xl + hover:scale)
       ============================================ */
    :root {
        /* Colors - EXACTLY matched to your instances list page */
        --im-bg-primary: transparent;
        --im-bg-secondary: rgb(255 255 255 / 0.05);
        --im-bg-tertiary: rgb(255 255 255 / 0.08);
        --im-bg-hover: rgb(255 255 255 / 0.08);
        
        --im-accent-primary: #3b82f6;
        --im-accent-primary-hover: #2563eb;
        --im-accent-success: #10b981;
        --im-accent-success-hover: #059669;
        --im-accent-danger: #ef4444;
        --im-accent-danger-hover: #dc2626;
        --im-accent-warning: #f59e0b;
        
        --im-text-primary: #f9fafb;
        --im-text-secondary: #9ca3af;
        --im-text-muted: #6b7280;
        
        --im-border-color: rgb(255 255 255 / 0.1);
        --im-border-color-hover: rgb(255 255 255 / 0.15);
        
        /* Spacing */
        --im-space-xs: 0.25rem;
        --im-space-sm: 0.5rem;
        --im-space-md: 0.75rem;
        --im-space-lg: 1rem;
        --im-space-xl: 1.5rem;
        --im-space-2xl: 2rem;
        --im-space-3xl: 3rem;
        
        /* Typography */
        --im-font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --im-font-mono: 'JetBrains Mono', 'Fira Code', 'Menlo', Monaco, monospace;
        
        /* Effects */
        --im-shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
        --im-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
        --im-shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3);
        --im-shadow-glow-blue: 0 0 20px rgba(59, 130, 246, 0.3);
        --im-shadow-glow-green: 0 0 20px rgba(16, 185, 129, 0.3);
        --im-shadow-glow-red: 0 0 20px rgba(239, 68, 68, 0.3);
        
        /* Radius - matched to list page rounded-2xl */
        --im-radius-sm: 6px;
        --im-radius-md: 8px;
        --im-radius-lg: 16px;
        --im-radius-xl: 16px;
        
        --im-transition-fast: 150ms ease;
        --im-transition-base: 250ms ease;
    }

    /* BASE - transparent like list page */
    .im-container * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .im-container {
        font-family: var(--im-font-sans);
        background: transparent;
        color: var(--im-text-primary);
        line-height: 1.5;
        width: 100%;
    }

    /* CARDS - exact list page look */
    .im-info-card,
    .im-terminal-wrap,
    .im-stat-card {
        background-color: var(--im-bg-secondary);
        border: 1px solid var(--im-border-color);
        border-radius: var(--im-radius-lg);
        transition: all var(--im-transition-base);
    }

    .im-info-card:hover,
    .im-terminal-wrap:hover,
    .im-stat-card:hover {
        background-color: var(--im-bg-hover);
        border-color: var(--im-border-color-hover);
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3);
    }

    /* All other styles (terminal, buttons, stats, alert, etc.) remain 100% functional */
    /* (only colors & hover are updated - everything else is untouched) */

    .im-header { display: none; } /* we use list page header instead */

    .im-page-wrapper {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
    }

    /* ACTION BUTTONS */
    .im-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .im-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--im-space-sm);
        padding: var(--im-space-sm) var(--im-space-md);
        font-size: 0.875rem;
        font-weight: 500;
        border: none;
        border-radius: var(--im-radius-md);
        cursor: pointer;
        transition: all var(--im-transition-fast);
        color: white;
        position: relative;
        overflow: hidden;
        white-space: nowrap;
        min-width: 100px;
    }

    .im-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .im-btn svg {
        width: 16px;
        height: 16px;
    }

    .im-btn-start { background-color: var(--im-accent-success); }
    .im-btn-start:hover:not(:disabled) {
        background-color: var(--im-accent-success-hover);
        box-shadow: var(--im-shadow-glow-green);
    }

    .im-btn-restart { background-color: var(--im-accent-primary); }
    .im-btn-restart:hover:not(:disabled) {
        background-color: var(--im-accent-primary-hover);
        box-shadow: var(--im-shadow-glow-blue);
    }

    .im-btn-stop { background-color: var(--im-accent-danger); }
    .im-btn-stop:hover:not(:disabled) {
        background-color: var(--im-accent-danger-hover);
        box-shadow: var(--im-shadow-glow-red);
    }

    .im-btn.loading svg {
        animation: im-spin 1s linear infinite;
    }

    @keyframes im-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* TERMINAL, STATS, ALERT - keep original but now use matched colors */
    .im-terminal-wrap {
        overflow: hidden;
        box-shadow: var(--im-shadow-lg);
        display: flex;
        flex-direction: column;
    }

    .im-terminal-header,
    .im-terminal-input {
        background-color: var(--im-bg-tertiary);
        border-color: var(--im-border-color);
    }

    .im-terminal-body {
        flex: 1;
        min-height: 350px;
        height: 400px;
    }

    @media (min-width: 768px) { .im-terminal-body { height: 500px; } }
    @media (min-width: 1024px) { .im-terminal-body { height: 600px; } }

    #im-terminal { width: 100%; height: 100%; padding: var(--im-space-md); }

    .xterm { padding: 0 !important; }
    .xterm-viewport { background-color: transparent !important; }

    .im-stat-card {
        padding: var(--im-space-lg);
        height: 120px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

    .im-stat-card canvas {
        position: absolute;
        inset: 0;
        opacity: 0.15;
        pointer-events: none;
    }

    .im-info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    @media (min-width: 640px) { .im-info-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .im-info-grid { grid-template-columns: repeat(4, 1fr); } }

    .im-alert {
        background-color: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: var(--im-radius-lg);
        padding: var(--im-space-lg);
        margin-bottom: var(--im-space-xl);
        display: flex;
        align-items: center;
        gap: var(--im-space-md);
    }

    /* NOTIFICATION */
    #im-notification {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        padding: 1rem 1.5rem;
        background-color: var(--im-bg-secondary);
        border: 1px solid var(--im-border-color);
        border-radius: var(--im-radius-lg);
        color: var(--im-text-primary);
        font-size: 0.875rem;
        font-weight: 500;
        box-shadow: var(--im-shadow-lg);
        z-index: 50;
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
        max-width: calc(100vw - 2rem * 2);
    }

    #im-notification.show {
        transform: translateY(0);
        opacity: 1;
    }

    @media (max-width: 640px) {
        #im-notification {
            left: 1rem;
            right: 1rem;
            bottom: 1rem;
        }
    }

    /* MOBILE & TOUCH */
    @media (max-width: 639px) {
        .im-btn { min-width: 48px; height: 40px; }
        .im-info-card { padding: 1rem; }
        .im-stat-card { height: 100px; padding: 1rem; }
    }

    @media (hover: none) and (pointer: coarse) {
        .im-info-card:hover,
        .im-terminal-wrap:hover,
        .im-stat-card:hover {
            transform: none;
        }
    }
</style>

<main id="content">
    <!-- HEADER - EXACT same layout, padding, colors and responsive as your instances list page -->
    <div class="bg-transparent">
        <div class="flex items-center justify-between px-4 sm:px-8 pt-4 flex-wrap gap-4">
            <!-- Left: Title + Subtitle -->
            <div class="flex-1 min-w-0">
                <h1 class="text-base font-medium text-white"><%= req.translations.manageInstance %></h1>
                <p class="text-sm text-neutral-400"><%= req.translations.manageInstanceText %></p>
            </div>

            <!-- Right: Power Buttons -->
            <div class="flex flex-wrap gap-3">
                <button id="im-startBtn" type="button" class="im-btn im-btn-start">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="im-btn-text"><%= req.translations.start %></span>
                </button>
                
                <button id="im-restartBtn" type="button" class="im-btn im-btn-restart">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="im-btn-text"><%= req.translations.restart %></span>
                </button>
                
                <button id="im-stopBtn" type="button" class="im-btn im-btn-stop">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="im-btn-text"><%= req.translations.stop %></span>
                </button>
            </div>
        </div>
    </div>

    <%- include('../components/instance') %>

    <!-- ALL CONTENT WRAPPED IN EXACT SAME PADDING AS LIST PAGE -->
    <div class="px-4 sm:px-6 lg:px-8 mt-8">
        <!-- Info Cards Grid -->
        <section class="im-info-section">
            <dl class="im-info-grid">
                <div class="im-info-card">
                    <div class="im-info-content">
                        <div class="im-info-text">
                            <dt class="im-info-label"><%= req.translations.address %></dt>
                            <dd class="im-info-value">
                                <%= instance.Node.address %><span style="color: var(--im-text-muted);">:<%= instance.Primary %></span>
                            </dd>
                        </div>
                        <div class="im-info-icon-wrap">
                            <svg class="im-info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </dl>
        </section>
        
        <!-- Daemon Down Alert -->
        <div class="im-alert im-hidden" id="im-daemonAlert">
            <div class="im-alert-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <div class="im-alert-content">
                <h3><%= req.translations.connectionFailure %></h3>
                <p><%= req.translations.connectionFailureText %></p>
            </div>
        </div>
        
        <!-- Main Layout: Console + Stats -->
        <div class="im-main">
            <!-- Console -->
            <div class="im-console-section">
                <div class="im-terminal-wrap">
                    <div class="im-terminal-header">
                        <div class="im-terminal-title">
                            <span>Instance Console</span>
                            <span class="im-terminal-badge">Live</span>
                        </div>
                        <div class="im-terminal-dots">
                            <span class="im-terminal-dot red"></span>
                            <span class="im-terminal-dot yellow"></span>
                            <span class="im-terminal-dot green"></span>
                        </div>
                    </div>
                    <div class="im-terminal-body">
                        <div id="im-terminal"></div>
                    </div>
                    <div class="im-terminal-input">
                        <span class="im-terminal-prompt">\~</span>
                        <input id="im-input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>" spellcheck="false">
                    </div>
                </div>
            </div>
            
            <!-- Stats -->
            <div class="im-stats-section">
                <div class="im-stats">
                    <div class="im-stat-card" id="im-statusCard">
                        <canvas id="im-statusChart"></canvas>
                        <div class="im-stat-content">
                            <div class="im-stat-header">
                                <span class="im-stat-label"><%= req.translations.status %></span>
                                <span class="im-stat-indicator" id="im-statusIndicator"></span>
                            </div>
                            <p id="im-status" class="im-stat-value">-</p>
                        </div>
                    </div>
                    
                    <div class="im-stat-card">
                        <canvas id="im-ramChart"></canvas>
                        <div class="im-stat-content">
                            <div class="im-stat-header">
                                <span class="im-stat-label"><%= req.translations.ramUsage %></span>
                            </div>
                            <p id="im-ram" class="im-stat-value small">-</p>
                            <p id="im-ramSub" class="im-stat-sub">Calculating...</p>
                        </div>
                    </div>
                    
                    <div class="im-stat-card">
                        <canvas id="im-cpuChart"></canvas>
                        <div class="im-stat-content">
                            <div class="im-stat-header">
                                <span class="im-stat-label"><%= req.translations.cpuUsage %></span>
                            </div>
                            <p id="im-cpu" class="im-stat-value">-</p>
                        </div>
                    </div>
                    
                    <div class="im-stat-card">
                        <canvas id="im-diskChart" class="im-hidden"></canvas>
                        <div class="im-stat-content">
                            <div class="im-stat-header">
                                <span class="im-stat-label"><%= req.translations.diskUsage %></span>
                            </div>
                            <p id="im-disk" class="im-stat-value small">-</p>
                            <p id="im-diskSub" class="im-stat-sub">Calculating...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Notification Toast -->
<div id="im-notification" role="status" aria-live="polite"></div>

<script>
    // ============================================
    // INSTANCE MANAGER - OPTIMISTIC IMPLEMENTATION
    // ============================================
    
    // Theme configuration
    const imTheme = {
        foreground: '#e5e7eb',
        background: 'transparent',
        selection: 'rgba(59, 130, 246, 0.3)',
        black: '#0f0f13',
        brightBlack: '#1a1a1f',
        red: '#ef4444',
        brightRed: '#f87171',
        green: '#10b981',
        brightGreen: '#34d399',
        yellow: '#f59e0b',
        brightYellow: '#fbbf24',
        blue: '#3b82f6',
        brightBlue: '#60a5fa',
        magenta: '#a855f7',
        brightMagenta: '#c084fc',
        cyan: '#06b6d4',
        brightCyan: '#22d3ee',
        white: '#f9fafb',
        brightWhite: '#ffffff',
        cursor: '#3b82f6',
        cursorAccent: '#1a1a1f',
    };
    
    // State management
    const imState = {
        protocol: window.location.protocol === 'https:' ? 'wss' : 'ws',
        instanceId: '<%= req.params.id %>',
        maxCommands: 50,
        commandHistory: [],
        currentCommandIndex: -1,
        term: null,
        ws: null,
        statsWs: null,
        reconnectAttempts: 0,
        maxReconnectAttempts: 10,
        charts: {},
        lastStats: null,
        isRunning: false
    };
    
    // Utilities
    const imUtils = {
        debounce: (fn, delay) => {
            let timeout;
            return (...args) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => fn(...args), delay);
            };
        },
        
        throttle: (fn, limit) => {
            let inThrottle;
            return (...args) => {
                if (!inThrottle) {
                    fn(...args);
                    inThrottle = true;
                    setTimeout(() => inThrottle = false, limit);
                }
            };
        },
        
        formatBytes: (bytes, decimals = 2) => {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        },
        
        isValidJson: (str) => {
            try {
                JSON.parse(str);
                return true;
            } catch {
                return false;
            }
        },
        
        showNotification: (message, type = 'info') => {
            const notification = document.getElementById('im-notification');
            notification.textContent = message;
            notification.className = 'show';
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    };
    
    // ============================================
    // TERMINAL INITIALIZATION
    // ============================================
    
    function imInitTerminal() {
        const screenWidth = window.innerWidth;
        const isMobile = screenWidth < 640;
        const isTablet = screenWidth < 1024;
        
        const config = {
            cols: isMobile ? 40 : isTablet ? 80 : 100,
            rows: isMobile ? 20 : 24,
            fontSize: isMobile ? 12 : 14,
        };
        
        imState.term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.5,
            rows: config.rows,
            cols: config.cols,
            fontFamily: 'JetBrains Mono, Fira Code, Menlo, Monaco, Courier New, monospace',
            fontSize: config.fontSize,
            theme: imTheme,
            allowTransparency: true,
            cursorBlink: false,
            scrollback: 5000,
            smoothScrollDuration: 0,
            fastScrollModifier: 'alt',
            fastScrollSensitivity: 5,
        });
        
        imState.term.open(document.getElementById('im-terminal'));
        
        const handleResize = imUtils.debounce(() => {
            const newWidth = window.innerWidth;
            const newIsMobile = newWidth < 640;
            const newIsTablet = newWidth < 1024;
            
            const newConfig = {
                cols: newIsMobile ? 40 : newIsTablet ? 80 : 100,
                rows: newIsMobile ? 20 : 24,
            };
            
            imState.term.resize(newConfig.cols, newConfig.rows);
        }, 250);
        
        window.addEventListener('resize', handleResize, { passive: true });
    }
    
    // ============================================
    // WEBSOCKET MANAGEMENT
    // ============================================
    
    function imInitWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `\( {imState.protocol}:// \){window.location.hostname}\( {port}/console/ \){imState.instanceId}`;
        
        imState.ws = new WebSocket(wsUrl);
        
        imState.ws.onopen = () => {
            console.log('[InstanceManager] WebSocket connected');
            imState.reconnectAttempts = 0;
            document.getElementById('im-daemonAlert').classList.add('im-hidden');
        };
        
        imState.ws.onmessage = imHandleWsMessage;
        
        imState.ws.onclose = () => {
            if (imState.reconnectAttempts < imState.maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, imState.reconnectAttempts), 30000);
                setTimeout(imInitWebSocket, delay);
                imState.reconnectAttempts++;
            }
        };
        
        imState.ws.onerror = (error) => {
            console.error('[InstanceManager] WebSocket error:', error);
        };
    }
    
    function imHandleWsMessage(msg) {
        const lines = msg.data.split('\n');
        let isFirstLine = true;
        let previousLineWasEmpty = false;
        let output = '';
        
        lines.forEach(line => {
            const trimmedLine = line.trim();
            if (trimmedLine === '' && previousLineWasEmpty) return;
            
            if (!isFirstLine && !previousLineWasEmpty) {
                output += '\r\n';
            }
            
            output += '\x1b[0m' + trimmedLine;
            
            if (trimmedLine.includes("Working on")) {
                output += '\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...';
                imState.ws.close();
            }
            
            if (trimmedLine.includes("KS Wings instance appears to be down")) {
                imState.ws.close();
                document.getElementById('im-daemonAlert').classList.remove('im-hidden');
            }
            
            isFirstLine = false;
            previousLineWasEmpty = (trimmedLine === '');
        });
        
        imState.term.write(output);
    }
    
    // ============================================
    // STATS WEBSOCKET
    // ============================================
    
    function imInitStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `\( {imState.protocol}:// \){window.location.hostname}\( {port}/stats/ \){imState.instanceId}`;
        
        imState.statsWs = new WebSocket(wsUrl);
        
        imState.statsWs.onmessage = imUtils.throttle((event) => {
            if (!imUtils.isValidJson(event.data)) return;
            
            const stats = JSON.parse(event.data);
            if (stats.error) {
                console.error('[InstanceManager] Stats error:', stats.error);
                return;
            }
            
            imState.lastStats = stats;
            imUpdateStats(stats);
        }, 1000);
        
        imState.statsWs.onclose = () => {
            setTimeout(imInitStatsWebSocket, 5000);
        };
    }
    
    // ============================================
    // STATS CHARTS
    // ============================================
    
    function imInitCharts() {
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false, min: 0, max: 100 } },
            animation: { duration: 0 },
            elements: { point: { radius: 0 }, line: { borderWidth: 2, tension: 0.4 } }
        };
        
        const createChart = (id, color, type = 'line') => {
            const ctx = document.getElementById(id);
            if (!ctx) return null;
            
            return new Chart(ctx, {
                type: type,
                data: {
                    labels: Array(20).fill(''),
                    datasets: [{
                        data: Array(20).fill(0),
                        borderColor: color,
                        backgroundColor: type === 'line' ? `\( {color}20` : ` \){color}40`,
                        fill: type === 'line',
                    }]
                },
                options: commonOptions
            });
        };
        
        imState.charts.status = createChart('im-statusChart', '#10b981');
        imState.charts.ram = createChart('im-ramChart', '#3b82f6');
        imState.charts.cpu = createChart('im-cpuChart', '#f59e0b');
    }
    
    function imUpdateStats(stats) {
        const ramUsage = stats.memory_stats?.usage || 0;
        const ramLimit = stats.memory_stats?.limit || 0;
        const ramPercent = ramLimit > 0 ? ((ramUsage / ramLimit) * 100).toFixed(1) : 0;
        
        document.getElementById('im-ram').textContent = `${ramPercent}%`;
        document.getElementById('im-ramSub').textContent = 
            `${imUtils.formatBytes(ramUsage)} / ${imUtils.formatBytes(ramLimit)}`;
        imUpdateChart(imState.charts.ram, ramPercent);
        
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const cpuPercent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        
        document.getElementById('im-cpu').textContent = `${cpuPercent}%`;
        imUpdateChart(imState.charts.cpu, cpuPercent);
        
        const diskUsage = parseFloat(stats.volumeSize) || 0;
        const diskLimit = <%= instance.Disk || 0 %>;
        const diskEl = document.getElementById('im-disk');
        const diskSubEl = document.getElementById('im-diskSub');
        
        if (diskLimit === 0) {
            diskEl.textContent = imUtils.formatBytes(diskUsage * 1024 * 1024);
            diskSubEl.textContent = 'Unlimited';
            diskEl.style.color = 'var(--im-accent-success)';
        } else {
            const diskPercent = ((diskUsage / diskLimit) * 100).toFixed(1);
            diskEl.textContent = `${diskPercent}%`;
            diskSubEl.textContent = `${imUtils.formatBytes(diskUsage * 1024 * 1024)} / ${imUtils.formatBytes(diskLimit * 1024 * 1024)}`;
            diskEl.style.color = diskPercent > 90 ? 'var(--im-accent-danger)' : diskPercent > 70 ? 'var(--im-accent-warning)' : 'var(--im-accent-success)';
        }
        
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
        imUpdateStatus(isRunning);
    }
    
    function imUpdateStatus(isRunning) {
        imState.isRunning = isRunning;
        
        const statusEl = document.getElementById('im-status');
        const statusCard = document.getElementById('im-statusCard');
        const indicator = document.getElementById('im-statusIndicator');
        
        if (isRunning) {
            statusEl.textContent = 'Online';
            statusEl.className = 'im-stat-value online';
            statusCard.classList.add('online');
            statusCard.classList.remove('offline');
            indicator.className = 'im-stat-indicator online';
            imUpdateStatusChart('#10b981');
        } else {
            statusEl.textContent = 'Offline';
            statusEl.className = 'im-stat-value offline';
            statusCard.classList.add('offline');
            statusCard.classList.remove('online');
            indicator.className = 'im-stat-indicator offline';
            imUpdateStatusChart('#ef4444');
        }
    }
    
    function imUpdateChart(chart, value) {
        if (!chart) return;
        const num = parseFloat(value) || 0;
        chart.data.datasets[0].data.push(num);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }
    
    function imUpdateStatusChart(color) {
        if (!imState.charts.status) return;
        imState.charts.status.data.datasets[0].backgroundColor = `${color}30`;
        imState.charts.status.data.datasets[0].borderColor = color;
        imState.charts.status.data.datasets[0].data = Array(20).fill(100);
        imState.charts.status.update('none');
    }
    
    // ============================================
    // COMMAND INPUT
    // ============================================
    
    function imInitCommandInput() {
        const input = document.getElementById('im-input');
        
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') imSendCommand();
        });
        
        input.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (imState.currentCommandIndex > 0) {
                    imState.currentCommandIndex--;
                    input.value = imState.commandHistory[imState.currentCommandIndex];
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (imState.currentCommandIndex < imState.commandHistory.length - 1) {
                    imState.currentCommandIndex++;
                    input.value = imState.commandHistory[imState.currentCommandIndex];
                } else {
                    imState.currentCommandIndex = imState.commandHistory.length;
                    input.value = '';
                }
            }
        });
    }
    
    function imSendCommand() {
        const input = document.getElementById('im-input');
        const command = input.value.trim();
        
        if (!command || !imState.ws) return;
        
        imState.term.write(`\r\n\u001b[1m\u001b[36m❯ \u001b[0m${command}\r\n`);
        
        imState.ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: imState.instanceId
        }));
        
        if (imState.commandHistory.length >= imState.maxCommands) {
            imState.commandHistory.shift();
        }
        imState.commandHistory.push(command);
        imState.currentCommandIndex = imState.commandHistory.length;
        
        input.value = '';
    }
    
    // ============================================
    // POWER BUTTONS - OPTIMISTIC UI
    // ============================================
    
    function imInitPowerButtons() {
        const buttons = {
            start: document.getElementById('im-startBtn'),
            restart: document.getElementById('im-restartBtn'),
            stop: document.getElementById('im-stopBtn')
        };
        
        const icons = {
            start: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/></svg>`,
            restart: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/></svg>`,
            stop: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/></svg>`
        };
        
        const labels = {
            start: '<%= req.translations.start %>',
            restart: '<%= req.translations.restart %>',
            stop: '<%= req.translations.stop %>'
        };
        
        Object.keys(buttons).forEach(action => {
            const btn = buttons[action];
            if (!btn) return;
            
            btn.addEventListener('click', async () => {
                if (!confirm(`Are you sure you want to ${action} this instance?`)) return;
                
                const originalHTML = btn.innerHTML;
                btn.disabled = true;
                btn.classList.add('loading');
                btn.innerHTML = `${icons[action]} <span class="im-btn-text">Processing...</span>`;
                
                if (action === 'start') imUpdateStatus(true);
                else if (action === 'stop') imUpdateStatus(false);
                
                try {
                    const res = await axios.post(`/instance/${imState.instanceId}/power`, { action });
                    
                    if (res.status === 200) {
                        btn.innerHTML = `\( {icons[action]} <span class="im-btn-text"> \){labels[action]}ed!</span>`;
                        btn.classList.remove('loading');
                        imUtils.showNotification(`Instance ${action}ed successfully`);
                        
                        setTimeout(() => {
                            btn.innerHTML = originalHTML;
                            btn.disabled = false;
                        }, 2000);
                    }
                } catch (err) {
                    console.error(err);
                    imUtils.showNotification(`Failed to ${action} instance`, 'error');
                    
                    btn.innerHTML = originalHTML;
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    
                    if (imState.lastStats) imUpdateStats(imState.lastStats);
                }
            });
        });
    }
    
    // ============================================
    // INITIALIZATION
    // ============================================
    
    document.addEventListener('DOMContentLoaded', () => {
        imInitTerminal();
        imInitWebSocket();
        imInitStatsWebSocket();
        imInitCharts();
        imInitCommandInput();
        imInitPowerButtons();
        
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (imState.statsWs) imState.statsWs.onmessage = null;
            } else {
                if (imState.statsWs) {
                    imState.statsWs.onmessage = imUtils.throttle((event) => {
                        if (!imUtils.isValidJson(event.data)) return;
                        const stats = JSON.parse(event.data);
                        if (!stats.error) imUpdateStats(stats);
                    }, 1000);
                }
            }
        });
    });
</script>

