<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    /* ============================================
       INSTANCE MANAGER - KS-INSTANCE DESIGN SYSTEM
       ============================================ */
    :root {
        /* Colors - Preserved exactly as requested */
        --ks-instance-bg-primary: #0f0f13;
        --ks-instance-bg-secondary: #1a1a1f;
        --ks-instance-bg-tertiary: #25252b;
        --ks-instance-bg-hover: #2a2a32;
        
        --ks-instance-accent-primary: #3b82f6;
        --ks-instance-accent-primary-hover: #2563eb;
        --ks-instance-accent-success: #10b981;
        --ks-instance-accent-success-hover: #059669;
        --ks-instance-accent-danger: #ef4444;
        --ks-instance-accent-danger-hover: #dc2626;
        --ks-instance-accent-warning: #f59e0b;
        
        --ks-instance-text-primary: #f9fafb;
        --ks-instance-text-secondary: #9ca3af;
        --ks-instance-text-muted: #6b7280;
        
        --ks-instance-border-color: rgba(255, 255, 255, 0.08);
        --ks-instance-border-color-hover: rgba(255, 255, 255, 0.15);
        
        /* Spacing */
        --ks-instance-space-xs: 0.25rem;
        --ks-instance-space-sm: 0.5rem;
        --ks-instance-space-md: 0.75rem;
        --ks-instance-space-lg: 1rem;
        --ks-instance-space-xl: 1.5rem;
        --ks-instance-space-2xl: 2rem;
        --ks-instance-space-3xl: 3rem;
        
        /* Typography */
        --ks-instance-font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --ks-instance-font-mono: 'JetBrains Mono', 'Fira Code', 'Menlo', Monaco, monospace;
        
        /* Effects */
        --ks-instance-shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
        --ks-instance-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
        --ks-instance-shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3);
        --ks-instance-shadow-glow-blue: 0 0 20px rgba(59, 130, 246, 0.3);
        --ks-instance-shadow-glow-green: 0 0 20px rgba(16, 185, 129, 0.3);
        --ks-instance-shadow-glow-red: 0 0 20px rgba(239, 68, 68, 0.3);
        
        --ks-instance-radius-sm: 6px;
        --ks-instance-radius-md: 8px;
        --ks-instance-radius-lg: 12px;
        --ks-instance-radius-xl: 16px;
        
        --ks-instance-transition-fast: 150ms ease;
        --ks-instance-transition-base: 250ms ease;
    }

    /* ============================================
       BASE STYLES
       ============================================ */
    .ks-instance-container * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .ks-instance-container {
        font-family: var(--ks-instance-font-sans);
        background-color: var(--ks-instance-bg-primary);
        color: var(--ks-instance-text-primary);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    /* ============================================
       LAYOUT CONTAINER
       ============================================ */
    .ks-instance-page-wrapper {
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        padding: var(--ks-instance-space-lg);
    }

    @media (min-width: 640px) {
        .ks-instance-page-wrapper {
            padding: var(--ks-instance-space-xl);
        }
    }

    @media (min-width: 1024px) {
        .ks-instance-page-wrapper {
            padding: var(--ks-instance-space-2xl);
        }
    }

    /* ============================================
       HEADER SECTION - Optimistic & Responsive
       ============================================ */
    .ks-instance-header {
        margin-bottom: var(--ks-instance-space-xl);
        padding-bottom: var(--ks-instance-space-lg);
        border-bottom: 1px solid var(--ks-instance-border-color);
    }

    .ks-instance-header-content {
        display: flex;
        flex-direction: column;
        gap: var(--ks-instance-space-lg);
    }

    @media (min-width: 768px) {
        .ks-instance-header-content {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-start;
        }
    }

    .ks-instance-brand {
        flex: 1;
        min-width: 0;
    }

    .ks-instance-title {
        font-size: clamp(1.25rem, 4vw, 1.875rem);
        font-weight: 700;
        color: var(--ks-instance-text-primary);
        margin-bottom: var(--ks-instance-space-sm);
        letter-spacing: -0.025em;
        line-height: 1.2;
    }

    .ks-instance-subtitle {
        font-size: clamp(0.75rem, 2vw, 0.875rem);
        color: var(--ks-instance-text-secondary);
        max-width: 600px;
        line-height: 1.5;
    }

    /* ============================================
       ACTION BUTTONS - Optimistic Interactions
       ============================================ */
    .ks-instance-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--ks-instance-space-sm);
    }

    @media (max-width: 639px) {
        .ks-instance-actions {
            width: 100%;
        }
    }

    .ks-instance-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--ks-instance-space-sm);
        padding: var(--ks-instance-space-sm) var(--ks-instance-space-md);
        font-size: 0.875rem;
        font-weight: 500;
        border: none;
        border-radius: var(--ks-instance-radius-md);
        cursor: pointer;
        transition: all var(--ks-instance-transition-fast);
        color: white;
        position: relative;
        overflow: hidden;
        white-space: nowrap;
        flex: 1;
        min-width: 80px;
    }

    @media (min-width: 640px) {
        .ks-instance-btn {
            flex: 0 0 auto;
            min-width: 100px;
        }
    }

    .ks-instance-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }

    .ks-instance-btn svg {
 {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .ks-instance-btn-start {
        background-color: var(--ks-instance-accent-success);
        box-shadow: var(--ks-instance-shadow-sm);
    }

    .ks-instance-btn-start:hover:not(:disabled) {
        background-color: var(--ks-instance-accent-success-hover);
        transform: translateY(-2px);
        box-shadow: var(--ks-instance-shadow-glow-green);
    }

    .ks-instance-btn-restart {
        background-color: var(--ks-instance-accent-primary);
        box-shadow: var(--ks-instance-shadow-sm);
    }

    .ks-instance-btn-restart:hover:not(:disabled) {
        background-color: var(--ks-instance-accent-primary-hover);
        transform: translateY(-2px);
        box-shadow: var(--ks-instance-shadow-glow-blue);
    }

    .ks-instance-btn-stop {
        background-color: var(--ks-instance-accent-danger);
        box-shadow: var(--ks-instance-shadow-sm);
    }

    .ks-instance-btn-stop:hover:not(:disabled) {
        background-color: var(--ks-instance-accent-danger-hover);
        transform: translateY(-2px);
        box-shadow: var(--ks-instance-shadow-glow-red);
    }

    .ks-instance-btn:active:not(:disabled) {
        transform: translateY(0);
    }

    /* Loading state */
    .ks-instance-btn.loading {
        pointer-events: none;
    }

    .ks-instance-btn.loading svg {
        animation: ks-instance-spin 1s linear infinite;
    }

    @keyframes ks-instance-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* ============================================
       INFO CARDS GRID - Responsive Layout
       ============================================ */
    .ks-instance-info-section {
        margin-bottom: var(--ks-instance-space-xl);
    }

    .ks-instance-info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--ks-instance-space-md);
    }

    @media (min-width: 640px) {
        .ks-instance-info-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .ks-instance-info-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .ks-instance-info-card {
        background-color: var(--ks-instance-bg-secondary);
        border: 1px solid var(--ks-instance-border-color);
        border-radius: var(--ks-instance-radius-lg);
        padding: var(--ks-instance-space-lg);
        transition: all var(--ks-instance-transition-base);
        position: relative;
        overflow: hidden;
    }

    .ks-instance-info-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--ks-instance-accent-primary), transparent);
        opacity: 0;
        transition: opacity var(--ks-instance-transition-base);
    }

    .ks-instance-info-card:hover {
        background-color: var(--ks-instance-bg-tertiary);
        border-color: var(--ks-instance-border-color-hover);
        transform: translateY(-2px);
        box-shadow: var(--ks-instance-shadow-md);
    }

    .ks-instance-info-card:hover::before {
        opacity: 1;
    }

    .ks-instance-info-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--ks-instance-space-md);
    }

    .ks-instance-info-text {
        flex: 1;
        min-width: 0;
        overflow: hidden;
    }

    .ks-instance-info-label {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ks-instance-text-muted);
        margin-bottom: var(--ks-instance-space-xs);
    }

    .ks-instance-info-value {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--ks-instance-text-primary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ks-instance-info-value-secondary {
        font-size: 0.8125rem;
        color: var(--ks-instance-text-secondary);
        margin-top: 2px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ks-instance-info-icon-wrap {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--ks-instance-bg-tertiary);
        border-radius: var(--ks-instance-radius-md);
        border: 1px solid var(--ks-instance-border-color);
        transition: all var(--ks-instance-transition-fast);
        flex-shrink: 0;
    }

    .ks-instance-info-card:hover .ks-instance-info-icon-wrap {
        background-color: var(--ks-instance-bg-hover);
        border-color: var(--ks-instance-border-color-hover);
    }

    .ks-instance-info-icon {
        width: 20px;
        height: 20px;
        color: var(--ks-instance-accent-primary);
        transition: color var(--ks-instance-transition-fast);
    }

    .ks-instance-info-card:hover .ks-instance-info-icon {
        color: var(--ks-instance-text-primary);
    }

    /* ============================================
       DAEMON ALERT
       ============================================ */
    .ks-instance-alert {
        background-color: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: var(--ks-instance-radius-lg);
        padding: var(--ks-instance-space-lg);
        margin-bottom: var(--ks-instance-space-xl);
        display: flex;
        align-items: center;
        gap: var(--ks-instance-space-md);
        animation: ks-instance-slideIn 0.3s ease;
    }

    @keyframes ks-instance-slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .ks-instance-alert.hidden {
        display: none;
    }

    .ks-instance-alert-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(239, 68, 68, 0.2);
        border-radius: var(--ks-instance-radius-md);
        color: var(--ks-instance-accent-danger);
        flex-shrink: 0;
    }

    .ks-instance-alert-content h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--ks-instance-text-primary);
        margin-bottom: var(--ks-instance-space-xs);
    }

    .ks-instance-alert-content p {
        font-size: 0.8125rem;
        color: var(--ks-instance-text-secondary);
        line-height: 1.5;
    }

    /* ============================================
       MAIN LAYOUT - Console + Stats
       ============================================ */
    .ks-instance-main {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--ks-instance-space-xl);
    }

    @media (min-width: 1024px) {
        .ks-instance-main {
            grid-template-columns: 1fr 320px;
        }
    }

    @media (min-width: 1280px) {
        .ks-instance-main {
            grid-template-columns: 1fr 380px;
        }
    }

    /* ============================================
       TERMINAL STYLES - Optimistic & Responsive
       ============================================ */
    .ks-instance-terminal-wrap {
        background-color: var(--ks-instance-bg-secondary);
        border: 1px solid var(--ks-instance-border-color);
        border-radius: var(--ks-instance-radius-lg);
        overflow: hidden;
        box-shadow: var(--ks-instance-shadow-lg);
        display: flex;
        flex-direction: column;
    }

    .ks-instance-terminal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--ks-instance-space-sm) var(--ks-instance-space-md);
        background-color: var(--ks-instance-bg-tertiary);
        border-bottom: 1px solid var(--ks-instance-border-color);
        flex-shrink: 0;
    }

    .ks-instance-terminal-title {
        font-family: var(--ks-instance-font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--ks-instance-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: var(--ks-instance-space-sm);
    }

    .ks-instance-terminal-badge {
        font-size: 0.625rem;
        padding: 2px 8px;
        background-color: var(--ks-instance-accent-success);
        color: white;
        border-radius: 9999px;
        font-weight: 600;
    }

    .ks-instance-terminal-dots {
        display: flex;
        gap: 6px;
    }

    .ks-instance-terminal-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .ks-instance-terminal-dot.red { 
        background-color: #ff5f56; 
        border: 1px solid #e0443e;
    }
    .ks-instance-terminal-dot.yellow { 
        background-color: #ffbd2e; 
        border: 1px solid #dea123;
    }
    .ks-instance-terminal-dot.green { 
        background-color: #27c93f; 
        border: 1px solid #1aab29;
    }

    .ks-instance-terminal-body {
        position: relative;
        flex: 1;
        min-height: 300px;
        height: 400px;
    }

    @media (min-width: 768px) {
        .ks-instance-terminal-body {
            height: 500px;
        }
    }

    @media (min-width: 1024px) {
        .ks-instance-terminal-body {
            height: 600px;
        }
    }

    #ks-instance-terminal {
        width: 100%;
        height: 100%;
        padding: var(--ks-instance-space-md);
    }

    .xterm {
        padding: 0 !important;
    }

    .xterm-viewport {
        background-color: transparent !important;
    }

    .xterm-viewport::-webkit-scrollbar {
        width: 8px;
    }

    .xterm-viewport::-webkit-scrollbar-track {
        background: var(--ks-instance-bg-tertiary);
    }

    .xterm-viewport::-webkit-scrollbar-thumb {
        background: var(--ks-instance-border-color-hover);
        border-radius: 4px;
    }

    .xterm-viewport::-webkit-scrollbar-thumb:hover {
        background: var(--ks-instance-text-muted);
    }

    .xterm-rows {
        font-family: var(--ks-instance-font-mono) !important;
        font-size: 13px !important;
        line-height: 1.6 !important;
    }

    .ks-instance-terminal-input {
        display: flex;
        align-items: center;
        gap: var(--ks-instance-space-sm);
        padding: var(--ks-instance-space-sm) var(--ks-instance-space-md);
        background-color: var(--ks-instance-bg-tertiary);
        border-top: 1px solid var(--ks-instance-border-color);
        flex-shrink: 0;
    }

    .ks-instance-terminal-prompt {
        font-family: var(--ks-instance-font-mono);
        color: var(--ks-instance-accent-success);
        font-weight: 600;
        font-size: 0.875rem;
        user-select: none;
        flex-shrink: 0;
    }

    #ks-instance-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--ks-instance-text-primary);
        font-family: var(--ks-instance-font-mono);
        font-size: 0.875rem;
        padding: var(--ks-instance-space-xs) 0;
        min-width: 0;
    }

    #ks-instance-input::placeholder {
        color: var(--ks-instance-text-muted);
    }

    /* ============================================
       STATS SECTION - Optimistic Cards
       ============================================ */
    .ks-instance-stats {
        display: flex;
        flex-direction: column;
        gap: var(--ks-instance-space-md);
    }

    .ks-instance-stat-card {
        background-color: var(--ks-instance-bg-secondary);
        border: 1px solid var(--ks-instance-border-color);
        border-radius: var(--ks-instance-radius-lg);
        padding: var(--ks-instance-space-lg);
        position: relative;
        overflow: hidden;
        transition: all var(--ks-instance-transition-base);
        height: 120px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ks-instance-stat-card:hover {
        border-color: var(--ks-instance-border-color-hover);
        transform: translateY(-2px);
        box-shadow: var(--ks-instance-shadow-md);
    }

    .ks-instance-stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--ks-instance-accent-primary);
        opacity: 0;
        transition: opacity var(--ks-instance-transition-base);
    }

    .ks-instance-stat-card.online::before {
        background: var(--ks-instance-accent-success);
        opacity: 1;
    }

    .ks-instance-stat-card.offline::before {
        background: var(--ks-instance-accent-danger);
        opacity: 1;
    }

    .ks-instance-stat-card canvas {
        position: absolute;
        inset: 0;
        width: 100% !important;
        height: 100% !important;
        opacity: 0.15;
        pointer-events: none;
    }

    .ks-instance-stat-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

    .ks-instance-stat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .ks-instance-stat-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ks-instance-text-muted);
    }

    .ks-instance-stat-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: var(--ks-instance-text-muted);
        box-shadow: 0 0 8px currentColor;
    }

    .ks-instance-stat-indicator.online {
        background-color: var(--ks-instance-accent-success);
        animation: ks-instance-pulse 2s infinite;
    }

    .ks-instance-stat-indicator.offline {
        background-color: var(--ks-instance-accent-danger);
    }

    @keyframes ks-instance-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .ks-instance-stat-value {
        font-family: var(--ks-instance-font-mono);
        font-size: clamp(1.25rem, 3vw, 1.5rem);
        font-weight: 700;
        color: var(--ks-instance-text-primary);
        letter-spacing: -0.02em;
    }

    .ks-instance-stat-value.small {
        font-size: clamp(1rem, 2.5vw, 1.125rem);
    }

    .ks-instance-stat-value.online {
        color: var(--ks-instance-accent-success);
    }

    .ks-instance-stat-value.offline {
        color: var(--ks-instance-accent-danger);
    }

    .ks-instance-stat-sub {
        font-size: 0.75rem;
        color: var(--ks-instance-text-secondary);
        font-family: var(--ks-instance-font-mono);
    }

    /* ============================================
       STATUS BADGE - Top Right
       ============================================ */
    .ks-instance-status-badge {
        position: fixed;
        top: var(--ks-instance-space-lg);
        right: var(--ks-instance-space-lg);
        z-index: 100;
        display: flex;
        align-items: center;
        gap: var(--ks-instance-space-sm);
        padding: var(--ks-instance-space-sm) var(--ks-instance-space-md);
        background-color: var(--ks-instance-bg-secondary);
        border: 1px solid var(--ks-instance-border-color);
        border-radius: var(--ks-instance-radius-md);
        box-shadow: var(--ks-instance-shadow-md);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .ks-instance-status-badge.online {
        border-color: var(--ks-instance-accent-success);
        color: var(--ks-instance-accent-success);
    }

    .ks-instance-status-badge.offline {
        border-color: var(--ks-instance-accent-danger);
        color: var(--ks-instance-accent-danger);
    }

    .ks-instance-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: currentColor;
        animation: ks-instance-pulse 2s infinite;
    }

    .ks-instance-status-badge.offline .ks-instance-status-dot {
        animation: none;
    }

    /* ============================================
       NOTIFICATION
       ============================================ */
    #ks-instance-notification {
        position: fixed;
        bottom: var(--ks-instance-space-xl);
        right: var(--ks-instance-space-xl);
        padding: var(--ks-instance-space-md) var(--ks-instance-space-lg);
        background-color: var(--ks-instance-bg-secondary);
        border: 1px solid var(--ks-instance-border-color);
        border-radius: var(--ks-instance-radius-lg);
        color: var(--ks-instance-text-primary);
        font-size: 0.875rem;
        font-weight: 500;
        box-shadow: var(--ks-instance-shadow-lg);
        z-index: 50;
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
        max-width: calc(100vw - var(--ks-instance-space-xl) * 2);
    }

    #ks-instance-notification.show {
        transform: translateY(0);
        opacity: 1;
    }

    @media (max-width: 640px) {
        #ks-instance-notification {
            left: var(--ks-instance-space-md);
            right: var(--ks-instance-space-md);
            bottom: var(--ks-instance-space-md);
        }
    }

    /* ============================================
       UTILITY CLASSES
       ============================================ */
    .ks-instance-font-mono {
        font-family: var(--ks-instance-font-mono);
    }

    .ks-instance-hidden {
        display: none !important;
    }

    /* Scrollbar */
    .ks-instance-container ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }

    .ks-instance-container ::-webkit-scrollbar-track {
        background: var(--ks-instance-bg-secondary);
    }

    .ks-instance-container ::-webkit-scrollbar-thumb {
        background: var(--ks-instance-border-color-hover);
        border-radius: 5px;
        border: 2px solid var(--ks-instance-bg-secondary);
    }

    .ks-instance-container ::-webkit-scrollbar-thumb:hover {
        background: var(--ks-instance-text-muted);
    }

    /* ============================================
       MOBILE OPTIMIZATIONS
       ============================================ */
    @media (max-width: 639px) {
        .ks-instance-btn-text {
            display: none;
        }
        
        .ks-instance-btn {
            padding: var(--ks-instance-space-sm);
            min-width: 48px;
            height: 40px;
        }
        
        .ks-instance-info-card {
            padding: var(--ks-instance-space-md);
        }
        
        .ks-instance-info-icon-wrap {
            width: 36px;
            height: 36px;
        }
        
        .ks-instance-stat-card {
            height: 100px;
            padding: var(--ks-instance-space-md);
        }

        .ks-instance-status-badge {
            top: var(--ks-instance-space-sm);
            right: var(--ks-instance-space-sm);
            font-size: 0.75rem;
        }
    }

    /* Touch device optimizations */
    @media (hover: none) and (pointer: coarse) {
        .ks-instance-info-card:hover {
            transform: none;
        }
        
        .ks-instance-stat-card:hover {
            transform: none;
        }
        
        .ks-instance-btn:hover:not(:disabled) {
            transform: none;
        }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .ks-instance-info-card,
        .ks-instance-stat-card,
        .ks-instance-btn {
            transition: none;
        }
        
        .ks-instance-stat-indicator.online,
        .ks-instance-status-dot {
            animation: none;
        }
    }
</style>

