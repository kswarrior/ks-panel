<script>
    // ============================================
    // INSTANCE MANAGER - OPTIMISTIC IMPLEMENTATION
    // ============================================
    
    // Theme configuration
    const ksInstanceTheme = {
        foreground: '#e5e7eb',
        background: 'transparent',
        selection: 'rgba(59, 130, 246, 0.3)',
        black: '#0f0f13',
        brightBlack: '#1a1a1f',
        red: '#ef4444',
        brightRed: '#f87171',
        green: '#10b981',
        brightGreen: '#34d399',
        yellow: '#f59e0b',
        brightYellow: '#fbbf24',
        blue: '#3b82f6',
        brightBlue: '#60a5fa',
        magenta: '#a855f7',
        brightMagenta: '#c084fc',
        cyan: '#06b6d4',
        brightCyan: '#22d3ee',
        white: '#f9fafb',
        brightWhite: '#ffffff',
        cursor: '#3b82f6',
        cursorAccent: '#1a1a1f',
    };
    
    // State management
    const ksInstanceState = {
        protocol: window.location.protocol === 'https:' ? 'wss' : 'ws',
        instanceId: '<%= req.params.id %>',
        maxCommands: 50,
        commandHistory: [],
        currentCommandIndex: -1,
        term: null,
        ws: null,
        statsWs: null,
        reconnectAttempts: 0,
        maxReconnectAttempts: 10,
        charts: {},
        lastStats: null,
        isRunning: false
    };
    
    // Utilities
    const ksInstanceUtils = {
        debounce: (fn, delay) => {
            let timeout;
            return (...args) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => fn(...args), delay);
            };
        },
        
        throttle: (fn, limit) => {
            let inThrottle;
            return (...args) => {
                if (!inThrottle) {
                    fn(...args);
                    inThrottle = true;
                    setTimeout(() => inThrottle = false, limit);
                }
            };
        },
        
        formatBytes: (bytes, decimals = 2) => {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        },
        
        isValidJson: (str) => {
            try {
                JSON.parse(str);
                return true;
            } catch {
                return false;
            }
        },
        
        showNotification: (message, type = 'info') => {
            const notification = document.getElementById('ks-instance-notification');
            notification.textContent = message;
            notification.className = 'show';
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    };
    
    // ============================================
    // TERMINAL INITIALIZATION
    // ============================================
    
    function ksInstanceInitTerminal() {
        const screenWidth = window.innerWidth;
        const isMobile = screenWidth < 640;
        const isTablet = screenWidth < 1024;
        
        const config = {
            cols: isMobile ? 40 : isTablet ? 80 : 100,
            rows: isMobile ? 20 : 24,
            fontSize: isMobile ? 12 : 14,
        };
        
        ksInstanceState.term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.5,
            rows: config.rows,
            cols: config.cols,
            fontFamily: 'JetBrains Mono, Fira Code, Menlo, Monaco, Courier New, monospace',
            fontSize: config.fontSize,
            theme: ksInstanceTheme,
            allowTransparency: true,
            cursorBlink: false,
            scrollback: 5000,
            smoothScrollDuration: 0,
            fastScrollModifier: 'alt',
            fastScrollSensitivity: 5,
        });
        
        ksInstanceState.term.open(document.getElementById('ks-instance-terminal'));
        
        // Responsive resize with debounce
        const handleResize = ksInstanceUtils.debounce(() => {
            const newWidth = window.innerWidth;
            const newIsMobile = newWidth < 640;
            const newIsTablet = newWidth < 1024;
            
            const newConfig = {
                cols: newIsMobile ? 40 : newIsTablet ? 80 : 100,
                rows: newIsMobile ? 20 : 24,
            };
            
            ksInstanceState.term.resize(newConfig.cols, newConfig.rows);
        }, 250);
        
        window.addEventListener('resize', handleResize, { passive: true });
    }
    
    // ============================================
    // WEBSOCKET MANAGEMENT
    // ============================================
    
    function ksInstanceInitWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `${ksInstanceState.protocol}://${window.location.hostname}${port}/console/${ksInstanceState.instanceId}`;
        
        ksInstanceState.ws = new WebSocket(wsUrl);
        
        ksInstanceState.ws.onopen = () => {
            console.log('[InstanceManager] WebSocket connected');
            ksInstanceState.reconnectAttempts = 0;
            document.getElementById('ks-instance-daemonAlert').classList.add('ks-instance-hidden');
        };
        
        ksInstanceState.ws.onmessage = ksInstanceHandleWsMessage;
        
        ksInstanceState.ws.onclose = () => {
            if (ksInstanceState.reconnectAttempts < ksInstanceState.maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, ksInstanceState.reconnectAttempts), 30000);
                setTimeout(ksInstanceInitWebSocket, delay);
                ksInstanceState.reconnectAttempts++;
            }
        };
        
        ksInstanceState.ws.onerror = (error) => {
            console.error('[InstanceManager] WebSocket error:', error);
        };
    }
    
    function ksInstanceHandleWsMessage(msg) {
        const lines = msg.data.split('\n');
        let isFirstLine = true;
        let previousLineWasEmpty = false;
        let output = '';
        
        lines.forEach(line => {
            const trimmedLine = line.trim();
            if (trimmedLine === '' && previousLineWasEmpty) return;
            
            if (!isFirstLine && !previousLineWasEmpty) {
                output += '\r\n';
            }
            
            output += '\x1b[0m' + trimmedLine;
            
            if (trimmedLine.includes("Working on")) {
                output += '\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...';
                ksInstanceState.ws.close();
            }
            
            if (trimmedLine.includes("KS Wings instance appears to be down")) {
                ksInstanceState.ws.close();
                document.getElementById('ks-instance-daemonAlert').classList.remove('ks-instance-hidden');
            }
            
            isFirstLine = false;
            previousLineWasEmpty = (trimmedLine === '');
        });
        
        ksInstanceState.term.write(output);
    }
    
    // ============================================
    // STATS WEBSOCKET
    // ============================================
    
    function ksInstanceInitStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `${ksInstanceState.protocol}://${window.location.hostname}${port}/stats/${ksInstanceState.instanceId}`;
        
        ksInstanceState.statsWs = new WebSocket(wsUrl);
        
        ksInstanceState.statsWs.onmessage = ksInstanceUtils.throttle((event) => {
            if (!ksInstanceUtils.isValidJson(event.data)) return;
            
            const stats = JSON.parse(event.data);
            if (stats.error) {
                console.error('[InstanceManager] Stats error:', stats.error);
                return;
            }
            
            ksInstanceState.lastStats = stats;
            ksInstanceUpdateStats(stats);
        }, 1000);
        
        ksInstanceState.statsWs.onclose = () => {
            setTimeout(ksInstanceInitStatsWebSocket, 5000);
        };
    }
    
    // ============================================
    // STATS CHARTS
    // ============================================
    
    function ksInstanceInitCharts() {
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false, min: 0, max: 100 } },
            animation: { duration: 0 },
            elements: { point: { radius: 0 }, line: { borderWidth: 2, tension: 0.4 } }
        };
        
        const createChart = (id, color, type = 'line') => {
            const ctx = document.getElementById(id);
            if (!ctx) return null;
            
            return new Chart(ctx, {
                type: type,
                data: {
                    labels: Array(20).fill(''),
                    datasets: [{
                        data: Array(20).fill(0),
                        borderColor: color,
                        backgroundColor: type === 'line' ? `${color}20` : `${color}40`,
                        fill: type === 'line',
                    }]
                },
                options: commonOptions
            });
        };
        
        ksInstanceState.charts.status = createChart('ks-instance-statusChart', '#10b981');
        ksInstanceState.charts.ram = createChart('ks-instance-ramChart', '#3b82f6');
        ksInstanceState.charts.cpu = createChart('ks-instance-cpuChart', '#f59e0b');
    }
    
    function ksInstanceUpdateStats(stats) {
        // RAM
        const ramUsage = stats.memory_stats?.usage || 0;
        const ramLimit = stats.memory_stats?.limit || 0;
        const ramPercent = ramLimit > 0 ? ((ramUsage / ramLimit) * 100).toFixed(1) : 0;
        
        document.getElementById('ks-instance-ram').textContent = `${ramPercent}%`;
        document.getElementById('ks-instance-ramSub').textContent = 
            `${ksInstanceUtils.formatBytes(ramUsage)} / ${ksInstanceUtils.formatBytes(ramLimit)}`;
        ksInstanceUpdateChart(ksInstanceState.charts.ram, ramPercent);
        
        // CPU
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const cpuPercent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        
        document.getElementById('ks-instance-cpu').textContent = `${cpuPercent}%`;
        ksInstanceUpdateChart(ksInstanceState.charts.cpu, cpuPercent);
        
        // Disk
        const diskUsage = parseFloat(stats.volumeSize) || 0;
        const diskLimit = <%= instance.Disk || 0 %>;
        const diskEl = document.getElementById('ks-instance-disk');
        const diskSubEl = document.getElementById('ks-instance-diskSub');
        
        if (diskLimit === 0) {
            diskEl.textContent = ksInstanceUtils.formatBytes(diskUsage * 1024 * 1024);
            diskSubEl.textContent = 'Unlimited';
            diskEl.style.color = 'var(--ks-instance-accent-success)';
        } else {
            const diskPercent = ((diskUsage / diskLimit) * 100).toFixed(1);
            diskEl.textContent = `${diskPercent}%`;
            diskSubEl.textContent = `${ksInstanceUtils.formatBytes(diskUsage * 1024 * 1024)} / ${ksInstanceUtils.formatBytes(diskLimit * 1024 * 1024)}`;
            diskEl.style.color = diskPercent > 90 ? 'var(--ks-instance-accent-danger)' : diskPercent > 70 ? 'var(--ks-instance-accent-warning)' : 'var(--ks-instance-accent-success)';
        }
        
        // Status detection
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
        ksInstanceUpdateStatus(isRunning);
    }
    
    function ksInstanceUpdateStatus(isRunning) {
        ksInstanceState.isRunning = isRunning;
        
        const statusEl = document.getElementById('ks-instance-status');
        const statusCard = document.getElementById('ks-instance-statusCard');
        const indicator = document.getElementById('ks-instance-statusIndicator');
        const statusBadge = document.getElementById('ks-instance-statusBadge');
        const statusBadgeText = document.getElementById('ks-instance-statusBadgeText');
        
        if (isRunning) {
            statusEl.textContent = 'Online';
            statusEl.className = 'ks-instance-stat-value online';
            statusCard.classList.add('online');
            statusCard.classList.remove('offline');
            indicator.className = 'ks-instance-stat-indicator online';
            
            // Update top-right badge
            statusBadge.classList.remove('offline');
            statusBadge.classList.add('online');
            statusBadgeText.textContent = 'Online';
            
            ksInstanceUpdateStatusChart('#10b981');
        } else {
            statusEl.textContent = 'Offline';
            statusEl.className = 'ks-instance-stat-value offline';
            statusCard.classList.add('offline');
            statusCard.classList.remove('online');
            indicator.className = 'ks-instance-stat-indicator offline';
            
            // Update top-right badge
            statusBadge.classList.remove('online');
            statusBadge.classList.add('offline');
            statusBadgeText.textContent = 'Offline';
            
            ksInstanceUpdateStatusChart('#ef4444');
        }
    }
    
    function ksInstanceUpdateChart(chart, value) {
        if (!chart) return;
        const num = parseFloat(value) || 0;
        chart.data.datasets[0].data.push(num);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }
    
    function ksInstanceUpdateStatusChart(color) {
        if (!ksInstanceState.charts.status) return;
        ksInstanceState.charts.status.data.datasets[0].backgroundColor = `${color}30`;
        ksInstanceState.charts.status.data.datasets[0].borderColor = color;
        ksInstanceState.charts.status.data.datasets[0].data = Array(20).fill(100);
        ksInstanceState.charts.status.update('none');
    }
    
    // ============================================
    // COMMAND INPUT
    // ============================================
    
    function ksInstanceInitCommandInput() {
        const input = document.getElementById('ks-instance-input');
        
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') ksInstanceSendCommand();
        });
        
        input.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (ksInstanceState.currentCommandIndex > 0) {
                    ksInstanceState.currentCommandIndex--;
                    input.value = ksInstanceState.commandHistory[ksInstanceState.currentCommandIndex];
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (ksInstanceState.currentCommandIndex < ksInstanceState.commandHistory.length - 1) {
                    ksInstanceState.currentCommandIndex++;
                    input.value = ksInstanceState.commandHistory[ksInstanceState.currentCommandIndex];
                } else {
                    ksInstanceState.currentCommandIndex = ksInstanceState.commandHistory.length;
                    input.value = '';
                }
            }
        });
    }
    
    function ksInstanceSendCommand() {
        const input = document.getElementById('ks-instance-input');
        const command = input.value.trim();
        
        if (!command || !ksInstanceState.ws) return;
        
        ksInstanceState.term.write(`\r\n\u001b[1m\u001b[36m❯ \u001b[0m${command}\r\n`);
        
        ksInstanceState.ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: ksInstanceState.instanceId
        }));
        
        if (ksInstanceState.commandHistory.length >= ksInstanceState.maxCommands) {
            ksInstanceState.commandHistory.shift();
        }
        ksInstanceState.commandHistory.push(command);
        ksInstanceState.currentCommandIndex = ksInstanceState.commandHistory.length;
        
        input.value = '';
    }
    
    // ============================================
    // POWER BUTTONS - OPTIMISTIC UI
    // ============================================
    
    function ksInstanceInitPowerButtons() {
        const buttons = {
            start: document.getElementById('ks-instance-startBtn'),
            restart: document.getElementById('ks-instance-restartBtn'),
            stop: document.getElementById('ks-instance-stopBtn')
        };
        
        const icons = {
            start: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/></svg>`,
            restart: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/></svg>`,
            stop: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/></svg>`
        };
        
        const labels = {
            start: '<%= req.translations.start %>',
            restart: '<%= req.translations.restart %>',
            stop: '<%= req.translations.stop %>'
        };
        
        Object.keys(buttons).forEach(action => {
            const btn = buttons[action];
            if (!btn) return;
            
            btn.addEventListener('click', async () => {
                if (!confirm(`Are you sure you want to ${action} this instance?`)) return;
                
                // Optimistic UI update
                const originalHTML = btn.innerHTML;
                btn.disabled = true;
                btn.classList.add('loading');
                btn.innerHTML = `${icons[action]} <span class="ks-instance-btn-text">Processing...</span>`;
                
                // Optimistic status update
                if (action === 'start') {
                    ksInstanceUpdateStatus(true);
                } else if (action === 'stop') {
                    ksInstanceUpdateStatus(false);
                }
                
                try {
                    const res = await axios.post(`/instance/${ksInstanceState.instanceId}/power`, { action });
                    
                    if (res.status === 200) {
                        // Success state
                        btn.innerHTML = `${icons[action]} <span class="ks-instance-btn-text">${labels[action]}ed!</span>`;
                        btn.classList.remove('loading');
                        ksInstanceUtils.showNotification(`Instance ${action}ed successfully`);
                        
                        // Revert after delay
                        setTimeout(() => {
                            btn.innerHTML = originalHTML;
                            btn.disabled = false;
                        }, 2000);
                    }
                } catch (err) {
                    console.error(err);
                    ksInstanceUtils.showNotification(`Failed to ${action} instance`, 'error');
                    
                    // Revert on error
                    btn.innerHTML = originalHTML;
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    
                    // Revert optimistic status
                    if (ksInstanceState.lastStats) {
                        ksInstanceUpdateStats(ksInstanceState.lastStats);
                    }
                }
            });
        });
    }
    
    // ============================================
    // INITIALIZATION
    // ============================================
    
    document.addEventListener('DOMContentLoaded', () => {
        ksInstanceInitTerminal();
        ksInstanceInitWebSocket();
        ksInstanceInitStatsWebSocket();
        ksInstanceInitCharts();
        ksInstanceInitCommandInput();
        ksInstanceInitPowerButtons();
        
        // Visibility change handling for performance
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (ksInstanceState.statsWs) ksInstanceState.statsWs.onmessage = null;
            } else {
                if (ksInstanceState.statsWs) {
                    ksInstanceState.statsWs.onmessage = ksInstanceUtils.throttle((event) => {
                        if (!ksInstanceUtils.isValidJson(event.data)) return;
                        const stats = JSON.parse(event.data);
                        if (!stats.error) ksInstanceUpdateStats(stats);
                    }, 1000);
                }
            }
        });
    });
</script>

