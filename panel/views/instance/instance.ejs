<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
    }

    .xterm-viewport {
        overflow-y: hidden !important;
    }

    /* Glassmorphism Base */
    .glass {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.18);
        box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
    }

    .glass-dark {
        background: rgba(16, 16, 16, 0.65);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.12);
    }
</style>

<main class="overflow-hidden" id="content">
    <% if (false) { %>
        <% if (instance.imageData.features && instance.imageData.features.includes('eula')) { %>
            <div class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur z-50">
                <div class="bg-white/5 backdrop-blur py-8 px-8 rounded-2xl shadow-lg w-1/2 h-48">
                    <p class="text-white text-lg font-medium">Do you accept Minecraft's EULA?</p>
                    <p class="text-sm text-neutral-400">By pressing this button you agree to the <a class="text-white" href="https://account.mojang.com/documents/minecraft_eula">Mojang EULA</a>.</p>
                    <button 
                    onclick="axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
                        .then(response => {
                            if (response.status === 200) {
                                location.reload();
                            }
                        })
                        .catch(error => {
                            console.error('There was an error!', error);
                        });" 
                    class="mt-8 bg-white text-sm font-sm text-gray-800 px-4 font-medium transition py-2 rounded-2xl hover:bg-gray-100">
                    I agree
                    </button>
                </div>
            </div>
        <% } %>
    <% } %>
    
    <div class="bg-transparent">
        <div class="sm:flex sm:items-center px-8 pt-4">
            <div class="sm:flex-auto">
                <h1 class="text-base font-medium leading-6 text-white"><%= req.translations.manageInstance %></h1>
                <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.manageInstanceText %></p>
            </div>
            <div class="mt-4 sm:mt-0 flex gap-2.5">
    <!-- Start Button -->
    <button id="startButton" type="button"
        class="flex items-center rounded-3xl bg-emerald-600/90 px-5 py-3 text-sm font-semibold text-white shadow-xl hover:bg-emerald-500 transition backdrop-blur-md">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
            class="w-4 h-4 mr-2 text-emerald-100">
            <path fill-rule="evenodd"
                d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z"
                clip-rule="evenodd" />
        </svg>
        <%= req.translations.start %>
    </button>

    <!-- Restart Button -->
    <button id="restartButton" type="button"
        class="flex items-center rounded-3xl bg-blue-600/90 px-5 py-3 text-sm font-semibold text-white shadow-xl hover:bg-blue-500 transition backdrop-blur-md">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
            class="w-4 h-4 mr-2 text-white">
            <path fill-rule="evenodd"
                d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z"
                clip-rule="evenodd" />
        </svg>
        <%= req.translations.restart %>
    </button>

    <!-- Stop Button -->
    <button id="stopButton" type="button"
        class="flex items-center rounded-3xl bg-red-600/90 px-5 py-3 text-sm font-semibold text-white shadow-xl hover:bg-red-500 transition backdrop-blur-md">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
            class="w-4 h-4 mr-2 text-red-100">
            <path fill-rule="evenodd"
                d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z"
                clip-rule="evenodd" />
        </svg>
        <%= req.translations.stop %>
    </button>
</div>
        </div>
    </div>

    <%- include('../components/instance') %>

    <!-- IP + Status Glass Card (combined as requested) -->
    <div class="mt-8 ml-8 mb-4 mr-8">
        <div class="glass rounded-3xl px-8 py-6 flex items-center justify-between">
            <div class="flex items-center gap-x-8">
                <!-- IP Address -->
                <div>
                    <p class="text-sm font-medium text-neutral-400 tracking-widest">IP ADDRESS</p>
                    <p class="mt-1 text-3xl font-semibold tracking-tighter text-white">
                        <%= instance.Node.address %><span class="text-neutral-400 text-2xl">:</span><span class="text-neutral-400"><%= instance.Primary %></span>
                    </p>
                </div>

                <!-- Vertical divider -->
                <div class="h-12 w-px bg-white/20"></div>

                <!-- Status -->
                <div>
                    <p class="text-sm font-medium text-neutral-400 tracking-widest">STATUS</p>
                    <p id="status" class="mt-1 text-3xl font-semibold tracking-tighter text-emerald-400">-</p>
                </div>
            </div>

            <!-- Decorative icon -->
            <div class="ml-auto flex-shrink-0 rounded-2xl bg-white/10 p-3 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 15a4 4 0 004 4h9a5 5 0 0010-5v-1m-10-4V9a4 4 0 00-4-4H5a4 4 0 00-4 4v.341C3 14.165 3 14.83 3 15z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
        </div>
    </div>

    <div class="rounded-3xl bg-red-900/20 backdrop-blur-xl border border-red-400/20 px-4 py-6 mt-8 ml-8 mb-8 mr-8 hidden" id="daemonIsDown">
        <div class="flex">
            <div class="flex-shrink-0 ml-1.5">
                <svg class="animate-spin mt-2 h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg"
                    fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                    </circle>
                    <path class="opacity-75" fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                    </path>
                </svg>
            </div>
            <div class="ml-5">
                <h3 class="text-sm font-medium text-red-400"><%= req.translations.connectionFailure %></h3>
                <div class="text-sm text-red-400/50">
                    <p><%= req.translations.connectionFailureText %></p>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col lg:flex-row px-8">
        <!-- Left side: Console (glass panel) -->
        <div class="w-full lg:w-2/3 lg:pr-5">
            <div class="glass-dark rounded-3xl p-2">
                <div id="terminal" class="overflow-hidden rounded-3xl bg-[#0a0a0a]/70 p-5 min-h-[380px]"></div>
                <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>"
                    class="glass-dark w-full mx-2 mb-2 px-5 py-4 text-white rounded-3xl text-sm font-medium placeholder:font-medium placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-white/30">
            </div>
        </div>
        
        <!-- Right side: Stats Cards (glass + bar graphs) -->
        <div class="w-full lg:w-1/3 mt-4 lg:mt-0 space-y-4">
            
            <!-- RAM Usage Card -->
            <div class="glass rounded-3xl px-6 py-6 shadow-2xl h-32 relative overflow-hidden">
                <canvas id="ramChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-400 tracking-widest">RAM USAGE</h2>
                    <p id="ramUsage" class="mt-2 text-2xl font-semibold tracking-tighter text-white"></p>
                </div>
            </div>
            
            <!-- CPU Usage Card -->
            <div class="glass rounded-3xl px-6 py-6 shadow-2xl h-32 relative overflow-hidden">
                <canvas id="cpuChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-400 tracking-widest">CPU USAGE</h2>
                    <p id="cpuUsage" class="mt-2 text-2xl font-semibold tracking-tighter text-white"></p>
                </div>
            </div>
            
            <!-- Disk Usage Card -->
            <div class="glass rounded-3xl px-6 py-6 shadow-2xl h-32 relative overflow-hidden">
                <canvas id="diskChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-400 tracking-widest">DISK USAGE</h2>
                    <p id="diskUsage" class="mt-2 text-2xl font-semibold tracking-tighter text-white"></p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // ============================================
    // FULL WORKING JS - ONLY JS ADDED (no style/HTML changed)
    // ============================================

    const baseTheme = {
        foreground: '#c5c9d1',
        background: 'rgba(0 0 0 / 0)',
        selection: '#5DA5D533',
        black: '#1E1E1D',
        brightBlack: '#262625',
        red: '#E54B4B',
        green: '#9ECE58',
        yellow: '#FAED70',
        blue: '#396FE2',
        magenta: '#BB80B3',
        cyan: '#2DDAFD',
        white: '#d0d0d0',
        brightBlack: 'rgba(255, 255, 255, 0.2)',
        brightRed: '#FF5370',
        brightGreen: '#C3E88D',
        brightYellow: '#FFCB6B',
        brightBlue: '#82AAFF',
        brightMagenta: '#C792EA',
        brightCyan: '#89DDFF',
        brightWhite: '#ffffff',
    };

    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 50;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let term;
    let ws;
    let statsWs;
    let reconnectAttempts = 0;
    const maxReconnectAttempts = 10;

    // Utilities
    function isValidJson(str) {
        try { JSON.parse(str); return true; } catch { return false; }
    }

    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }

    // Terminal
    function setupTerminal() {
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.35,
            rows: 19,
            cols: 100,
            fontFamily: 'Menlo, monospace',
            theme: baseTheme,
            allowTransparency: true,
            fontSize: 12,
        });
        term.open(document.getElementById('terminal'));
    }

    // Console WebSocket
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);

        ws.onopen = () => {
            console.log('[Console] WebSocket connected');
            reconnectAttempts = 0;
            document.getElementById('daemonIsDown').classList.add('hidden');
        };

        ws.onmessage = (msg) => {
            const lines = msg.data.split('\n');
            let isFirstLine = true;
            let previousLineWasEmpty = false;

            lines.forEach(line => {
                const trimmedLine = line.trim();
                if (trimmedLine === '' && previousLineWasEmpty) return;

                if (!isFirstLine && !previousLineWasEmpty) term.write('\r\n');

                term.write('\x1b[0m' + trimmedLine);

                if (trimmedLine.includes("Working on")) {
                    term.write('\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...');
                    ws.close();
                }

                if (trimmedLine.includes("KS Wings instance appears to be down")) {
                    ws.close();
                    document.getElementById('daemonIsDown').classList.remove('hidden');
                }

                isFirstLine = false;
                previousLineWasEmpty = (trimmedLine === '');
            });
        };

        ws.onclose = () => {
            if (reconnectAttempts < maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000);
                setTimeout(initWebSocket, delay);
                reconnectAttempts++;
            }
        };

        ws.onerror = (error) => console.error('[Console] WebSocket error:', error);
    }

    // Command handling
    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        if (!command || !ws) return;

        term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');

        ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: instanceId
        }));

        if (commandHistory.length >= maxCommands) commandHistory.shift();
        commandHistory.push(command);
        currentCommandIndex = commandHistory.length;

        input.value = '';
    }

    function handleKeyUp(e) {
        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
        } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
        }
    }

    // Power buttons (using axios - reliable and matches backend)
    function initPowerButtons() {
        const actions = {
            start: document.getElementById('startButton'),
            restart: document.getElementById('restartButton'),
            stop: document.getElementById('stopButton')
        };

        Object.keys(actions).forEach(action => {
            const btn = actions[action];
            btn.addEventListener('click', async () => {
                if (!confirm(`Are you sure you want to ${action} this instance?`)) return;

                try {
                    const res = await axios.post(`/instance/${instanceId}/power`, { action });
                    if (res.status === 200) {
                        console.log(`Instance ${action}ed successfully`);
                    }
                } catch (err) {
                    console.error(`Failed to ${action} instance`, err);
                }
            });
        });
    }

    // Stats WebSocket + Charts
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);

        statsWs.onmessage = (event) => {
            if (!isValidJson(event.data)) return;
            const stats = JSON.parse(event.data);
            if (stats.error) return;

            updateRamUsage(stats);
            updateCpuUsage(stats);
            updateDiskUsage(stats);
            updateStatus(stats);
        };

        statsWs.onclose = () => setTimeout(initStatsWebSocket, 5000);
    }

    // BAR GRAPHS (sparkline style) - as requested
    const ramChart = new Chart(document.getElementById('ramChart'), {
        type: 'bar',
        data: { 
            labels: Array(20).fill(''), 
            datasets: [{ 
                data: Array(20).fill(0), 
                backgroundColor: '#3b82f6',
                borderColor: '#1e40af',
                borderWidth: 1,
                barThickness: 7
            }] 
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false, 
            plugins: { legend: { display: false }, tooltip: { enabled: false } }, 
            scales: { 
                x: { display: false, grid: { display: false } }, 
                y: { display: false, min: 0, max: 100, grid: { display: false } } 
            }, 
            animation: { duration: 0 } 
        }
    });

    const cpuChart = new Chart(document.getElementById('cpuChart'), {
        type: 'bar',
        data: { 
            labels: Array(20).fill(''), 
            datasets: [{ 
                data: Array(20).fill(0), 
                backgroundColor: '#f59e0b',
                borderColor: '#b45309',
                borderWidth: 1,
                barThickness: 7
            }] 
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false, 
            plugins: { legend: { display: false }, tooltip: { enabled: false } }, 
            scales: { 
                x: { display: false, grid: { display: false } }, 
                y: { display: false, min: 0, max: 100, grid: { display: false } } 
            }, 
            animation: { duration: 0 } 
        }
    });

    const diskChart = new Chart(document.getElementById('diskChart'), {
        type: 'bar',
        data: { 
            labels: Array(20).fill(''), 
            datasets: [{ 
                data: Array(20).fill(0), 
                backgroundColor: '#10b981',
                borderColor: '#166534',
                borderWidth: 1,
                barThickness: 7
            }] 
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false, 
            plugins: { legend: { display: false }, tooltip: { enabled: false } }, 
            scales: { 
                x: { display: false, grid: { display: false } }, 
                y: { display: false, min: 0, max: 100, grid: { display: false } } 
            }, 
            animation: { duration: 0 } 
        }
    });

    function updateChart(chart, value) {
        chart.data.datasets[0].data.push(parseFloat(value) || 0);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }

    function updateRamUsage(stats) {
        const usage = stats.memory_stats?.usage || 0;
        const limit = stats.memory_stats?.limit || 0;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;
        document.getElementById('ramUsage').textContent = `${percent}% (${formatBytes(usage)} / ${formatBytes(limit)})`;
        updateChart(ramChart, percent);
    }

    function updateCpuUsage(stats) {
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const percent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        document.getElementById('cpuUsage').textContent = `${percent}%`;
        updateChart(cpuChart, percent);
    }

    function updateDiskUsage(stats) {
        const usage = parseFloat(stats.volumeSize) || 0;
        const limit = <%= instance.Disk || 0 %>;
        const el = document.getElementById('diskUsage');
        let percent = 0;
        
        if (limit === 0) {
            el.textContent = `${formatBytes(usage * 1024 * 1024)} / Unlimited`;
        } else {
            percent = ((usage / limit) * 100).toFixed(1);
            el.textContent = `${percent}% (${formatBytes(usage * 1024 * 1024)} / ${formatBytes(limit * 1024 * 1024)})`;
        }
        updateChart(diskChart, percent);
    }

    function updateStatus(stats) {
        const ramUsage = stats.memory_stats?.usage || 0;
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
        const statusEl = document.getElementById('status');
        if (isRunning) {
            statusEl.textContent = 'Online';
            statusEl.className = 'mt-1 text-3xl font-semibold tracking-tighter text-emerald-400';
        } else {
            statusEl.textContent = 'Offline';
            statusEl.className = 'mt-1 text-3xl font-semibold tracking-tighter text-red-400';
        }
    }

    // Main initialization
    document.addEventListener('DOMContentLoaded', () => {
        setupTerminal();
        initWebSocket();
        initPowerButtons();
        initStatsWebSocket();

        const input = document.getElementById('input');
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendCommand(); });
        input.addEventListener('keydown', handleKeyUp);

        // Visibility handling
        document.addEventListener('visibilitychange', () => {
            if (document.hidden && statsWs) statsWs.onmessage = null;
            else if (statsWs) initStatsWebSocket();
        });
    });
</script>

<%- include('../components/footer') %>
