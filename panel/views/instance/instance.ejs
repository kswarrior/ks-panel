<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>

<style>
    /* ==================== MODERN CONSOLE + BAR GRAPHS ==================== */
    .log-terminal {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 1.25rem;
        font-family: ui-monospace, Menlo, Monaco, "Cascadia Mono", "Segoe UI Mono", "Roboto Mono", monospace;
        font-size: 0.875rem;
        line-height: 1.55;
        color: #94a3b8;
        overflow-y: auto;
        white-space: pre-wrap;
        scrollbar-width: thin;
        scrollbar-color: rgba(148,163,184,0.3) transparent;
        flex: 1;
        min-height: 320px;
    }

    .log-terminal::-webkit-scrollbar {
        width: 6px;
    }

    .bar-graph {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 68px;
        background: rgba(255,255,255,0.06);
        border-radius: 14px;
        padding: 9px 10px;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .bar-graph .bar {
        width: 6px;
        background: linear-gradient(to bottom, transparent, currentColor);
        border-radius: 9999px;
        transition: height 520ms cubic-bezier(0.25, 1.8, 0.45, 1.35);
        opacity: 0.92;
    }

    .status-dot {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    @media (max-width: 640px) {
        .log-terminal {
            min-height: 280px;
            font-size: 0.8rem;
        }
        .bar-graph {
            height: 56px;
        }
    }
</style>

<main id="content" class="max-w-screen-2xl mx-auto overflow-hidden">
    <div class="bg-transparent px-4 md:px-6 lg:px-8">
        
        <!-- HEADER -->
        <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
            <div>
                <h1 class="text-3xl font-semibold text-white tracking-tight"><%= req.translations.manageInstance %></h1>
                <p class="mt-1 text-sm text-neutral-400"><%= req.translations.manageInstanceText %></p>
            </div>
            
            <!-- POWER BUTTONS - TOUCH FRIENDLY -->
            <div class="flex items-center gap-2.5">
                <!-- Start -->
                <button id="startButton"
                    class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 transition-all text-white text-sm font-medium px-5 py-3 rounded-2xl shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 4.01V8" />
                    </svg>
                    <%= req.translations.start %>
                </button>

                <!-- Restart -->
                <button id="restartButton"
                    class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 transition-all text-white text-sm font-medium px-5 py-3 rounded-2xl shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.058 11H1M12 3v2m0 16v2m9-9H15" />
                    </svg>
                    <%= req.translations.restart %>
                </button>

                <!-- Stop -->
                <button id="stopButton"
                    class="flex items-center gap-2 bg-red-600 hover:bg-red-500 transition-all text-white text-sm font-medium px-5 py-3 rounded-2xl shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6h12v12" />
                    </svg>
                    <%= req.translations.stop %>
                </button>
            </div>
        </header>

        <!-- INSTANCE INFO - RESPONSIVE -->
        <div class="mt-8">
            <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <!-- Address -->
                <div class="overflow-hidden rounded-2xl bg-white/5 px-5 py-6 flex items-center">
                    <div class="flex-grow">
                        <dt class="text-xs font-medium text-neutral-400"><%= req.translations.address %></dt>
                        <dd class="mt-1 text-xl font-medium tracking-tighter text-white"><%= instance.Node.address %><span class="text-neutral-400">:<%= instance.Primary %></span></dd>
                    </div>
                    <div class="ml-4 w-9 h-9 flex items-center justify-center bg-white/10 rounded-2xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="currentColor" viewBox="0 0 256 256"><path d="M240 120a8 8 0 01-8 8H200v32h8a16 16 0 0116 16v32a16 16 0 01-16 16H176a16 16 0 01-16-16V176a16 16 0 0116-16h8V128H72v32h8a16 16 0 0116 16v32a16 16 0 01-16 16H48a16 16 0 01-16-16V176a16 16 0 0116-16h8V128H24a8 8 0 010-16h96V88h-8A16 16 0 0196 72V40a16 16 0 0116-16h32a16 16 0 0116 16V72a16 16 0 01-16 16h-8v24h96a8 8 0 018 8z"/></svg>
                    </div>
                </div>

                <!-- Image -->
                <div class="overflow-hidden rounded-2xl bg-white/5 px-5 py-6 flex items-center">
                    <div class="flex-grow">
                        <dt class="text-xs font-medium text-neutral-400"><%= req.translations.image %></dt>
                        <dd class="mt-1 text-xl font-medium tracking-tighter text-white"><%= instance.Image %></dd>
                    </div>
                    <div class="ml-4 w-9 h-9 flex items-center justify-center bg-white/10 rounded-2xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="currentColor" viewBox="0 0 256 256"><path d="M243.31 136L144 36.69A15.86 15.86 0 00132.69 32H40a8 8 0 00-8 8v92.69A15.86 15.86 0 0036.69 144L136 243.31a16 16 0 0022.63 0l84.68-84.68a16 16 0 000-22.63zM84 96a12 12 0 1112-12 12 12 0 01-12 12z"/></svg>
                    </div>
                </div>

                <!-- Node -->
                <div class="overflow-hidden rounded-2xl bg-white/5 px-5 py-6 flex items-center">
                    <div class="flex-grow">
                        <dt class="text-xs font-medium text-neutral-400"><%= req.translations.node %></dt>
                        <dd class="mt-1 text-xl font-medium tracking-tighter text-white"><%= instance.Node.name %> <span class="text-neutral-500">(<%= instance.Node.address %>)</span></dd>
                    </div>
                    <div class="ml-4 w-9 h-9 flex items-center justify-center bg-white/10 rounded-2xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="currentColor" viewBox="0 0 256 256"><path d="M208 40H48A16 16 0 0032 56v48a16 16 0 0016 16H208a16 16 0 0016-16V56A16 16 0 00208 40z"/><path d="M208 136H48a16 16 0 00-16 16v48a16 16 0 0016 16H208a16 16 0 0016-16V152A16 16 0 00208 136z"/></svg>
                    </div>
                </div>

                <!-- ID -->
                <div class="overflow-hidden rounded-2xl bg-white/5 px-5 py-6 flex items-center">
                    <div class="flex-grow">
                        <dt class="text-xs font-medium text-neutral-400"><%= req.translations.identifier %></dt>
                        <dd class="mt-1 text-xl font-medium tracking-tighter text-white"><%= req.params.id %></dd>
                    </div>
                    <div class="ml-4 w-9 h-9 flex items-center justify-center bg-white/10 rounded-2xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="currentColor" viewBox="0 0 256 256"><path d="M116.25 112h31.5l-8 32h-31.5zM224 48v160a16 16 0 01-16 16H48a16 16 0 01-16-16V48a16 16 0 0116-16h160a16 16 0 0116 16z"/></svg>
                    </div>
                </div>
            </dl>
        </div>

        <!-- DAEMON DOWN ALERT -->
        <div id="daemonIsDown" class="hidden mt-8 bg-red-900/20 border border-red-500/30 rounded-2xl p-5 flex items-center gap-4">
            <div class="flex-shrink-0">
                <svg class="animate-spin h-6 w-6 text-red-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
            <div>
                <h3 class="font-medium text-red-400"><%= req.translations.connectionFailure %></h3>
                <p class="text-sm text-red-400/70"><%= req.translations.connectionFailureText %></p>
            </div>
        </div>

        <!-- FULL-WIDTH LIVE CONSOLE (MOBILE FIRST) -->
        <div class="mt-10 bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-6 flex flex-col" style="height: 520px;">
            <div class="flex items-center justify-between mb-5">
                <div class="flex items-center gap-3">
                    <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
                    <h2 class="text-2xl font-semibold text-white">Live Console</h2>
                </div>
                <button onclick="clearConsole()" 
                        class="px-5 py-2 bg-neutral-900/80 hover:bg-neutral-800 border border-white/10 rounded-2xl text-sm font-medium flex items-center gap-2">
                    <span>🗑️</span> Clear
                </button>
            </div>
            
            <div id="console-logs" class="log-terminal"></div>
            
            <!-- COMMAND INPUT -->
            <div class="mt-4">
                <input id="input" 
                       type="text" 
                       autocomplete="off"
                       placeholder="<%= req.translations.SendACommand %>"
                       class="w-full bg-[#0f172a] border border-white/10 focus:border-emerald-500 focus:ring-0 rounded-2xl px-6 py-4 text-white placeholder:text-neutral-500 text-sm transition-all">
            </div>
        </div>

        <!-- RESOURCES MONITOR -->
        <div class="mt-14">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-semibold text-white tracking-tight">Resources Monitor</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <!-- STATUS -->
                <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8">
                    <div class="flex items-center gap-5 mb-6">
                        <div id="status-icon" class="text-6xl transition-all">⏹️</div>
                        <div class="flex-1">
                            <p class="text-neutral-400 text-sm font-medium">Status</p>
                            <p id="status" class="text-6xl font-bold tracking-tighter text-red-500">Offline</p>
                        </div>
                    </div>
                    <div id="status-dot" class="status-dot text-red-400">
                        <div class="w-3 h-3 bg-red-400 rounded-full"></div>
                        OFFLINE
                    </div>
                </div>

                <!-- CPU -->
                <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8">
                    <div class="flex items-center gap-5 mb-6">
                        <div class="text-6xl">⚡</div>
                        <div class="flex-1">
                            <p class="text-neutral-400 text-sm font-medium">CPU Usage</p>
                            <p id="cpu-text" class="text-6xl font-bold text-orange-400">0%</p>
                        </div>
                    </div>
                    <div id="cpu-graph" class="bar-graph"></div>
                    <p id="cpu-status" class="text-xs text-neutral-500 mt-6">Normal</p>
                </div>

                <!-- RAM -->
                <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8">
                    <div class="flex items-center gap-5 mb-6">
                        <div class="text-6xl">🧠</div>
                        <div class="flex-1">
                            <p class="text-neutral-400 text-sm font-medium">RAM Usage</p>
                            <p id="ram-text" class="text-6xl font-bold text-blue-400">0%</p>
                        </div>
                    </div>
                    <div id="ram-graph" class="bar-graph"></div>
                    <div class="flex justify-between text-xs text-neutral-400 mt-6">
                        <span id="ram-used">0 MB</span>
                        <span id="ram-total">0 MB</span>
                    </div>
                </div>

                <!-- DISK -->
                <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8">
                    <div class="flex items-center gap-5 mb-6">
                        <div class="text-6xl">💾</div>
                        <div class="flex-1">
                            <p class="text-neutral-400 text-sm font-medium">Disk Usage</p>
                            <p id="disk-text" class="text-6xl font-bold text-emerald-400">0%</p>
                        </div>
                    </div>
                    <div id="disk-graph" class="bar-graph"></div>
                    <div class="flex justify-between text-xs text-neutral-400 mt-6">
                        <span id="disk-used">0 MB</span>
                        <span id="disk-total">0 MB</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 12;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let ws;
    let statsWs;
    let eulaModalShown = false;

    // ==================== BAR GRAPH (auto-responsive) ====================
    function updateBarGraph(graphId, percent, colorClass) {
        const graph = document.getElementById(graphId);
        if (!graph) return;
        
        const targetHeight = Math.max(8, Math.min(100, Math.round(percent || 0))) + '%';

        // Create bars on first call (or after resize)
        if (graph.children.length === 0) {
            graph.innerHTML = '';
            const paddingTotal = 20;
            const availableWidth = graph.clientWidth - paddingTotal || 240;
            const barWidthWithGap = 9;
            let numBars = Math.floor(availableWidth / barWidthWithGap);
            numBars = Math.max(10, Math.min(45, numBars));

            const fragment = document.createDocumentFragment();
            for (let i = 0; i < numBars; i++) {
                const bar = document.createElement('div');
                bar.className = `bar ${colorClass}`;
                bar.style.transitionDelay = `${i * 7}ms`;
                fragment.appendChild(bar);
            }
            graph.appendChild(fragment);
        }

        Array.from(graph.children).forEach(bar => {
            bar.style.height = targetHeight;
        });
    }

    // ==================== CACHE ELEMENTS ====================
    let cpuEl, ramTextEl, ramUsedEl, ramTotalEl, diskTextEl, diskUsedEl, diskTotalEl, 
        cpuStatusEl, statusEl, statusIconEl, statusDotEl;

    // ==================== CONSOLE WS ====================
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);
        
        ws.onopen = () => console.log('[Console] Connected');
        
        ws.onmessage = handleWebSocketMessage;
        
        ws.onclose = () => {
            console.log('[Console] Closed – reconnecting...');
            setTimeout(initWebSocket, 2200);
        };
    }

    function handleWebSocketMessage(msg) {
        const logsDiv = document.getElementById('console-logs');
        const lines = msg.data.split('\n');

        lines.forEach(line => {
            const trimmed = line.trim();
            if (!trimmed) return;

            // EULA detection
            if (trimmed.toLowerCase().includes('you need to agree to the eula') || 
                trimmed.toLowerCase().includes('eula.txt')) {
                showEulaModal();
            }

            // Reconnect notice
            if (trimmed.includes("Working on")) {
                logsDiv.innerHTML = '<div class="text-amber-300">[panel] reconnecting socket...</div>';
                if (ws) ws.close();
                return;
            }

            // Daemon down
            if (trimmed.includes("KS Wings instance appears to be down")) {
                document.getElementById('daemonIsDown').classList.remove('hidden');
            } else {
                document.getElementById('daemonIsDown').classList.add('hidden');
            }

            const lineEl = document.createElement('div');
            lineEl.textContent = trimmed;
            logsDiv.appendChild(lineEl);
            logsDiv.scrollTop = logsDiv.scrollHeight;
        });
    }

    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        if (!command || !ws) return;

        const logsDiv = document.getElementById('console-logs');
        const cmdEl = document.createElement('div');
        cmdEl.innerHTML = `<span class="text-amber-400">~ </span>${command}`;
        logsDiv.appendChild(cmdEl);
        logsDiv.scrollTop = logsDiv.scrollHeight;

        ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: instanceId
        }));

        if (commandHistory.length === maxCommands) commandHistory.shift();
        commandHistory.push(command);
        currentCommandIndex = commandHistory.length;

        input.value = '';
    }

    function handleKeyUp(e) {
        if (e.key === 'ArrowUp') {
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
            e.preventDefault();
        } else if (e.key === 'ArrowDown') {
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
            e.preventDefault();
        }
    }

    // ==================== STATS WS + UPDATES ====================
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);

        statsWs.onmessage = event => {
            if (!isValidJson(event.data)) return;
            const stats = JSON.parse(event.data);
            if (stats.error) return;

            updateStatus(stats);
            updateCpuUsage(stats);
            updateRamUsage(stats);
            updateDiskUsage(stats);
        };

        statsWs.onclose = () => setTimeout(initStatsWebSocket, 2800);
    }

    function isValidJson(str) {
        try { JSON.parse(str); return true; } catch { return false; }
    }

    function formatBytes(bytes) {
        if (!bytes) return '0 MB';
        const k = 1024;
        const sizes = ['Bytes','KB','MB','GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }

    function updateStatus(stats) {
        const ramRaw = (stats.memory_stats?.usage || 0) / 1024 / 1024;
        if (ramRaw > 1) {
            statusEl.textContent = 'Online';
            statusEl.className = 'text-6xl font-bold tracking-tighter text-emerald-400';
            statusIconEl.textContent = '🟢';
            statusDotEl.innerHTML = `<div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div> LIVE`;
            statusDotEl.className = 'status-dot text-emerald-400';
        } else {
            statusEl.textContent = 'Offline';
            statusEl.className = 'text-6xl font-bold tracking-tighter text-red-400';
            statusIconEl.textContent = '⏹️';
            statusDotEl.innerHTML = `<div class="w-3 h-3 bg-red-400 rounded-full"></div> OFFLINE`;
            statusDotEl.className = 'status-dot text-red-400';
        }
    }

    function updateCpuUsage(stats) {
        const cpuDelta = stats.cpu_stats.cpu_usage.total_usage - (stats.precpu_stats?.cpu_usage.total_usage || 0);
        const sysDelta = stats.cpu_stats.system_cpu_usage - (stats.precpu_stats?.system_cpu_usage || 0);
        let percent = sysDelta ? ((cpuDelta / sysDelta) * 100) : 0;
        if (isNaN(percent)) percent = 0;

        cpuEl.textContent = Math.round(percent) + '%';
        cpuStatusEl.textContent = percent > 85 ? 'HIGH LOAD ⚠️' : 'Normal';
        updateBarGraph('cpu-graph', percent, 'text-orange-400');
    }

    function updateRamUsage(stats) {
        const usage = stats.memory_stats?.usage || 0;
        const limit = stats.memory_stats?.limit || <%= instance.Memory %> * 1024 * 1024;
        const usageMB = usage / 1024 / 1024;
        const limitMB = limit / 1024 / 1024;
        const percent = limitMB ? Math.round((usageMB / limitMB) * 100) : 0;

        ramTextEl.textContent = percent + '%';
        ramUsedEl.textContent = formatBytes(usage);
        ramTotalEl.textContent = formatBytes(limit);
        updateBarGraph('ram-graph', percent, 'text-blue-400');
    }

    function updateDiskUsage(stats) {
        const usedRaw = parseFloat(stats.volumeSize || 0);
        const limitMiB = <%= instance.Disk || 0 %>;
        
        if (limitMiB === 0) {
            diskTextEl.textContent = `${formatBytes(usedRaw * 1024 * 1024)} / Unlimited`;
            updateBarGraph('disk-graph', 0, 'text-emerald-400');
        } else {
            const percent = Math.round((usedRaw / limitMiB) * 100);
            diskTextEl.textContent = `${percent}%`;
            diskUsedEl.textContent = formatBytes(usedRaw * 1024 * 1024);
            diskTotalEl.textContent = formatBytes(limitMiB * 1024 * 1024);
            updateBarGraph('disk-graph', percent, 'text-emerald-400');
        }
    }

    // ==================== EULA MODAL ====================
    function showEulaModal() {
        if (eulaModalShown) return;
        eulaModalShown = true;
        
        const modal = document.createElement('div');
        modal.className = 'fixed inset-0 flex items-center justify-center bg-black/70 backdrop-blur z-[9999]';
        modal.innerHTML = `
            <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 w-full max-w-md mx-4 text-center">
                <p class="text-white text-xl font-medium">Minecraft EULA</p>
                <p class="mt-3 text-neutral-400 text-sm">You must accept the Mojang EULA to continue.</p>
                <a href="https://account.mojang.com/documents/minecraft_eula" target="_blank" class="text-emerald-400 underline mt-2 block">Read EULA</a>
                <button onclick="acceptEula()" 
                        class="mt-8 w-full bg-white text-gray-900 font-medium py-3.5 rounded-2xl hover:bg-gray-100">
                    I Agree
                </button>
            </div>
        `;
        document.body.appendChild(modal);
    }

    window.acceptEula = function() {
        axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
            .then(() => location.reload())
            .catch(console.error);
    };

    // ==================== CLEAR CONSOLE ====================
    window.clearConsole = function() {
        const logs = document.getElementById('console-logs');
        logs.innerHTML = '<div class="text-neutral-400">Console cleared.</div>';
    };

    // ==================== RESPONSIVE BAR GRAPHS ====================
    function makeGraphsResponsive() {
        const graphs = document.querySelectorAll('.bar-graph');
        graphs.forEach(g => g.innerHTML = '');
    }

    let resizeTimer;
    function handleResize() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(makeGraphsResponsive, 180);
    }

    // ==================== INIT ====================
    document.addEventListener('DOMContentLoaded', () => {
        // Cache DOM
        cpuEl = document.getElementById('cpu-text');
        ramTextEl = document.getElementById('ram-text');
        ramUsedEl = document.getElementById('ram-used');
        ramTotalEl = document.getElementById('ram-total');
        diskTextEl = document.getElementById('disk-text');
        diskUsedEl = document.getElementById('disk-used');
        diskTotalEl = document.getElementById('disk-total');
        cpuStatusEl = document.getElementById('cpu-status');
        statusEl = document.getElementById('status');
        statusIconEl = document.getElementById('status-icon');
        statusDotEl = document.getElementById('status-dot');

        // Setup console
        initWebSocket();

        // Command input
        const inputEl = document.getElementById('input');
        inputEl.addEventListener('keypress', e => { if (e.key === 'Enter') sendCommand(); });
        inputEl.addEventListener('keydown', handleKeyUp);

        // Power buttons
        ['start','restart','stop'].forEach(act => {
            document.getElementById(act + 'Button').addEventListener('click', () => {
                if (ws) ws.send(JSON.stringify({ event: `power:${act}`, containerId: instanceId }));
            });
        });

        // Stats
        initStatsWebSocket();

        // Resize handler
        window.addEventListener('resize', handleResize);
    });

    window.onbeforeunload = () => {
        if (ws) ws.close();
        if (statsWs) statsWs.close();
    };
</script>
