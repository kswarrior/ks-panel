<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
    }

    .xterm-viewport {
        overflow-y: hidden !important;
    }

    /* Premium glassmorphic design - PRESERVED EXACTLY */
    .glass {
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 8px 32px -12px rgb(0 0 0 / 0.3);
    }

    .glass:hover {
        background: rgba(255,255,255,0.09);
        border-color: rgba(255,255,255,0.25);
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.2);
    }

    .power-btn {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .power-btn:hover {
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.3);
    }
    .power-btn:active {
        transform: scale(0.97);
    }

    /* Stats cards - ultra smooth */
    .stat-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 25px 25px 50px -12px rgb(0 0 0 / 0.25);
    }

    /* ============================================
       RESPONSIVE DESIGN - PHONE & DESKTOP OPTIMIZED
       ============================================ */
    
    /* Mobile-first base styles */
    .main-container {
        padding: 0.75rem;
    }
    
    /* Power buttons container */
    .power-controls {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 0.75rem;
        padding: 0 0.75rem;
    }
    
    .power-btn {
        flex: 1;
        min-width: 80px;
        justify-content: center;
        padding: 0.625rem 0.75rem;
        font-size: 0.8125rem;
        border-radius: 1rem;
    }
    
    /* Instance info card */
    .instance-header {
        margin: 0.75rem;
        margin-bottom: 0.5rem;
    }
    
    .instance-card {
        padding: 1rem;
        border-radius: 1.5rem;
    }
    
    .instance-name {
        font-size: 1.125rem;
        font-weight: 600;
    }
    
    .instance-ip {
        margin-top: 0.5rem;
        font-size: 0.9375rem;
        gap: 0.5rem;
    }
    
    .instance-icon {
        margin-left: 0.75rem;
        padding: 0.625rem;
        border-radius: 0.75rem;
    }
    
    .instance-icon svg {
        width: 1.5rem;
        height: 1.5rem;
    }
    
    /* Status tag */
    .status-tag {
        padding: 0.375rem 0.75rem;
        font-size: 0.6875rem;
        border-radius: 9999px;
        letter-spacing: 0.05em;
    }
    
    /* Error banner */
    .error-banner {
        margin: 0.75rem;
        padding: 1rem;
        border-radius: 1rem;
    }
    
    /* Main content layout */
    .content-layout {
        display: flex;
        flex-direction: column;
        padding: 0 0.75rem;
        gap: 0.75rem;
    }
    
    /* Console section */
    .console-section {
        width: 100%;
    }
    
    .terminal-container {
        padding: 0.75rem;
        border-radius: 1.25rem;
    }
    
    #terminal {
        height: 280px;
        border-radius: 0.75rem;
        font-size: 11px;
    }
    
    .command-input {
        margin-top: 0.75rem;
        padding: 0.875rem 1rem;
        border-radius: 1rem;
        font-size: 0.9375rem;
    }
    
    /* Stats section */
    .stats-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }
    
    .stat-card {
        padding: 1rem;
        border-radius: 1.25rem;
        height: 120px;
    }
    
    .stat-label {
        font-size: 0.75rem;
    }
    
    .stat-percent {
        font-size: 2rem;
        margin-top: 0.125rem;
    }
    
    .stat-detail {
        font-size: 0.8125rem;
    }
    
    .stat-chart-container {
        margin-top: 0.5rem;
        height: 50px;
    }
    
    /* ============================================
       TABLET BREAKPOINT (768px+)
       ============================================ */
    @media (min-width: 768px) {
        .main-container {
            padding: 1rem;
        }
        
        .power-controls {
            gap: 0.625rem;
            margin-top: 1rem;
            padding: 0 1rem;
        }
        
        .power-btn {
            flex: 0 1 auto;
            padding: 0.625rem 1rem;
            font-size: 0.875rem;
            border-radius: 1rem;
        }
        
        .instance-header {
            margin: 1rem;
            margin-bottom: 0.75rem;
        }
        
        .instance-card {
            padding: 1.25rem;
        }
        
        .instance-name {
            font-size: 1.25rem;
        }
        
        .instance-ip {
            margin-top: 0.625rem;
            font-size: 1rem;
        }
        
        .instance-icon {
            padding: 0.75rem;
        }
        
        .instance-icon svg {
            width: 1.75rem;
            height: 1.75rem;
        }
        
        .status-tag {
            padding: 0.375rem 0.875rem;
            font-size: 0.75rem;
        }
        
        .error-banner {
            margin: 1rem;
            padding: 1.25rem;
        }
        
        .content-layout {
            padding: 0 1rem;
            gap: 1rem;
        }
        
        .terminal-container {
            padding: 1rem;
        }
        
        #terminal {
            height: 320px;
            font-size: 12px;
        }
        
        .command-input {
            margin-top: 0.875rem;
            padding: 1rem 1.25rem;
        }
        
        .stats-section {
            gap: 0.75rem;
        }
        
        .stat-card {
            padding: 1.25rem;
            height: 130px;
        }
        
        .stat-percent {
            font-size: 2.25rem;
        }
        
        .stat-chart-container {
            height: 55px;
        }
    }
    
    /* ============================================
       DESKTOP BREAKPOINT (1024px+)
       ============================================ */
    @media (min-width: 1024px) {
        .main-container {
            padding: 1.5rem;
        }
        
        .power-controls {
            gap: 0.75rem;
            margin-top: 1rem;
            padding: 0 1.5rem;
        }
        
        .power-btn {
            padding: 0.625rem 1.25rem;
        }
        
        .instance-header {
            margin: 1.5rem;
            margin-top: 1rem;
            margin-bottom: 0.75rem;
        }
        
        .instance-card {
            padding: 1.5rem;
            border-radius: 1.5rem;
        }
        
        .instance-name {
            font-size: 1.5rem;
        }
        
        .instance-ip {
            margin-top: 0.75rem;
            font-size: 1.125rem;
            gap: 0.75rem;
        }
        
        .instance-icon {
            margin-left: 1rem;
            padding: 0.875rem;
            border-radius: 1rem;
        }
        
        .instance-icon svg {
            width: 2rem;
            height: 2rem;
        }
        
        .status-tag {
            padding: 0.5rem 1rem;
            font-size: 0.8125rem;
        }
        
        .error-banner {
            margin: 1.5rem;
            margin-top: 1.5rem;
            margin-bottom: 1.5rem;
            padding: 1.5rem;
            border-radius: 1.25rem;
        }
        
        .content-layout {
            flex-direction: row;
            padding: 0 1.5rem;
            gap: 1.25rem;
        }
        
        .console-section {
            width: 66.666667%;
            padding-right: 0;
        }
        
        .terminal-container {
            padding: 1rem;
            border-radius: 1.5rem;
        }
        
        #terminal {
            height: 380px;
            border-radius: 1rem;
        }
        
        .command-input {
            margin-top: 1rem;
            padding: 1.125rem 1.5rem;
            border-radius: 1.25rem;
            font-size: 1rem;
        }
        
        .stats-section {
            width: 33.333333%;
            margin-top: 0;
            gap: 0.75rem;
        }
        
        .stat-card {
            padding: 1.25rem 1.5rem;
            border-radius: 1.5rem;
            height: 140px;
        }
        
        .stat-label {
            font-size: 0.875rem;
        }
        
        .stat-percent {
            font-size: 2.5rem;
            margin-top: 0.25rem;
        }
        
        .stat-detail {
            font-size: 0.9375rem;
        }
        
        .stat-chart-container {
            margin-top: 0.75rem;
            height: 60px;
        }
    }
    
    /* ============================================
       LARGE DESKTOP BREAKPOINT (1280px+)
       ============================================ */
    @media (min-width: 1280px) {
        .content-layout {
            gap: 1.5rem;
        }
        
        .console-section {
            width: 70%;
        }
        
        .stats-section {
            width: 30%;
        }
        
        #terminal {
            height: 420px;
        }
        
        .stat-card {
            height: 150px;
        }
        
        .stat-percent {
            font-size: 3rem;
        }
        
        .stat-chart-container {
            height: 70px;
        }
    }
    
    /* ============================================
       TOUCH OPTIMIZATIONS
       ============================================ */
    @media (hover: none) and (pointer: coarse) {
        .power-btn:hover {
            transform: none;
            box-shadow: 0 8px 32px -12px rgb(0 0 0 / 0.3);
        }
        
        .power-btn:active {
            transform: scale(0.96);
        }
        
        .stat-card:hover {
            transform: none;
            box-shadow: 0 8px 32px -12px rgb(0 0 0 / 0.3);
        }
        
        .glass:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.12);
            box-shadow: 0 8px 32px -12px rgb(0 0 0 / 0.3);
        }
    }
    
    /* ============================================
       SAFE AREA INSETS FOR MODERN PHONES
       ============================================ */
    @supports (padding: max(0px)) {
        .main-container {
            padding-left: max(0.75rem, env(safe-area-inset-left));
            padding-right: max(0.75rem, env(safe-area-inset-right));
            padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
        }
        
        @media (min-width: 768px) {
            .main-container {
                padding-left: max(1rem, env(safe-area-inset-left));
                padding-right: max(1rem, env(safe-area-inset-right));
                padding-bottom: max(1rem, env(safe-area-inset-bottom));
            }
        }
        
        @media (min-width: 1024px) {
            .main-container {
                padding-left: max(1.5rem, env(safe-area-inset-left));
                padding-right: max(1.5rem, env(safe-area-inset-right));
            }
        }
    }
</style>

<main class="overflow-hidden main-container" id="content">
    <% if (false) { %>
        <% if (instance.imageData.features && instance.imageData.features.includes('eula')) { %>
            <div class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur z-50">
                <div class="bg-white/5 backdrop-blur py-8 px-8 rounded-2xl shadow-lg w-1/2 h-48">
                    <p class="text-white text-lg font-medium">Do you accept Minecraft's EULA?</p>
                    <p class="text-sm text-neutral-400">By pressing this button you agree to the <a class="text-white" href="https://account.mojang.com/documents/minecraft_eula">Mojang EULA</a>.</p>
                    <button 
                    onclick="axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
                        .then(response => {
                            if (response.status === 200) {
                                location.reload();
                            }
                        })
                        .catch(error => {
                            console.error('There was an error!', error);
                        });" 
                    class="mt-8 bg-white text-sm font-sm text-gray-800 px-4 font-medium transition py-2 rounded-2xl hover:bg-gray-100">
                    I agree
                    </button>
                </div>
            </div>
        <% } %>
    <% } %>
    
    <%- include('../components/instance') %>

    <!-- Power Controls - Optimized for touch on mobile -->
    <div class="power-controls">
        <!-- Start Button -->
        <button id="startButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-emerald-600 text-sm font-medium text-white shadow-lg hover:bg-emerald-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1.5 text-emerald-100 flex-shrink-0">
                <path fill-rule="evenodd"
                    d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z"
                    clip-rule="evenodd" />
            </svg>
            <span class="whitespace-nowrap"><%= req.translations.start %></span>
        </button>

        <!-- Restart Button -->
        <button id="restartButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-blue-600 text-sm font-medium text-white shadow-lg hover:bg-blue-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1.5 text-white flex-shrink-0">
                <path fill-rule="evenodd"
                    d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z"
                    clip-rule="evenodd" />
            </svg>
            <span class="whitespace-nowrap"><%= req.translations.restart %></span>
        </button>

        <!-- Stop Button -->
        <button id="stopButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-red-600 text-sm font-medium text-white shadow-lg hover:bg-red-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1.5 text-red-100 flex-shrink-0">
                <path fill-rule="evenodd"
                    d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z"
                    clip-rule="evenodd" />
            </svg>
            <span class="whitespace-nowrap"><%= req.translations.stop %></span>
        </button>
    </div>

    <!-- Instance Header Card -->
    <div class="instance-header">
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Address Card -->
            <div class="overflow-hidden instance-card glass shadow-xl flex items-center col-span-1 sm:col-span-2 lg:col-span-1">
                <div class="flex-grow min-w-0">
                    <div class="flex items-center justify-between flex-wrap gap-2">
                        <!-- Name -->
                        <span class="instance-name text-white truncate"><%= instance.Name %></span>
                        
                        <!-- Status tag -->
                        <span id="statusTag" class="status-tag inline-flex items-center bg-emerald-500/10 text-emerald-400">Online</span>
                    </div>
                    
                    <!-- IP -->
                    <div onclick="copyIP()" id="ipContainer"
                        class="instance-ip font-normal italic text-white flex items-center gap-2 cursor-pointer hover:text-emerald-300 transition break-all">
                        <span id="ipText" class="truncate">
                            <%= instance.Allocation.IP %><span class="text-neutral-400 not-italic">:</span><%= instance.Allocation.Port %>
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16v-4m4 4v4m-8-8h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v4a2 2 0 002 2z" />
                        </svg>
                    </div>
                </div>
                <div class="instance-icon shadow border border-white/10">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M240,120a8,8,0,0,1-8,8H200v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H176a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H72v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H24a8,8,0,0,1,0-16h96V88h-8A16,16,0,0,1,96,72V40a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V72a16,16,0,0,1-16,16h-8v24h96A8,8,0,0,1,240,120Z"/></svg>
                </div>
            </div>
        </dl>
    </div>

    <!-- Error Banner -->
    <div class="error-banner bg-red-800/10 hidden" id="daemonIsDown">
        <div class="flex">
            <div class="flex-shrink-0 ml-1">
                <svg class="animate-spin mt-1.5 h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg"
                    fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                    </circle>
                    <path class="opacity-75" fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                    </path>
                </svg>
            </div>
            <div class="ml-4">
                <h3 class="text-sm font-medium text-red-400"><%= req.translations.connectionFailure %></h3>
                <div class="text-sm text-red-400/70 mt-1">
                    <p><%= req.translations.connectionFailureText %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content: Console + Stats -->
    <div class="content-layout">
        <!-- Left side: Console -->
        <div class="console-section">
            <div class="glass terminal-container">
                <div id="terminal" class="overflow-x-auto whitespace-pre-wrap"></div>
            </div>
            <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>"
                class="command-input w-full bg-[#101010]/70 text-white border border-white/10 focus:border-white/30 placeholder:font-medium placeholder:text-neutral-400 focus:outline-none transition-all">
        </div>
        
        <!-- Right side: Stats Cards -->
        <div class="stats-section">
            
            <!-- RAM Card -->
            <div class="stat-card bg-white/5 shadow flex flex-col relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="stat-label font-medium text-neutral-400"><%= req.translations.ramUsage %></span>
                        <div id="ramPercent" class="stat-percent font-semibold leading-none text-white">0%</div>
                    </div>
                    <div id="ramUsageText" class="stat-detail font-medium text-white">0 GB / 0 GB</div>
                </div>
                <div class="stat-chart-container flex-1 relative">
                    <canvas id="ramChart"></canvas>
                </div>
            </div>
            
            <!-- CPU Card -->
            <div class="stat-card bg-white/5 shadow flex flex-col relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="stat-label font-medium text-neutral-400"><%= req.translations.cpuUsage %></span>
                        <div id="cpuPercent" class="stat-percent font-semibold leading-none text-white">0%</div>
                    </div>
                    <div id="cpuUsageText" class="stat-detail font-medium text-white">0%</div>
                </div>
                <div class="stat-chart-container flex-1 relative">
                    <canvas id="cpuChart"></canvas>
                </div>
            </div>
            
            <!-- Disk Card -->
            <div class="stat-card bg-white/5 shadow flex flex-col relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="stat-label font-medium text-neutral-400"><%= req.translations.diskUsage %></span>
                        <div id="diskPercent" class="stat-percent font-semibold leading-none text-white">0%</div>
                    </div>
                    <div id="diskUsageText" class="stat-detail font-medium text-white">0 GB / 0 GB</div>
                </div>
                <div class="stat-chart-container flex-1 relative">
                    <canvas id="diskChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // ============================================
    // FULL WORKING JS - PRESERVED EXACTLY
    // ============================================

    const baseTheme = {
        foreground: '#c5c9d1',
        background: 'rgba(0 0 0 / 0)',
        selection: '#5DA5D533',
        black: '#1E1E1D',
        brightBlack: '#262625',
        red: '#E54B4B',
        green: '#9ECE58',
        yellow: '#FAED70',
        blue: '#396FE2',
        magenta: '#BB80B3',
        cyan: '#2DDAFD',
        white: '#d0d0d0',
        brightBlack: 'rgba(255, 255, 255, 0.2)',
        brightRed: '#FF5370',
        brightGreen: '#C3E88D',
        brightYellow: '#FFCB6B',
        brightBlue: '#82AAFF',
        brightMagenta: '#C792EA',
        brightCyan: '#89DDFF',
        brightWhite: '#ffffff',
    };

    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 50;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let term;
    let ws;
    let statsWs;
    let reconnectAttempts = 0;
    const maxReconnectAttempts = 10;

    // Utilities
    function isValidJson(str) {
        try { JSON.parse(str); return true; } catch { return false; }
    }

    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }

    // Copy IP:Port
    function copyIP() {
        const ipText = document.getElementById('ipText').textContent.trim();
        navigator.clipboard.writeText(ipText).then(() => {
            const container = document.getElementById('ipContainer');
            const originalHTML = container.innerHTML;
            container.style.transition = 'all 0.2s';
            container.style.color = '#10b981';
            setTimeout(() => {
                container.innerHTML = originalHTML.replace('text-neutral-400', 'text-emerald-400');
                setTimeout(() => {
                    container.innerHTML = originalHTML;
                    container.style.color = '';
                }, 1200);
            }, 80);
        });
    }

    // Stylish SVG loading spinner for power buttons
    function showProcessing(btn) {
        const originalHTML = btn.innerHTML;
        btn.dataset.originalHTML = originalHTML;
        btn.disabled = true;
        btn.style.opacity = '0.75';
        btn.style.pointerEvents = 'none';
        
        btn.innerHTML = `
            <svg class="animate-spin h-4 w-4 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Processing...
        `;
    }

    function hideProcessing(btn) {
        if (btn.dataset.originalHTML) {
            btn.innerHTML = btn.dataset.originalHTML;
            btn.disabled = false;
            btn.style.opacity = '';
            btn.style.pointerEvents = '';
            delete btn.dataset.originalHTML;
        }
    }

    // Power action with direct execution (no confirm) + stylish SVG animation
    async function performPowerAction(btn, action) {
        showProcessing(btn);
        
        try {
            const res = await axios.post(`/instance/${instanceId}/power`, { action });
            if (res.status === 200) {
                console.log(`Instance ${action}ed successfully`);
            }
        } catch (err) {
            console.error(`Failed to ${action} instance`, err);
        } finally {
            hideProcessing(btn);
        }
    }

    // Terminal
    function setupTerminal() {
        // Responsive terminal sizing
        const terminalEl = document.getElementById('terminal');
        const isMobile = window.innerWidth < 768;
        const isTablet = window.innerWidth >= 768 && window.innerWidth < 1024;
        
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.35,
            rows: isMobile ? 16 : (isTablet ? 18 : 19),
            cols: isMobile ? 60 : (isTablet ? 80 : 100),
            fontFamily: 'Menlo, monospace',
            theme: baseTheme,
            allowTransparency: true,
            fontSize: isMobile ? 11 : 12,
        });
        term.open(terminalEl);
    }

    // Console WebSocket
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);

        ws.onopen = () => {
            console.log('[Console] WebSocket connected');
            reconnectAttempts = 0;
            document.getElementById('daemonIsDown').classList.add('hidden');
        };

        ws.onmessage = (msg) => {
            const data = msg.data;
            term.write(data);

            if (data.includes("Working on")) {
                term.write('\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...');
                ws.close();
            }

            if (data.includes("KS Wings instance appears to be down")) {
                ws.close();
                document.getElementById('daemonIsDown').classList.remove('hidden');
            }
        };

        ws.onclose = () => {
            if (reconnectAttempts < maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000);
                setTimeout(initWebSocket, delay);
                reconnectAttempts++;
            }
        };

        ws.onerror = (error) => console.error('[Console] WebSocket error:', error);
    }

    // Command handling
    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        if (!command || !ws) return;

        term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');

        ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: instanceId
        }));

        if (commandHistory.length >= maxCommands) commandHistory.shift();
        commandHistory.push(command);
        currentCommandIndex = commandHistory.length;

        input.value = '';
    }

    function handleKeyUp(e) {
        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
        } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
        }
    }

    // Power buttons
    function initPowerButtons() {
        const actions = {
            start: document.getElementById('startButton'),
            restart: document.getElementById('restartButton'),
            stop: document.getElementById('stopButton')
        };

        Object.keys(actions).forEach(action => {
            const btn = actions[action];
            btn.addEventListener('click', () => {
                performPowerAction(btn, action);
            });
        });
    }

    // Stats WebSocket
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);

        statsWs.onmessage = (event) => {
            if (!isValidJson(event.data)) return;
            const stats = JSON.parse(event.data);
            if (stats.error) return;

            updateRamUsage(stats);
            updateCpuUsage(stats);
            updateDiskUsage(stats);
            updateStatus(stats);
        };

        statsWs.onclose = () => setTimeout(initStatsWebSocket, 5000);
    }

    // === SMOOTH & BEAUTIFUL CHARTS ===
    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: { 
            x: { display: false },
            y: { display: false, min: 0, max: 100 }
        },
        animation: { duration: 0 },
        elements: {
            line: {
                borderWidth: 3,
                tension: 0.5
            },
            point: {
                radius: 0
            }
        }
    };

    const ramChart = new Chart(document.getElementById('ramChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.15)', fill: true }] },
        options: chartOptions
    });

    const cpuChart = new Chart(document.getElementById('cpuChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.15)', fill: true }] },
        options: chartOptions
    });

    const diskChart = new Chart(document.getElementById('diskChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#8b5cf6', backgroundColor: 'rgba(139,92,246,0.15)', fill: true }] },
        options: chartOptions
    });

    function updateChart(chart, value) {
        chart.data.datasets[0].data.push(parseFloat(value) || 0);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }

    function updateRamUsage(stats) {
        const usage = stats.memory_stats?.usage || 0;
        const limit = stats.memory_stats?.limit || 0;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;

        document.getElementById('ramPercent').textContent = `${percent}%`;
        document.getElementById('ramUsageText').textContent = `${formatBytes(usage)} / ${formatBytes(limit)}`;
        updateChart(ramChart, percent);
    }

    function updateCpuUsage(stats) {
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const percent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;

        document.getElementById('cpuPercent').textContent = `${percent}%`;
        document.getElementById('cpuUsageText').textContent = `${percent}%`;
        updateChart(cpuChart, percent);
    }

    function updateDiskUsage(stats) {
        const usage = parseFloat(stats.volumeSize) || 0;
        const limit = <%= instance.Disk || 0 %>;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;

        document.getElementById('diskPercent').textContent = `${percent}%`;
        if (limit === 0) {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / Unlimited`;
        } else {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / ${formatBytes(limit * 1024 * 1024)}`;
        }
        updateChart(diskChart, percent);
    }

    // Status tag
    function updateStatus(stats) {
        const ramUsage = stats.memory_stats?.usage || 0;
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;

        const tag = document.getElementById('statusTag');

        if (isRunning) {
            tag.textContent = 'Online';
            tag.className = 'status-tag inline-flex items-center bg-emerald-500/10 text-emerald-400';
        } else {
            tag.textContent = 'Offline';
            tag.className = 'status-tag inline-flex items-center bg-red-500/10 text-red-400';
        }
    }

    // Handle resize for terminal
    function handleResize() {
        if (term) {
            const isMobile = window.innerWidth < 768;
            const isTablet = window.innerWidth >= 768 && window.innerWidth < 1024;
            
            // Update terminal options
            term.options.rows = isMobile ? 16 : (isTablet ? 18 : 19);
            term.options.cols = isMobile ? 60 : (isTablet ? 80 : 100);
            term.options.fontSize = isMobile ? 11 : 12;
        }
    }

    // Main initialization
    document.addEventListener('DOMContentLoaded', () => {
        setupTerminal();
        initWebSocket();
        initPowerButtons();
        initStatsWebSocket();

        const input = document.getElementById('input');
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendCommand(); });
        input.addEventListener('keydown', handleKeyUp);

        // Visibility handling
        document.addEventListener('visibilitychange', () => {
            if (document.hidden && statsWs) statsWs.onmessage = null;
            else if (statsWs) initStatsWebSocket();
        });

        // Responsive resize handling
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(handleResize, 250);
        });
    });
</script>

<%- include('../components/footer') %>
