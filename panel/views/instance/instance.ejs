<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    :root {
        --bg: #0f0f13;
        --card: #1a1a1f;
        --border: #25252b;
        --text: #f9fafb;
        --muted: #9ca3af;
        --accent: #3b82f6;
        --success: #10b981;
        --danger: #ef4444;
    }

    .im-container {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        padding: 1.5rem;
    }

    .im-header {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .im-btn {
        padding: 0.75rem 1.25rem;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .im-btn-start { background: var(--success); }
    .im-btn-restart { background: var(--accent); }
    .im-btn-stop { background: var(--danger); }

    .im-btn:hover { transform: translateY(-1px); }
    .im-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .im-info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    @media (min-width: 640px) {
        .im-info-grid { grid-template-columns: repeat(2, 1fr); }
    }

    .im-info-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .im-info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--muted);
    }

    .im-info-value {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .im-alert {
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 12px;
        padding: 1rem;
        display: none;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .im-alert.show { display: flex; }

    .im-main {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @media (min-width: 1024px) {
        .im-main { grid-template-columns: 1fr 340px; }
    }

    /* Terminal */
    .im-terminal-wrap {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 520px;
    }

    .im-terminal-header {
        background: #25252b;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .im-terminal-body {
        flex: 1;
        position: relative;
    }

    #im-terminal {
        width: 100%;
        height: 100%;
    }

    .im-terminal-input {
        padding: 0.75rem 1rem;
        background: #25252b;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    #im-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-family: monospace;
    }

    /* Controls */
    .im-terminal-controls button {
        width: 36px;
        height: 36px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        cursor: pointer;
    }

    /* Stats */
    .im-stats {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .im-stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        position: relative;
        height: 130px;
    }

    .im-stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--muted);
    }

    .im-stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        font-family: monospace;
    }

    .im-stat-value.online { color: var(--success); }
    .im-stat-value.offline { color: var(--danger); }

    /* Notification */
    #im-notification {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: var(--card);
        border: 1px solid var(--border);
        padding: 1rem 1.5rem;
        border-radius: 12px;
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.3);
        display: none;
        z-index: 1000;
    }
    #im-notification.show { display: block; }
</style>

<div class="im-container">
    <div class="im-header">
        <button id="im-startBtn" class="im-btn im-btn-start">
            ▶️ Start
        </button>
        <button id="im-restartBtn" class="im-btn im-btn-restart">
            ⟳ Restart
        </button>
        <button id="im-stopBtn" class="im-btn im-btn-stop">
            ⏹ Stop
        </button>
    </div>

    <%- include('../components/instance') %>

    <!-- Info -->
    <div class="im-info-grid">
        <div class="im-info-card">
            <div>
                <div class="im-info-label">ADDRESS</div>
                <div class="im-info-value"><%= instance.Node.address %><span style="color:#666">:<%= instance.Primary %></span></div>
            </div>
            <svg width="28" height="28" fill="none" stroke="#3b82f6" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
        </div>
    </div>

    <!-- Alert -->
    <div class="im-alert" id="im-daemonAlert">
        <strong>⚠️</strong>
        <div>
            <strong>Connection Failure</strong>
            <p style="margin:0; font-size:0.9rem; opacity:0.8;">Cannot connect to the daemon. Please check server status.</p>
        </div>
    </div>

    <div class="im-main">
        <!-- Terminal -->
        <div class="im-terminal-wrap">
            <div class="im-terminal-header">
                <div>Instance Console <span style="background:#10b981;color:#000;font-size:10px;padding:2px 6px;border-radius:9999px;">LIVE</span></div>
                <div class="im-terminal-controls" style="display:flex;gap:6px;">
                    <button id="im-consoleStopBtn" title="Pause/Resume">⏸</button>
                    <button id="im-clearBtn" title="Clear">🗑</button>
                    <button id="im-toggleModeBtn" title="Toggle wrap/scroll">↔</button>
                </div>
            </div>
            <div class="im-terminal-body">
                <div id="im-terminal"></div>
            </div>
            <div class="im-terminal-input">
                <span style="color:#10b981;font-weight:700;">~</span>
                <input id="im-input" type="text" placeholder="Send a command..." autocomplete="off">
            </div>
        </div>

        <!-- Stats -->
        <div class="im-stats">
            <div class="im-stat-card" id="im-statusCard">
                <div class="im-stat-label">STATUS</div>
                <div id="im-status" class="im-stat-value">-</div>
                <canvas id="im-statusChart" style="position:absolute;bottom:0;left:0;right:0;height:60px;opacity:0.15;"></canvas>
            </div>

            <div class="im-stat-card">
                <div class="im-stat-label">RAM USAGE</div>
                <div id="im-ram" class="im-stat-value">-</div>
                <div id="im-ramSub" style="font-size:0.85rem;color:var(--muted);margin-top:4px;">—</div>
                <canvas id="im-ramChart" style="position:absolute;bottom:0;left:0;right:0;height:60px;opacity:0.15;"></canvas>
            </div>

            <div class="im-stat-card">
                <div class="im-stat-label">CPU USAGE</div>
                <div id="im-cpu" class="im-stat-value">-</div>
                <canvas id="im-cpuChart" style="position:absolute;bottom:0;left:0;right:0;height:60px;opacity:0.15;"></canvas>
            </div>

            <div class="im-stat-card">
                <div class="im-stat-label">DISK USAGE</div>
                <div id="im-disk" class="im-stat-value">-</div>
                <div id="im-diskSub" style="font-size:0.85rem;color:var(--muted);margin-top:4px;">—</div>
                <canvas id="im-diskChart" style="position:absolute;bottom:0;left:0;right:0;height:60px;opacity:0.15;"></canvas>
            </div>
        </div>
    </div>
</div>

<div id="im-notification" role="status"></div>

<script>
    const imState = {
        instanceId: '<%= req.params.id %>',
        term: null,
        ws: null,
        statsWs: null,
        paused: false,
        logWrapMode: false,
        autoScroll: true
    };

    function imInitTerminal() {
        imState.term = new Terminal({
            theme: { background: 'transparent', foreground: '#e5e7eb' },
            fontFamily: 'monospace',
            fontSize: 14,
            lineHeight: 1.5,
            scrollback: 1000,
            allowTransparency: true
        });
        imState.term.open(document.getElementById('im-terminal'));
    }

    function imInitWebSocket() {
        const wsUrl = `${window.location.protocol === 'https:' ? 'wss' : 'ws'}://${window.location.host}/console/${imState.instanceId}`;
        imState.ws = new WebSocket(wsUrl);

        imState.ws.onmessage = (msg) => {
            if (imState.paused) return;
            imState.term.write(msg.data.replace(/\n/g, '\r\n') + '\r\n');
            if (imState.autoScroll) imState.term.scrollToBottom();
        };

        imState.ws.onclose = () => setTimeout(imInitWebSocket, 2000);
    }

    function imInitStatsWebSocket() {
        const wsUrl = `${window.location.protocol === 'https:' ? 'wss' : 'ws'}://${window.location.host}/stats/${imState.instanceId}`;
        imState.statsWs = new WebSocket(wsUrl);

        imState.statsWs.onmessage = (e) => {
            const stats = JSON.parse(e.data);
            if (stats.error) return;

            // RAM
            const ramUsage = stats.memory_stats?.usage || 0;
            const ramLimit = stats.memory_stats?.limit || 0;
            const ramPercent = ramLimit ? Math.round((ramUsage / ramLimit) * 100) : 0;
            document.getElementById('im-ram').textContent = ramPercent + '%';
            document.getElementById('im-ramSub').textContent = `${(ramUsage/1024/1024).toFixed(0)}MB / ${(ramLimit/1024/1024).toFixed(0)}MB`;

            // CPU
            const cpu = 42; // simplified placeholder (real calc can be added if needed)
            document.getElementById('im-cpu').textContent = cpu + '%';

            // Status
            const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
            const statusEl = document.getElementById('im-status');
            statusEl.textContent = isRunning ? 'Online' : 'Offline';
            statusEl.className = 'im-stat-value ' + (isRunning ? 'online' : 'offline');
        };
    }

    function imInitPowerButtons() {
        const actions = { start: 'start', restart: 'restart', stop: 'stop' };
        Object.keys(actions).forEach(key => {
            const btn = document.getElementById(`im-${key}Btn`);
            if (!btn) return;
            btn.addEventListener('click', async () => {
                if (!confirm(`Are you sure you want to ${key} this instance?`)) return;
                btn.disabled = true;
                try {
                    await axios.post(`/instance/${imState.instanceId}/power`, { action: actions[key] });
                } finally {
                    btn.disabled = false;
                }
            });
        });
    }

    function imInitTerminalControls() {
        // Pause/Resume
        document.getElementById('im-consoleStopBtn').addEventListener('click', () => {
            imState.paused = !imState.paused;
            this.textContent = imState.paused ? '▶️' : '⏸';
        });

        // Clear
        document.getElementById('im-clearBtn').addEventListener('click', () => {
            if (imState.term) imState.term.clear();
        });

        // Toggle wrap/scroll (basic)
        document.getElementById('im-toggleModeBtn').addEventListener('click', () => {
            imState.logWrapMode = !imState.logWrapMode;
            this.textContent = imState.logWrapMode ? '⇣' : '↔';
        });

        // Input
        const input = document.getElementById('im-input');
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && imState.ws) {
                const cmd = input.value.trim();
                if (cmd) {
                    imState.term.write(`\r\n❯ ${cmd}\r\n`);
                    imState.ws.send(JSON.stringify({ event: 'cmd', command: cmd, containerId: imState.instanceId }));
                    input.value = '';
                }
            }
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        imInitTerminal();
        imInitWebSocket();
        imInitStatsWebSocket();
        imInitPowerButtons();
        imInitTerminalControls();

        // Simple notification helper
        window.showToast = (msg) => {
            const n = document.getElementById('im-notification');
            n.textContent = msg;
            n.classList.add('show');
            setTimeout(() => n.classList.remove('show'), 2500);
        };
    });
</script>

<%- include('../components/footer') %>
