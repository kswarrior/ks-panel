    </div>

    <!-- Main Content Grid - Responsive Layout -->
    <div class="flex flex-col lg:flex-row px-4 sm:px-6 gap-4 lg:gap-6 pb-6">
        <!-- Console Section - Full width on mobile, 2/3 on desktop -->
        <div class="w-full lg:w-2/3 flex flex-col">
            <div class="glass rounded-2xl p-3 sm:p-4 flex-1">
                <div id="terminal" class="overflow-x-auto whitespace-pre-wrap h-[300px] sm:h-[380px] md:h-[400px] rounded-xl"></div>
            </div>
            <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>"
                class="mt-3 w-full px-4 sm:px-6 py-3 sm:py-4 bg-[#101010]/70 text-white rounded-2xl text-sm sm:text-base border border-white/10 focus:border-white/30 placeholder:font-medium placeholder:text-neutral-400 focus:outline-none transition-all">
        </div>
        
        <!-- Stats Cards - Responsive Grid: 1 col mobile, 2 col tablet, 3 col desktop -->
        <div class="w-full lg:w-1/3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-3 gap-3 sm:gap-4">
            <!-- RAM -->
