<!-- Notification Toast -->
<div id="notification" role="status" aria-live="polite"></div>

<script>
    // Theme configuration
    const baseTheme = {
        foreground: '#e5e7eb',
        background: 'transparent',
        selection: 'rgba(59, 130, 246, 0.3)',
        black: '#0f0f13',
        brightBlack: '#1a1a1f',
        red: '#ef4444',
        brightRed: '#f87171',
        green: '#10b981',
        brightGreen: '#34d399',
        yellow: '#f59e0b',
        brightYellow: '#fbbf24',
        blue: '#3b82f6',
        brightBlue: '#60a5fa',
        magenta: '#a855f7',
        brightMagenta: '#c084fc',
        cyan: '#06b6d4',
        brightCyan: '#22d3ee',
        white: '#f9fafb',
        brightWhite: '#ffffff',
        cursor: '#3b82f6',
        cursorAccent: '#1a1a1f',
    };
    
    // State management
    const state = {
        protocol: window.location.protocol === 'https:' ? 'wss' : 'ws',
        instanceId: '<%= req.params.id %>',
        maxCommands: 50,
        commandHistory: [],
        currentCommandIndex: -1,
        term: null,
        ws: null,
        statsWs: null,
        eulaModalShown: false,
        reconnectAttempts: 0,
        maxReconnectAttempts: 10,
        charts: {},
        lastStats: null
    };
    
    // Utilities
    const utils = {
        debounce: (fn, delay) => {
            let timeout;
            return (...args) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => fn(...args), delay);
            };
        },
        
        throttle: (fn, limit) => {
            let inThrottle;
            return (...args) => {
                if (!inThrottle) {
                    fn(...args);
                    inThrottle = true;
                    setTimeout(() => inThrottle = false, limit);
                }
            };
        },
        
        formatBytes: (bytes, decimals = 2) => {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        },
        
        isValidJson: (str) => {
            try {
                JSON.parse(str);
                return true;
            } catch {
                return false;
            }
        },
        
        showNotification: (message, type = 'info') => {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = 'show';
            setTimeout(() => notification.classList.remove('show'), 3000);
        }
    };
    
    // Terminal initialization
    function initTerminal() {
        const screenWidth = window.innerWidth;
        const config = {
            cols: screenWidth < 640 ? 40 : screenWidth < 1024 ? 80 : 100,
            rows: screenWidth < 640 ? 20 : 24,
            fontSize: screenWidth < 640 ? 12 : 14,
        };
        
        state.term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.5,
            rows: config.rows,
            cols: config.cols,
            fontFamily: 'JetBrains Mono, Fira Code, Menlo, Monaco, Courier New, monospace',
            fontSize: config.fontSize,
            theme: baseTheme,
            allowTransparency: true,
            cursorBlink: false,
            scrollback: 5000,
            smoothScrollDuration: 0,
            fastScrollModifier: 'alt',
            fastScrollSensitivity: 5,
        });
        
        state.term.open(document.getElementById('terminal'));
        
        const handleResize = utils.debounce(() => {
            const newWidth = window.innerWidth;
            const newConfig = {
                cols: newWidth < 640 ? 40 : newWidth < 1024 ? 80 : 100,
                rows: newWidth < 640 ? 20 : 24,
            };
            state.term.resize(newConfig.cols, newConfig.rows);
        }, 250);
        
        window.addEventListener('resize', handleResize, { passive: true });
    }
    
    // WebSocket management
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `${state.protocol}://${window.location.hostname}${port}/console/${state.instanceId}`;
        
        state.ws = new WebSocket(wsUrl);
        
        state.ws.onopen = () => {
            console.log('WebSocket connected');
            state.reconnectAttempts = 0;
            document.getElementById('daemonIsDown').classList.add('hidden');
        };
        
        state.ws.onmessage = handleWebSocketMessage;
        
        state.ws.onclose = () => {
            if (state.reconnectAttempts < state.maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, state.reconnectAttempts), 30000);
                setTimeout(initWebSocket, delay);
                state.reconnectAttempts++;
            }
        };
        
        state.ws.onerror = (error) => {
            console.error('WebSocket error:', error);
        };
    }
    
    function handleWebSocketMessage(msg) {
        const lines = msg.data.split('\n');
        let isFirstLine = true;
        let previousLineWasEmpty = false;
        let output = '';
        
        lines.forEach(line => {
            const trimmedLine = line.trim();
            if (trimmedLine === '' && previousLineWasEmpty) return;
            
            if (trimmedLine.toLowerCase().includes('you need to agree to the eula') && 
                !state.eulaModalShown) {
                showEulaModal();
            }
            
            if (!isFirstLine && !previousLineWasEmpty) {
                output += '\r\n';
            }
            
            output += '\x1b[0m' + trimmedLine;
            
            if (trimmedLine.includes("Working on")) {
                output += '\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...';
                state.ws.close();
            }
            
            if (trimmedLine.includes("KS Wings instance appears to be down")) {
                state.ws.close();
                document.getElementById('daemonIsDown').classList.remove('hidden');
            }
            
            isFirstLine = false;
            previousLineWasEmpty = (trimmedLine === '');
        });
        
        state.term.write(output);
    }
    
    // Stats WebSocket
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const wsUrl = `${state.protocol}://${window.location.hostname}${port}/stats/${state.instanceId}`;
        
        state.statsWs = new WebSocket(wsUrl);
        
        state.statsWs.onmessage = utils.throttle((event) => {
            if (!utils.isValidJson(event.data)) return;
            
            const stats = JSON.parse(event.data);
            if (stats.error) {
                console.error('Stats error:', stats.error);
                return;
            }
            
            state.lastStats = stats;
            updateStats(stats);
        }, 1000);
        
        state.statsWs.onclose = () => {
            setTimeout(initStatsWebSocket, 5000);
        };
    }
    
    // Stats charts
    function initCharts() {
        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false, min: 0, max: 100 } },
            animation: { duration: 0 },
            elements: { point: { radius: 0 }, line: { borderWidth: 2, tension: 0.4 } }
        };
        
        const createChart = (id, color, type = 'line') => {
            const ctx = document.getElementById(id);
            if (!ctx) return null;
            
            return new Chart(ctx, {
                type: type,
                data: {
                    labels: Array(20).fill(''),
                    datasets: [{
                        data: Array(20).fill(0),
                        borderColor: color,
                        backgroundColor: type === 'line' ? `${color}20` : `${color}40`,
                        fill: type === 'line',
                    }]
                },
                options: commonOptions
            });
        };
        
        state.charts.status = createChart('statusChart', '#10b981');
        state.charts.ram = createChart('ramChart', '#3b82f6');
        state.charts.cpu = createChart('cpuChart', '#f59e0b');
    }
    
    function updateStats(stats) {
        // RAM
        const ramUsage = stats.memory_stats?.usage || 0;
        const ramLimit = stats.memory_stats?.limit || 0;
        const ramPercent = ramLimit > 0 ? ((ramUsage / ramLimit) * 100).toFixed(1) : 0;
        
        document.getElementById('ramUsage').textContent = `${ramPercent}%`;
        document.getElementById('ramSubvalue').textContent = 
            `${utils.formatBytes(ramUsage)} / ${utils.formatBytes(ramLimit)}`;
        updateChart(state.charts.ram, ramPercent);
        
        // CPU
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const cpuPercent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        
        document.getElementById('cpuUsage').textContent = `${cpuPercent}%`;
        updateChart(state.charts.cpu, cpuPercent);
        
        // Disk
        const diskUsage = parseFloat(stats.volumeSize) || 0;
        const diskLimit = <%= instance.Disk || 0 %>;
        const diskEl = document.getElementById('diskUsage');
        const diskSubEl = document.getElementById('diskSubvalue');
        
        if (diskLimit === 0) {
            diskEl.textContent = utils.formatBytes(diskUsage * 1024 * 1024);
            diskSubEl.textContent = 'Unlimited';
            diskEl.style.color = 'var(--accent-success)';
        } else {
            const diskPercent = ((diskUsage / diskLimit) * 100).toFixed(1);
            diskEl.textContent = `${diskPercent}%`;
            diskSubEl.textContent = `${utils.formatBytes(diskUsage * 1024 * 1024)} / ${utils.formatBytes(diskLimit * 1024 * 1024)}`;
            diskEl.style.color = diskPercent > 90 ? 'var(--accent-danger)' : diskPercent > 70 ? 'var(--accent-warning)' : 'var(--accent-success)';
        }
        
        // Status
        const statusEl = document.getElementById('status');
        const statusCard = document.getElementById('statusCard');
        const indicator = document.getElementById('statusIndicator');
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
        
        if (isRunning) {
            statusEl.textContent = 'Online';
            statusEl.className = 'stats-value online';
            statusCard.classList.add('online');
            statusCard.classList.remove('offline');
            indicator.className = 'stats-indicator online';
            updateStatusChart('#10b981');
        } else {
            statusEl.textContent = 'Offline';
            statusEl.className = 'stats-value offline';
            statusCard.classList.add('offline');
            statusCard.classList.remove('online');
            indicator.className = 'stats-indicator offline';
            updateStatusChart('#ef4444');
        }
    }
    
    function updateChart(chart, value) {
        if (!chart) return;
        const num = parseFloat(value) || 0;
        chart.data.datasets[0].data.push(num);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }
    
    function updateStatusChart(color) {
        if (!state.charts.status) return;
        state.charts.status.data.datasets[0].backgroundColor = `${color}30`;
        state.charts.status.data.datasets[0].borderColor = color;
        state.charts.status.data.datasets[0].data = Array(20).fill(100);
        state.charts.status.update('none');
    }
    
    // EULA Modal
    function showEulaModal() {
        if (state.eulaModalShown) return;
        state.eulaModalShown = true;
        
        const modal = document.createElement('div');
        modal.className = 'modal-overlay';
        modal.id = 'eulaModal';
        modal.innerHTML = `
            <div class="eula-modal">
                <div class="eula-header">
                    <svg class="eula-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                    </svg>
                    <div>
                        <p class="eula-title">Minecraft EULA Agreement</p>
                        <p class="eula-subtitle">License Agreement Required</p>
                    </div>
                </div>
                <p class="eula-text">
                    By clicking "I Agree" below, you acknowledge that you have read, understood, and agree to be bound by the terms of the <a href="https://account.mojang.com/documents/minecraft_eula" target="_blank" rel="noopener noreferrer">Minecraft End User License Agreement</a>. This server will not start until the EULA is accepted.
                </p>
                <button onclick="acceptEula()" class="eula-btn">I Agree to the EULA</button>
            </div>
        `;
        document.body.appendChild(modal);
    }
    
    function acceptEula() {
        axios.post(`/instance/${state.instanceId}/imagefeatures/eula`)
            .then(response => {
                if (response.status === 200) {
                    document.getElementById('eulaModal')?.remove();
                    state.eulaModalShown = false;
                    utils.showNotification('EULA accepted successfully');
                }
            })
            .catch(error => {
                console.error('EULA error:', error);
                utils.showNotification('Failed to accept EULA', 'error');
            });
    }
    
    // Command input
    function initCommandInput() {
        const input = document.getElementById('input');
        
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendCommand();
        });
        
        input.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (state.currentCommandIndex > 0) {
                    state.currentCommandIndex--;
                    input.value = state.commandHistory[state.currentCommandIndex];
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (state.currentCommandIndex < state.commandHistory.length - 1) {
                    state.currentCommandIndex++;
                    input.value = state.commandHistory[state.currentCommandIndex];
                } else {
                    state.currentCommandIndex = state.commandHistory.length;
                    input.value = '';
                }
            }
        });
    }
    
    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        
        if (!command || !state.ws) return;
        
        state.term.write(`\r\n\u001b[1m\u001b[36m❯ \u001b[0m${command}\r\n`);
        
        state.ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: state.instanceId
        }));
        
        if (state.commandHistory.length >= state.maxCommands) {
            state.commandHistory.shift();
        }
        state.commandHistory.push(command);
        state.currentCommandIndex = state.commandHistory.length;
        
        input.value = '';
    }
    
    // Power buttons
    function initPowerButtons() {
        const actions = ['start', 'restart', 'stop'];
        
        actions.forEach(action => {
            const btn = document.getElementById(`${action}Button`);
            if (!btn) return;
            
            btn.addEventListener('click', async () => {
                if (!confirm(`Are you sure you want to ${action} this instance?`)) return;
                
                const originalHTML = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = `<svg class="animate-spin" style="width: 16px; height: 16px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity: 0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Processing...</span>`;
                
                try {
                    const res = await axios.post(`/instance/${state.instanceId}/power`, { action });
                    
                    if (res.status === 200) {
                        btn.innerHTML = `<svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> <span>${action.charAt(0).toUpperCase() + action.slice(1)}ed!</span>`;
                        utils.showNotification(`Instance ${action}ed successfully`);
                        
                        setTimeout(() => {
                            btn.innerHTML = originalHTML;
                            btn.disabled = false;
                        }, 2000);
                    }
                } catch (err) {
                    console.error(err);
                    utils.showNotification(`Failed to ${action} instance`, 'error');
                    btn.innerHTML = originalHTML;
                    btn.disabled = false;
                }
            });
        });
    }
    
    // Initialization
    document.addEventListener('DOMContentLoaded', () => {
        initTerminal();
        initWebSocket();
        initStatsWebSocket();
        initCharts();
        initCommandInput();
        initPowerButtons();
        
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (state.statsWs) state.statsWs.onmessage = null;
            } else {
                if (state.statsWs) {
                    state.statsWs.onmessage = utils.throttle((event) => {
                        if (!utils.isValidJson(event.data)) return;
                        const stats = JSON.parse(event.data);
                        if (!stats.error) updateStats(stats);
                    }, 1000);
                }
            }
        });
    });
</script>

