<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    :root {
        --bg: #0a0a0f;
        --bg-secondary: #12121a;
        --card: rgba(20, 20, 28, 0.6);
        --card-border: rgba(255, 255, 255, 0.08);
        --text: #f9fafb;
        --muted: #9ca3af;
        --accent: #3b82f6;
        --accent-glow: rgba(59, 130, 246, 0.3);
        --success: #10b981;
        --success-glow: rgba(16, 185, 129, 0.3);
        --danger: #ef4444;
        --danger-glow: rgba(239, 68, 68, 0.3);
        --warning: #f59e0b;
        --glass-border: rgba(255, 255, 255, 0.1);
        --glass-highlight: rgba(255, 255, 255, 0.05);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .ks-instance-container {
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        background-image: 
            radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(16, 185, 129, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 40% 20%, rgba(239, 68, 68, 0.05) 0%, transparent 50%);
        color: var(--text);
        min-height: 100vh;
        padding: 1rem;
        position: relative;
        overflow-x: hidden;
    }

    /* Animated background grid */
    .ks-instance-container::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            linear-gradient(rgba(59, 130, 246, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59, 130, 246, 0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
        z-index: 0;
    }

    .ks-instance-content {
        position: relative;
        z-index: 1;
        max-width: 1600px;
        margin: 0 auto;
    }

    /* Header Section */
    .ks-instance-header {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        position: relative;
    }

    .ks-instance-btn {
        padding: 0.875rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 700;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        color: var(--text);
    }

    .ks-instance-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
    }

    .ks-instance-btn:hover::before {
        left: 100%;
    }

    .ks-instance-btn-start { 
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.2), rgba(16, 185, 129, 0.1));
        border-color: rgba(16, 185, 129, 0.3);
        color: var(--success);
        box-shadow: 0 4px 20px var(--success-glow);
    }
    .ks-instance-btn-start:hover { 
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 8px 30px var(--success-glow);
        border-color: var(--success);
    }

    .ks-instance-btn-restart { 
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(59, 130, 246, 0.1));
        border-color: rgba(59, 130, 246, 0.3);
        color: var(--accent);
        box-shadow: 0 4px 20px var(--accent-glow);
    }
    .ks-instance-btn-restart:hover { 
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 8px 30px var(--accent-glow);
        border-color: var(--accent);
    }

    .ks-instance-btn-stop { 
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(239, 68, 68, 0.1));
        border-color: rgba(239, 68, 68, 0.3);
        color: var(--danger);
        box-shadow: 0 4px 20px var(--danger-glow);
    }
    .ks-instance-btn-stop:hover { 
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 8px 30px var(--danger-glow);
        border-color: var(--danger);
    }

    .ks-instance-btn:disabled { 
 
        opacity: 0.4; 
        cursor: not-allowed;
        transform: none !important;
    }

    /* Info Grid - Glass Cards */
    .ks-instance-info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    @media (min-width: 640px) {
        .ks-instance-info-grid { 
            grid-template-columns: repeat(2, 1fr); 
        }
    }

    @media (min-width: 1024px) {
        .ks-instance-info-grid { 
            grid-template-columns: repeat(2, 1fr); 
        }
    }

    .ks-instance-info-card {
        background: var(--card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .ks-instance-info-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .ks-instance-info-card:hover {
        transform: translateY(-3px);
        border-color: var(--glass-border);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .ks-instance-info-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .ks-instance-info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        font-family: 'Courier New', monospace;
    }

    .ks-instance-info-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.2);
        transition: all 0.3s ease;
    }

    .ks-instance-info-card:hover .ks-instance-info-icon {
        transform: scale(1.1) rotate(5deg);
        background: rgba(59, 130, 246, 0.2);
    }

    /* Alert */
    .ks-instance-alert {
        background: rgba(239, 68, 68, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 16px;
        padding: 1.25rem;
        display: none;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .ks-instance-alert::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: var(--danger);
    }

    .ks-instance-alert.show { display: flex; }

    /* Main Layout */
    .ks-instance-main {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @media (min-width: 1024px) {
        .ks-instance-main { 
            grid-template-columns: 1fr 360px; 
        }
    }

    @media (min-width: 1280px) {
        .ks-instance-main { 
            grid-template-columns: 1fr 400px; 
        }
    }

    /* Terminal - Gaming Style with Glassmorphism */
    .ks-instance-terminal-wrap {
        background: rgba(15, 15, 20, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 500px;
        position: relative;
        box-shadow: 
            0 20px 60px rgba(0, 0, 0, 0.5),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .ks-instance-terminal-wrap::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
        z-index: 10;
    }

    .ks-instance-terminal-header {
        background: rgba(26, 26, 35, 0.8);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        border-bottom: 1px solid var(--card-border);
        position: relative;
    }

    .ks-instance-terminal-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .ks-instance-terminal-status::before {
        content: '';
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--success);
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .ks-instance-terminal-body {
        flex: 1;
        position: relative;
        background: rgba(10, 10, 15, 0.3);
        overflow: hidden;
    }

    #im-terminal {
        width: 100%;
        height: 100%;
        padding: 0.5rem;
    }

    .ks-instance-terminal-input {
        padding: 1rem 1.25rem;
        background: rgba(26, 26, 35, 0.9);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-top: 1px solid var(--card-border);
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
    }

    .ks-instance-terminal-input::before {
        content: '>';
        color: var(--success);
        font-weight: 900;
        font-size: 1.2rem;
        animation: blink 1s infinite;
    }

    @keyframes blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
    }

    #im-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text);
        font-family: 'Courier New', monospace;
        font-size: 0.95rem;
        font-weight: 500;
    }

    #im-input::placeholder {
        color: var(--muted);
        opacity: 0.6;
    }

    /* Terminal Controls */
    .ks-instance-terminal-controls {
        display: flex;
        gap: 8px;
    }

    .ks-instance-terminal-controls button {
        width: 36px;
        height: 36px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }

    .ks-instance-terminal-controls button:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--accent);
        color: var(--accent);
        transform: translateY(-2px);
    }

    /* Stats Panel */
    .ks-instance-stats {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    @media (min-width: 640px) and (max-width: 1023px) {
        .ks-instance-stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .ks-instance-stat-card {
        background: var(--card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 1.5rem;
        position: relative;
        height: 140px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .ks-instance-stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .ks-instance-stat-card:hover {
        transform: translateY(-3px);
        border-color: var(--glass-border);
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.3);
    }

    .ks-instance-stat-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.75rem;
    }

    .ks-instance-stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--muted);
        font-weight: 700;
    }

    .ks-instance-stat-icon {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--card-border);
    }

    .ks-instance-stat-value {
        font-size: 2rem;
        font-weight: 800;
        font-family: 'Courier New', monospace;
        position: relative;
        z-index: 2;
    }

    .ks-instance-stat-value.online { 
        color: var(--success);
        text-shadow: 0 0 20px var(--success-glow);
    }
    .ks-instance-stat-value.offline { 
        color: var(--danger);
        text-shadow: 0 0 20px var(--danger-glow);
    }

    .ks-instance-stat-sub {
        font-size: 0.85rem;
        color: var(--muted);
        margin-top: 0.5rem;
        font-weight: 500;
    }

    .ks-instance-stat-chart {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60px;
        opacity: 0.2;
        pointer-events: none;
    }

    /* Notification */
    #im-notification {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background: var(--card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        padding: 1.25rem 1.75rem;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
        display: none;
        z-index: 1000;
        font-weight: 600;
        transform: translateY(100px);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #im-notification.show { 
        display: block;
        transform: translateY(0);
    }

    /* Mobile Optimizations */
    @media (max-width: 640px) {
        .ks-instance-container {
            padding: 0.75rem;
        }

        .ks-instance-header {
            gap: 0.5rem;
            margin-bottom: 1rem;
            justify-content: stretch;
        }

        .ks-instance-btn {
            padding: 0.75rem 1rem;
            font-size: 0.8rem;
            flex: 1;
            justify-content: center;
            border-radius: 10px;
        }

        .ks-instance-info-grid {
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .ks-instance-info-card {
            padding: 1rem;
            border-radius: 12px;
        }

        .ks-instance-info-value {
            font-size: 0.95rem;
        }

        .ks-instance-info-icon {
            width: 40px;
            height: 40px;
        }

        .ks-instance-terminal-wrap {
            height: 380px;
            border-radius: 16px;
        }

        .ks-instance-terminal-header {
            padding: 0.875rem 1rem;
            font-size: 0.75rem;
        }

        .ks-instance-terminal-input {
            padding: 0.875rem 1rem;
        }

        .ks-instance-main {
            gap: 1rem;
        }

        .ks-instance-stats {
            gap: 0.75rem;
        }

        .ks-instance-stat-card {
            height: 120px;
            padding: 1.25rem;
            border-radius: 16px;
        }

        .ks-instance-stat-value {
            font-size: 1.75rem;
        }

        .ks-instance-stat-sub {
            font-size: 0.8rem;
        }

        #im-notification {
            left: 16px;
            right: 16px;
            bottom: 16px;
        }
    }

    /* Tablet Optimizations */
    @media (min-width: 641px) and (max-width: 1023px) {
        .ks-instance-terminal-wrap {
            height: 450px;
        }

        .ks-instance-stat-card {
            height: 130px;
        }
    }

    /* Large Desktop Optimizations */
    @media (min-width: 1280px) {
        .ks-instance-container {
            padding: 2rem;
        }

        .ks-instance-terminal-wrap {
            height: 600px;
        }

        .ks-instance-stat-card {
            height: 150px;
        }

        .ks-instance-stat-value {
            font-size: 2.25rem;
        }
    }

    /* Extra Large Screens */
    @media (min-width: 1536px) {
        .ks-instance-main {
            grid-template-columns: 1fr 450px;
        }

        .ks-instance-terminal-wrap {
            height: 650px;
        }
    }

    /* Smooth transitions for all interactive elements */
    .ks-instance-info-card,
    .ks-instance-stat-card,
    .ks-instance-terminal-wrap,
    .ks-instance-btn {
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), 
                    box-shadow 0.3s ease,
                    border-color 0.3s ease;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }

    ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    /* Loading animation for stats */
    @keyframes statPulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }

    .ks-instance-stat-value.loading {
        animation: statPulse 1.5s infinite;
    }

    /* XTerm specific overrides for better glassmorphism integration */
    .xterm {
        background: transparent !important;
    }

    .xterm-screen {
        background: transparent !important;
    }

    .xterm-viewport {
        background: transparent !important;
    }
</style>

<div class="ks-instance-container">
    <div class="ks-instance-content">
        <div class="ks-instance-header">
            <button id="im-startBtn" class="ks-instance-btn ks-instance-btn-start">
                <span>▶</span> Start
            </button>
            <button id="im-restartBtn" class="ks-instance-btn ks-instance-btn-restart">
                <span>↻</span> Restart
            </button>
            <button id="im-stopBtn" class="ks-instance-btn ks-instance-btn-stop">
                <span>■</span> Stop
            </button>
        </div>

        <%- include('../components/instance') %>

        <!-- Info Grid - Only Address -->
        <div class="ks-instance-info-grid">
            <div class="ks-instance-info-card">
                <div>
                    <div class="ks-instance-info-label">Server Address</div>
                    <div class="ks-instance-info-value"><%= instance.Node.address %><span style="color:var(--muted)">:<%= instance.Primary %></span></div>
                </div>
                <div class="ks-instance-info-icon">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                    </svg>
                </div>
            </div>

            <div class="ks-instance-info-card">
                <div>
                    <div class="ks-instance-info-label">Connection</div>
                    <div class="ks-instance-info-value" style="color: var(--success);">Secure WebSocket</div>
                </div>
                <div class="ks-instance-info-icon" style="background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2);">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: var(--success);">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Alert -->
        <div class="ks-instance-alert" id="im-daemonAlert">
            <strong style="font-size: 1.5rem;">⚠</strong>
            <div>
                <strong style="color: var(--danger); font-size: 1.1rem;">Connection Failure</strong>
                <p style="margin:0.25rem 0 0 0; font-size:0.9rem; color: var(--muted);">Cannot connect to the daemon. Please check server status.</p>
            </div>
        </div>

        <div class="ks-instance-main">
            <!-- Terminal -->
            <div class="ks-instance-terminal-wrap">
                <div class="ks-instance-terminal-header">
                    <div class="ks-instance-terminal-status">
                        Instance Console
                    </div>
                    <div class="ks-instance-terminal-controls">
                        <button id="im-consoleStopBtn" title="Pause/Resume">⏸</button>
                        <button id="im-clearBtn" title="Clear">🗑</button>
                        <button id="im-toggleModeBtn" title="Toggle wrap/scroll">⇄</button>
                    </div>
                </div>
                <div class="ks-instance-terminal-body">
                    <div id="im-terminal"></div>
                </div>
                <div class="ks-instance-terminal-input">
                    <input id="im-input" type="text" placeholder="Enter command..." autocomplete="off" spellcheck="false">
                </div>
            </div>

            <!-- Stats -->
            <div class="ks-instance-stats">
                <div class="ks-instance-stat-card" id="im-statusCard">
                    <div class="ks-instance-stat-header">
                        <div class="ks-instance-stat-label">Status</div>
                        <div class="ks-instance-stat-icon" style="color: var(--success);">●</div>
                    </div>
                    <div id="im-status" class="ks-instance-stat-value loading">-</div>
                    <canvas id="im-statusChart" class="ks-instance-stat-chart"></canvas>
                </div>

                <div class="ks-instance-stat-card">
                    <div class="ks-instance-stat-header">
                        <div class="ks-instance-stat-label">RAM Usage</div>
                        <div class="ks-instance-stat-icon" style="color: var(--accent);">◈</div>
                    </div>
                    <div id="im-ram" class="ks-instance-stat-value loading">-</div>
                    <div id="im-ramSub" class="ks-instance-stat-sub">—</div>
                    <canvas id="im-ramChart" class="ks-instance-stat-chart"></canvas>
                </div>

                <div class="ks-instance-stat-card">
                    <div class="ks-instance-stat-header">
                        <div class="ks-instance-stat-label">CPU Usage</div>
                        <div class="ks-instance-stat-icon" style="color: var(--warning);">◉</div>
                    </div>
                    <div id="im-cpu" class="ks-instance-stat-value loading">-</div>
                    <canvas id="im-cpuChart" class="ks-instance-stat-chart"></canvas>
                </div>

                <div class="ks-instance-stat-card">
                    <div class="ks-instance-stat-header">
                        <div class="ks-instance-stat-label">Disk Usage</div>
                        <div class="ks-instance-stat-icon" style="color: var(--danger);">◉</div>
                    </div>
                    <div id="im-disk" class="ks-instance-stat-value loading">-</div>
                    <div id="im-diskSub" class="ks-instance-stat-sub">—</div>
                    <canvas id="im-diskChart" class="ks-instance-stat-chart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="im-notification" role="status"></div>

<script>
    const imState = {
        instanceId: '<%= req.params.id %>',
        term: null,
        ws: null,
        statsWs: null,
        paused: false,
        logWrapMode: false,
        autoScroll: true,
        charts: {},
        reconnectAttempts: 0
    };

    function imInitTerminal() {
        const terminalContainer = document.getElementById('im-terminal');
        
        // Ensure container is ready
        if (!terminalContainer) {
            console.error('Terminal container not found');
            return;
        }

        imState.term = new Terminal({
            theme: { 
                background: 'transparent', 
                foreground: '#e5e7eb',
                cursor: '#3b82f6',
                selection: 'rgba(59, 130, 246, 0.3)',
                black: '#1a1a1f',
                red: '#ef4444',
                green: '#10b981',
                yellow: '#f59e0b',
                blue: '#3b82f6',
                magenta: '#8b5cf6',
                cyan: '#06b6d4',
                white: '#f9fafb'
            },
            fontFamily: "'Courier New', 'Monaco', 'Menlo', monospace",
            fontSize: 14,
            lineHeight: 1.3,
            scrollback: 10000,
            allowTransparency: true,
            cursorBlink: true,
            cursorStyle: 'block',
            convertEol: true,
            disableStdin: false,
            rendererType: 'canvas'
        });

        // Fit addon simulation
        const fitAddon = {
            fit: () => {
                const dims = imState.term._core._renderService.dimensions;
                if (dims && dims.css) {
                    const cols = Math.floor(terminalContainer.clientWidth / dims.css.cell.width);
                    const rows = Math.floor(terminalContainer.clientHeight / dims.css.cell.height);
                    if (cols > 0 && rows > 0) {
                        imState.term.resize(cols, rows);
                    }
                }
            }
        };

        imState.term.open(terminalContainer);
        
        // Initial fit
        setTimeout(() => {
            fitAddon.fit();
            imState.term.focus();
        }, 100);

        // Handle resize
        window.addEventListener('resize', () => {
            setTimeout(() => fitAddon.fit(), 100);
        });

        // Welcome message - single lines, no extra spacing
        imState.term.writeln('\x1b[1;34m╔══════════════════════════════════════════╗\x1b[0m');
        imState.term.writeln('\x1b[1;34m║\x1b[0m  \x1b[1;32m⚡ Instance Console Connected\x1b[0m          \x1b[1;34m║\x1b[0m');
        imState.term.writeln('\x1b[1;34m╚══════════════════════════════════════════╝\x1b[0m');
        imState.term.writeln('');
        imState.term.writeln('\x1b[90mWaiting for connection...\x1b[0m');
    }

    function imInitWebSocket() {
        const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        const wsUrl = `${protocol}//${window.location.host}/console/${imState.instanceId}`;
        
        console.log('Connecting to WebSocket:', wsUrl);
        
        try {
            imState.ws = new WebSocket(wsUrl);

            imState.ws.onopen = () => {
                console.log('WebSocket connected');
                imState.reconnectAttempts = 0;
                if (imState.term) {
                    imState.term.writeln('');
                    imState.term.writeln('\x1b[1;32m✓ Connected to instance\x1b[0m');
                    imState.term.writeln('');
                }
            };

            imState.ws.onmessage = (event) => {
                if (imState.paused || !imState.term) return;
                
                // Write data directly without extra newlines
                const data = event.data;
                if (data) {
                    imState.term.write(data);
                    if (imState.autoScroll) {
                        imState.term.scrollToBottom();
                    }
                }
            };

            imState.ws.onerror = (error) => {
                console.error('WebSocket error:', error);
                if (imState.term) {
                    imState.term.writeln('');
                    imState.term.writeln('\x1b[1;31m✗ Connection error\x1b[0m');
                }
            };

            imState.ws.onclose = (event) => {
                console.log('WebSocket closed:', event.code, event.reason);
                if (imState.term) {
                    imState.term.writeln('');
                    imState.term.writeln('\x1b[1;33m⚠ Connection lost. Reconnecting...\x1b[0m');
                }
                
                // Exponential backoff
                const delay = Math.min(1000 * Math.pow(2, imState.reconnectAttempts), 10000);
                imState.reconnectAttempts++;
                
                setTimeout(imInitWebSocket, delay);
            };
        } catch (err) {
            console.error('Failed to create WebSocket:', err);
        }
    }

    function imInitStatsWebSocket() {
        const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        const wsUrl = `${protocol}//${window.location.host}/stats/${imState.instanceId}`;
        
        try {
            imState.statsWs = new WebSocket(wsUrl);

            imState.statsWs.onmessage = (event) => {
                try {
                    const stats = JSON.parse(event.data);
                    if (stats.error) return;

                    // Remove loading class
                    document.querySelectorAll('.ks-instance-stat-value').forEach(el => el.classList.remove('loading'));

                    // RAM
                    const ramUsage = stats.memory_stats?.usage || 0;
                    const ramLimit = stats.memory_stats?.limit || 1;
                    const ramPercent = Math.min(Math.round((ramUsage / ramLimit) * 100), 100);
                    
                    const ramEl = document.getElementById('im-ram');
                    ramEl.textContent = ramPercent + '%';
                    
                    const ramSub = document.getElementById('im-ramSub');
                    if (ramSub) {
                        ramSub.textContent = `${(ramUsage/1024/1024).toFixed(0)}MB / ${(ramLimit/1024/1024).toFixed(0)}MB`;
                    }
                    
                    // Color code RAM
                    if (ramPercent > 90) ramEl.style.color = 'var(--danger)';
                    else if (ramPercent > 70) ramEl.style.color = 'var(--warning)';
                    else ramEl.style.color = 'var(--success)';

                    // CPU calculation
                    const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage || 0) - (stats.precpu_stats?.cpu_usage?.total_usage || 0);
                    const systemDelta = (stats.cpu_stats?.system_cpu_usage || 0) - (stats.precpu_stats?.system_cpu_usage || 0);
                    const cpuCount = stats.cpu_stats?.online_cpus || 1;
                    
                    let cpuPercent = 0;
                    if (systemDelta > 0 && cpuDelta > 0) {
                        cpuPercent = Math.min(Math.round((cpuDelta / systemDelta) * cpuCount * 100), 100);
                    }
                    
                    const cpuEl = document.getElementById('im-cpu');
                    if (cpuEl) cpuEl.textContent = cpuPercent + '%';

                    // Disk
                    const diskUsage = stats.disk_stats?.used || 0;
                    const diskTotal = stats.disk_stats?.total || 0;
                    const diskEl = document.getElementById('im-disk');
                    const diskSub = document.getElementById('im-diskSub');
                    
                    if (diskTotal > 0 && diskEl) {
                        const diskPercent = Math.round((diskUsage / diskTotal) * 100);
                        diskEl.textContent = diskPercent + '%';
                        if (diskSub) {
                            diskSub.textContent = `${(diskUsage/1024/1024/1024).toFixed(1)}GB / ${(diskTotal/1024/1024/1024).toFixed(1)}GB`;
                        }
                    } else if (diskEl) {
                        diskEl.textContent = 'N/A';
                        if (diskSub) diskSub.textContent = '—';
                    }

                    // Status
                    const isRunning = stats.state === 'running' || (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
                    const statusEl = document.getElementById('im-status');
                    if (statusEl) {
                        statusEl.textContent = isRunning ? 'ONLINE' : 'OFFLINE';
                        statusEl.className = 'ks-instance-stat-value ' + (isRunning ? 'online' : 'offline');
                    }

                    // Update charts if they exist
                    imUpdateCharts({ ram: ramPercent, cpu: cpuPercent, status: isRunning ? 100 : 0, disk: diskTotal > 0 ? Math.round((diskUsage/diskTotal)*100) : 0 });
                    
                } catch (err) {
                    console.error('Error parsing stats:', err);
                }
            };

            imState.statsWs.onclose = () => {
                setTimeout(imInitStatsWebSocket, 5000);
            };
        } catch (err) {
            console.error('Failed to create stats WebSocket:', err);
        }
    }

    function imInitPowerButtons() {
        const actions = { start: 'start', restart: 'restart', stop: 'stop' };
        
        Object.keys(actions).forEach(key => {
            const btn = document.getElementById(`im-${key}Btn`);
            if (!btn) return;
            
            btn.addEventListener('click', async () => {
                const actionText = key.charAt(0).toUpperCase() + key.slice(1);
                
                if (!confirm(`Are you sure you want to ${key} this instance?`)) return;
                
                btn.disabled = true;
                btn.style.opacity = '0.6';
                
                try {
                    const response = await axios.post(`/instance/${imState.instanceId}/power`, { action: actions[key] });
                    window.showToast(`Instance ${actionText} command sent`, 'success');
                    
                    if (imState.term) {
                        imState.term.writeln('');
                        imState.term.writeln(`\x1b[1;33m⚡ ${actionText} command sent...\x1b[0m`);
                    }
                } catch (err) {
                    window.showToast(`Failed to ${key} instance: ${err.message}`, 'error');
                } finally {
                    btn.disabled = false;
                    btn.style.opacity = '';
                }
            });
        });
    }

    function imInitTerminalControls() {
        // Pause/Resume
        const pauseBtn = document.getElementById('im-consoleStopBtn');
        if (pauseBtn) {
            pauseBtn.addEventListener('click', function() {
                imState.paused = !imState.paused;
                this.innerHTML = imState.paused ? '▶' : '⏸';
                this.style.color = imState.paused ? 'var(--success)' : '';
                this.title = imState.paused ? 'Resume' : 'Pause';
                window.showToast(imState.paused ? 'Console paused' : 'Console resumed');
            });
        }

        // Clear
        const clearBtn = document.getElementById('im-clearBtn');
        if (clearBtn) {
            clearBtn.addEventListener('click', () => {
                if (imState.term) {
                    imState.term.clear();
                    imState.term.writeln('\x1b[1;36m✓ Console cleared\x1b[0m');
                    imState.term.writeln('');
                }
            });
        }

        // Toggle wrap/scroll
        const toggleBtn = document.getElementById('im-toggleModeBtn');
        if (toggleBtn) {
            toggleBtn.addEventListener('click', function() {
                imState.logWrapMode = !imState.logWrapMode;
                this.innerHTML = imState.logWrapMode ? '⇣' : '⇄';
                window.showToast(imState.logWrapMode ? 'Wrap mode enabled' : 'Scroll mode enabled');
            });
        }

        // Input handling
        const input = document.getElementById('im-input');
        if (input) {
            input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter' && imState.ws && imState.ws.readyState === WebSocket.OPEN) {
                    const cmd = input.value.trim();
                    if (cmd) {
                        if (imState.term) {
                            imState.term.writeln(`\x1b[1;32m❯\x1b[0m \x1b[1m${cmd}\x1b[0m`);
                        }
                        
                        imState.ws.send(JSON.stringify({ 
                            event: 'cmd', 
                            command: cmd, 
                            containerId: imState.instanceId 
                        }));
                        
                        input.value = '';
                    }
                }
            });

            // Focus input on terminal click
            const terminalEl = document.getElementById('im-terminal');
            if (terminalEl) {
                terminalEl.addEventListener('click', () => {
                    input.focus();
                });
            }
        }
    }

    // Initialize charts
    function imInitCharts() {
        const chartConfigs = {
            'im-statusChart': { color: '#10b981', label: 'Status' },
            'im-ramChart': { color: '#3b82f6', label: 'RAM' },
            'im-cpuChart': { color: '#f59e0b', label: 'CPU' },
            'im-diskChart': { color: '#ef4444', label: 'Disk' }
        };

        Object.keys(chartConfigs).forEach(id => {
            const canvas = document.getElementById(id);
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 60);
            gradient.addColorStop(0, `${chartConfigs[id].color}33`);
            gradient.addColorStop(1, `${chartConfigs[id].color}00`);

            imState.charts[id] = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array(20).fill(''),
                    datasets: [{
                        data: Array(20).fill(0),
                        borderColor: chartConfigs[id].color,
                        backgroundColor: gradient,
                        borderWidth: 2,
                        tension: 0.4,
                        pointRadius: 0,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: false },
                        y: { display: false, min: 0, max: 100 }
                    },
                    animation: { duration: 0 }
                }
            });
        });
    }

    function imUpdateCharts(data) {
        Object.keys(imState.charts).forEach(chartId => {
            const chart = imState.charts[chartId];
            if (!chart) return;

            const valueMap = {
                'im-statusChart': data.status || 0,
                'im-ramChart': data.ram || 0,
                'im-cpuChart': data.cpu || 0,
                'im-diskChart': data.disk || 0
            };

            const newValue = valueMap[chartId] || 0;
            
            chart.data.datasets[0].data.shift();
            chart.data.datasets[0].data.push(newValue);
            chart.update('none');
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Initialize in order
        imInitTerminal();
        imInitWebSocket();
        imInitStatsWebSocket();
        imInitPowerButtons();
        imInitTerminalControls();
        imInitCharts();

        // Enhanced notification helper
        window.showToast = (msg, type = 'info') => {
            const n = document.getElementById('im-notification');
            if (!n) return;

            const colors = {
                info: 'var(--accent)',
                success: 'var(--success)',
                error: 'var(--danger)',
                warning: 'var(--warning)'
            };
            
            n.textContent = msg;
            n.style.borderLeft = `4px solid ${colors[type] || colors.info}`;
            n.classList.add('show');
            
            setTimeout(() => n.classList.remove('show'), 3000);
        };

        // Handle window resize for responsive charts
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                Object.values(imState.charts).forEach(chart => {
                    if (chart) chart.resize();
                });
            }, 250);
        });
    });
</script>

<%- include('../components/footer') %>
