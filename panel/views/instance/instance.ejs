</main>

<script>
    // ============================================
    // FULL WORKING JS - ONLY JS ADDED (no style/HTML changed)
    // DOUBLE LOGS FIXED: added initialized guard + WS safety
    // ============================================

    const baseTheme = {
        foreground: '#c5c9d1',
        background: 'rgba(0 0 0 / 0)',
        selection: '#5DA5D533',
        black: '#1E1E1D',
        brightBlack: '#262625',
        red: '#E54B4B',
        green: '#9ECE58',
        yellow: '#FAED70',
        blue: '#396FE2',
        magenta: '#BB80B3',
        cyan: '#2DDAFD',
        white: '#d0d0d0',
        brightBlack: 'rgba(255, 255, 255, 0.2)',
        brightRed: '#FF5370',
        brightGreen: '#C3E88D',
        brightYellow: '#FFCB6B',
        brightBlue: '#82AAFF',
        brightMagenta: '#C792EA',
        brightCyan: '#89DDFF',
        brightWhite: '#ffffff',
    };

    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 50;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let term;
    let ws;
    let statsWs;
    let reconnectAttempts = 0;
    const maxReconnectAttempts = 10;
    let initialized = false;   // ← ADDED: prevents double initialization / double WS / double logs

    function isValidJson(str) {
        try { JSON.parse(str); return true; } catch { return false; }
    }

    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }

    function copyIP() {
        const ipText = document.getElementById('ipText').textContent.trim();
        navigator.clipboard.writeText(ipText).then(() => {
            const container = document.getElementById('ipContainer');
            const originalHTML = container.innerHTML;
            container.style.transition = 'all 0.2s';
            container.style.color = '#10b981';
            setTimeout(() => {
                container.innerHTML = originalHTML.replace('text-neutral-400', 'text-emerald-400');
                setTimeout(() => {
                    container.innerHTML = originalHTML;
                    container.style.color = '';
                }, 1200);
            }, 80);
        });
    }

    function showProcessing(btn) {
        const originalHTML = btn.innerHTML;
        btn.dataset.originalHTML = originalHTML;
        btn.disabled = true;
        btn.style.opacity = '0.75';
        btn.style.pointerEvents = 'none';
        btn.innerHTML = `<svg class="animate-spin h-4 w-4 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Processing...`;
    }

    function hideProcessing(btn) {
        if (btn.dataset.originalHTML) {
            btn.innerHTML = btn.dataset.originalHTML;
            btn.disabled = false;
            btn.opacity = '';
            btn.style.pointerEvents = '';
            delete btn.dataset.originalHTML;
        }
    }

    async function performPowerAction(btn, action) {
        showProcessing(btn);
        try {
            const res = await axios.post(`/instance/${instanceId}/power`, { action });
            if (res.status === 200) {
                console.log(`Instance ${action}ed successfully`);
                
                // FIX #2: Force console reconnect after start/restart so logs appear instantly (no page refresh needed)
                if (action === 'start' || action === 'restart') {
                    setTimeout(() => {
                        if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) {
                            ws.close();
                        }
                        initWebSocket();
                    }, 1200); // small delay so backend can attach the new console stream
                }
            }
        } catch (err) {
            console.error(`Failed to ${action} instance`, err);
        } finally {
            hideProcessing(btn);
        }
    }

    function setupTerminal() {
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.35,
            rows: 19,
            cols: 100,
            fontFamily: 'Menlo, monospace',
            theme: baseTheme,
            allowTransparency: true,
            fontSize: 12,
        });
        term.open(document.getElementById('terminal'));
        
        // Responsive terminal sizing
        function fitTerminal() {
            const terminalContainer = document.getElementById('terminal');
            if (terminalContainer && term) {
                const dims = term.proposeGeometry();
                if (dims) {
                    term.resize(dims.cols, dims.rows);
                }
            }
        }
        
        window.addEventListener('resize', fitTerminal);
        setTimeout(fitTerminal, 100);
    }

    function initWebSocket() {
        // ← ADDED: full protection against duplicate WebSocket (this was the cause of double logs)
        if (initialized && ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) {
            console.warn('[Console] Already connected – skipping duplicate WS');
            return;
        }
        if (ws) {
            ws.onclose = null;
            ws.close();
        }

        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);

        ws.onopen = () => {
            console.log('[Console] WebSocket connected');
            reconnectAttempts = 0;
            document.getElementById('daemonIsDown').classList.add('hidden');
        };

        ws.onmessage = (msg) => {
            const data = msg.data;
            term.write(data);

            if (data.includes("Working on")) {
                term.write('\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...');
                ws.close();
            }

            if (data.includes("KS Wings instance appears to be down")) {
                ws.close();
                document.getElementById('daemonIsDown').classList.remove('hidden');
            }
        };

        ws.onclose = () => {
            ws = null;   // ← ADDED: clean reference so next init doesn't think old WS is still alive
            if (reconnectAttempts < maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000);
                setTimeout(initWebSocket, delay);
                reconnectAttempts++;
            }
        };

        ws.onerror = (error) => console.error('[Console] WebSocket error:', error);
    }

    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        if (!command || !ws) return;

        term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');

        ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: instanceId
        }));

        if (commandHistory.length >= maxCommands) commandHistory.shift();
        commandHistory.push(command);
        currentCommandIndex = commandHistory.length;

        input.value = '';
    }

    function handleKeyUp(e) {
        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
        } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
        }
    }

    function initPowerButtons() {
        const actions = {
            start: document.getElementById('startButton'),
            restart: document.getElementById('restartButton'),
            stop: document.getElementById('stopButton')
        };

        Object.keys(actions).forEach(action => {
            const btn = actions[action];
            btn.addEventListener('click', () => performPowerAction(btn, action));
        });
    }

    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);

        statsWs.onmessage = (event) => {
            if (!isValidJson(event.data)) return;
            const stats = JSON.parse(event.data);
            if (stats.error) return;

            updateRamUsage(stats);
            updateCpuUsage(stats);
            updateDiskUsage(stats);
            updateStatus(stats);
        };

        statsWs.onclose = () => setTimeout(initStatsWebSocket, 5000);
    }

    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: { x: { display: false }, y: { display: false, min: 0, max: 100 } },
        animation: { duration: 0 },
        elements: { line: { borderWidth: 2, tension: 0.5 }, point: { radius: 0 } }
    };

    const ramChart = new Chart(document.getElementById('ramChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.15)', fill: true }] },
        options: chartOptions
    });

    const cpuChart = new Chart(document.getElementById('cpuChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.15)', fill: true }] },
        options: chartOptions
    });

    const diskChart = new Chart(document.getElementById('diskChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#8b5cf6', backgroundColor: 'rgba(139,92,246,0.15)', fill: true }] },
        options: chartOptions
    });

    function updateChart(chart, value) {
        chart.data.datasets[0].data.push(parseFloat(value) || 0);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }

    function updateRamUsage(stats) {
        const usage = stats.memory_stats?.usage || 0;
        const limit = stats.memory_stats?.limit || 0;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;
        document.getElementById('ramPercent').textContent = `${percent}%`;
        document.getElementById('ramUsageText').textContent = `${formatBytes(usage)} / ${formatBytes(limit)}`;
        updateChart(ramChart, percent);
    }

    function updateCpuUsage(stats) {
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const percent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        document.getElementById('cpuPercent').textContent = `${percent}%`;
        document.getElementById('cpuUsageText').textContent = `${percent}%`;
        updateChart(cpuChart, percent);
    }

    function updateDiskUsage(stats) {
        const usage = parseFloat(stats.volumeSize) || 0;
        const limit = <%= instance.Disk || 0 %>;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;
        document.getElementById('diskPercent').textContent = `${percent}%`;
        if (limit === 0) {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / Unlimited`;
        } else {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / ${formatBytes(limit * 1024 * 1024)}`;
        }
        updateChart(diskChart, percent);
    }

    function updateStatus(stats) {
        const ramUsage = stats.memory_stats?.usage || 0;
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;
        const tag = document.getElementById('statusTag');
        if (isRunning) {
            tag.textContent = 'Online';
            tag.className = 'inline-flex items-center self-start sm:self-auto px-3 py-1 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-2xl tracking-wider';
        } else {
            tag.textContent = 'Offline';
            tag.className = 'inline-flex items-center self-start sm:self-auto px-3 py-1 text-xs font-medium bg-red-500/10 text-red-400 rounded-2xl tracking-wider';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // ← ADDED: single initialization guard (this eliminates the double WS creation on page load)
        if (initialized) {
            console.log('[Console] Already initialized – skipping duplicate');
            return;
        }
        initialized = true;

        setupTerminal();
        initWebSocket();
        initPowerButtons();
        initStatsWebSocket();

        const input = document.getElementById('input');
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendCommand(); });
        input.addEventListener('keydown', handleKeyUp);

        document.addEventListener('visibilitychange', () => {
            if (document.hidden && statsWs) statsWs.onmessage = null;
            else if (statsWs) initStatsWebSocket();
        });
    });
</script>

<%- include('../components/footer') %>
