<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    /* ============================================
       CSS VARIABLES - CONSISTENT DESIGN SYSTEM
       ============================================ */
    :root {
        --glass-bg: rgba(255, 255, 255, 0.05);
        --glass-border: rgba(255, 255, 255, 0.1);
        --glass-blur: blur(20px);
        --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-bounce: all 0.5s cubic-bezier(0.25, 1.8, 0.45, 1.35);
        --radius-sm: 10px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 20px;
        --shadow-glow: 0 0 20px rgba(255, 255, 255, 0.05);
        --shadow-elevated: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    /* ============================================
       BASE STYLES & RESETS
       ============================================ */
    canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
    }

    .xterm-viewport {
        overflow-y: hidden !important;
    }

    /* Custom scrollbar for terminal */
    .xterm .xterm-viewport::-webkit-scrollbar {
        width: 8px;
    }
    .xterm .xterm-viewport::-webkit-scrollbar-track {
        background: rgba(255,255,255,0.05);
    }
    .xterm .xterm-viewport::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.2);
        border-radius: 4px;
    }

    /* ============================================
       TERMINAL - RESPONSIVE SIZING
       ============================================ */
    #terminal {
        width: 100%;
        height: 250px;
    }

    @media (min-width: 640px) {
        #terminal {
            height: 350px;
        }
    }

    @media (min-width: 1024px) {
        #terminal {
            height: 450px;
        }
    }

    @media (min-width: 1280px) {
        #terminal {
            height: 500px;
        }
    }

    .xterm-rows {
        font-size: 10px !important;
    }

    @media (min-width: 640px) {
        .xterm-rows {
            font-size: 11px !important;
        }
    }

    @media (min-width: 1024px) {
        .xterm-rows {
            font-size: 12px !important;
        }
    }

    /* ============================================
       STATS CARDS - ENHANCED GLASSMORPHISM
       ============================================ */
    .stats-card {
        height: clamp(70px, 12vh, 90px);
        position: relative;
        overflow: hidden;
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-glow), 0 4px 24px rgba(0,0,0,0.1);
        transition: var(--transition-smooth);
    }

    .stats-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
        transition: left 0.7s ease;
        pointer-events: none;
    }

    .stats-card:hover::before {
        left: 100%;
    }

    .stats-card:hover {
        transform: translateY(-2px);
        border-color: rgba(255,255,255,0.15);
        box-shadow: var(--shadow-glow), 0 8px 32px rgba(0,0,0,0.15);
    }

    @media (min-width: 640px) {
        .stats-card {
            height: clamp(80px, 14vh, 100px);
        }
    }

    @media (min-width: 1024px) {
        .stats-card {
            height: clamp(90px, 16vh, 110px);
        }
    }

    /* ============================================
       ACTION BUTTONS - MODERN ENHANCED
       ============================================ */
    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border-radius: var(--radius-md);
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        transition: var(--transition-smooth);
        white-space: nowrap;
        position: relative;
        overflow: hidden;
        border: none;
        cursor: pointer;
        letter-spacing: 0.01em;
    }

    .action-btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s ease, height 0.6s ease;
    }

    .action-btn:active::before {
        width: 300px;
        height: 300px;
    }

    .action-btn:active {
        transform: scale(0.96);
    }

    .action-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
    }

    /* Button Variants */
    .btn-start {
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(5, 150, 105, 0.3);
    }

    .btn-start:hover {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        box-shadow: 0 6px 20px rgba(5, 150, 105, 0.4);
        transform: translateY(-2px);
    }

    .btn-restart {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    .btn-restart:hover {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
        transform: translateY(-2px);
    }

    .btn-stop {
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
    }

    .btn-stop:hover {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
        transform: translateY(-2px);
    }

    @media (max-width: 639px) {
        .action-btn {
            flex: 1;
            min-width: 0;
            padding: 0.625rem 0.5rem;
            font-size: 0.75rem;
            gap: 0.25rem;
            min-height: 44px;
        }
        
        .action-btn svg {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
        }
        
        .action-btn span {
            font-size: 0.75rem;
        }
    }

    @media (min-width: 640px) and (max-width: 1023px) {
        .action-btn {
            padding: 0.625rem 1.25rem;
        }
    }

    /* ============================================
       INFO GRID - BENTO LAYOUT
       ============================================ */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }

    @media (min-width: 640px) {
        .info-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
    }

    @media (min-width: 1024px) {
        .info-grid {
            grid-template-columns: repeat(4, 1fr);
            gap: 1.25rem;
        }
    }

    /* Info Card Styling */
    .info-card {
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: 1rem;
        box-shadow: var(--shadow-glow), 0 4px 24px rgba(0,0,0,0.1);
        transition: var(--transition-smooth);
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .info-card:hover {
        border-color: rgba(255,255,255,0.15);
        transform: translateY(-2px);
        box-shadow: var(--shadow-glow), 0 8px 32px rgba(0,0,0,0.15);
    }

    .info-icon-wrapper {
        flex-shrink: 0;
        margin-left: 0.75rem;
        padding: 0.625rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: var(--radius-md);
        transition: var(--transition-smooth);
    }

    .info-card:hover .info-icon-wrapper {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.2);
    }

    .info-icon {
        width: 1.25rem;
        height: 1.25rem;
        color: #9ca3af;
    }

    @media (min-width: 640px) {
        .info-card {
            padding: 1.25rem;
        }
        
        .info-icon-wrapper {
            padding: 0.75rem;
            margin-left: 1rem;
        }
        
        .info-icon {
            width: 1.5rem;
            height: 1.5rem;
        }
    }

    /* ============================================
       MAIN LAYOUT - RESPONSIVE FLEX
       ============================================ */
    .main-layout {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    @media (min-width: 1024px) {
        .main-layout {
            flex-direction: row;
            gap: 1.5rem;
        }
        
        .console-section {
            flex: 1;
            min-width: 0;
            width: 65%;
        }
        
        .stats-section {
            width: 35%;
            min-width: 280px;
            max-width: 380px;
        }
    }

    @media (min-width: 1280px) {
        .console-section {
            width: 70%;
        }
        
        .stats-section {
            width: 30%;
            max-width: 400px;
        }
    }

    /* ============================================
       HEADER - MODERN RESPONSIVE
       ============================================ */
    .page-header {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
    }

    @media (min-width: 640px) {
        .page-header {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .page-header {
            padding: 1.5rem 2rem;
        }
    }

    .header-title {
        font-size: clamp(1.25rem, 3vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.8) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .header-subtitle {
        font-size: clamp(0.75rem, 1.5vw, 0.875rem);
        color: #9ca3af;
        margin-top: 0.25rem;
        line-height: 1.5;
    }

    /* ============================================
       BUTTONS CONTAINER
       ============================================ */
    .actions-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        width: 100%;
    }

    @media (min-width: 640px) {
        .actions-container {
            width: auto;
            flex-wrap: nowrap;
            gap: 0.75rem;
        }
    }

    /* ============================================
       STATS GRID MOBILE OPTIMIZATION
       ============================================ */
    @media (max-width: 639px) {
        .stats-grid-mobile {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }
        
        .stats-grid-mobile .stats-card {
            height: 80px;
        }
    }

    @media (min-width: 640px) and (max-width: 1023px) {
        .stats-grid-mobile {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
    }

    /* ============================================
       EULA MODAL - ENHANCED GLASSMORPHISM
       ============================================ */
    .eula-modal {
        width: min(92%, 500px);
        max-height: 85vh;
        overflow-y: auto;
        margin: 1rem;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-elevated);
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        z-index: 50;
        padding: 1rem;
    }

    /* ============================================
       DAEMON ALERT - MODERN STYLING
       ============================================ */
    .daemon-alert {
        background: rgba(239, 68, 68, 0.1);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: var(--radius-lg);
        padding: 1rem;
        margin: 1rem 0;
    }

    @media (min-width: 640px) {
        .daemon-alert {
            padding: 1.25rem;
        }
    }

    /* ============================================
       TERMINAL INPUT - MODERN STYLING
       ============================================ */
    .terminal-input {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(10, 10, 10, 0.6);
        border: 1px solid rgba(255,255,255,0.05);
        border-top: none;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        color: white;
        font-size: 0.875rem;
        font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
        transition: var(--transition-smooth);
    }

    .terminal-input:focus {
        outline: none;
        background: rgba(10, 10, 10, 0.8);
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
    }

    .terminal-input::placeholder {
        color: #525252;
    }

    @media (min-width: 640px) {
        .terminal-input {
            padding: 1rem 1.25rem;
            font-size: 0.9375rem;
        }
    }

    /* ============================================
       TOUCH FRIENDLY IMPROVEMENTS
       ============================================ */
    @media (hover: none) and (pointer: coarse) {
        .action-btn {
            min-height: 44px;
        }
        
        .action-btn:active {
            transform: scale(0.96);
        }
        
        .terminal-input {
            min-height: 48px;
            font-size: 16px;
        }
    }

    /* ============================================
       SMOOTH TRANSITIONS
       ============================================ */
    .stats-card, .action-btn, .info-card {
        transition: var(--transition-smooth);
    }

    /* ============================================
       FOCUS STATES FOR ACCESSIBILITY
       ============================================ */
    .terminal-input:focus,
    .action-btn:focus-visible,
    button:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.3);
        outline-offset: 2px;
    }

    /* ============================================
       NOTIFICATION RESPONSIVE
       ============================================ */
    @media (max-width: 639px) {
        #notification {
            left: 1rem;
            right: 1rem;
            bottom: 1rem;
        }
    }

    /* ============================================
       UTILITY CLASSES
       ============================================ */
    .text-gradient {
        background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.8) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .truncate-address {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
        display: block;
    }

    /* Metric text styling */
    .metric-label {
        font-size: 0.625rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #9ca3af;
    }

    @media (min-width: 640px) {
        .metric-label {
            font-size: 0.75rem;
        }
    }

    .metric-value {
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.02em;
    }

    /* Status colors */
    .status-online {
        color: #10b981;
        text-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
    }

    .status-offline {
        color: #ef4444;
        text-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
    }

    /* ============================================
       REDUCED MOTION SUPPORT
       ============================================ */
    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }

    /* ============================================
       SCROLLBAR STYLING
       ============================================ */
    * {
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
    }

    *::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    *::-webkit-scrollbar-track {
        background: transparent;
    }

    *::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
    }

    *::-webkit-scrollbar-thumb:hover {
        background: rgba(255,255,255,0.2);
    }
</style>

<main class="overflow-hidden min-h-screen bg-transparent" id="content">
    <% if (false) { %>
        <% if (instance.imageData.features && instance.imageData.features.includes('eula')) { %>
            <div class="modal-overlay">
                <div class="eula-modal py-6 sm:py-8 px-4 sm:px-8">
                    <div class="flex items-center gap-3 mb-4">
                        <svg class="w-8 h-8 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                        </svg>
                        <p class="text-white text-lg sm:text-xl font-semibold">Do you accept Minecraft's EULA?</p>
                    </div>
                    <p class="text-xs sm:text-sm text-neutral-400 mb-6 leading-relaxed">By pressing this button you agree to the <a class="text-white hover:underline font-medium transition-colors" href="https://account.mojang.com/documents/minecraft_eula" target="_blank">Mojang EULA</a>.</p>
                    <button 
                    onclick="axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
                        .then(response => {
                            if (response.status === 200) {
                                location.reload();
                            }
                        })
                        .catch(error => {
                            console.error('There was an error!', error);
                        });" 
                    class="w-full sm:w-auto bg-white text-sm font-semibold text-gray-900 px-8 py-3 rounded-xl hover:bg-gray-100 transition-all duration-200 active:scale-95 shadow-lg">
                    I agree
                    </button>
                </div>
            </div>
        <% } %>
    <% } %>
    
    <div class="bg-transparent">
        <div class="page-header">
            <div class="flex-1 min-w-0">
                <h1 class="header-title"><%= req.translations.manageInstance %></h1>
                <p class="header-subtitle"><%= req.translations.manageInstanceText %></p>
            </div>
            <div class="actions-container">
                <!-- Start Button -->
                <button id="startButton" type="button" class="action-btn btn-start">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                        <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="hidden sm:inline"><%= req.translations.start %></span>
                    <span class="sm:hidden">Start</span>
                </button>

                <!-- Restart Button -->
                <button id="restartButton" type="button" class="action-btn btn-restart">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                        <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="hidden sm:inline"><%= req.translations.restart %></span>
                    <span class="sm:hidden">Restart</span>
                </button>

                <!-- Stop Button -->
                <button id="stopButton" type="button" class="action-btn btn-stop">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                        <path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/>
                    </svg>
                    <span class="hidden sm:inline"><%= req.translations.stop %></span>
                    <span class="sm:hidden">Stop</span>
                </button>
            </div>
        </div>
    </div>
    
    <%- include('../components/instance') %>
    
    <!-- Info Cards Grid -->
    <div class="mt-4 sm:mt-6 lg:mt-8 px-4 sm:px-6 lg:px-8 mb-4 sm:mb-6">
        <dl class="info-grid">
            <!-- Address Card -->
            <div class="info-card group">
                <div class="flex-grow min-w-0">
                    <dt class="metric-label"><%= req.translations.address %></dt>
                    <dd class="mt-1 text-base sm:text-lg font-semibold tracking-tight text-white">
                        <span class="truncate-address">
                            <%= instance.Node.address %><span class="text-neutral-500">:<%= instance.Primary %></span>
                        </span>
                    </dd>
                </div>
                <div class="info-icon-wrapper">
                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-11.25-3.75v6.75m8.25-6.75v6.75m-13.5-9.75h18m-9-6.75v6.75"/>
                    </svg>
                </div>
            </div>

            <!-- Template Card -->
            <div class="info-card group">
                <div class="flex-grow min-w-0">
                    <dt class="metric-label">Template</dt>
                    <dd class="mt-1 text-base sm:text-lg font-semibold tracking-tight text-white truncate">
                        <%= instance.imageData && instance.imageData.meta && instance.imageData.meta.display_name ? instance.imageData.meta.display_name : (instance.Template || instance.Image) %>
                    </dd>
                </div>
                <div class="info-icon-wrapper">
                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/>
                    </svg>
                </div>
            </div>

            <!-- Node Card -->
            <div class="info-card group">
                <div class="flex-grow min-w-0">
                    <dt class="metric-label"><%= req.translations.node %></dt>
                    <dd class="mt-1 text-base sm:text-lg font-semibold tracking-tight text-white">
                        <span class="truncate block"><%= instance.Node.name %></span>
                        <span class="text-neutral-500 text-xs sm:text-sm truncate block font-normal">(<%= instance.Node.address %>)</span>
                    </dd>
                </div>
                <div class="info-icon-wrapper">
                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-11.25-3.75v6.75m8.25-6.75v6.75m-13.5-9.75h18m-9-6.75v6.75"/>
                    </svg>
                </div>
            </div>

            <!-- Identifier Card -->
            <div class="info-card group">
                <div class="flex-grow min-w-0">
                    <dt class="metric-label"><%= req.translations.identifier %></dt>
                    <dd class="mt-1 text-sm sm:text-base font-semibold tracking-tight text-white font-mono truncate">
                        <%= req.params.id %>
                    </dd>
                </div>
                <div class="info-icon-wrapper">
                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                    </svg>
                </div>
            </div>
        </dl>
    </div>

    <!-- Daemon Down Alert -->
    <div class="daemon-alert hidden mx-4 sm:mx-6 lg:mx-8 mt-4 sm:mt-6" id="daemonIsDown">
        <div class="flex items-start gap-3 sm:gap-4">
            <div class="flex-shrink-0">
                <svg class="animate-spin h-5 w-5 text-red-400 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-red-400"><%= req.translations.connectionFailure %></h3>
                <div class="text-xs sm:text-sm text-red-400/70 mt-1 leading-relaxed">
                    <p><%= req.translations.connectionFailureText %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Layout: Console + Stats -->
    <div class="main-layout px-4 sm:px-6 lg:px-8 pb-6 sm:pb-8">
        <!-- Left side: Console -->
        <div class="console-section w-full">
            <div class="bg-[#0a0a0a]/80 backdrop-blur-sm rounded-t-xl p-2 sm:p-3 overflow-hidden border border-white/5 border-b-0">
                <div id="terminal"></div>
            </div>
            <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>" class="terminal-input rounded-b-xl">
        </div>
        
        <!-- Right side: Stats Cards -->
        <div class="stats-section w-full stats-grid-mobile lg:block space-y-3 sm:space-y-4">
            <!-- Status Card -->
            <div class="stats-card px-4 py-3 sm:py-4">
                <canvas id="statusChart"></canvas>
                <div class="relative z-10 h-full flex flex-col justify-center">
                    <h2 class="metric-label"><%= req.translations.status %></h2>
                    <p id="status" class="mt-1 text-lg sm:text-xl font-bold tracking-tight metric-value">-</p>
                </div>
            </div>
            
            <!-- RAM Usage Card -->
            <div class="stats-card px-4 py-3 sm:py-4">
                <canvas id="ramChart"></canvas>
                <div class="relative z-10 h-full flex flex-col justify-center">
                    <h2 class="metric-label"><%= req.translations.ramUsage %></h2>
                    <p id="ramUsage" class="mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-white truncate">-</p>
                </div>
            </div>
            
            <!-- CPU Usage Card -->
            <div class="stats-card px-4 py-3 sm:py-4">
                <canvas id="cpuChart"></canvas>
                <div class="relative z-10 h-full flex flex-col justify-center">
                    <h2 class="metric-label"><%= req.translations.cpuUsage %></h2>
                    <p id="cpuUsage" class="mt-1 text-lg sm:text-xl font-bold tracking-tight metric-value text-white">-</p>
                </div>
            </div>
            
            <!-- Disk Usage Card -->
            <div class="stats-card px-4 py-3 sm:py-4">
                <canvas id="diskChart" class="hidden"></canvas>
                <div class="relative z-10 h-full flex flex-col justify-center">
                    <h2 class="metric-label"><%= req.translations.diskUsage %></h2>
                    <p id="diskUsage" class="mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-white truncate">-</p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const baseTheme = {
        foreground: '#c5c9d1',
        background: 'rgba(0 0 0 / 0)',
        selection: '#5DA5D533',
        black: '#1E1E1D',
        brightBlack: '#262625',
        red: '#E54B4B',
        green: '#9ECE58',
        yellow: '#FAED70',
        blue: '#396FE2',
        magenta: '#BB80B3',
        cyan: '#2DDAFD',
        white: '#d0d0d0',
        brightBlack: 'rgba(255, 255, 255, 0.2)',
        brightRed: '#FF5370',
        brightGreen: '#C3E88D',
        brightYellow: '#FFCB6B',
        brightBlue: '#82AAFF',
        brightMagenta: '#C792EA',
        brightCyan: '#89DDFF',
        brightWhite: '#ffffff',
    };
    
    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 10;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let term;
    let ws;
    let eulaModalShown = false;
    
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);
        
        ws.onopen = () => console.log('WebSocket connected!');
        ws.onmessage = handleWebSocketMessage;
        ws.onclose = () => {
            console.log('WebSocket connection closed, attempting to reconnect...');
            setTimeout(initWebSocket, 3000);
        };
        ws.onerror = (error) => {
            console.log('WebSocket encountered an error:', error, 'Attempting to reconnect...');
            setTimeout(initWebSocket, 5000);
        };
    }
    
    function showEulaModal() {
        if (eulaModalShown) return;
        eulaModalShown = true;
        
        const modalHtml = `
            <div class="modal-overlay" id="eulaModal">
                <div class="eula-modal py-6 sm:py-8 px-4 sm:px-8">
                    <div class="flex items-center gap-3 mb-4">
                        <svg class="w-8 h-8 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                        </svg>
                        <p class="text-white text-lg sm:text-xl font-semibold">Do you accept Minecraft's EULA?</p>
                    </div>
                    <p class="text-xs sm:text-sm text-neutral-400 mb-6 leading-relaxed">By pressing this button you agree to the <a class="text-white hover:underline font-medium transition-colors" href="https://account.mojang.com/documents/minecraft_eula" target="_blank">Mojang EULA</a>.</p>
                    <button 
                    onclick="acceptEula()" 
                    class="w-full sm:w-auto bg-white text-sm font-semibold text-gray-900 px-8 py-3 rounded-xl hover:bg-gray-100 transition-all duration-200 active:scale-95 shadow-lg">
                    I agree
                    </button>
                </div>
            </div>
        `;
        
        document.body.insertAdjacentHTML('beforeend', modalHtml);
    }
    
    function acceptEula() {
        axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
            .then(response => {
                if (response.status === 200) {
                    const modal = document.getElementById('eulaModal');
                    if (modal) modal.remove();
                    eulaModalShown = false;
                }
            })
            .catch(error => {
                console.error('There was an error!', error);
            });
    }
    
    function handleWebSocketMessage(msg) {
        const lines = msg.data.split('\n');
        let isFirstLine = true;
        let previousLineWasEmpty = false;
    
        lines.forEach(line => {
            const trimmedLine = line.trim();
            if (trimmedLine === '' && previousLineWasEmpty) return;
            
            if (trimmedLine.toLowerCase().includes('you need to agree to the eula') && 
                (trimmedLine.toLowerCase().includes('eula.txt') || trimmedLine.toLowerCase().includes('dialog above'))) {
                showEulaModal();
            }
            
            if (!isFirstLine && !previousLineWasEmpty) {
                term.write('\r\n');
            }
    
            term.write('\x1b[0m' + trimmedLine);
    
            if (trimmedLine.includes("Working on")) {
                term.write('\r\n\u001b[1m\u001b[33m[panel] \u001b[0mreconnecting socket, hold on...');
                term.clear();
                ws.close();
            }
            
            if (trimmedLine.includes("KS Wings instance appears to be down")) {
                ws.close();
                document.getElementById('daemonIsDown').classList.remove('hidden');
            } else {
                document.getElementById('daemonIsDown').classList.add('hidden');
            }
    
            isFirstLine = false;
            previousLineWasEmpty = (trimmedLine === '');
        });
    }
    
    function setupTerminal() {
        const screenWidth = window.innerWidth;
        let cols = 80;
        let rows = 16;
        
        if (screenWidth < 640) {
            cols = 32;
            rows = 12;
        } else if (screenWidth < 1024) {
            cols = 60;
            rows = 18;
        } else {
            cols = 80;
            rows = 22;
        }
        
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.35,
            rows: rows,
            cols: cols,
            fontFamily: 'Menlo, Monaco, "Courier New", monospace',
            theme: baseTheme,
            allowTransparency: true,
            fontSize: screenWidth < 640 ? 10 : 12,
            cursorBlink: false,
            scrollback: 1000,
        });
        
        term.open(document.getElementById('terminal'));
        
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                const newWidth = window.innerWidth;
                let newCols = 80;
                let newRows = 22;
                
                if (newWidth < 640) {
                    newCols = 32;
                    newRows = 12;
                } else if (newWidth < 1024) {
                    newCols = 60;
                    newRows = 18;
                }
                
                term.resize(newCols, newRows);
            }, 250);
        });
    }
    
    function sendCommand() {
        const inputElement = document.getElementById('input');
        const command = inputElement.value.trim();
        if (command && ws) {
            term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');
            ws.send(JSON.stringify({
                event: 'cmd',
                command: command,
                containerId: instanceId
            }));
    
            if (commandHistory.length === maxCommands) {
                commandHistory.shift();
            }
            commandHistory.push(command);
            currentCommandIndex = commandHistory.length;
    
            inputElement.value = '';
        }
    }
    
    function handleKeyUp(event) {
        if (event.key === 'ArrowUp') {
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
            event.preventDefault();
        } else if (event.key === 'ArrowDown') {
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
            event.preventDefault();
        }
    }
    
    document.addEventListener('DOMContentLoaded', function () {
        setupTerminal();
        initWebSocket();
    
        const inputElement = document.getElementById('input');
        inputElement.addEventListener('keypress', function (event) {
            if (event.key === 'Enter') {
                sendCommand();
            }
        });
    
        inputElement.addEventListener('keydown', handleKeyUp);
    
        ['start', 'stop', 'restart'].forEach(action => {
            const btn = document.getElementById(`${action}Button`);
            if (!btn) return;
            btn.addEventListener('click', async function () {
                if (!confirm(`Are you sure you want to ${action} this instance?`)) return;

                const originalHTML = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = `<svg class="animate-spin w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Processing...</span>`;

                try {
                    const res = await axios.post(`/instance/<%= req.params.id %>/power`, { action });
                    if (res.status === 200) {
                        btn.innerHTML = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> <span>${action.charAt(0).toUpperCase() + action.slice(1)}ed!</span>`;
                        setTimeout(() => {
                            btn.innerHTML = originalHTML;
                            btn.disabled = false;
                        }, 2000);
                    } else {
                        throw new Error(res.data?.message || 'Unknown error');
                    }
                } catch (err) {
                    console.error(err);
                    alert("Power action failed: " + (err.response?.data?.message || err.message || 'Unknown'));
                    btn.innerHTML = originalHTML;
                    btn.disabled = false;
                }
            });
        });
    
        initStatsWebSocket();
    });

    function isValidJson(str) {
        try {
          JSON.parse(str);
        } catch (e) {
          return false;
        }
        return true;
    }
    
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        const statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);
        
        statsWs.onmessage = event => {
            if (isValidJson(event.data)) {
                const stats = JSON.parse(event.data);
                if (stats.error) {
                    console.error('Error fetching stats:', stats.error);
                    return;
                }
    
                updateRamUsage(stats);
                updateCpuUsage(stats);
                updateDiskUsage(stats);
                updateStatus(stats);
            } else {
                console.log('Received non-JSON data:', event.data);
            }
        };

        statsWs.onclose = () => {
            console.log('WebSocket Stats connection closed, attempting to reconnect...');
            setTimeout(initStatsWebSocket, 3000);
        };
    }
    
    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB', 'PB', 'EB', 'ZB', 'YB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }
    
    function createBackgroundChart(canvasId, type = 'line') {
        const ctx = document.getElementById(canvasId);
        if (!ctx) return null;
        
        return new Chart(ctx.getContext('2d'), {
            type: type,
            data: {
                labels: [],
                datasets: [{
                    data: [],
                    borderColor: 'rgba(255, 255, 255, 0.1)',
                    backgroundColor: 'rgba(255, 255, 255, 0.05)',
                    borderWidth: 1,
                    pointRadius: 0,
                    fill: true,
                    tension: 0.4,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { enabled: false }
                },
                scales: {
                    x: { display: false },
                    y: { display: false, min: 0, max: 100 }
                },
                animation: { duration: 0 }
            }
        });
    }
    
    let statusChart, ramChart, cpuChart, diskChart;
    
    document.addEventListener('DOMContentLoaded', function() {
        statusChart = createBackgroundChart('statusChart');
        ramChart = createBackgroundChart('ramChart');
        cpuChart = createBackgroundChart('cpuChart');
        diskChart = createBackgroundChart('diskChart', 'doughnut');
    });
    
    function updateRamUsage(stats) {
        const ramStatsUsage = stats.memory_stats?.usage || 0;
        const ramStatsLimit = stats.memory_stats?.limit || 0;

        const ramUsageRaw = ramStatsUsage / 1024 / 1024 || 0;
        const ramLimitRaw = ramStatsLimit / 1024 / 1024 || <%= instance.Memory || 1024 %>;
        const ramUsagePercent = (ramLimitRaw > 0) ? ((ramUsageRaw / ramLimitRaw) * 100).toFixed(2) : '0.00';
        
        const ramElement = document.getElementById('ramUsage');
        if (ramElement) {
            ramElement.textContent = `${ramUsagePercent}% (${formatBytes(ramStatsUsage)} / ${formatBytes(ramStatsLimit)})`;
        }
    
        if (ramStatsUsage > 0 && ramChart) {
            updateChart(ramChart, ramUsagePercent);
        }
    }
    
    function updateCpuUsage(stats) {
        const cpuDelta = stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage || 0;
        const systemCpuDelta = stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage || 0;
        let cpuUsagePercent = 0;
        
        if (systemCpuDelta > 0) {
            cpuUsagePercent = ((cpuDelta / systemCpuDelta) * 100).toFixed(2);
        }
    
        if (isNaN(cpuUsagePercent)) {
            cpuUsagePercent = 0;
        }
    
        const cpuElement = document.getElementById('cpuUsage');
        if (cpuElement) {
            cpuElement.textContent = `${cpuUsagePercent}%`;
        }
        
        if (cpuUsagePercent > 0 && cpuChart) {
            updateChart(cpuChart, cpuUsagePercent);
        }
    }
    
    function updateDiskUsage(stats) {
        const diskUsageRaw = parseFloat(stats.volumeSize) || 0;
        const diskLimitMiB = <%= instance.Disk || 0 %>;
        
        const diskElement = document.getElementById('diskUsage');
        if (!diskElement) return;
        
        if (diskLimitMiB === 0) {
            diskElement.textContent = `${formatBytes(diskUsageRaw * 1024 * 1024)} / Unlimited`;
            diskElement.className = 'mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-emerald-400';
        } else {
            const diskLimitRaw = diskLimitMiB;
            const diskUsagePercent = (diskUsageRaw / diskLimitRaw * 100).toFixed(2);
            diskElement.textContent = `${diskUsagePercent}% (${formatBytes(diskUsageRaw * 1024 * 1024)} / ${formatBytes(diskLimitRaw * 1024 * 1024)})`;
            
            if (parseFloat(diskUsagePercent) >= 100) {
                diskElement.className = 'mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-red-500';
            } else if (parseFloat(diskUsagePercent) >= 90) {
                diskElement.className = 'mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-amber-400';
            } else {
                diskElement.className = 'mt-1 text-base sm:text-lg font-bold tracking-tight metric-value text-emerald-400';
            }
        }
    }
    
    function updateStatus(stats) {
        const statusElement = document.getElementById('status');
        if (!statusElement) return;
        
        const containerStatus = (stats.status || stats.state || stats.State?.Status || '').toLowerCase();
        const ramUsageRaw = stats.memory_stats?.usage / 1024 / 1024 || 0;
        
        const isOnline = containerStatus === 'running' || ramUsageRaw > 1;
        
        if (isOnline) {
            statusElement.textContent = 'Online';
            statusElement.className = 'mt-1 text-lg sm:text-xl font-bold tracking-tight metric-value status-online';
            updateStatusChart('rgba(16, 185, 129, 0.15)', 'rgba(16, 185, 129, 0.3)');
        } else {
            statusElement.textContent = 'Offline';
            statusElement.className = 'mt-1 text-lg sm:text-xl font-bold tracking-tight metric-value status-offline';
            updateStatusChart('rgba(239, 68, 68, 0.15)', 'rgba(239, 68, 68, 0.3)');
        }
    }
    
    function updateChart(chart, value) {
        if (!chart) return;
        
        const numValue = parseFloat(value) || 0;
        chart.data.labels.push('');
        chart.data.datasets[0].data.push(numValue);
    
        if (chart.data.labels.length > 20) {
            chart.data.labels.shift();
            chart.data.datasets[0].data.shift();
        }
    
        chart.update('none');
    }
    
    function updateStatusChart(backgroundColor, borderColor) {
        if (!statusChart) return;
        
        statusChart.data.datasets[0].backgroundColor = backgroundColor;
        statusChart.data.datasets[0].borderColor = borderColor;
        statusChart.data.labels = [''];
        statusChart.data.datasets[0].data = [100];
        statusChart.update('none');
    }
</script>
<%- include('../components/footer') %>
