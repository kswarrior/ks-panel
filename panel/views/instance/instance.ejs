<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
    }

    .xterm-viewport {
        overflow-y: hidden !important;
    }

    /* Premium glassmorphic design */
    .glass {
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 8px 32px -12px rgb(0 0 0 / 0.3);
    }

    .glass:hover {
        background: rgba(255,255,255,0.09);
        border-color: rgba(255,255,255,0.25);
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.2);
    }

    .power-btn {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .power-btn:hover {
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.3);
    }
    .power-btn:active {
        transform: scale(0.97);
    }

    /* Stats cards - ultra smooth */
    .stat-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 25px 25px 50px -12px rgb(0 0 0 / 0.25);
    }
</style>

<main class="overflow-hidden" id="content">
    <% if (false) { %>
        <% if (instance.imageData.features && instance.imageData.features.includes('eula')) { %>
            <div class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 backdrop-blur z-50">
                <div class="bg-white/5 backdrop-blur py-8 px-8 rounded-2xl shadow-lg w-1/2 h-48">
                    <p class="text-white text-lg font-medium">Do you accept Minecraft's EULA?</p>
                    <p class="text-sm text-neutral-400">By pressing this button you agree to the <a class="text-white" href="https://account.mojang.com/documents/minecraft_eula">Mojang EULA</a>.</p>
                    <button 
                    onclick="axios.post('/instance/<%= req.params.id %>/imagefeatures/eula')
                        .then(response => {
                            if (response.status === 200) {
                                location.reload();
                            }
                        })
                        .catch(error => {
                            console.error('There was an error!', error);
                        });" 
                    class="mt-8 bg-white text-sm font-sm text-gray-800 px-4 font-medium transition py-2 rounded-2xl hover:bg-gray-100">
                    I agree
                    </button>
                </div>
            </div>
        <% } %>
    <% } %>
    
    <%- include('../components/instance') %>

    <!-- Start / Restart / Stop buttons (tighter spacing) -->
    <div class="px-6 mt-4 flex gap-2">
        <!-- Start Button -->
        <button id="startButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-emerald-600 px-3 py-2 text-sm font-medium text-white shadow-lg hover:bg-emerald-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1 text-emerald-100">
                <path fill-rule="evenodd"
                    d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z"
                    clip-rule="evenodd" />
            </svg>
            <%= req.translations.start %>
        </button>

        <!-- Restart Button -->
        <button id="restartButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-blue-600 px-3 py-2 text-sm font-medium text-white shadow-lg hover:bg-blue-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1 text-white">
                <path fill-rule="evenodd"
                    d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z"
                    clip-rule="evenodd" />
            </svg>
            <%= req.translations.restart %>
        </button>

        <!-- Stop Button -->
        <button id="stopButton" type="button"
            class="power-btn flex items-center rounded-2xl bg-red-600 px-3 py-2 text-sm font-medium text-white shadow-lg hover:bg-red-500 transition">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="w-4 h-4 mr-1 text-red-100">
                <path fill-rule="evenodd"
                    d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z"
                    clip-rule="evenodd" />
            </svg>
            <%= req.translations.stop %>
        </button>
    </div>

    <div class="mt-6 ml-6 mb-3">
        <dl class="mt-3 grid grid-cols-1 gap-5 sm:grid-cols-4 mr-6">
            <!-- Updated Address Card -->
            <div class="overflow-hidden rounded-3xl glass px-6 py-6 shadow-xl flex items-center">
                <div class="flex-grow">
                    <div class="flex items-center justify-between">
                        <!-- Name: normal size but bold -->
                        <span class="font-semibold text-xl text-white"><%= instance.Name %></span>
                        
                        <!-- Status tag (Online / Offline) -->
                        <span id="statusTag" class="inline-flex items-center px-3 py-1 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-3xl tracking-wider">Online</span>
                    </div>
                    
                    <!-- IP: normal size, not bold, italic -->
                    <div onclick="copyIP()" id="ipContainer"
                        class="mt-3 text-base font-normal italic text-white flex items-center gap-3 cursor-pointer hover:text-emerald-300 transition">
                        <span id="ipText">
                            <%= instance.Allocation.IP %><span class="text-neutral-400 not-italic">:</span><%= instance.Allocation.Port %>
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16v-4m4 4v4m-8-8h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v4a2 2 0 002 2z" />
                        </svg>
                    </div>
                </div>
                <div class="ml-4 shadow border border-white/10 rounded-2xl p-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-7 w-7 text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M240,120a8,8,0,0,1-8,8H200v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H176a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H72v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H24a8,8,0,0,1,0-16h96V88h-8A16,16,0,0,1,96,72V40a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V72a16,16,0,0,1-16,16h-8v24h96A8,8,0,0,1,240,120Z"/></svg>
                </div>
            </div>
        </dl>
    </div>

    <div class="rounded-3xl bg-red-800/10 px-4 py-6 mt-6 ml-6 mb-6 mr-6 hidden" id="daemonIsDown">
        <div class="flex">
            <div class="flex-shrink-0 ml-1.5">
                <svg class="animate-spin mt-2 h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg"
                    fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                    </circle>
                    <path class="opacity-75" fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                    </path>
                </svg>
            </div>
            <div class="ml-5">
                <h3 class="text-sm font-medium text-red-400"><%= req.translations.connectionFailure %></h3>
                <div class="text-sm text-red-400/50">
                    <p><%= req.translations.connectionFailureText %></p>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col lg:flex-row px-6">
        <!-- Left side: Console -->
        <div class="w-full lg:w-2/3 lg:pr-4">
            <div class="glass rounded-3xl p-4">
                <div id="terminal" class="overflow-x-auto whitespace-pre-wrap h-[380px] rounded-2xl"></div>
            </div>
            <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.SendACommand %>"
                class="mt-3 w-full px-6 py-4 bg-[#101010]/70 text-white rounded-3xl text-base border border-white/10 focus:border-white/30 placeholder:font-medium placeholder:text-neutral-400 focus:outline-none transition-all">
        </div>
        
        <!-- Right side: Redesigned Stats Cards (smaller text + smoother graphs) -->
        <div class="w-full lg:w-1/3 mt-4 lg:mt-0 space-y-3">
            
            <!-- RAM Card -->
            <div class="stat-card bg-white/5 rounded-3xl px-6 py-5 shadow flex flex-col h-40 relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="text-sm font-medium text-neutral-400"><%= req.translations.ramUsage %></span>
                        <div id="ramPercent" class="text-4xl font-semibold leading-none text-white mt-1">0%</div>
                    </div>
                    <div id="ramUsageText" class="text-right text-base font-medium text-white">0 GB / 0 GB</div>
                </div>
                <div class="flex-1 mt-4 relative">
                    <canvas id="ramChart" class="absolute inset-0 w-full h-full"></canvas>
                </div>
            </div>
            
            <!-- CPU Card -->
            <div class="stat-card bg-white/5 rounded-3xl px-6 py-5 shadow flex flex-col h-40 relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="text-sm font-medium text-neutral-400"><%= req.translations.cpuUsage %></span>
                        <div id="cpuPercent" class="text-4xl font-semibold leading-none text-white mt-1">0%</div>
                    </div>
                    <div id="cpuUsageText" class="text-right text-base font-medium text-white">0%</div>
                </div>
                <div class="flex-1 mt-4 relative">
                    <canvas id="cpuChart" class="absolute inset-0 w-full h-full"></canvas>
                </div>
            </div>
            
            <!-- Disk Card -->
            <div class="stat-card bg-white/5 rounded-3xl px-6 py-5 shadow flex flex-col h-40 relative overflow-hidden">
                <div class="flex justify-between items-baseline">
                    <div>
                        <span class="text-sm font-medium text-neutral-400"><%= req.translations.diskUsage %></span>
                        <div id="diskPercent" class="text-4xl font-semibold leading-none text-white mt-1">0%</div>
                    </div>
                    <div id="diskUsageText" class="text-right text-base font-medium text-white">0 GB / 0 GB</div>
                </div>
                <div class="flex-1 mt-4 relative">
                    <canvas id="diskChart" class="absolute inset-0 w-full h-full"></canvas>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // ============================================
    // FULL WORKING JS - ONLY JS ADDED (no style/HTML changed)
    // ============================================

    const baseTheme = {
        foreground: '#c5c9d1',
        background: 'rgba(0 0 0 / 0)',
        selection: '#5DA5D533',
        black: '#1E1E1D',
        brightBlack: '#262625',
        red: '#E54B4B',
        green: '#9ECE58',
        yellow: '#FAED70',
        blue: '#396FE2',
        magenta: '#BB80B3',
        cyan: '#2DDAFD',
        white: '#d0d0d0',
        brightBlack: 'rgba(255, 255, 255, 0.2)',
        brightRed: '#FF5370',
        brightGreen: '#C3E88D',
        brightYellow: '#FFCB6B',
        brightBlue: '#82AAFF',
        brightMagenta: '#C792EA',
        brightCyan: '#89DDFF',
        brightWhite: '#ffffff',
    };

    const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
    const instanceId = '<%= req.params.id %>';
    const maxCommands = 50;
    let commandHistory = [];
    let currentCommandIndex = -1;
    let term;
    let ws;
    let statsWs;
    let reconnectAttempts = 0;
    const maxReconnectAttempts = 10;

    // Utilities
    function isValidJson(str) {
        try { JSON.parse(str); return true; } catch { return false; }
    }

    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }

    // Copy IP:Port
    function copyIP() {
        const ipText = document.getElementById('ipText').textContent.trim();
        navigator.clipboard.writeText(ipText).then(() => {
            const container = document.getElementById('ipContainer');
            const originalHTML = container.innerHTML;
            container.style.transition = 'all 0.2s';
            container.style.color = '#10b981';
            setTimeout(() => {
                container.innerHTML = originalHTML.replace('text-neutral-400', 'text-emerald-400');
                setTimeout(() => {
                    container.innerHTML = originalHTML;
                    container.style.color = '';
                }, 1200);
            }, 80);
        });
    }

    // Stylish SVG loading spinner for power buttons
    function showProcessing(btn) {
        const originalHTML = btn.innerHTML;
        btn.dataset.originalHTML = originalHTML;
        btn.disabled = true;
        btn.style.opacity = '0.75';
        btn.style.pointerEvents = 'none';
        
        btn.innerHTML = `
            <svg class="animate-spin h-4 w-4 mr-2 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Processing...
        `;
    }

    function hideProcessing(btn) {
        if (btn.dataset.originalHTML) {
            btn.innerHTML = btn.dataset.originalHTML;
            btn.disabled = false;
            btn.style.opacity = '';
            btn.style.pointerEvents = '';
            delete btn.dataset.originalHTML;
        }
    }

    // Power action with direct execution (no confirm) + stylish SVG animation
    async function performPowerAction(btn, action) {
        showProcessing(btn);
        
        try {
            const res = await axios.post(`/instance/${instanceId}/power`, { action });
            if (res.status === 200) {
                console.log(`Instance ${action}ed successfully`);
            }
        } catch (err) {
            console.error(`Failed to ${action} instance`, err);
        } finally {
            hideProcessing(btn);
        }
    }

    // Terminal
    function setupTerminal() {
        term = new Terminal({
            disableStdin: true,
            allowProposedApi: true,
            lineHeight: 1.35,
            rows: 19,
            cols: 100,
            fontFamily: 'Menlo, monospace',
            theme: baseTheme,
            allowTransparency: true,
            fontSize: 12,
        });
        term.open(document.getElementById('terminal'));
    }

    // Console WebSocket
    function initWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        ws = new WebSocket(`${protocol}://${window.location.hostname}${port}/console/${instanceId}`);

        ws.onopen = () => {
            console.log('[Console] WebSocket connected');
            reconnectAttempts = 0;
            document.getElementById('daemonIsDown').classList.add('hidden');
        };

        ws.onmessage = (msg) => {
            const data = msg.data;
            term.write(data);

            if (data.includes("Working on")) {
                term.write('\r\n\u001b[1m\u001b[33m[panel] \u001b[0mReconnecting...');
                ws.close();
            }

            if (data.includes("KS Wings instance appears to be down")) {
                ws.close();
                document.getElementById('daemonIsDown').classList.remove('hidden');
            }
        };

        ws.onclose = () => {
            if (reconnectAttempts < maxReconnectAttempts) {
                const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 30000);
                setTimeout(initWebSocket, delay);
                reconnectAttempts++;
            }
        };

        ws.onerror = (error) => console.error('[Console] WebSocket error:', error);
    }

    // Command handling
    function sendCommand() {
        const input = document.getElementById('input');
        const command = input.value.trim();
        if (!command || !ws) return;

        term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');

        ws.send(JSON.stringify({
            event: 'cmd',
            command: command,
            containerId: instanceId
        }));

        if (commandHistory.length >= maxCommands) commandHistory.shift();
        commandHistory.push(command);
        currentCommandIndex = commandHistory.length;

        input.value = '';
    }

    function handleKeyUp(e) {
        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
        } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
        }
    }

    // Power buttons
    function initPowerButtons() {
        const actions = {
            start: document.getElementById('startButton'),
            restart: document.getElementById('restartButton'),
            stop: document.getElementById('stopButton')
        };

        Object.keys(actions).forEach(action => {
            const btn = actions[action];
            btn.addEventListener('click', () => {
                performPowerAction(btn, action);
            });
        });
    }

    // Stats WebSocket
    function initStatsWebSocket() {
        const port = window.location.port ? `:${window.location.port}` : '';
        statsWs = new WebSocket(`${protocol}://${window.location.hostname}${port}/stats/${instanceId}`);

        statsWs.onmessage = (event) => {
            if (!isValidJson(event.data)) return;
            const stats = JSON.parse(event.data);
            if (stats.error) return;

            updateRamUsage(stats);
            updateCpuUsage(stats);
            updateDiskUsage(stats);
            updateStatus(stats);
        };

        statsWs.onclose = () => setTimeout(initStatsWebSocket, 5000);
    }

    // === SMOOTH & BEAUTIFUL CHARTS ===
    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: { 
            x: { display: false },
            y: { display: false, min: 0, max: 100 }
        },
        animation: { duration: 0 },
        elements: {
            line: {
                borderWidth: 3,
                tension: 0.5
            },
            point: {
                radius: 0
            }
        }
    };

    const ramChart = new Chart(document.getElementById('ramChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.15)', fill: true }] },
        options: chartOptions
    });

    const cpuChart = new Chart(document.getElementById('cpuChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.15)', fill: true }] },
        options: chartOptions
    });

    const diskChart = new Chart(document.getElementById('diskChart'), {
        type: 'line',
        data: { labels: Array(30).fill(''), datasets: [{ data: Array(30).fill(0), borderColor: '#8b5cf6', backgroundColor: 'rgba(139,92,246,0.15)', fill: true }] },
        options: chartOptions
    });

    function updateChart(chart, value) {
        chart.data.datasets[0].data.push(parseFloat(value) || 0);
        chart.data.datasets[0].data.shift();
        chart.update('none');
    }

    function updateRamUsage(stats) {
        const usage = stats.memory_stats?.usage || 0;
        const limit = stats.memory_stats?.limit || 0;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;

        document.getElementById('ramPercent').textContent = `${percent}%`;
        document.getElementById('ramUsageText').textContent = `${formatBytes(usage)} / ${formatBytes(limit)}`;
        updateChart(ramChart, percent);
    }

    function updateCpuUsage(stats) {
        const cpuDelta = (stats.cpu_stats?.cpu_usage?.total_usage - stats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (stats.cpu_stats?.system_cpu_usage - stats.precpu_stats?.system_cpu_usage) || 0;
        const percent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;

        document.getElementById('cpuPercent').textContent = `${percent}%`;
        document.getElementById('cpuUsageText').textContent = `${percent}%`;
        updateChart(cpuChart, percent);
    }

    function updateDiskUsage(stats) {
        const usage = parseFloat(stats.volumeSize) || 0;
        const limit = <%= instance.Disk || 0 %>;
        const percent = limit > 0 ? ((usage / limit) * 100).toFixed(1) : 0;

        document.getElementById('diskPercent').textContent = `${percent}%`;
        if (limit === 0) {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / Unlimited`;
        } else {
            document.getElementById('diskUsageText').textContent = `${formatBytes(usage * 1024 * 1024)} / ${formatBytes(limit * 1024 * 1024)}`;
        }
        updateChart(diskChart, percent);
    }

    // Status tag
    function updateStatus(stats) {
        const ramUsage = stats.memory_stats?.usage || 0;
        const isRunning = (stats.status || '').toLowerCase() === 'running' || ramUsage > 0;

        const tag = document.getElementById('statusTag');

        if (isRunning) {
            tag.textContent = 'Online';
            tag.className = 'inline-flex items-center px-3 py-1 text-xs font-medium bg-emerald-500/10 text-emerald-400 rounded-3xl tracking-wider';
        } else {
            tag.textContent = 'Offline';
            tag.className = 'inline-flex items-center px-3 py-1 text-xs font-medium bg-red-500/10 text-red-400 rounded-3xl tracking-wider';
        }
    }

    // Main initialization
    document.addEventListener('DOMContentLoaded', () => {
        setupTerminal();
        initWebSocket();
        initPowerButtons();
        initStatsWebSocket();

        const input = document.getElementById('input');
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendCommand(); });
        input.addEventListener('keydown', handleKeyUp);

        // Visibility handling
        document.addEventListener('visibilitychange', () => {
            if (document.hidden && statsWs) statsWs.onmessage = null;
            else if (statsWs) initStatsWebSocket();
        });
    });
</script>

