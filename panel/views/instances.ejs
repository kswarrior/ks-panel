<%- include('components/template') %>
<% /* SSB0aGluayBJJ3ZlIGZvdW5kIG15IHZvaWNlCkknbSBhIGxlZWNoIHN1Y2tpbmcgYmxvb2QgYmFncwpUYXN0ZSBkZWZlYXQsIGl0J3MgYSBzYW5kYmFnClNhbGluZSBTb2x1dGlvbg== */ %>
<main id="content">
  <div class="bg-transparent">
    <div class="flex items-center justify-between px-4 sm:px-8 pt-4 flex-wrap gap-4">

  <!-- Left Side -->
  <h1 class="text-base font-medium text-white">
    <%= req.translations.instances %>
  </h1>

  <% if (req.user.admin === true) { %>
  <!-- Right Side -->
  <label for="instance-toggle" class="flex items-center cursor-pointer select-none">
  <div class="relative w-11 h-6">

    <input type="checkbox"
           id="instance-toggle"
           class="peer sr-only"
           <%= req.query.see === 'other' ? 'checked' : '' %>>

    <!-- Track -->
    <div class="w-full h-full rounded-full
                bg-white/10
                peer-checked:bg-blue-600
                transition-colors duration-300">
    </div>

    <!-- Dot -->
    <div class="absolute top-0 left-0
                w-6 h-6 rounded-full bg-white shadow-md
                transition-transform duration-300
                peer-checked:translate-x-5">
    </div>

  </div>

  <span class="ml-3 text-sm font-medium text-white">
    Show All
  </span>
</label>
  <% } %>

</div>
  </div>
  <% if (req.query.err == "NOTACTIVEYET") { %>
    <div class="rounded-xl bg-amber-800/10 px-4 py-6 m-4 sm:m-7">
      <div class="flex">
          <div class="flex-shrink-0 ml-1.5">
              <svg class="animate-spin mt-2 h-5 w-5 text-amber-400" xmlns="http://www.w3.org/2000/svg"
                  fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4">
                  </circle>
                  <path class="opacity-75" fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                  </path>
              </svg>
          </div>
          <div class="ml-5">
              <h3 class="text-sm font-medium text-amber-400">Awaiting Installation</h3>
              <div class="text-sm text-amber-400/50">
                  <p>The instance either isn't installed yet, or is in a failed state.</p>
              </div>
          </div>
      </div>
  </div>
    <% } %>	  
  <div class="px-4 sm:px-6 lg:px-8 mt-8">
    <% if (instances.length == 0) { %>
      <!-- No instances -->
      <div id="noInstancesContainer" class="text-center mt-32 sm:mt-64 px-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
          class="mx-auto h-12 w-12 text-neutral-500">
          <path fill-rule="evenodd"
            d="M11.622 1.602a.75.75 0 0 1 .756 0l2.25 1.313a.75.75 0 0 1-.756 1.295L12 3.118 10.128 4.21a.75.75 0 1 1-.756-1.295l2.25-1.313ZM5.898 5.81a.75.75 0 0 1-.27 1.025l-1.14.665 1.14.665a.75.75 0 1 1-.756 1.295L3.75 8.806v.944a.75.75 0 0 1-1.5 0V7.5a.75.75 0 0 1 .372-.648l2.25-1.312a.75.75 0 0 1 1.026.27Zm12.204 0a.75.75 0 0 1 1.026-.27l2.25 1.312a.75.75 0 0 1 .372.648v2.25a.75.75 0 0 1-1.5 0v-.944l-1.122.654a.75.75 0 1 1-.756-1.295l1.14-.665-1.14-.665a.75.75 0 0 1-.27-1.025Zm-9 5.25a.75.75 0 0 1 1.026-.27L12 11.882l1.872-1.092a.75.75 0 1 1 .756 1.295l-1.878 1.096V15a.75.75 0 0 1-1.5 0v-1.82l-1.878-1.095a.75.75 0 0 1-.27-1.025ZM3 13.5a.75.75 0 0 1 .75.75v1.82l1.878 1.095a.75.75 0 1 1-.756 1.295l-2.25-1.312a.75.75 0 0 1-.372-.648v-2.25A.75.75 0 0 1 3 13.5Zm18 0a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-.372.648l-2.25 1.312a.75.75 0 1 1-.756-1.295l1.878-1.096V14.25a.75.75 0 0 1 .75-.75Zm-9 5.25a.75.75 0 0 1 .75.75v.944l1.122-.654a.75.75 0 1 1 .756 1.295l-2.25 1.313a.75.75 0 0 1-.756 0l-2.25-1.313a.75.75 0 1 1 .756-1.295l1.122.654V19.5a.75.75 0 0 1 .75-.75Z"
            clip-rule="evenodd" />
        </svg>
        <h3 class="mt-4 text-md font-medium text-white"><%= req.translations.noInstances %></h3>
        <p class="mt-1 text-sm text-neutral-400"><%= req.translations.noInstancesText %></p>
      </div>
    <% } else { %>
      <!-- Responsive Grid Container -->
      <div class="instances-container grid grid-cols-1 xl:grid-cols-2 2xl:grid-cols-3 gap-4 md:gap-6">
        <% instances.forEach(function (instance) { %>
          <!-- Instance Card -->
          <div 
            onclick="window.location.href = '../instance/<%= instance.Id %>';"
            class="instance-card group cursor-pointer bg-white/5 rounded-2xl p-5 border border-white/10 hover:bg-white/[0.08] transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-black/20 relative overflow-hidden"
            data-instance-id="<%= instance.Id %>"
            data-disk-limit="<%= instance.Disk || 0 %>"
          >
            <!-- Suspended Overlay -->
            <% if (instance.suspended === true) { %>
              <div class="absolute inset-0 bg-red-500/5 z-0 pointer-events-none"></div>
              <div class="absolute top-3 right-3 z-10">
                <span class="inline-flex items-center bg-red-500/20 text-red-400 px-2 py-1 rounded-full text-xs font-bold border border-red-500/30">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 mr-1">
                    <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm-1.72 6.97a.75.75 0 10-1.06 1.06L10.94 12l-1.72 1.72a.75.75 0 101.06 1.06L12 13.06l1.72 1.72a.75.75 0 101.06-1.06L13.06 12l1.72-1.72a.75.75 0 10-1.06-1.06L12 10.94l-1.72-1.72z" clip-rule="evenodd" />
                  </svg>
                  SUSPENDED
                </span>
              </div>
            <% } %>

            <!-- Card Header -->
            <div class="flex items-start justify-between mb-4 relative z-10">
              <div class="flex items-center gap-3">
                <div class="rounded-xl bg-white/10 p-3 group-hover:bg-white/20 transition-all duration-300 group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-white">
                    <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white text-base group-hover:text-blue-400 transition-colors"><%= instance.Name %></h3>
                  <span class="text-xs text-neutral-400 flex items-center gap-1 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
                      <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd" />
                    </svg>
                    <%= instance.Id %>
                  </span>
                </div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-neutral-500 group-hover:text-white transition-all duration-300 group-hover:translate-x-1">
                <path fill-rule="evenodd" d="M16.28 11.47a.75.75 0 0 1 0 1.06l-7.5 7.5a.75.75 0 0 1-1.06-1.06L14.69 12 7.72 5.03a.75.75 0 0 1 1.06-1.06l7.5 7.5Z" clip-rule="evenodd" />
              </svg>
            </div>

            <!-- Status Badge -->
            <div class="mb-4 relative z-10">
              <span data-status-bg class="inline-flex items-center bg-neutral-600/20 text-neutral-400 px-3 py-1.5 rounded-full text-xs font-medium border border-white/5">
                <span data-status class="flex items-center gap-1.5">
                  <% if (instance.InternalState) { %>
                    <%= instance.InternalState %>
                  <% } else { %>
                    <svg class="animate-spin h-3 w-3 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <%= req.translations.loading %>
                  <% } %>
                </span>
              </span>
            </div>

            <!-- Info Grid - Node, Docker, Volume -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4 relative z-10">
              <!-- Node -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:bg-white/10 transition-colors">
                <div class="flex items-center gap-1.5 mb-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-blue-400">
                    <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 011.272.71l-1.992 7.302h7.268a.75.75 0 01-.548-1.262l-10.5-11.25a.75.75 0 01.852-.359z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">Node</span>
                </div>
                <span class="text-xs text-white font-medium truncate block"><%= instance.Node ? instance.Node.name : 'N/A' %></span>
              </div>

              <!-- Docker ID -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:bg-white/10 transition-colors">
                <div class="flex items-center gap-1.5 mb-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-emerald-400">
                    <path fill-rule="evenodd" d="M2.25 6a3 3 0 013-3h13.5a3 3 0 013 3v12a3 3 0 01-3 3H5.25a3 3 0 01-3-3V6zm3.97.97a.75.75 0 011.06 0l2.25 2.25a.75.75 0 010 1.06l-2.25 2.25a.75.75 0 11-1.06-1.06l1.72-1.72-1.72-1.72a.75.75 0 010-1.06zm4.28 4.28a.75.75 0 000 1.5h3a.75.75 0 000-1.5h-3z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">Docker</span>
                </div>
                <span class="text-xs text-white font-mono truncate block"><%= instance.ContainerId ? instance.ContainerId.substring(0, 12) : 'N/A' %></span>
              </div>

              <!-- Volume -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:bg-white/10 transition-colors">
                <div class="flex items-center gap-1.5 mb-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-amber-400">
                    <path fill-rule="evenodd" d="M19.5 21a3 3 0 003-3V9a3 3 0 00-3-3h-5.379a.75.75 0 01-.53-.22L11.47 3.66A2.25 2.25 0 009.879 3H4.5a3 3 0 00-3 3v12a3 3 0 003 3h15zm-6.75-10.5a.75.75 0 00-1.5 0v4.19l-1.72-1.72a.75.75 0 00-1.06 1.06l3 3a.75.75 0 001.06 0l3-3a.75.75 0 10-1.06-1.06l-1.72 1.72V10.5z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">Volume</span>
                </div>
                <span class="text-xs text-white font-mono truncate block">/volumes/<%= instance.VolumeId ? instance.VolumeId.substring(0, 8) : 'N/A' %></span>
              </div>
            </div>

            <!-- Stats Grid - RAM, CPU, Disk -->
            <div class="grid grid-cols-3 gap-3 relative z-10">
              <!-- RAM -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:border-white/10 transition-all">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">RAM</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-purple-400">
                    <path d="M16.5 7.5h-9v9h9v-9z" />
                    <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V6zm4.5 1.5a.75.75 0 00-1.5 0v9a.75.75 0 001.5 0v-9zm3.75-1.5a.75.75 0 00-.75.75v9a.75.75 0 001.5 0v-9a.75.75 0 00-.75-.75zm3.75.75a.75.75 0 00-1.5 0v9a.75.75 0 001.5 0v-9z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span data-ram-usage class="text-sm font-bold text-white block mb-2">
                  <svg class="animate-spin h-3 w-3 text-white mr-1 inline-flex" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <%= req.translations.loading %>
                </span>
                <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div data-ram-bar class="h-full bg-gradient-to-r from-purple-500 to-purple-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
                </div>
              </div>
              
              <!-- CPU -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:border-white/10 transition-all">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">CPU</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-cyan-400">
                    <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span data-cpu-usage class="text-sm font-bold text-white block mb-2">
                  <svg class="animate-spin h-3 w-3 text-white mr-1 inline-flex" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <%= req.translations.loading %>
                </span>
                <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div data-cpu-bar class="h-full bg-gradient-to-r from-cyan-500 to-cyan-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
                </div>
              </div>

              <!-- Disk -->
              <div class="bg-white/5 rounded-xl p-3 border border-white/5 hover:border-white/10 transition-all">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-semibold">Disk</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-rose-400">
                    <path fill-rule="evenodd" d="M19.5 21a3 3 0 003-3V9a3 3 0 00-3-3h-5.379a.75.75 0 01-.53-.22L11.47 3.66A2.25 2.25 0 009.879 3H4.5a3 3 0 00-3 3v12a3 3 0 003 3h15zm-6.75-10.5a.75.75 0 00-1.5 0v4.19l-1.72-1.72a.75.75 0 00-1.06 1.06l3 3a.75.75 0 001.06 0l3-3a.75.75 0 10-1.06-1.06l-1.72 1.72V10.5z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span data-disk-usage class="text-sm font-bold text-white block mb-2">
                  <svg class="animate-spin h-3 w-3 text-white mr-1 inline-flex" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <%= req.translations.loading %>
                </span>
                <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div data-disk-bar class="h-full bg-gradient-to-r from-rose-500 to-rose-400 transition-all duration-500 rounded-full" style="width: 0%"></div>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</main>
<%- include('components/footer') %>

<style>
  /* Toggle Switch Styles */
  #instance-toggle:checked ~ .toggle-track {
    background-color: rgba(255, 255, 255, 0.2);
  }
  #instance-toggle:checked ~ .toggle-dot {
    transform: translateX(100%);
  }

  /* Card Animations */
  .instance-card {
    animation: slideIn 0.4s ease-out backwards;
  }
  
  .instance-card:nth-child(1) { animation-delay: 0.05s; }
  .instance-card:nth-child(2) { animation-delay: 0.1s; }
  .instance-card:nth-child(3) { animation-delay: 0.15s; }
  .instance-card:nth-child(4) { animation-delay: 0.2s; }
  .instance-card:nth-child(5) { animation-delay: 0.25s; }
  .instance-card:nth-child(6) { animation-delay: 0.3s; }
  
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Hover glow effect */
  .instance-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
    transition: left 0.5s;
  }
  
  .instance-card:hover::before {
    left: 100%;
  }

  /* Touch-friendly improvements */
  @media (hover: none) and (pointer: coarse) {
    .instance-card:active {
      transform: scale(0.98);
    }
  }

  /* Safe area support for notched phones */
  @supports (padding: max(0px)) {
    .px-4 {
      padding-left: max(1rem, env(safe-area-inset-left));
      padding-right: max(1rem, env(safe-area-inset-right));
    }
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .instance-card {
      margin-bottom: 0.5rem;
    }
  }

  /* Custom scrollbar for webkit */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  
  ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  
  ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleSwitch = document.getElementById('instance-toggle');
    if (toggleSwitch) {
      toggleSwitch.addEventListener('change', function () {
        if (this.checked) {
          window.location.href = '/instances?see=other';
        } else {
          window.location.href = '/instances';
        }
      });
    }

    const instances = document.querySelectorAll('[data-instance-id]');
    instances.forEach(instance => {
      const containerId = instance.dataset.instanceId;
      const diskLimitRawFromServer = parseFloat(instance.dataset.diskLimit) || 0;
      
      // ✅ FIXED: Exact same reliable WebSocket URL construction as the working detail page (instance.ejs)
      const port = window.location.port ? `:${window.location.port}` : '';
      const wsProtocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
      const socket = new WebSocket(`${wsProtocol}://${window.location.hostname}${port}/stats/${containerId}`);

      // Query ALL elements so both views update
      const statusElements = instance.querySelectorAll('[data-status]');
      const statusBgElements = instance.querySelectorAll('[data-status-bg]');
      const ramUsageElements = instance.querySelectorAll('[data-ram-usage]');
      const cpuUsageElements = instance.querySelectorAll('[data-cpu-usage]');
      const diskUsageElements = instance.querySelectorAll('[data-disk-usage]');
      const ramBarElements = instance.querySelectorAll('[data-ram-bar]');
      const cpuBarElements = instance.querySelectorAll('[data-cpu-bar]');
      const diskBarElements = instance.querySelectorAll('[data-disk-bar]');

      function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
      }

      function updateAll(elements, value) {
        elements.forEach(el => el.textContent = value);
      }

      function updateProgress(bars, percent) {
        bars.forEach(bar => {
          bar.style.width = `${Math.max(0, Math.min(100, percent))}%`;
        });
      }

      // === IMMEDIATE FALLBACK FOR STOPPED CONTAINERS ===
      const currentStatusText = statusElements[0] ? statusElements[0].textContent.trim() : '';
      if (currentStatusText === 'STOPPED' || currentStatusText.includes('Offline') || currentStatusText.includes('Stopped')) {
        updateAll(ramUsageElements, `0 B`);
        updateAll(cpuUsageElements, `0%`);
        updateAll(diskUsageElements, `0 B`);
        updateProgress(ramBarElements, 0);
        updateProgress(cpuBarElements, 0);
        updateProgress(diskBarElements, 0);
        console.log('🚀 STOPPED container detected - instantly set 0 values');
      }

      socket.onmessage = event => {
        console.log('✅ Raw WS data received for', containerId, ':', event.data);

        let stats = null;

        if (typeof event.data === 'string') {
          if (event.data.includes('The KS Wings instance appears to be down. Retrying...')) {
            statusBgElements.forEach(bg => bg.classList.add('bg-yellow-600/10'));
            statusElements.forEach(el => { el.className = 'text-orange-500 flex items-center gap-1.5'; el.textContent = 'KS Wings is Offline!'; });
            updateAll(ramUsageElements, `0 B`);
            updateAll(cpuUsageElements, `0%`);
            updateAll(diskUsageElements, `0 B`);
            updateProgress(ramBarElements, 0);
            updateProgress(cpuBarElements, 0);
            updateProgress(diskBarElements, 0);
            socket.close();
            return;
          }
          if (event.data.includes('Container not found')) {
            statusBgElements.forEach(bg => bg.classList.add('bg-yellow-600/10'));
            statusElements.forEach(el => { el.className = 'text-orange-500 flex items-center gap-1.5'; el.textContent = 'Container not found!'; });
            updateAll(ramUsageElements, `0 B`);
            updateAll(cpuUsageElements, `0%`);
            updateAll(diskUsageElements, `0 B`);
            updateProgress(ramBarElements, 0);
            updateProgress(cpuBarElements, 0);
            updateProgress(diskBarElements, 0);
            socket.close();
            return;
          }
        }

        try {
          if (event.data && event.data.trim()) stats = JSON.parse(event.data);
        } catch (e) {
          console.error('JSON parse failed for', containerId);
          return;
        }

        let realStats = stats;
        if (stats && stats.event === 'stats' && Array.isArray(stats.args) && stats.args.length > 0) {
          realStats = stats.args[0];
          console.log('✅ Unwrapped real stats for', containerId);
        }

        if (!realStats || realStats.error) {
          console.warn('Error or no stats for', containerId, realStats);
          updateAll(ramUsageElements, `0 B`);
          updateAll(cpuUsageElements, `0%`);
          updateAll(diskUsageElements, `0 B`);
          updateProgress(ramBarElements, 0);
          updateProgress(cpuBarElements, 0);
          updateProgress(diskBarElements, 0);
          return;
        }

        // RAM (matches detail page logic - percent + bytes in list view)
        const ramUsageRaw = realStats.memory_stats?.usage || 0;
        const ramLimitRaw = realStats.memory_stats?.limit || 0;
        const ramPercent = ramLimitRaw > 0 ? ((ramUsageRaw / ramLimitRaw) * 100).toFixed(1) : 0;
        updateAll(ramUsageElements, `${ramPercent}%`);
        updateProgress(ramBarElements, ramPercent);

        // CPU (exact same as working detail page)
        const cpuDelta = (realStats.cpu_stats?.cpu_usage?.total_usage - realStats.precpu_stats?.cpu_usage?.total_usage) || 0;
        const systemDelta = (realStats.cpu_stats?.system_cpu_usage - realStats.precpu_stats?.system_cpu_usage) || 0;
        const cpuPercent = systemDelta > 0 ? ((cpuDelta / systemDelta) * 100).toFixed(1) : 0;
        updateAll(cpuUsageElements, `${cpuPercent}%`);
        updateProgress(cpuBarElements, cpuPercent);

        // Disk - FIXED: now uses data-disk-limit attribute instead of undefined EJS variable
        const diskUsageRaw = parseFloat(realStats.volumeSize) || 0;
        let diskText = '';
        let diskPercent = 0;

        if (diskLimitRawFromServer === 0) {
          diskText = formatBytes(diskUsageRaw * 1024 * 1024);
          diskPercent = 0;
        } else {
          diskPercent = ((diskUsageRaw / diskLimitRawFromServer) * 100).toFixed(1);
          diskText = `${diskPercent}%`;
        }
        updateAll(diskUsageElements, diskText);
        updateProgress(diskBarElements, diskPercent);

        // Status (matches detail page)
        const isRunning = (realStats.status || '').toLowerCase() === 'running' || ramUsageRaw > 0;
        statusBgElements.forEach(bg => {
          bg.classList.remove('bg-neutral-600/20', 'bg-emerald-600/10', 'bg-red-700/30', 'bg-yellow-600/10');
          bg.classList.add(isRunning ? 'bg-emerald-600/10' : 'bg-red-700/30');
        });
        statusElements.forEach(el => {
          el.className = isRunning ? 'text-emerald-500 flex items-center gap-1.5' : 'text-red-500 flex items-center gap-1.5';
          el.innerHTML = isRunning ? 
            '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>Online' : 
            '<span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>Offline';
        });
      };

      socket.onerror = () => console.error(`❌ WS error for ${containerId}`);
      socket.onclose = () => console.warn(`⚠️ WS closed for ${containerId}`);
    });
  });
</script>
