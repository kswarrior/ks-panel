<%- include('../components/template') %>
<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.js"
    integrity="sha512-2PRgAav8Os8vLcOAh1gSaDoNLe1fAyq8/G3QSdyjFFD+OqNjLeHE/8q4+S4MEZgPsuo+itHopj+hJvqS8XUQ8A=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/xterm.min.css"
    integrity="sha512-iLYuqv+v/P4u9erpk+KM83Ioe/l7SEmr7wB6g+Kg1qmEit8EShDKnKtLHlv2QXUp7GGJhmqDI+1PhJYLTsfb8w=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/attach/attach.min.js"
    integrity="sha512-43J76SR5UijcuJTzs73z8NpkyWon8a8EoV+dX6obqXW7O26Yb268H2vP6EiJjD7sWXqxS3G/YOqPyyLF9fmqgA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xterm/3.14.5/addons/fit/fit.min.js"
    integrity="sha512-+wh8VA1djpW3Dj9/IJDu6Ufi4vVQ0zxLv9Vmfo70AbmYFJm0z3NLnV98vdRKBdPDV4Kwpi7EZdr8mDY9L8JIA=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    /* ============================================
       ROOT VARIABLES - ADVANCED DESIGN SYSTEM
       ============================================ */
    :root {
        /* Glassmorphism Core */
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-bg-hover: rgba(255, 255, 255, 0.08);
        --glass-border: rgba(255, 255, 255, 0.08);
        --glass-border-hover: rgba(255, 255, 255, 0.15);
        --glass-blur: blur(20px) saturate(180%);
        --glass-blur-heavy: blur(40px) saturate(200%);
        
        /* Premium Gradients */
        --gradient-primary: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(168, 85, 247, 0.15) 100%);
        --gradient-success: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(5, 150, 105, 0.2) 100%);
        --gradient-danger: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%);
        --gradient-warning: linear-gradient(135deg, rgba(245, 158, 11, 0.2) 0%, rgba(217, 119, 6, 0.2) 100%);
        --gradient-info: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
        
        /* Glow Effects */
        --glow-primary: 0 0 40px rgba(99, 102, 241, 0.3);
        --glow-success: 0 0 40px rgba(16, 185, 129, 0.3);
        --glow-danger: 0 0 40px rgba(239, 68, 68, 0.3);
        --glow-warning: 0 0 40px rgba(245, 158, 11, 0.3);
        
        /* Shadows */
        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
        --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.3);
        --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.4);
        --shadow-elevated: 0 24px 64px rgba(0, 0, 0, 0.5);
        --shadow-inner: inset 0 2px 4px rgba(0, 0, 0, 0.3);
        
        /* Transitions - Optimized for Performance */
        --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-base: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-smooth: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --transition-bounce: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        
        /* Radii */
        --radius-xs: 6px;
        --radius-sm: 10px;
        --radius-md: 14px;
        --radius-lg: 20px;
        --radius-xl: 28px;
        --radius-full: 9999px;
        
        /* Spacing Scale */
        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.25rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-10: 2.5rem;
        --space-12: 3rem;
        
        /* Typography */
        --font-mono: 'JetBrains Mono', 'Fira Code', 'Menlo', 'Monaco', 'Courier New', monospace;
        --font-sans: 'Inter', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        
        /* Colors */
        --color-text-primary: rgba(255, 255, 255, 0.95);
        --color-text-secondary: rgba(255, 255, 255, 0.6);
        --color-text-muted: rgba(255, 255, 255, 0.4);
        --color-accent-primary: #818cf8;
        --color-accent-success: #34d399;
        --color-accent-danger: #f87171;
        --color-accent-warning: #fbbf24;
    }

    /* ============================================
       BASE RESET & OPTIMIZATIONS
       ============================================ */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
    
    /* GPU Acceleration for Smooth Animations */
    .gpu-accelerated {
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
        will-change: transform;
    }

    /* ============================================
       DYNAMIC BACKGROUND MESH
       ============================================ */
    .bg-mesh {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        background: radial-gradient(ellipse at top, #1e1b4b 0%, #0f0f1e 50%, #0a0a0f 100%);
    }
    
    .bg-mesh::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: 
            radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 40% 40%, rgba(99, 102, 241, 0.2) 0%, transparent 40%);
        animation: meshMove 20s ease-in-out infinite;
        pointer-events: none;
    }
    
    @keyframes meshMove {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(30px, -30px) rotate(120deg); }
        66% { transform: translate(-20px, 20px) rotate(240deg); }
    }

    /* ============================================
       XTERM TERMINAL - ENHANCED STYLING
       ============================================ */
    .terminal-container {
        position: relative;
        background: rgba(10, 10, 15, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-lg), 0 0 0 1px rgba(255, 255, 255, 0.02);
        transition: var(--transition-base);
    }
    
    .terminal-container:hover {
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: var(--shadow-lg), var(--glow-primary);
    }
    
    .terminal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3) var(--space-4);
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .terminal-title {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }
    
    .terminal-dots {
        display: flex;
        gap: 6px;
    }
    
    .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: var(--radius-full);
        box-shadow: 0 0 6px currentColor;
    }
    
    .terminal-dot.red { background: #ff5f56; color: #ff5f56; }
    .terminal-dot.yellow { background: #ffbd2e; color: #ffbd2e; }
    .terminal-dot.green { background: #27c93f; color: #27c93f; }
    
    #terminal {
        width: 100%;
        height: clamp(300px, 50vh, 600px);
        padding: var(--space-4);
    }
    
    .xterm {
        padding: 0 !important;
    }
    
    .xterm-viewport {
        overflow-y: auto !important;
        background: transparent !important;
    }
    
    .xterm-viewport::-webkit-scrollbar {
        width: 8px;
    }
    
    .xterm-viewport::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 4px;
    }
    
    .xterm-viewport::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        transition: var(--transition-fast);
    }
    
    .xterm-viewport::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    
    .xterm-rows {
        font-family: var(--font-mono) !important;
        font-size: 13px !important;
        line-height: 1.6 !important;
    }
    
    @media (max-width: 768px) {
        .xterm-rows {
            font-size: 11px !important;
        }
        #terminal {
            height: 350px;
        }
    }

    /* ============================================
       TERMINAL INPUT - COMMAND LINE
       ============================================ */
    .terminal-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(0, 0, 0, 0.6);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding: var(--space-3) var(--space-4);
    }
    
    .terminal-prompt {
        font-family: var(--font-mono);
        color: var(--color-accent-success);
        font-weight: 600;
        margin-right: var(--space-3);
        font-size: 0.875rem;
        white-space: nowrap;
    }
    
    #input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--color-text-primary);
        font-family: var(--font-mono);
        font-size: 0.875rem;
        padding: var(--space-2) 0;
    }
    
    #input::placeholder {
        color: var(--color-text-muted);
    }
    
    .terminal-input-wrapper:focus-within {
        background: rgba(0, 0, 0, 0.8);
    }

    /* ============================================
       HEADER SECTION - PREMIUM DESIGN
       ============================================ */
    .page-header {
        position: relative;
        padding: var(--space-6) var(--space-8);
        margin-bottom: var(--space-6);
    }
    
    .header-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }
    
    @media (min-width: 1024px) {
        .header-content {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }
    
    .header-brand {
        position: relative;
    }
    
    .header-title {
        font-family: var(--font-sans);
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 50%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: var(--space-2);
        position: relative;
        display: inline-block;
    }
    
    .header-title::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, #6366f1, #a855f7);
        border-radius: var(--radius-full);
    }
    
    .header-subtitle {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        max-width: 400px;
        line-height: 1.6;
    }

    /* ============================================
       ACTION BUTTONS - PREMIUM GLASS BUTTONS
       ============================================ */
    .actions-container {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
    }
    
    .action-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        overflow: hidden;
        transition: var(--transition-base);
        transform: translateZ(0);
        will-change: transform;
    }
    
    .action-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 100%);
        opacity: 0;
        transition: var(--transition-fast);
    }
    
    .action-btn:hover::before {
        opacity: 1;
    }
    
    .action-btn::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s ease, height 0.6s ease;
    }
    
    .action-btn:active::after {
        width: 300px;
        height: 300px;
    }
    
    .action-btn:active {
        transform: scale(0.96) translateZ(0);
    }
    
    .action-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }
    
    /* Button Variants with Glassmorphism */
    .btn-start {
        background: var(--gradient-success);
        color: white;
        border: 1px solid rgba(16, 185, 129, 0.3);
        box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3), var(--shadow-sm);
    }
    
    .btn-start:hover {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.3) 0%, rgba(5, 150, 105, 0.3) 100%);
        box-shadow: 0 8px 30px rgba(16, 185, 129, 0.4), var(--glow-success);
        transform: translateY(-2px) translateZ(0);
    }
    
    .btn-restart {
        background: var(--gradient-info);
        color: white;
        border: 1px solid rgba(59, 130, 246, 0.3);
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3), var(--shadow-sm);
    }
    
    .btn-restart:hover {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.3) 0%, rgba(37, 99, 235, 0.3) 100%);
        box-shadow: 0 8px 30px rgba(59, 130, 246, 0.4), var(--glow-primary);
        transform: translateY(-2px) translateZ(0);
    }
    
    .btn-stop {
        background: var(--gradient-danger);
        color: white;
        border: 1px solid rgba(239, 68, 68, 0.3);
        box-shadow: 0 4px 20px rgba(239, 68, 68, 0.3), var(--shadow-sm);
    }
    
    .btn-stop:hover {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.3) 0%, rgba(220, 38, 38, 0.3) 100%);
        box-shadow: 0 8px 30px rgba(239, 68, 68, 0.4), var(--glow-danger);
        transform: translateY(-2px) translateZ(0);
    }
    
    .action-btn svg {
        width: 18px;
        height: 18px;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
    }
    
    @media (max-width: 640px) {
        .actions-container {
            width: 100%;
        }
        .action-btn {
            flex: 1;
            min-width: calc(33.333% - var(--space-3));
            padding: var(--space-3) var(--space-2);
            font-size: 0.75rem;
        }
        .action-btn span.full { display: none; }
        .action-btn span.short { display: inline; }
    }
    
    @media (min-width: 641px) {
        .action-btn span.short { display: none; }
    }

    /* ============================================
       INFO CARDS - BENTO GRID LAYOUT
       ============================================ */
    .info-section {
        padding: 0 var(--space-8);
        margin-bottom: var(--space-8);
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(1, 1fr);
        gap: var(--space-4);
    }
    
    @media (min-width: 640px) {
        .info-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    
    @media (min-width: 1024px) {
        .info-grid {
            grid-template-columns: repeat(4, 1fr);
            gap: var(--space-5);
        }
    }
    
    .info-card {
        position: relative;
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        overflow: hidden;
        transition: var(--transition-smooth);
        transform: translateZ(0);
        will-change: transform;
    }
    
    .info-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--gradient-primary);
        opacity: 0;
        transition: var(--transition-base);
    }
    
    .info-card:hover {
        background: var(--glass-bg-hover);
        border-color: var(--glass-border-hover);
        transform: translateY(-4px) translateZ(0);
        box-shadow: var(--shadow-lg), var(--glow-primary);
    }
    
    .info-card:hover::before {
        opacity: 0.5;
    }
    
    .info-card-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
    }
    
    .info-text {
        flex: 1;
        min-width: 0;
    }
    
    .info-label {
        font-size: 0.625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-text-muted);
        margin-bottom: var(--space-1);
    }
    
    .info-value {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-text-primary);
        letter-spacing: -0.01em;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    
    .info-value.secondary {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        margin-top: 2px;
    }
    
    .info-icon-wrapper {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-md);
        transition: var(--transition-base);
    }
    
    .info-card:hover .info-icon-wrapper {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        transform: scale(1.1) rotate(5deg);
    }
    
    .info-icon {
        width: 22px;
        height: 22px;
        color: var(--color-accent-primary);
        transition: var(--transition-base);
    }
    
    .info-card:hover .info-icon {
        color: white;
    }

    /* ============================================
       MAIN LAYOUT - CONSOLE + STATS
       ============================================ */
    .main-layout {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
        padding: 0 var(--space-8) var(--space-8);
    }
    
    @media (min-width: 1024px) {
        .main-layout {
            flex-direction: row;
            gap: var(--space-8);
        }
        
        .console-section {
            flex: 1.5;
            min-width: 0;
        }
        
        .stats-section {
            width: 340px;
            flex-shrink: 0;
        }
    }
    
    @media (min-width: 1280px) {
        .stats-section {
            width: 380px;
        }
    }

    /* ============================================
       STATS CARDS - DYNAMIC VISUALIZATION
       ============================================ */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
    }
    
    @media (min-width: 640px) and (max-width: 1023px) {
        .stats-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
    
    @media (min-width: 1024px) {
        .stats-grid {
            grid-template-columns: 1fr;
            gap: var(--space-5);
        }
    }
    
    .stats-card {
        position: relative;
        height: 120px;
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: var(--space-4);
        overflow: hidden;
        transition: var(--transition-smooth);
        transform: translateZ(0);
        will-change: transform;
    }
    
    .stats-card::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: var(--transition-base);
    }
    
    .stats-card.online::before {
        background: var(--gradient-success);
        opacity: 0.1;
    }
    
    .stats-card.offline::before {
        background: var(--gradient-danger);
        opacity: 0.1;
    }
    
    .stats-card:hover {
        transform: translateY(-4px) translateZ(0);
        border-color: var(--glass-border-hover);
        box-shadow: var(--shadow-lg);
    }
    
    .stats-card canvas {
        position: absolute;
        inset: 0;
        width: 100% !important;
        height: 100% !important;
        opacity: 0.3;
    }
    
    .stats-content {
        position: relative;
        z-index: 1;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    
    .stats-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    .stats-label {
        font-size: 0.625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-text-muted);
    }
    
    .stats-indicator {
        width: 8px;
        height: 8px;
        border-radius: var(--radius-full);
        box-shadow: 0 0 8px currentColor;
        animation: pulse 2s ease-in-out infinite;
    }
    
    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(0.9); }
    }
    
    .stats-value {
        font-family: var(--font-mono);
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--color-text-primary);
    }
    
    .stats-value.small {
        font-size: 1rem;
    }
    
    .stats-value.online {
        color: var(--color-accent-success);
        text-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
    }
    
    .stats-value.offline {
        color: var(--color-accent-danger);
        text-shadow: 0 0 20px rgba(239, 68, 68, 0.4);
    }
    
    .stats-subvalue {
        font-size: 0.75rem;
        color: var(--color-text-secondary);
        font-family: var(--font-mono);
    }

    /* ============================================
       DAEMON ALERT - ENHANCED NOTIFICATION
       ============================================ */
    .daemon-alert {
        position: relative;
        margin: 0 var(--space-8) var(--space-6);
        background: var(--gradient-danger);
        backdrop-filter: var(--glass-blur);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        overflow: hidden;
        animation: slideIn 0.5s var(--transition-bounce);
    }
    
    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .daemon-alert::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05' fill-rule='evenodd'/%3E%3C/svg%3E");
        opacity: 0.3;
    }
    
    .daemon-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
    }
    
    .daemon-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-md);
        animation: spin 3s linear infinite;
    }
    
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    .daemon-text h3 {
        font-size: 0.875rem;
        font-weight: 700;
        color: #fecaca;
        margin-bottom: var(--space-1);
    }
    
    .daemon-text p {
        font-size: 0.8125rem;
        color: rgba(254, 202, 202, 0.8);
        line-height: 1.5;
    }

    /* ============================================
       EULA MODAL - PREMIUM DIALOG
       ============================================ */
    .modal-overlay {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: var(--glass-blur-heavy);
        z-index: 100;
        padding: var(--space-4);
        animation: fadeIn 0.3s ease;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    .eula-modal {
        width: 100%;
        max-width: 480px;
        max-height: 90vh;
        overflow-y: auto;
        background: linear-gradient(135deg, rgba(30, 30, 45, 0.95) 0%, rgba(20, 20, 35, 0.95) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-xl);
        padding: var(--space-8);
        box-shadow: var(--shadow-elevated), 0 0 0 1px rgba(255, 255, 255, 0.05);
        animation: modalSlide 0.4s var(--transition-bounce);
    }
    
    @keyframes modalSlide {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(20px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }
    
    .eula-header {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-bottom: var(--space-5);
    }
    
    .eula-icon {
        width: 48px;
        height: 48px;
        color: #fbbf24;
        filter: drop-shadow(0 0 12px rgba(251, 191, 36, 0.4));
    }
    
    .eula-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
    }
    
    .eula-text {
        font-size: 0.875rem;
        line-height: 1.7;
        color: var(--color-text-secondary);
        margin-bottom: var(--space-6);
    }
    
    .eula-text a {
        color: white;
        font-weight: 600;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        transition: var(--transition-fast);
    }
    
    .eula-text a:hover {
        border-color: white;
    }
    
    .eula-btn {
        width: 100%;
        padding: var(--space-4);
        background: white;
        color: #0f0f1e;
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 700;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: var(--transition-base);
        box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);
    }
    
    .eula-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(255, 255, 255, 0.3);
    }
    
    .eula-btn:active {
        transform: translateY(0);
    }

    /* ============================================
       NOTIFICATION TOAST
       ============================================ */
    #notification {
        position: fixed;
        bottom: var(--space-6);
        right: var(--space-6);
        padding: var(--space-4) var(--space-6);
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        color: white;
        font-size: 0.875rem;
        font-weight: 500;
        box-shadow: var(--shadow-lg);
        z-index: 50;
        transform: translateY(100px);
        opacity: 0;
        transition: var(--transition-smooth);
    }
    
    #notification.show {
        transform: translateY(0);
        opacity: 1;
    }
    
    @media (max-width: 640px) {
        #notification {
            left: var(--space-4);
            right: var(--space-4);
            bottom: var(--space-4);
        }
    }

    /* ============================================
       LOADING STATES & SKELETONS
       ============================================ */
    .skeleton {
        background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: var(--radius-sm);
    }
    
    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* ============================================
       ACCESSIBILITY & REDUCED MOTION
       ============================================ */
    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }
    
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    /* ============================================
       SCROLLBAR STYLING
       ============================================ */
    ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }
    
    ::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 5px;
        border: 2px solid transparent;
        background-clip: padding-box;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }
    
    ::-webkit-scrollbar-corner {
        background: transparent;
    }
</style>

