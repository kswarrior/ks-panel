<%- include('../components/template') %>
<main id="content" class="min-h-screen p-4 md:p-8">
   <div class="max-w-7xl mx-auto">
      <header class="flex flex-col md:flex-row md:items-center justify-between mb-12 gap-6">
         <div>
            <h1 class="text-5xl font-black text-white tracking-tighter">Billing Center</h1>
            <p class="text-white/40 mt-2 font-medium text-lg">Manage your digital wallet, resources, and hosting stability.</p>
         </div>
         <div class="flex items-center gap-4">
            <div class="backdrop-blur-2xl bg-white/5 border border-white/10 rounded-[2rem] px-8 py-4 shadow-2xl flex items-center gap-4">
               <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-600/40">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
               </div>
               <div>
                  <p class="text-[10px] font-black text-white/40 uppercase tracking-[0.2em]">Your Balance</p>
                  <p class="text-2xl font-black text-white"><%= balance %> <span class="text-sm text-blue-400">CR</span></p>
               </div>
            </div>
         </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
         <!-- Left Column: Quick Actions & Specs -->
         <div class="lg:col-span-4 space-y-6">
            <!-- Daily Reward Card -->
            <button onclick="claimDaily()" class="w-full relative group overflow-hidden rounded-[2.5rem] p-8 bg-gradient-to-br from-green-600 to-emerald-800 text-white shadow-2xl transition-all hover:scale-[1.02] active:scale-[0.98]">
               <div class="relative z-10 flex flex-col items-start text-left">
                  <span class="bg-white/20 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4">Daily Bonus</span>
                  <h3 class="text-2xl font-black mb-1">Claim Reward</h3>
                  <p class="text-white/70 text-sm font-medium">Get your free <%= settings.dailyReward %> credits now!</p>
                  <div class="mt-6 flex items-center gap-2 text-[10px] font-black uppercase">
                     <span>Tap to Collect</span>
                     <svg class="w-3 h-3 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                  </div>
               </div>
               <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-white/20 transition-all duration-500"></div>
               <svg class="absolute bottom-4 right-6 w-20 h-20 text-white/10" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 100-16 8 8 0 000 16zm-3.5-6h7a.5.5 0 010 1h-7a.5.5 0 010-1zm0-3h7a.5.5 0 010 1h-7a.5.5 0 010-1z"></path></svg>
            </button>

            <!-- Quota & Info -->
            <div class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-[2.5rem] p-8 shadow-2xl">
               <h3 class="text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mb-6">Service Quotas</h3>
               <div class="space-y-6">
                  <div class="flex items-center justify-between">
                     <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-blue-400 border border-white/5">
                           <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="text-sm font-bold text-white/60">Renewal Rate</span>
                     </div>
                     <span class="text-sm font-black text-white"><%= settings.renewalCost %> CR / <%= settings.renewalInterval %>d</span>
                  </div>
                  <div class="flex items-center justify-between">
                     <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-purple-400 border border-white/5">
                           <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                        </div>
                        <span class="text-sm font-bold text-white/60">Max Instances</span>
                     </div>
                     <span class="text-sm font-black text-white"><%= settings.defaultSlots %> Slots</span>
                  </div>
               </div>

               <div class="mt-8 pt-8 border-t border-white/5">
                  <p class="text-[10px] font-black text-white/20 uppercase tracking-widest mb-4">Quick Actions</p>
                  <div class="flex flex-col gap-3">
                     <button onclick="document.getElementById('couponBox').classList.toggle('hidden')" class="w-full py-3 rounded-xl bg-white/5 border border-white/5 text-[10px] font-black text-white hover:bg-white/10 transition-all uppercase tracking-widest">Redeem Coupon</button>
                     <div id="couponBox" class="hidden animate-slide-up">
                        <div class="flex gap-2">
                           <input type="text" id="couponCode" placeholder="PROMO-CODE" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-xs text-white focus:outline-none focus:border-blue-500 uppercase font-black">
                           <button onclick="redeemCoupon()" class="bg-blue-600 hover:bg-blue-700 text-white font-black px-6 py-2 rounded-xl text-[10px] transition-all">OK</button>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>

         <!-- Right Column: Store & History -->
         <div class="lg:col-span-8 space-y-8">
            <!-- Package Store -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
               <% if (!settings.enabled) { %>
                  <div class="col-span-full backdrop-blur-xl bg-amber-500/10 border border-amber-500/20 rounded-[3rem] p-12 text-center shadow-2xl">
                     <div class="w-20 h-20 bg-amber-500/20 rounded-[2rem] flex items-center justify-center mx-auto mb-6 text-amber-500 border border-amber-500/20">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                     </div>
                     <h2 class="text-2xl font-black text-white mb-2">Free Hosting Active</h2>
                     <p class="text-neutral-400 font-medium max-w-sm mx-auto">The administrator has disabled the credit system. You have unrestricted access to all resources!</p>
                  </div>
               <% } else { %>
                  <% packages.forEach(pkg => { %>
                     <div class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-[3rem] p-10 hover:bg-white/[0.08] transition-all group relative overflow-hidden shadow-2xl border-b-[4px] border-b-blue-600">
                        <div class="relative z-10">
                           <div class="flex justify-between items-start mb-4">
                              <h3 class="text-2xl font-black text-white tracking-tighter"><%= pkg.name %></h3>
                              <span class="bg-blue-600/20 text-blue-400 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-blue-600/30">Limited Time</span>
                           </div>
                           <p class="text-4xl font-black text-white mb-8"><%= pkg.credits %> <span class="text-xs uppercase text-white/30 tracking-[0.3em] font-bold">Credits</span></p>

                           <div class="space-y-4 mb-10">
                              <div class="flex items-center gap-3 text-xs text-white/60 font-medium">
                                 <div class="w-5 h-5 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-500">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                 </div>
                                 Instant balance update
                              </div>
                              <div class="flex items-center gap-3 text-xs text-white/60 font-medium">
                                 <div class="w-5 h-5 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-500">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                 </div>
                                 Secure transaction
                              </div>
                           </div>

                           <button onclick="buyPackage('<%= pkg.id %>')" class="w-full bg-white text-black font-black py-5 rounded-2xl hover:bg-blue-500 hover:text-white transition-all active:scale-95 shadow-xl shadow-white/5 uppercase tracking-[0.2em] text-xs">
                              Buy for $<%= pkg.price %>
                           </button>
                        </div>
                        <div class="absolute -bottom-20 -right-20 w-48 h-48 bg-blue-600/10 rounded-full blur-3xl group-hover:bg-blue-600/20 transition-all duration-700"></div>
                     </div>
                  <% }) %>
               <% } %>
            </div>

            <!-- Transaction Log (Placeholder for future feature) -->
            <div class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-[3rem] p-10 shadow-2xl">
               <h3 class="text-xl font-black text-white mb-6 tracking-tight">Recent Activity</h3>
               <div class="flex flex-col items-center justify-center py-12 text-center border-2 border-dashed border-white/5 rounded-[2rem]">
                  <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mb-4 text-white/20">
                     <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                  </div>
                  <p class="text-neutral-500 font-bold text-sm">No recent transactions found.</p>
                  <p class="text-[10px] text-neutral-600 uppercase tracking-widest mt-1">Activity logs are kept for 90 days</p>
               </div>
            </div>
         </div>
      </div>
   </div>
</main>

<script>
async function buyPackage(id) {
   if (!confirm('Confirm simulated purchase?')) return;
   const res = await fetch(`/billing/buy/${id}`, { method: 'POST' });
   if (res.ok) {
      alert('Balance updated!');
      location.reload();
   } else {
      alert('Error processing purchase.');
   }
}

async function claimDaily() {
   const res = await fetch('/billing/daily', { method: 'POST' });
   const data = await res.json();
   if (res.ok) {
      alert(`Success! You claimed ${data.amount} credits.`);
      location.reload();
   } else {
      alert(data.error || 'Daily reward unavailable.');
   }
}

async function redeemCoupon() {
   const code = document.getElementById('couponCode').value;
   if (!code) return;
   const res = await fetch('/billing/redeem', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code })
   });
   const data = await res.json();
   if (res.ok) {
      alert(`Validated! ${data.amount} credits added.`);
      location.reload();
   } else {
      alert(data.error || 'Invalid promotional code.');
   }
}
</script>
