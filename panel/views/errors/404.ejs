<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %> - 404</title>
  <link href="/css/ks-panel.css" rel="stylesheet">

<style>
/* ================= BODY ================= */
body {
    font-family: 'Public Sans';
    background:
      linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
      url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://cdn.discordapp.com/attachments/1315671132203913218/1482722679101456599/image0.gif?ex=69b7fc9a&is=69b6ab1a&hm=8b71dec0f5da4a2fe26d74e104ddb078812e39780e8efbbbdf94517f1a2bfc52&" %>');
    background-position: center top;
    background-repeat: no-repeat;
    background-size: cover;
    background-attachment: fixed;

  color: var(--text);
  font-family: var(--font-family);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100dvh;
  user-select: none;
  margin: var(--margin-body);
}

/* ================= CARD ================= */
.card {
  padding: var(--card-padding);
  width: 100%;
  max-width: 500px;
  backdrop-filter: blur(var(--backdrop-blur));
  background: rgba(0, 0, 0, 0.4);
  border-radius: var(--card-radius);
  display: flex;
  flex-direction: column;
  gap: var(--gap);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
  text-align: center;
}

.card h1 {
  font-size: 90px;
  font-weight: 900;
  margin-bottom: 10px;
}

.card h2 {
  font-size: var(--h2-size);
  font-weight: 800;
}

.card p {
  color: var(--muted);
  font-size: var(--p-size);
  margin-top: 8px;
}

/* ================= BUTTON ================= */
.btn {
  margin-top: 20px;
  padding: var(--btn-padding);
  border-radius: var(--btn-radius);
  border: none;
  background: var(--accent);
  color: #000;
  width: 100%;
  font-weight: var(--btn-font-weight);
  cursor: pointer;
  transition: all var(--transition);
  box-shadow: var(--btn-shadow);
}

.btn:hover {
  transform: scale(1.03);
}

/* ================= RESPONSIVE ================= */
@media (max-width: 480px) {
  .card {
    padding: var(--card-padding-mobile);
  }

  .card h1 {
    font-size: 70px;
  }
}
</style>
</head>

<body>

<div class="card">
  <div>
    <h1>404</h1>
    <h2>Page Not Found</h2>
    <p>Sorry, the page you are looking for doesn’t exist or has been moved.</p>
  </div>

  <div>
    <button class="btn" onclick="window.location.href='/'">
      Back to <%= name %>
    </button>
  </div>
</div>

</body>
</html>
