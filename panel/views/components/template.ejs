<!doctype html>
<html>
   <!--
     
   HEAD SECTION
     
   -->
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
<style>
         /* Base Styles */
         .panel-body {
            font-family: 'Public Sans', sans-serif;
            background-color: #000000;
            background-image: url('/assets/background.webp');
            background-position: center top;
            background-repeat: repeat-y;
            background-size: 100% auto;
            color: white;
            margin: 0;
            padding: 0;
         }

         /* Sidebar Styles */
         .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            z-index: 50;
            display: none;
         }

         .sidebar-content {
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
         }

         .sidebar-nav {
            display: flex;
            flex: 1;
            flex-direction: column;
         }

         .user-info {
            display: flex;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.12);
            border-radius: 0.75rem;
            margin-bottom: 1.5rem;
         }

         .user-avatar {
            width: 2rem;
            height: 2rem;
            border-radius: 9999px;
            flex-shrink: 0;
         }

         .user-details {
            min-width: 0;
            flex: 1;
            margin-left: 0.75rem;
         }

         .username {
            font-size: 0.875rem;
            font-weight: 500;
            color: white;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
         }

         .user-id {
            font-size: 0.75rem;
            color: rgba(209,213,219,1);
         }

         .nav-list {
            display: flex;
            flex: 1;
            flex-direction: column;
            gap: 0.5rem;
            margin-top: 1rem;
            position: relative;
            padding: 0;
            list-style: none;
         }

         .active-background {
            position: absolute;
            left: 0;
            width: 100%;
            height: 2.5rem;
            background: rgba(255,255,255,0.2);
            border-radius: 0.75rem;
            transition: all 0.3s ease-in-out;
            opacity: 0;
            transform: scale(0.95);
            z-index: 10;
         }

         .nav-group {
            margin-left: -0.5rem;
            margin-right: -0.5rem;
         }

         .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            margin-left: 0.5rem;
            margin-right: 0.5rem;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            font-weight: normal;
            color: rgba(209,213,219,1);
            text-decoration: none;
            position: relative;
            z-index: 10;
            transition: all 0.3s ease-in-out;
         }

         .nav-link:hover {
            color: white;
            background: rgba(255,255,255,0.1);
         }

         .nav-link.active {
            color: white;
            font-weight: 500;
         }

         .nav-icon {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
            transition: transform 0.2s;
            margin-right: 0.75rem;
         }

         .nav-link:hover .nav-icon {
            transform: scale(1.1);
         }

         .nav-text {
            flex: 1;
            min-width: 0;
         }

         .admin-section {
            margin-top: 1rem;
         }

         .section-title {
            padding: 0.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: rgba(209,213,219,1);
         }

         .logout-section {
            border-top: 1px solid rgba(255,255,255,0.12);
            margin-top: auto;
         }

         .logout-link {
            display: flex;
            align-items: center;
            margin: -0.5rem;
            border-radius: 0.75rem;
            padding: 0.75rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: rgba(209,213,219,1);
            text-decoration: none;
            transition: all 0.3s ease-in-out;
            position: relative;
            z-index: 10;
         }

         .logout-link:hover {
            color: white;
            background: rgba(255,255,255,0.1);
         }

         /* Content Wrapper */
         .content-wrapper {
            min-height: 100vh;
            transition: all 0.3s ease-in-out;
            margin-left: 0;
         }

         /* Topbar Styles */
         .topbar {
            position: sticky;
            top: 0;
            z-index: 40;
            display: flex;
            height: 4rem;
            flex-shrink: 0;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            background: rgba(0,0,0,0.4);
            border-bottom: 1px solid rgba(255,255,255,0.12);
            padding: 0 1rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
         }

         .mobile-toggle-wrapper {
            display: flex;
            align-items: center;
         }

         .mobile-toggle-button {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            border: 1px solid rgba(255,255,255,0.12);
            background: #1c3b54;
            color: white;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
         }

         .toggle-icon {
            width: 1.25rem;
            height: 1.25rem;
            transition: transform 0.2s;
         }

         .mobile-toggle-button:hover .toggle-icon {
            transform: scale(1.1);
         }

         .logo {
            height: 1.5rem;
            width: 1.5rem;
            object-fit: contain;
            border-radius: 0.25rem;
         }

         .panel-title {
            color: white;
            font-weight: 500;
            font-size: 1rem;
            margin-left: 0.25rem;
         }

         .desktop-header {
            display: flex;
            flex: 1;
            align-items: center;
            gap: 1rem;
         }

         .search-results {
            position: absolute;
            background: rgba(18,18,28,0.85);
            width: 20rem;
            border-radius: 0.75rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            display: none;
            margin-top: 4rem;
            padding: 0.75rem;
            left: 0;
            z-index: 50;
            border: 1px solid rgba(255,255,255,0.12);
            color: white;
         }

         .status-wrapper {
            display: flex;
            align-items: center;
            gap: 0.75rem;
         }

         .status-icon {
            cursor: pointer;
            transition: all 0.2s;
            transform: scale(1);
            color: rgba(209,213,219,1);
         }

         .status-icon:hover {
            transform: scale(1.1);
            color: white;
         }

         .dropdown {
            position: absolute;
            right: 0;
            margin-top: 0.5rem;
            border-radius: 0.75rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            z-index: 50;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(18,18,28,0.85);
            color: white;
            transform: scale(0.95);
            opacity: 0;
            transition: all 0.2s ease-out;
         }

         .dropdown.hidden {
            display: none;
         }

         .dropdown.dropdown-visible {
            display: block;
            transform: scale(1);
            opacity: 1;
         }

         .dropdown-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: white;
            margin-bottom: 1rem;
         }

         .action-button {
            width: 100%;
            background: white;
            color: black;
            padding: 0.5rem;
            border-radius: 0.5rem;
            font-weight: bold;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
            transition: all 0.2s;
            border: none;
            cursor: pointer;
         }

         .action-button:hover {
            transform: scale(1.05);
         }

         .ping-display {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: white;
            cursor: default;
         }

         .ping-icon {
            transition: all 0.3s;
         }

         .ping-value {
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 0.125rem;
         }

         .resource-fill {
            transition: all 0.3s;
         }

         .resource-monitor:hover {
            transform: scale(1.1);
         }

         .resource-section {
            margin-bottom: 1rem;
         }

         .resource-label {
            color: white;
            font-weight: 500;
            margin-bottom: 0.5rem;
         }

         .resource-info {
            color: rgba(209,213,219,1);
            font-size: 0.875rem;
            margin-bottom: 0.5rem;
         }

         .progress-bar-wrapper {
            width: 100%;
            background: rgba(255,255,255,0.12);
            height: 0.5rem;
            border-radius: 9999px;
            overflow: hidden;
         }

         .progress-bar {
            height: 100%;
            background: white;
            border-radius: 9999px;
            transition: all 0.3s;
            width: 0%;
         }

         .user-dropdown {
            position: relative;
         }

         .user-button {
            margin: -0.375rem;
            display: flex;
            align-items: center;
            padding: 0.375rem;
            border: none;
            background: none;
            cursor: pointer;
         }

         .user-icon {
            transition: transform 0.2s;
            transform: scale(1);
            color: white;
         }

         .user-button:hover .user-icon {
            transform: scale(1.1);
         }

         .user-info-text {
            display: flex;
            align-items: center;
            margin-left: 0.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: white;
         }

         .user-id-text {
            font-family: monospace;
            font-size: 0.75rem;
            color: rgba(209,213,219,1);
            font-weight: normal;
            margin-left: 0.25rem;
         }

         .dropdown-content {
            padding: 1rem;
         }

         .language-section {
            padding: 0.5rem;
         }

         .label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            color: white;
            margin-bottom: 0.5rem;
         }

         .select-wrapper {
            position: relative;
         }

         .select {
            width: 100%;
            background: #1c3b54;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 0.5rem;
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
            color: white;
            outline: none;
            transition: all 0.2s;
            appearance: none;
         }

         .select:focus {
            border-color: white;
         }

         /* Mobile Sidebar Styles */
         @media (max-width: 1023px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 280px;
               background: rgba(0, 0, 0, 0.6);
               overflow-y: auto;
               transform: translateX(-100%);
               opacity: 0;
               transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
               backdrop-filter: blur(12px);
            }

            .sidebar.open {
               display: flex;
               transform: translateX(0);
               opacity: 1;
            }

            .desktop-header,
            .user-info-text {
               display: none;
            }

            .mobile-toggle-wrapper {
               display: flex;
            }

            .content-wrapper {
               margin-left: 0;
            }
         }

         @media (min-width: 1024px) {
            .sidebar {
               display: flex;
               width: 16rem;
               flex-direction: column;
               background: rgba(0,0,0,0.4);
               border-right: 1px solid rgba(255,255,255,0.12);
               border-top-right-radius: 0.75rem;
               padding: 1rem;
               overflow-y: auto;
            }

            .mobile-toggle-wrapper {
               display: none;
            }

            .desktop-header {
               display: flex;
            }

            .user-info-text {
               display: flex;
            }

            .content-wrapper {
               margin-left: 16rem;
            }
         }

         /* Animations */
         @keyframes sidebarSlide {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
         }
      </style>
   </head>
   <body class="panel-body">
      <!--
     
      SIDEBAR (Desktop & Mobile Unified)
     
      -->
      <div id="sidebar" class="sidebar">
         <div class="sidebar-content">
            <nav class="sidebar-nav">
               <!--
               
      USER INFO SECTION
               
               -->
               <div class="user-info">
                  <img class="user-avatar" src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
                  <div class="user-details">
                     <p class="username"><%= user.username %></p>
                     <p class="user-id"><%= user.userId.substring(0, 6) %></p>
                  </div>
               </div>
               <ul role="list" class="nav-list">
                  <div id="active-background" class="active-background"></div>
                  <li class="nav-group">
                     <a href="/instances" class="nav-link" searchdata="container instances servers" subterm="jegli:/server/servername">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="nav-icon"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
                        <span class="nav-text"><%= req.translations.instances %></span>
                     </a>
                     <a href="/account" searchdata="account profile <%= user.username %>" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="nav-icon">
                          <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                        </svg>                                                           
                        <span class="nav-text"><%= req.translations.account %></span>
                     </a>
                     <% plugins.forEach(plugin => { %>
                        <% if (plugin.sidebar) { %>
                            <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                                <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="nav-link">
                                    <% if (value.icon) { %>
                                        <span class="svg-icon nav-icon" data-icon-url="<%= value.icon %>"></span>
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="nav-icon">
                                            <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                        </svg>
                                    <% } %>
                                    <span class="nav-text"><%= key %></span>
                                </a>
                            <% }); %>
                        <% } %>
                    <% }); %>
                    
                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            document.querySelectorAll('.svg-icon').forEach(function(span) {
                                const url = span.getAttribute('data-icon-url');
                        
                                fetch(url)
                                    .then(response => {
                                        if (!response.ok) {
                                            throw new Error('Network response was not ok');
                                        } else if (response.status !== 200) {
                                            throw new Error(`Request failed with status ${response.status}`);
                                        } else if (!response.text().includes('<svg')) {
                                           throw new Error('Response does not contain an SVG');
                                        }
                                        return response.text();
                                    })
                                    .then(svgContent => {
                                        span.innerHTML = svgContent;
                                    })
                                    .catch(error => {
                                        console.error('Error on Loading the SVG:', error);
                                    });
                            });
                        });
                    </script>
                    
                  </li>
                  <% if (user.admin == true) { %>
                  <li class="admin-section">
                     <p class="section-title">Admin Panel</p>
                  </li>
                  <li class="nav-group">
                     <a href="/admin/overview" searchdata="admin overview control" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="nav-icon"><rect width="256" height="256" fill="none"/><path d="M224,120v96a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8V164a4,4,0,0,0-4-4H108a4,4,0,0,0-4,4v52a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V120a16,16,0,0,1,4.69-11.31l80-80a16,16,0,0,1,22.62,0l80,80A16,16,0,0,1,224,120Z"/></svg>
                        <span class="nav-text"><%= req.translations.overview %></span>
                     </a>
                     <a href="/admin/settings" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="nav-icon"><rect width="256" height="256" fill="none"/><path d="M237.94,107.21a8,8,0,0,0-3.89-5.4l-29.83-17-.12-33.62a8,8,0,0,0-2.83-6.08,111.91,111.91,0,0,0-36.72-20.67,8,8,0,0,0-6.46.59L128,41.85,97.88,25a8,8,0,0,0-6.47-.6A111.92,111.92,0,0,0,54.73,45.15a8,8,0,0,0-2.83,6.07l-.15,33.65-29.83,17a8,8,0,0,0-3.89,5.4,106.47,106.47,0,0,0,0,41.56,8,8,0,0,0,3.89,5.4l29.83,17,.12,33.63a8,8,0,0,0,2.83,6.08,111.91,111.91,0,0,0,36.72,20.67,8,8,0,0,0,6.46-.59L128,214.15,158.12,231a7.91,7.91,0,0,0,3.9,1,8.09,8.09,0,0,0,2.57-.42,112.1,112.1,0,0,0,36.68-20.73,8,8,0,0,0,2.83-6.07l.15-33.65,29.83-17a8,8,0,0,0,3.89-5.4A106.47,106.47,0,0,0,237.94,107.21ZM128,168a40,40,0,1,1,40-40A40,40,0,0,1,128,168Z"/></svg>
                        <span class="nav-text"><%= req.translations.settings %></span>
                     </a>
                     <a href="/admin/users" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="nav-icon">
                          <path d="M7 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM14.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM1.615 16.428a1.224 1.224 0 0 1-.569-1.175 6.002 6.002 0 0 1 11.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 0 1 7 18a9.953 9.953 0 0 1-5.385-1.572ZM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 0 0-1.588-3.755 4.502 4.502 0 0 1 5.874 2.636.818.818 0 0 1-.36.98A7.465 7.465 0 0 1 14.5 16Z" />
                        </svg>                               
                        <span class="nav-text"><%= req.translations.users %></span>
                     </a>
                     <a href="/admin/instances" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="nav-icon"><rect width="256" height="256" fill="none"/><path d="M24,80a8,8,0,0,1,4-6.91l96-56a8,8,0,0,1,8.06,0l96,56a8,8,0,0,1,0,13.82l-96,56a8,8,0,0,1-8.06,0l-96-56A8,8,0,0,1,24,80Zm196,41.09-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09ZM232,192H216V176a8,8,0,0,0-16,0v16H184a8,8,0,0,0,0,16h16v16a8,8,0,0,0,16,0V208h16a8,8,0,0,0,0-16Zm-92,23.76-12,7L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l16-9.33A8,8,0,1,0,140,215.76Z"/></svg>
                        <span class="nav-text"><%= req.translations.instances %></span>
                     </a>
                     <a href="/admin/templates/overview" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="nav-icon"><path d="M4 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4zm2 2v3h12V6H6zm0 5v9h4v-9H6zm6 0v4h6v-4h-6zm0 6v3h6v-3h-6z"/></svg>
                        <span class="nav-text"><%= req.translations.templates %></span>
                     </a>
                     <a href="/admin/nodes" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="nav-icon"><rect width="256" height="256" fill="none"/><path d="M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM180,92a12,12,0,1,1,12-12A12,12,0,0,1,180,92Z"/><path d="M208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm-28,52a12,12,0,1,1,12-12A12,12,0,0,1,180,188Z"/></svg>
                        <span class="nav-text"><%= req.translations.nodes %></span>
                     </a>
                     <a href="/admin/locations" class="nav-link">
