   <body 
  style="
    font-family: 'Public Sans';
    background:
      linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
      url('/assets/background.webp');
    background-position: center top;
    background-repeat: repeat-y;
    background-size: 100% auto;" >
      <!-- Enhanced animations + optimized sidebar styles -->
      <style>
         .sidebar nav ul {
            position: relative;
         }
         .nav-link {
            position: relative;
            z-index: 1;
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
         }
         .nav-link:hover {
            transform: translateX(6px);
            color: #e5e7eb;
         }
         .nav-link.active {
            color: white;
            font-weight: 500;
         }
         /* Smooth sidebar collapse & mobile slide */
         @media (max-width: 1024px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 215px;
               backdrop-filter: blur(var(--backdrop-blur));
               background: rgba(0, 0, 0, 0.4);
               overflow-y: auto;
               transform: translateX(-110%);
               opacity: 0;
               transition: 
                  transform 0.45s cubic-bezier(0.32, 0.72, 0, 1),
                  opacity 0.35s ease;
            }
            .sidebar.open {
               display: block;
               transform: translateX(0);
               opacity: 1;
            }
         }
         /* Optimized desktop collapse */
         .sidebar.collapsed {
            width: 68px !important;
         }
         .sidebar.collapsed .lg\\:group-\\[\\.collapsed\\]\\:hidden {
            opacity: 0;
            width: 0;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
         }

         /* Global UI animations */
         @keyframes dropdownPop {
            from {
               opacity: 0;
               transform: scale(0.85) translateY(-12px);
            }
            to {
               opacity: 1;
               transform: scale(1) translateY(0);
            }
         }
         .dropdown {
            animation: dropdownPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
         }

         @keyframes barRise {
            from { height: 8%; }
            to { height: var(--bar-height); }
         }

         /* Ping SVG smooth animation */
         #pingIcon {
            transition: filter 0.3s ease;
         }
         #pingLayer1, #pingLayer2, #pingLayer3, #pingDot {
            transition: stroke 0.4s ease, opacity 0.4s ease, fill 0.4s ease;
         }
         #pingDot {
            animation: pingPulse 1.8s infinite ease-in-out;
         }
         @keyframes pingPulse {
            0%, 100% { transform: scale(1); opacity: 0.65; }
            50% { transform: scale(1.18); opacity: 1; }
         }

         /* Resource history bars */
         .history-bar {
            transition: height 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
         }
      </style>

