      <style>

         /* ================= SIDEBAR CUSTOM CLASSES ================= */
         .sidebar {
            display: flex;
            flex-direction: column;
            height: 100vh;
            width: 224px;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 50;
            padding: var(--gap-small);
            background: var(--card);
            backdrop-filter: blur(var(--backdrop-blur));
            border-right: 1px solid var(--border);
            overflow-y: auto;
            transition: var(--transition);
         }

         .sidebar.collapsed {
            width: 4rem;
         }

         .sidebar nav {
            position: relative;
            display: flex;
            flex: 1;
            flex-direction: column;
         }

         .sidebar nav ul {
            position: relative;
            list-style: none;
            padding: 0;
            margin: var(--gap) 0 0 0;
            display: flex;
            flex-direction: column;
            gap: var(--gap);
         }

         .nav-link {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: var(--gap-small);
            padding: var(--input-padding);
            margin: 0 var(--gap-small);
            border-radius: var(--btn-radius);
            color: var(--text-muted);
            text-decoration: none;
            font-size: var(--small-size);
            font-weight: var(--label-font-weight);
            transition: var(--transition);
            border: 1px solid transparent;
         }

         .nav-link:hover {
            background: var(--btn-hover);
            color: var(--text);
            border-color: var(--border);
         }

         .nav-link.active {
            color: var(--text);
            font-weight: var(--btn-font-weight);
            background: var(--btn-bg);
            border-color: var(--accent-glow);
         }

         .nav-link svg {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
         }

         .nav-link span {
            opacity: 1;
            transition: var(--transition);
         }

         .sidebar.collapsed .nav-link span {
            opacity: 0;
            visibility: hidden;
            width: 0;
            overflow: hidden;
         }

         .active-background {
            position: absolute;
            left: var(--gap-small);
            width: calc(100% - 2 * var(--gap-small));
            height: 2.5rem;
            background: var(--btn-hover);
            border-radius: var(--btn-radius);
            transition: var(--transition);
            z-index: 0;
         }

         .user-info {
            display: flex;
            align-items: center;
            gap: var(--gap-small);
            padding: var(--input-padding);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
         }

         .user-info img {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 50%;
         }

         .user-info .username {
            font-size: var(--small-size);
            font-weight: var(--label-font-weight);
            color: var(--text);
            margin: 0;
         }

         .user-info .user-id {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
         }

         .sidebar.collapsed .user-info .username,
         .sidebar.collapsed .user-info .user-id {
            display: none;
         }

         .admin-header {
            padding: var(--gap) 2rem var(--gap-small) 2rem;
            font-size: var(--small-size);
            font-weight: var(--btn-font-weight);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text);
         }

         .sidebar.collapsed .admin-header {
            display: none;
         }

         .logout-link {
            margin-top: auto;
            padding-top: var(--gap);
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: var(--gap-small);
            padding: var(--btn-padding);
            margin: 0 calc(-1 * var(--gap-small));
            border-radius: var(--btn-radius);
            color: var(--text-muted);
            text-decoration: none;
            font-size: var(--small-size);
            font-weight: var(--label-font-weight);
            transition: var(--transition);
         }

         .logout-link:hover {
            background: var(--btn-hover);
            color: var(--text);
         }

         /* ================= HEADER CUSTOM CLASSES ================= */
         .header {
            position: sticky;
            top: 0;
            z-index: 40;
            display: flex;
            align-items: center;
            height: 4rem;
            padding: 0 var(--section-padding);
            background: var(--card);
            backdrop-filter: blur(var(--backdrop-blur));
            border-bottom: 1px solid var(--border);
            gap: var(--gap);
         }

         .header-content {
            display: flex;
            flex: 1;
            align-items: center;
            gap: var(--gap-large);
         }

         .logo-section {
            display: flex;
            align-items: center;
            gap: var(--gap-small);
            padding: var(--input-padding);
            border-radius: var(--btn-radius);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: var(--transition);
            color: var(--text);
            background: transparent;
         }

         .logo-section:hover {
            transform: scale(1.05);
         }

         .logo-section img {
            height: 1.5rem;
            width: 1.5rem;
            object-fit: contain;
            border-radius: var(--badge-radius);
         }

         .logo-title {
            font-size: var(--h3-size);
            font-weight: var(--btn-font-weight);
            color: var(--text);
         }

         .header-actions {
            display: flex;
            align-items: center;
            gap: var(--gap-small);
         }

         .header-actions svg {
            width: 1.25rem;
            height: 1.25rem;
            color: var(--text-muted);
            cursor: pointer;
            transition: var(--transition);
         }

         .header-actions svg:hover {
            color: var(--text);
         }

         .user-menu {
            position: relative;
            display: flex;
            align-items: center;
            padding: var(--input-padding);
            border-radius: var(--btn-radius);
            border: 1px solid var(--border);
            cursor: pointer;
            background: transparent;
            color: var(--text);
            transition: var(--transition);
         }

         .user-menu:hover {
            border-color: var(--accent-glow);
         }

         .user-menu svg {
            width: 1.75rem;
            height: 1.75rem;
         }

         .user-info-text {
            display: flex;
            align-items: center;
            gap: var(--gap-small);
            margin-left: var(--gap-small);
         }

         .user-info-text .username {
            font-size: var(--small-size);
            font-weight: var(--label-font-weight);
            color: var(--text);
         }

         .user-info-text .user-id {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-family: monospace;
         }

         .dropdown-menu {
            position: absolute;
            right: 0;
            top: 100%;
            z-index: 10;
            margin-top: var(--gap-small);
            width: 14rem;
            background: var(--card);
            border-radius: var(--card-radius);
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            padding-bottom: var(--gap-small);
            opacity: 0;
            transform: scale(0.95);
            transition: var(--transition);
         }

         .dropdown-menu.show {
            opacity: 1;
            transform: scale(1);
         }

         .language-selector {
            padding: var(--card-padding-mobile);
         }

         .language-selector label {
            display: block;
            font-size: var(--small-size);
            font-weight: var(--label-font-weight);
            color: var(--text);
            margin-bottom: var(--gap-small);
         }

         .language-selector select {
            width: 100%;
            padding: var(--input-padding);
            border-radius: var(--input-radius);
            border: 1px solid var(--input-border);
            background: var(--input-bg);
            color: var(--text);
            font-size: var(--small-size);
         }

         /* ================= MOBILE SIDEBAR ================= */
         @media (max-width: 1024px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 225px;
               backdrop-filter: blur(var(--backdrop-blur));
               background: rgba(0, 0, 0, 0.4);
               overflow-y: auto;

               /* Original transform */
               transform: translateX(-100%);

               /* Added smooth animation */
               opacity: 0;
               transition: 
                 transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                 opacity 0.3s ease;
            }

            .sidebar.open {
               display: flex;
               transform: translateX(0);

               /* Added fade in */
               opacity: 1;
               animation: sidebarSlide 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            }

            .sidebar.expanded {
               width: 100%;
            }
         }

         /* Animation */
         @keyframes sidebarSlide {
           from {
             transform: translateX(-110%);
             opacity: 0;
           }
           to {
             transform: translateX(0);
             opacity: 1;
           }
         }

         /* ================= MAIN CONTENT ================= */
         .main-content {
            margin-left: 224px;
            transition: var(--transition);
