<!doctype html>
<html class="h-full w-full">
<head>
   <title><%= name || 'KS Panel' %></title>
   <link rel="icon" href="/assets/logo.webp" type="image/webp">
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
   <meta content="<%= ogTitle %>" property="og:title">
   <meta content="<%= ogDescription %>" property="og:description">
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
   <link href="/css/ks-panel.css" rel="stylesheet">
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
   <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
   
   <style>
      * {
         box-sizing: border-box;
      }
      
      body {
         font-family: 'Public Sans', system-ui, -apple-system, sans-serif;
         margin: 0;
         padding: 0;
         min-height: 100vh;
         background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
                     url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://cdn.discordapp.com/attachments/1315671132203913218/1482722679101456599/image0.gif?ex=69b7fc9a&is=69b6ab1a&hm=8b71dec0f5da4a2fe26d74e104ddb078812e39780e8efbbbdf94517f1a2bfc52&" %>');
         background-position: center top;
         background-repeat: no-repeat;
         background-size: cover;
         background-attachment: fixed;
         -webkit-font-smoothing: antialiased;
         -moz-osx-font-smoothing: grayscale;
      }

      /* Prevent body scroll when sidebar open on mobile */
      body.sidebar-open {
         overflow: hidden;
         position: fixed;
         width: 100%;
         height: 100%;
      }

      /* Reset all form elements to default browser styling */
      input, select, textarea, button {
         font-family: inherit;
         font-size: inherit;
         color: inherit;
         background-color: initial;
         border: initial;
         outline: initial;
         appearance: auto;
         -webkit-appearance: auto;
         -moz-appearance: auto;
      }

      /* Sidebar Base - FIXED FOR MOBILE SCROLL */
      .sidebar {
         position: fixed;
         top: 0;
         left: 0;
         height: 100vh;
         height: 100dvh; /* Dynamic viewport height for mobile */
         width: 15rem;
         z-index: 50;
         overflow-y: auto; /* Enable scrolling */
         overflow-x: hidden;
         overscroll-behavior-y: contain; /* Prevent body scroll chaining [^4^] */
         -webkit-overflow-scrolling: touch; /* Smooth scroll on iOS */
         background: rgba(0, 0, 0, 0.85);
         backdrop-filter: blur(16px);
         -webkit-backdrop-filter: blur(16px);
         border-right: 1px solid rgba(255, 255, 255, 0.1);
         transform: translateX(-100%);
         transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .sidebar.open {
         transform: translateX(0);
      }

      /* Desktop Sidebar */
      @media (min-width: 1024px) {
         .sidebar {
            transform: translateX(0);
            width: 16rem;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(12px);
            transition: width 0.3s ease;
         }
         
         .sidebar.collapsed {
            width: 4.5rem;
         }
         
         .sidebar.collapsed .nav-text,
         .sidebar.collapsed .admin-label,
         .sidebar.collapsed .user-info {
            display: none;
         }
         
         .sidebar.collapsed .user-section {
            justify-content: center;
            padding: 0.75rem;
         }
         
         .sidebar.collapsed .nav-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
            margin-left: 0.5rem;
            margin-right: 0.5rem;
         }
         
         .sidebar.collapsed .logout-btn {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
         }
         
         .sidebar.collapsed .logout-btn .nav-text {
            display: none;
         }
      }

      /* Mobile optimizations */
      @media (max-width: 1023px) {
         .sidebar {
            width: 85vw; /* Better mobile width */
            max-width: 20rem;
         }
         
         .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            z-index: 40;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;
         }
         
         .sidebar-overlay.active {
            opacity: 1;
            visibility: visible;
         }
      }

      /* Navigation */
      .nav-link {
         display: flex;
         align-items: center;
         gap: 0.75rem;
         padding: 0.625rem 1rem;
         margin: 0.25rem 0.75rem;
         border-radius: 0.75rem;
         color: rgba(255, 255, 255, 0.7);
         text-decoration: none;
         font-size: 0.875rem;
         font-weight: 400;
         transition: all 0.2s ease;
         position: relative;
         white-space: nowrap;
         flex-shrink: 0;
      }

      .nav-link:hover {
         color: rgba(255, 255, 255, 0.95);
         background: rgba(255, 255, 255, 0.08);
      }

      .nav-link.active {
         color: white;
         font-weight: 500;
         background: rgba(255, 255, 255, 0.15);
      }

      .nav-icon {
         width: 1.25rem;
         height: 1.25rem;
         flex-shrink: 0;
      }

      /* Main Content */
      .main-container {
         min-height: 100vh;
         transition: padding-left 0.3s ease;
      }

      @media (min-width: 1024px) {
         .main-container {
            padding-left: 16rem;
         }
         
         .main-container.sidebar-collapsed {
            padding-left: 4.5rem;
         }
      }

      @media (max-width: 1023px) {
         .main-container {
            padding-left: 0;
         }
      }

      /* Header */
      .header {
         position: sticky;
         top: 0;
         z-index: 30;
         height: 4rem;
         display: flex;
         align-items: center;
         gap: 1rem;
         padding: 0 1rem;
         background: rgba(0, 0, 0, 0.2);
         backdrop-filter: blur(12px);
         -webkit-backdrop-filter: blur(12px);
         border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      @media (min-width: 640px) {
         .header {
            padding: 0 1.5rem;
            gap: 1.5rem;
         }
      }

      /* Mobile Menu Toggle - FIXED: Only show on mobile */
      .menu-toggle {
         display: flex;
         align-items: center;
         gap: 0.75rem;
         padding: 0.5rem 0.75rem;
         border-radius: 0.75rem;
         border: 1px solid rgba(255, 255, 255, 0.1);
         background: rgba(255, 255, 255, 0.05);
         color: white;
         cursor: pointer;
         transition: all 0.2s ease;
         -webkit-tap-highlight-color: transparent;
      }

      .menu-toggle:hover {
         background: rgba(255, 255, 255, 0.1);
      }

      .menu-toggle:active {
         transform: scale(0.98);
      }

      /* FIXED: Hide mobile toggle on desktop */
      @media (min-width: 1024px) {
         .menu-toggle {
            display: none !important;
         }
      }

      /* FIXED: Hide desktop brand on mobile */
      .desktop-brand {
         display: none;
      }

      @media (min-width: 1024px) {
         .desktop-brand {
            display: flex;
         }
      }

      /* Brand */
      .brand {
         display: flex;
         align-items: center;
         gap: 0.75rem;
      }

      .brand-logo {
         width: 1.5rem;
         height: 1.5rem;
         object-fit: contain;
         border-radius: 0.25rem;
         flex-shrink: 0;
      }

      .brand-name {
         font-size: 1.125rem;
         font-weight: 500;
         color: white;
         letter-spacing: -0.025em;
         white-space: nowrap;
      }

      @media (max-width: 640px) {
         .brand-name {
            font-size: 1rem;
         }
      }

      /* Header Actions */
      .header-actions {
         display: flex;
         align-items: center;
         gap: 0.5rem;
         margin-left: auto;
      }

      @media (min-width: 640px) {
         .header-actions {
            gap: 0.75rem;
         }
      }

      .icon-btn {
         position: relative;
         display: flex;
         align-items: center;
         justify-content: center;
         width: 2.25rem;
         height: 2.25rem;
         border-radius: 0.5rem;
         color: rgba(255, 255, 255, 0.7);
         background: transparent;
         border: none;
         cursor: pointer;
         transition: all 0.2s ease;
         -webkit-tap-highlight-color: transparent;
      }

      .icon-btn:hover {
         color: white;
         background: rgba(255, 255, 255, 0.1);
      }

      .icon-btn svg {
         width: 1.25rem;
         height: 1.25rem;
      }

      /* Dropdowns */
      .dropdown {
         position: absolute;
         right: 0;
         top: calc(100% + 0.5rem);
         min-width: 14rem;
         background: rgba(20, 20, 20, 0.95);
         backdrop-filter: blur(16px);
         -webkit-backdrop-filter: blur(16px);
         border: 1px solid rgba(255, 255, 255, 0.1);
         border-radius: 0.75rem;
         padding: 0.75rem;
         box-shadow: 0 10px 40px rgba(0,0,0,0.4);
         opacity: 0;
         visibility: hidden;
         transform: translateY(-10px);
         transition: all 0.2s ease;
         z-index: 100;
      }

      .dropdown.active {
         opacity: 1;
         visibility: visible;
         transform: translateY(0);
      }

      .dropdown-wide {
         min-width: 16rem;
      }

      /* Resource Monitor Bars */
      .resource-bar-bg {
         width: 100%;
         height: 0.5rem;
         background: rgba(255, 255, 255, 0.1);
         border-radius: 9999px;
         overflow: hidden;
      }

      .resource-bar-fill {
         height: 100%;
         border-radius: 9999px;
         transition: width 0.3s ease, background-color 0.3s ease;
      }

      /* User Section in Sidebar */
      .user-section {
         display: flex;
         align-items: center;
         gap: 0.75rem;
         padding: 1rem;
         margin: 0.5rem;
         border-radius: 0.75rem;
         background: rgba(255, 255, 255, 0.05);
         border: 1px solid rgba(255, 255, 255, 0.05);
         flex-shrink: 0;
      }

      .user-avatar {
         width: 2rem;
         height: 2rem;
         border-radius: 50%;
         flex-shrink: 0;
      }

      .user-info {
         min-width: 0;
      }

      .user-name {
         font-size: 0.875rem;
         font-weight: 500;
         color: white;
         white-space: nowrap;
         overflow: hidden;
         text-overflow: ellipsis;
      }

      .user-id {
         font-size: 0.75rem;
         color: rgba(255, 255, 255, 0.5);
         font-family: monospace;
      }

      /* Admin Label */
      .admin-label {
         font-size: 0.75rem;
         font-weight: 600;
         text-transform: uppercase;
         letter-spacing: 0.05em;
         color: rgba(255, 255, 255, 0.4);
         padding: 1.25rem 1.5rem 0.5rem;
         margin-top: 0.5rem;
         flex-shrink: 0;
      }

      /* Logout Button */
      .logout-btn {
         display: flex;
         align-items: center;
         gap: 0.75rem;
         padding: 0.875rem 1rem;
         margin: 0.5rem 0.75rem;
         border-radius: 0.75rem;
         color: rgba(255, 255, 255, 0.5);
         text-decoration: none;
         font-size: 0.875rem;
         transition: all 0.2s ease;
         margin-top: auto;
         flex-shrink: 0;
      }

      .logout-btn:hover {
         color: rgba(255, 255, 255, 0.9);
         background: rgba(255, 255, 255, 0.05);
      }

      /* Content Area */
      .content {
         padding: 1rem;
         min-height: calc(100vh - 4rem);
      }

      @media (min-width: 640px) {
         .content {
            padding: 1.5rem;
         }
      }

      @media (min-width: 1024px) {
         .content {
            padding: 2rem;
         }
      }

      /* Ping Display */
      .ping-display {
         display: flex;
         flex-direction: column;
         align-items: center;
         gap: 0.125rem;
         font-size: 0.625rem;
         font-weight: 600;
         color: rgba(255, 255, 255, 0.6);
      }

      .ping-icon {
         width: 1.25rem;
         height: 1rem;
      }

      /* Resource Icon */
      .resource-icon {
         width: 1.25rem;
         height: 1.25rem;
      }

      /* Language Selector */
      .lang-select {
         width: 100%;
         padding: 0.5rem;
         border-radius: 0.375rem;
         border: 1px solid rgba(255, 255, 255, 0.2);
         background: rgba(0, 0, 0, 0.5);
         color: white;
         font-size: 0.875rem;
         cursor: pointer;
      }

      .lang-label {
         display: block;
         font-size: 0.875rem;
         font-weight: 500;
         color: rgba(255, 255, 255, 0.9);
         margin-bottom: 0.5rem;
      }

      /* Scrollbar Styling */
      .sidebar::-webkit-scrollbar {
         width: 4px;
      }

      .sidebar::-webkit-scrollbar-track {
         background: transparent;
      }

      .sidebar::-webkit-scrollbar-thumb {
         background: rgba(255, 255, 255, 0.2);
         border-radius: 2px;
      }

      .sidebar::-webkit-scrollbar-thumb:hover {
         background: rgba(255, 255, 255, 0.3);
      }

      /* Focus visible for accessibility */
      .nav-link:focus-visible,
      .icon-btn:focus-visible,
      .menu-toggle:focus-visible,
      .logout-btn:focus-visible {
         outline: 2px solid rgba(255, 255, 255, 0.5);
         outline-offset: 2px;
      }

      /* Safe area for notched phones */
      @supports (padding-top: env(safe-area-inset-top)) {
         .sidebar {
            padding-top: env(safe-area-inset-top);
            height: calc(100dvh - env(safe-area-inset-top));
         }
         
         .header {
            padding-top: max(0.5rem, env(safe-area-inset-top));
            height: calc(4rem + env(safe-area-inset-top));
         }
      }
   </style>
</head>
<body>

   <!-- Mobile Overlay -->
   <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

   <!-- Sidebar -->
   <aside class="sidebar" id="sidebar">
      <nav style="display: flex; flex-direction: column; min-height: 100%;">
         
         <!-- User Info -->
         <div class="user-section">
            <img class="user-avatar" src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
            <div class="user-info">
               <div class="user-name"><%= user.username %></div>
               <div class="user-id"><%= user.userId.substring(0, 6) %></div>
            </div>
         </div>

         <!-- Navigation -->
         <div style="flex: 1; overflow-y: auto; padding: 0.5rem 0; overscroll-behavior-y: contain;">
            <a href="/instances" class="nav-link <%= req.path === '/instances' ? 'active' : '' %>">
               <svg class="nav-icon" viewBox="0 0 256 256" fill="currentColor">
                  <path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/>
                  <path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/>
                  <path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/>
               </svg>
               <span class="nav-text"><%= req.translations.instances %></span>
            </a>

            <a href="/account" class="nav-link <%= req.path === '/account' ? 'active' : '' %>">
               <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z"/>
               </svg>
               <span class="nav-text"><%= req.translations.account %></span>
            </a>

            <% plugins.forEach(plugin => { %>
               <% if (plugin.sidebar) { %>
                  <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                     <a href="<%= value.url %>" class="nav-link <%= req.path === value.url ? 'active' : '' %>">
                        <% if (value.icon) { %>
                           <span class="svg-icon nav-icon" data-icon-url="<%= value.icon %>"></span>
                        <% } else { %>
                           <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                              <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z"/>
                           </svg>
                        <% } %>
                        <span class="nav-text"><%= key %></span>
                     </a>
                  <% }); %>
               <% } %>
            <% }); %>

            <% if (user.admin == true) { %>
               <div class="admin-label">Admin Panel</div>
               
               <a href="/admin/dashboard/overview" class="nav-link <%= req.path.startsWith('/admin/dashboard') ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 256 256" fill="currentColor">
                     <path d="M224,120v96a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8V164a4,4,0,0,0-4-4H108a4,4,0,0,0-4,4v52a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V120a16,16,0,0,1,4.69-11.31l80-80a16,16,0,0,1,22.62,0l80,80A16,16,0,0,1,224,120Z"/>
                  </svg>
                  <span class="nav-text">Dashboard</span>
               </a>

               <a href="/admin/database/overview" class="nav-link <%= req.path.startsWith('/admin/database') ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 256 256" fill="currentColor">
                     <path d="M128,40c-44.18,0-80,14.33-80,32s35.82,32,80,32,80-14.33,80-32S172.18,40,128,40Z"/>
                     <path d="M48,72v48c0,17.67,35.82,32,80,32s80-14.33,80-32V72"/>
                     <path d="M48,120v48c0,17.67,35.82,32,80,32s80-14.33,80-32V120"/>
                     <path d="M48,168v16c0,17.67,35.82,32,80,32s80-14.33,80-32V168"/>
                  </svg>
                  <span class="nav-text">Database</span>
               </a>

               <a href="/admin/settings" class="nav-link <%= req.path === '/admin/settings' ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 256 256" fill="currentColor">
                     <path d="M237.94,107.21a8,8,0,0,0-3.89-5.4l-29.83-17-.12-33.62a8,8,0,0,0-2.83-6.08,111.91,111.91,0,0,0-36.72-20.67,8,8,0,0,0-6.46.59L128,41.85,97.88,25a8,8,0,0,0-6.47-.6A111.92,111.92,0,0,0,54.73,45.15a8,8,0,0,0-2.83,6.07l-.15,33.65-29.83,17a8,8,0,0,0-3.89,5.4,106.47,106.47,0,0,0,0,41.56,8,8,0,0,0,3.89,5.4l29.83,17,.12,33.63a8,8,0,0,0,2.83,6.08,111.91,111.91,0,0,0,36.72,20.67,8,8,0,0,0,6.46-.59L128,214.15,158.12,231a7.91,7.91,0,0,0,3.9,1,8.09,8.09,0,0,0,2.57-.42,112.1,112.1,0,0,0,36.68-20.73,8,8,0,0,0,2.83-6.07l.15-33.65,29.83-17a8,8,0,0,0,3.89-5.4A106.47,106.47,0,0,0,237.94,107.21ZM128,168a40,40,0,1,1,40-40A40,40,0,0,1,128,168Z"/>
                  </svg>
                  <span class="nav-text"><%= req.translations.settings %></span>
               </a>

               <a href="/admin/users" class="nav-link <%= req.path === '/admin/users' ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor">
                     <path d="M7 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM14.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM1.615 16.428a1.224 1.224 0 0 1-.569-1.175 6.002 6.002 0 0 1 11.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 0 1 7 18a9.953 9.953 0 0 1-5.385-1.572ZM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 0 0-1.588-3.755 4.502 4.502 0 0 1 5.874 2.636.818.818 0 0 1-.36.98A7.465 7.465 0 0 1 14.5 16Z"/>
                  </svg>
                  <span class="nav-text"><%= req.translations.users %></span>
               </a>

               <a href="/admin/instances/overview" class="nav-link <%= req.path.startsWith('/admin/instances') ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 256 256" fill="currentColor">
                     <path d="M24,80a8,8,0,0,1,4-6.91l96-56a8,8,0,0,1,8.06,0l96,56a8,8,0,0,1,0,13.82l-96,56a8,8,0,0,1-8.06,0l-96-56A8,8,0,0,1,24,80Zm196,41.09-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09ZM232,192H216V176a8,8,0,0,0-16,0v16H184a8,8,0,0,0,0,16h16v16a8,8,0,0,0,16,0V208h16a8,8,0,0,0,0-16Zm-92,23.76-12,7L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l16-9.33A8,8,0,1,0,140,215.76Z"/>
                  </svg>
                  <span class="nav-text"><%= req.translations.instances %></span>
               </a>

               <a href="/admin/templates/overview" class="nav-link <%= req.path.startsWith('/admin/templates') ? 'active' : '' %>">
                  <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor">
