      <script>
         // SVG Icon Loader for Plugins
         document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll('.svg-icon').forEach(function(span) {
               const url = span.getAttribute('data-icon-url');
               if (url) {
                  fetch(url)
                     .then(response => response.text())
                     .then(svgContent => {
                        if (svgContent.includes('<svg')) {
                           span.innerHTML = svgContent;
                           const svg = span.querySelector('svg');
                           if (svg) {
                              svg.classList.add('w-5', 'h-5', 'flex-shrink-0');
                           }
                        }
                     })
                     .catch(error => {
                        console.error('Error loading SVG:', error);
                     });
               }
            });
         });
      </script>

      <!-- KS Panel - Main JavaScript (combined inline) -->
      <script>
         // ==========================================
         // KS Panel - Main JavaScript
         // ==========================================

         // Global State
         const AppState = {
             isSidebarCollapsed: false,
             isMobile: false,
             currentPing: 0,
             updateCheckInterval: null,
             resourceInterval: null,
             pingInterval: null,
             isAnimating: false
         };

         // ==========================================
         // Utility Functions
         // ==========================================

         function getCookie(name) {
             const value = `; ${document.cookie}`;
             const parts = value.split(`; ${name}=`);
             if (parts.length === 2) return parts.pop().split(';').shift();
             return null;
         }

         function setCookie(name, value, days = 7) {
             const date = new Date();
             date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
             const expires = `expires=${date.toUTCString()}`;
             document.cookie = `${name}=${value};${expires};path=/;SameSite=Lax`;
         }

         function debounce(func, wait) {
             let timeout;
             return function executedFunction(...args) {
                 const later = () => {
                     clearTimeout(timeout);
                     func(...args);
                 };
                 clearTimeout(timeout);
                 timeout = setTimeout(later, wait);
             };
         }

         function throttle(func, limit) {
             let inThrottle;
             return function(...args) {
                 if (!inThrottle) {
                     func.apply(this, args);
                     inThrottle = true;
                     setTimeout(() => inThrottle = false, limit);
                 }
             };
         }

         // ==========================================
         // Sidebar Management
         // ==========================================

         function initSidebar() {
             const sidebar = document.getElementById('sidebar');
             const desktopToggle = document.getElementById('desktop-toggle');
             const mobileMenuBtn = document.getElementById('mobile-menu-btn');
             const overlay = document.getElementById('sidebar-overlay');
             const colcont = document.querySelector('.main-content');

             if (!sidebar) return;

             // Check if mobile
             const checkMobile = () => {
                 AppState.isMobile = window.innerWidth < 1024;
                 return AppState.isMobile;
             };

             // Initialize sidebar state
             const initState = () => {
                 const isMobile = checkMobile();
                 const savedState = getCookie('sidebar-collapsed');
                 
                 if (isMobile) {
                     // Mobile: always start closed, never collapsed style
                     sidebar.classList.remove('collapsed', 'open');
                     setCookie('sidebar-collapsed', 'false');
                     AppState.isSidebarCollapsed = false;
                 } else {
                     // Desktop: respect saved state
                     if (savedState === 'true') {
                         sidebar.classList.add('collapsed');
                         AppState.isSidebarCollapsed = true;
                     } else {
                         sidebar.classList.remove('collapsed');
                         AppState.isSidebarCollapsed = false;
                     }
                 }
             };

             // Toggle desktop sidebar
             const toggleDesktopSidebar = () => {
                 if (AppState.isMobile) return;
                 
                 sidebar.classList.toggle('collapsed');
                 AppState.isSidebarCollapsed = sidebar.classList.contains('collapsed');
                 setCookie('sidebar-collapsed', AppState.isSidebarCollapsed);
                 
                 // Animate content
                 if (colcont) {
                     colcont.style.opacity = '0.8';
                     setTimeout(() => {
                         colcont.style.opacity = '1';
                     }, 150);
                 }
             };

             // Toggle mobile sidebar
             const toggleMobileSidebar = (show) => {
                 if (!AppState.isMobile) return;
                 
                 if (show === undefined) {
                     sidebar.classList.toggle('open');
                 } else if (show) {
                     sidebar.classList.add('open');
                 } else {
                     sidebar.classList.remove('open');
                 }
                 
                 // Toggle overlay
                 if (sidebar.classList.contains('open')) {
                     overlay.classList.add('show');
                     document.body.style.overflow = 'hidden';
                 } else {
                     overlay.classList.remove('show');
                     document.body.style.overflow = '';
                 }
             };

             // Event listeners
             if (desktopToggle) {
                 desktopToggle.addEventListener('click', toggleDesktopSidebar);
             }

             if (mobileMenuBtn) {
                 mobileMenuBtn.addEventListener('click', () => toggleMobileSidebar(true));
             }

             if (overlay) {
                 overlay.addEventListener('click', () => toggleMobileSidebar(false));
             }

             // Close mobile sidebar on escape key
             document.addEventListener('keydown', (e) => {
                 if (e.key === 'Escape' && sidebar.classList.contains('open')) {
                     toggleMobileSidebar(false);
                 }
             });

             // Handle resize
             const handleResize = debounce(() => {
                 const wasMobile = AppState.isMobile;
                 const isMobile = checkMobile();
                 
                 if (wasMobile !== isMobile) {
                     // Switched between mobile/desktop
                     initState();
                     if (!isMobile) {
                         toggleMobileSidebar(false);
                     }
                 }
             }, 250);

             window.addEventListener('resize', handleResize);

             // Initialize
             initState();
         }

         // ==========================================
         // Navigation Active State
         // ==========================================

         function initNavigation() {
             const navLinks = document.querySelectorAll('.nav-link');
             const activeBackground = document.getElementById('active-background');
             const content = document.getElementById('content');

             if (!navLinks.length || !activeBackground) return;

             let currentActiveLink = null;

             function updateActiveBackground(link, instant = false) {
                 if (!link) {
                     activeBackground.style.opacity = '0';
                     return;
                 }

                 const linkRect = link.getBoundingClientRect();
                 const navRect = link.closest('ul').getBoundingClientRect();
                 const topOffset = linkRect.top - navRect.top + link.closest('ul').scrollTop;

                 if (instant) {
                     activeBackground.style.transition = 'none';
                 } else {
                     activeBackground.style.transition = 'transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), height 0.3s ease, opacity 0.2s ease';
                 }

                 activeBackground.style.height = `${linkRect.height}px`;
                 activeBackground.style.transform = `translateY(${topOffset}px)`;
                 activeBackground.style.opacity = '1';

                 if (instant) {
                     activeBackground.offsetHeight; // Force reflow
                     activeBackground.style.transition = 'transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), height 0.3s ease, opacity 0.2s ease';
                 }

                 currentActiveLink = link;
             }

             function setActiveLink(path) {
                 let found = false;
                 
                 navLinks.forEach(link => {
                     const href = link.getAttribute('href');
                     const normalizedPath = path.replace('instance/', 'instances');
                     
                     if (normalizedPath.startsWith(href) || path === href) {
                         link.classList.add('active');
                         updateActiveBackground(link, true);
                         found = true;
                     } else {
                         link.classList.remove('active');
                     }
                 });

                 if (!found) {
                     activeBackground.style.opacity = '0';
                 }
             }

             // Set initial active state
             setActiveLink(window.location.pathname);

             // Handle clicks with page transition
             navLinks.forEach(link => {
                 link.addEventListener('click', (e) => {
                     const href = link.getAttribute('href');
                     if (!href || href.startsWith('http')) return;
                     
                     e.preventDefault();
                     
                     if (AppState.isAnimating) return;
                     AppState.isAnimating = true;

                     // Update visual state
                     navLinks.forEach(l => l.classList.remove('active'));
                     link.classList.add('active');
                     updateActiveBackground(link);

                     // Animate content out
                     if (content) {
                         content.style.opacity = '0';
                         content.style.transform = 'translateX(-20px)';
                         content.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
                     }

                     // Navigate after animation
                     setTimeout(() => {
                         window.location.href = href;
                     }, 200);
                 });
             });

             // Handle browser back/forward
             window.addEventListener('popstate', () => {
                 setActiveLink(window.location.pathname);
             });

             // Update on scroll (in case of fixed positioning issues)
             window.addEventListener('scroll', throttle(() => {
                 if (currentActiveLink) {
                     updateActiveBackground(currentActiveLink, true);
                 }
             }, 100));
         }

         // ==========================================
         // Ping Monitor
         // ==========================================

         function initPingMonitor() {
             const pingValue = document.getElementById('ping-value');
             const layer1 = document.getElementById('ping-layer-1');
             const layer2 = document.getElementById('ping-layer-2');
             const layer3 = document.getElementById('ping-layer-3');
             const dot = document.getElementById('ping-dot');

             if (!pingValue) return;

             const layers = [layer1, layer2, layer3, dot].filter(Boolean);

             function resetSignal() {
                 layers.forEach(el => {
                     el.style.opacity = '0.2';
                     el.style.filter = 'none';
                     if (el.tagName === 'path') {
                         el.setAttribute('stroke', 'currentColor');
                     } else {
                         el.setAttribute('fill', 'currentColor');
                     }
                 });
             }

             function setSignalColor(activeLayers, color) {
                 activeLayers.forEach(el => {
                     if (!el) return;
                     el.style.opacity = '1';
                     el.style.filter = `drop-shadow(0 0 6px ${color})`;
                     if (el.tagName === 'path') {
                         el.setAttribute('stroke', color);
                     } else {
                         el.setAttribute('fill', color);
                     }
                 });
             }

             async function measurePing() {
                 const startTime = performance.now();

                 try {
                     const response = await fetch('/ping', { 
                         cache: 'no-store',
                         method: 'HEAD',
                         headers: { 'X-Requested-With': 'XMLHttpRequest' }
                     });
                     
                     if (!response.ok) throw new Error('Ping failed');

                     const latency = Math.round(performance.now() - startTime);
                     AppState.currentPing = latency;

                     // Update display
                     pingValue.textContent = latency;
                     
                     // Color code based on latency
                     let color, activeLayers;
                     
                     if (latency < 100) {
                         color = '#22c55e'; // Green
                         activeLayers = layers;
                     } else if (latency < 200) {
                         color = '#eab308'; // Yellow
                         activeLayers = [layer1, layer2, dot];
                     } else {
                         color = '#ef4444'; // Red
                         activeLayers = [layer1, dot];
                     }

                     resetSignal();
                     setSignalColor(activeLayers, color);

                 } catch (error) {
                     pingValue.textContent = '--';
                     resetSignal();
                     setSignalColor([layer1, dot], '#ef4444');
                 }
             }

             // Initial measurement
             measurePing();
             
             // Regular updates
             AppState.pingInterval = setInterval(measurePing, 2500);
             
             // Measure on visibility change (when user returns to tab)
             document.addEventListener('visibilitychange', () => {
                 if (!document.hidden) {
                     measurePing();
                 }
             });
         }

         // ==========================================
         // Resource Monitor
         // ==========================================

         function initResourceMonitor() {
             const resourceBtn = document.getElementById('resource-btn');
             const resourceDropdown = document.getElementById('resource-dropdown');
             
             // Icon elements
             const ramFill = document.getElementById('ram-fill');
             const cpuFill = document.getElementById('cpu-fill');
             const diskFill = document.getElementById('disk-fill');
             
             // Dropdown elements
             const ramText = document.getElementById('ram-text');
             const cpuText = document.getElementById('cpu-text');
             const diskText = document.getElementById('disk-text');
             const ramBar = document.getElementById('ram-bar');
             const cpuBar = document.getElementById('cpu-bar');
             const diskBar = document.getElementById('disk-bar');

             if (!ramFill || !cpuFill || !diskFill) return;

             const maxHeight = 16;

             function getColor(percent) {
                 if (percent > 95) return '#ef4444'; // Red
                 if (percent > 75) return '#eab308'; // Yellow
                 return '#22c55e'; // Green
             }

             function getColorClass(percent) {
                 if (percent > 95) return 'bg-red-500';
                 if (percent > 75) return 'bg-yellow-500';
                 return 'bg-green-500';
             }

             function updateIcon(data) {
                 // Update RAM icon
                 const ramHeight = (data.ram.percent / 100) * maxHeight;
                 const ramY = 2 + (maxHeight - ramHeight);
                 ramFill.setAttribute('y', ramY);
                 ramFill.setAttribute('height', ramHeight);
                 ramFill.setAttribute('fill', getColor(data.ram.percent));

                 // Update CPU icon
                 const cpuHeight = (data.cpu.percent / 100) * maxHeight;
                 const cpuY = 2 + (maxHeight - cpuHeight);
                 cpuFill.setAttribute('y', cpuY);
                 cpuFill.setAttribute('height', cpuHeight);
                 cpuFill.setAttribute('fill', getColor(data.cpu.percent));

                 // Update Disk icon
                 const diskHeight = (data.disk.percent / 100) * maxHeight;
                 const diskY = 2 + (maxHeight - diskHeight);
                 diskFill.setAttribute('y', diskY);
                 diskFill.setAttribute('height', diskHeight);
                 diskFill.setAttribute('fill', getColor(data.disk.percent));
             }

             function updateDropdown(data) {
                 if (!ramText || !cpuText || !diskText) return;

                 // Update text
                 ramText.textContent = `${data.ram.used.toFixed(1)} / ${data.ram.total.toFixed(1)} GB (${data.ram.percent.toFixed(0)}%)`;
                 cpuText.textContent = `${data.cpu.percent.toFixed(0)}%`;
                 diskText.textContent = `${data.disk.used.toFixed(1)} / ${data.disk.total.toFixed(1)} GB (${data.disk.percent.toFixed(0)}%)`;

                 // Update bars
                 ramBar.style.width = `${data.ram.percent}%`;
                 cpuBar.style.width = `${data.cpu.percent}%`;
                 diskBar.style.width = `${data.disk.percent}%`;

                 // Update colors
                 ramBar.className = `resource-bar-fill ${getColorClass(data.ram.percent)}`;
                 cpuBar.className = `resource-bar-fill ${getColorClass(data.cpu.percent)}`;
                 diskBar.className = `resource-bar-fill ${getColorClass(data.disk.percent)}`;
             }

             async function fetchResourceData() {
                 try {
                     const response = await fetch('/resourceMonitor', {
                         headers: { 'X-Requested-With': 'XMLHttpRequest' }
                     });
                     
                     if (!response.ok) throw new Error('Failed to fetch');
                     
                     const data = await response.json();
                     
                     updateIcon(data);
                     
                     // Only update dropdown if visible (optimization)
                     if (resourceDropdown && !resourceDropdown.classList.contains('hidden')) {
                         updateDropdown(data);
                     }
                     
                     return data;
                 } catch (error) {
                     console.error('Resource monitor error:', error);
                 }
             }

             // Toggle dropdown
             if (resourceBtn && resourceDropdown) {
                 resourceBtn.addEventListener('click', async (e) => {
                     e.stopPropagation();
                     
                     const isHidden = resourceDropdown.classList.contains('hidden');
                     
                     // Close other dropdowns
                     closeAllDropdowns();
                     
                     if (isHidden) {
                         resourceDropdown.classList.remove('hidden');
                         // Fetch fresh data when opening
                         const data = await fetchResourceData();
                         if (data) updateDropdown(data);
                     } else {
                         resourceDropdown.classList.add('hidden');
                     }
                 });

                 // Close on outside click
                 document.addEventListener('click', (e) => {
                     if (!resourceDropdown.contains(e.target) && !resourceBtn.contains(e.target)) {
                         resourceDropdown.classList.add('hidden');
                     }
                 });
             }

             // Initial fetch and interval
             fetchResourceData();
             AppState.resourceInterval = setInterval(fetchResourceData, 2500);
         }

         // ==========================================
         // Update Manager
         // ==========================================

         function initUpdateManager() {
             const updateBtn = document.getElementById('update-btn');
             const updateDropdown = document.getElementById('update-dropdown');
             const updateIcon = document.getElementById('update-icon');
             const updateBadge = document.getElementById('update-badge');
             const updateStatus = document.getElementById('update-status');
             const updateAction = document.getElementById('update-action');

             if (!updateBtn || !updateDropdown) return;

             let currentVersion = null;
             let latestVersion = null;
             let isOutdated = false;

             function setUpdateIconColor(color) {
                 if (updateIcon) {
                     const paths = updateIcon.querySelectorAll('path');
                     paths.forEach(path => path.setAttribute('stroke', color));
                 }
             }

             async function checkVersion() {
                 try {
                     const response = await fetch('/version', {
                         headers: { 'X-Requested-With': 'XMLHttpRequest' }
                     });
                     
                     const data = await response.json();
                     
                     currentVersion = data.currentVersion;
                     latestVersion = data.latestVersion;
                     isOutdated = data.status === 'outdated';

                     if (isOutdated) {
                         setUpdateIconColor('#FFC107'); // Yellow/Orange
                         if (updateBadge) updateBadge.classList.remove('hidden');
                         if (updateStatus) updateStatus.textContent = `Update available: v${currentVersion} → v${latestVersion}`;
                         if (updateAction) {
                             updateAction.textContent = `Update to v${latestVersion}`;
                             updateAction.className = 'w-full bg-yellow-600 hover:bg-yellow-700 text-white py-2 rounded-lg transition-colors text-sm font-medium';
                         }
                     } else {
                         setUpdateIconColor('#4CAF50'); // Green
                         if (updateBadge) updateBadge.classList.add('hidden');
                         if (updateStatus) updateStatus.textContent = `Up to date (v${currentVersion})`;
                         if (updateAction) {
                             updateAction.textContent = 'Reinstall Current Version';
                             updateAction.className = 'w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg transition-colors text-sm font-medium';
                         }
                     }
                 } catch (error) {
                     console.error('Version check error:', error);
                     setUpdateIconColor('#808080'); // Gray
                     if (updateStatus) updateStatus.textContent = 'Unable to check updates';
                     if (updateAction) updateAction.textContent = 'Retry';
                 }
             }

             // Toggle dropdown
             updateBtn.addEventListener('click', (e) => {
                 e.stopPropagation();
                 
                 const isHidden = updateDropdown.classList.contains('hidden');
                 closeAllDropdowns();
                 
                 if (isHidden) {
                     updateDropdown.classList.remove('hidden');
                 } else {
                     updateDropdown.classList.add('hidden');
                 }
             });

             // Perform action (update or reinstall)
             if (updateAction) {
                 updateAction.addEventListener('click', async () => {
                     const action = isOutdated ? 'update' : 'reinstall';
                     
                     if (!confirm(`Are you sure you want to ${action}? This may restart the server.`)) {
                         return;
                     }

                     updateAction.disabled = true;
                     updateAction.textContent = 'Processing...';
                     updateAction.classList.add('opacity-50', 'cursor-not-allowed');

                     try {
                         const response = await fetch('/reinstall', { 
                             method: 'GET',
                             headers: { 'X-Requested-With': 'XMLHttpRequest' }
                         });
                         
                         if (response.ok) {
                             alert(`${action === 'update' ? 'Update' : 'Reinstall'} started successfully!`);
                             updateAction.textContent = 'In Progress...';
                         } else {
                             throw new Error('Server returned error');
                         }
                     } catch (error) {
                         alert(`Error starting ${action}: ${error.message}`);
                         updateAction.disabled = false;
                         updateAction.classList.remove('opacity-50', 'cursor-not-allowed');
                         checkVersion(); // Reset button text
                     }
                 });
             }

             // Close on outside click
             document.addEventListener('click', (e) => {
                 if (!updateDropdown.contains(e.target) && !updateBtn.contains(e.target)) {
                     updateDropdown.classList.add('hidden');
                 }
             });

             // Initial check and interval
             checkVersion();
             AppState.updateCheckInterval = setInterval(checkVersion, 5000);
         }

         // ==========================================
         // User Menu / Language Selector
         // ==========================================

         function initUserMenu() {
             const userMenuBtn = document.getElementById('user-menu-btn');
             const userDropdown = document.getElementById('user-dropdown');
             const languageSelect = document.getElementById('language-select');

             if (!userMenuBtn || !userDropdown) return;

             // Toggle dropdown
             userMenuBtn.addEventListener('click', (e) => {
                 e.stopPropagation();
                 
                 const isHidden = userDropdown.classList.contains('hidden');
                 closeAllDropdowns();
                 
                 if (isHidden) {
                     userDropdown.classList.remove('hidden');
                 } else {
                     userDropdown.classList.add('hidden');
                 }
             });

             // Language change
             if (languageSelect) {
                 languageSelect.addEventListener('change', async (e) => {
                     const lang = e.target.value;
                     
                     try {
                         const response = await fetch(`/lang/${lang}`, {
                             method: 'GET',
                             headers: { 'X-Requested-With': 'XMLHttpRequest' }
                         });
                         
                         if (response.ok) {
                             setCookie('lang', lang, 365);
                             window.location.reload();
                         } else {
                             throw new Error('Failed to change language');
                         }
                     } catch (error) {
                         console.error('Language change error:', error);
                         alert('Failed to change language');
                     }
                 });
             }

             // Close on outside click
             document.addEventListener('click', (e) => {
                 if (!userDropdown.contains(e.target) && !userMenuBtn.contains(e.target)) {
                     userDropdown.classList.add('hidden');
                 }
             });
         }

         // ==========================================
         // Search Functionality
         // ==========================================

         function initSearch() {
             const searchInput = document.getElementById('search-input');
             const searchResults = document.getElementById('search-results');
             
             if (!searchInput || !searchResults) return;

             const navLinks = Array.from(document.querySelectorAll('.nav-link'));
             
             function performSearch(query) {
                 if (!query.trim()) {
                     searchResults.classList.add('hidden');
                     return;
                 }

                 const normalizedQuery = query.toLowerCase();
                 const matches = navLinks.filter(link => {
                     const searchData = link.getAttribute('data-search') || '';
                     const text = link.textContent.toLowerCase();
                     const href = link.getAttribute('href').toLowerCase();
                     
                     return searchData.includes(normalizedQuery) || 
                            text.includes(normalizedQuery) || 
                            href.includes(normalizedQuery);
                 });

                 displayResults(matches, query);
             }

             function displayResults(matches, query) {
                 if (matches.length === 0) {
                     searchResults.innerHTML = `
                         <div class="p-4 text-center text-neutral-400 text-sm">
                             No results found for "${query}"
                         </div>
                     `;
                 } else {
                     searchResults.innerHTML = matches.map(link => {
                         const href = link.getAttribute('href');
                         const text = link.querySelector('.nav-text')?.textContent || '';
                         const svg = link.querySelector('svg')?.outerHTML || '';
                         
                         return `
                             <a href="${href}" class="flex items-center gap-3 p-3 hover:bg-white/5 transition-colors rounded-lg mx-2 first:mt-2 last:mb-2">
                                 <div class="text-neutral-400 w-5 h-5">${svg}</div>
                                 <span class="text-white text-sm">${text}</span>
                             </a>
                         `;
                     }).join('');
                 }
                 
                 searchResults.classList.remove('hidden');
             }

             // Debounced search
             const debouncedSearch = debounce((value) => performSearch(value), 300);

             searchInput.addEventListener('input', (e) => {
                 debouncedSearch(e.target.value);
             });

             // Close on escape
             searchInput.addEventListener('keydown', (e) => {
                 if (e.key === 'Escape') {
                     searchResults.classList.add('hidden');
                     searchInput.blur();
                 }
             });

             // Close on outside click
             document.addEventListener('click', (e) => {
                 if (!searchResults.contains(e.target) && !searchInput.contains(e.target)) {
                     searchResults.classList.add('hidden');
                 }
             });

             // Focus shortcut (Ctrl/Cmd + K)
             document.addEventListener('keydown', (e) => {
                 if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                     e.preventDefault();
                     searchInput.focus();
                 }
             });
         }

         // ==========================================
         // Utility: Close all dropdowns
         // ==========================================

         function closeAllDropdowns() {
             const dropdowns = [
                 document.getElementById('update-dropdown'),
                 document.getElementById('resource-dropdown'),
                 document.getElementById('user-dropdown'),
                 document.getElementById('search-results')
             ];
             
             dropdowns.forEach(dropdown => {
                 if (dropdown) dropdown.classList.add('hidden');
             });
         }

         // ==========================================
         // Content Animation on Load
         // ==========================================

         function initContentAnimation() {
             const content = document.getElementById('content');
             if (content) {
                 // Reset animation
                 content.style.opacity = '0';
                 content.style.transform = 'translateY(20px)';
                 content.style.transition = 'opacity 0.4s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1)';
                 
                 // Trigger animation
                 requestAnimationFrame(() => {
                     content.style.opacity = '1';
                     content.style.transform = 'translateY(0)';
                 });
             }
         }

         // ==========================================
         // Touch Gestures (Mobile)
         // ==========================================

         function initTouchGestures() {
             if (!('ontouchstart' in window)) return;

             const sidebar = document.getElementById('sidebar');
             const overlay = document.getElementById('sidebar-overlay');
             let touchStartX = 0;
             let touchEndX = 0;

             // Swipe from left edge to open
             document.addEventListener('touchstart', (e) => {
                 touchStartX = e.changedTouches[0].screenX;
             }, { passive: true });

             document.addEventListener('touchend', (e) => {
                 touchEndX = e.changedTouches[0].screenX;
                 handleSwipe();
             }, { passive: true });

             function handleSwipe() {
                 const swipeThreshold = 100;
                 const diff = touchEndX - touchStartX;
                 const isLeftEdge = touchStartX < 50;

                 // Open: swipe right from left edge
                 if (diff > swipeThreshold && isLeftEdge && AppState.isMobile) {
                     sidebar.classList.add('open');
                     overlay.classList.add('show');
                 }
                 
                 // Close: swipe left
                 if (diff < -swipeThreshold && sidebar.classList.contains('open')) {
                     sidebar.classList.remove('open');
                     overlay.classList.remove('show');
                 }
             }
         }

         // ==========================================
         // Service Worker / PWA Support
         // ==========================================

         function initPWA() {
             if ('serviceWorker' in navigator) {
                 window.addEventListener('load', () => {
                     navigator.serviceWorker.register('/sw.js').catch(err => {
                         console.log('ServiceWorker registration failed:', err);
                     });
                 });
             }
         }

         // ==========================================
         // Cleanup on Page Hide
         // ==========================================

         function initCleanup() {
             window.addEventListener('beforeunload', () => {
                 if (AppState.pingInterval) clearInterval(AppState.pingInterval);
                 if (AppState.resourceInterval) clearInterval(AppState.resourceInterval);
                 if (AppState.updateCheckInterval) clearInterval(AppState.updateCheckInterval);
             });

             // Pause expensive operations when hidden
             document.addEventListener('visibilitychange', () => {
                 if (document.hidden) {
                     // Optional: reduce interval frequency when hidden
                 }
             });
         }

         // ==========================================
         // Error Handling
         // ==========================================

         window.addEventListener('error', (e) => {
             console.error('Global error:', e.error);
         });

         window.addEventListener('unhandledrejection', (e) => {
             console.error('Unhandled promise rejection:', e.reason);
         });

         // ==========================================
         // Initialize Everything
         // ==========================================

         document.addEventListener('DOMContentLoaded', () => {
             initSidebar();
             initNavigation();
             initPingMonitor();
             initResourceMonitor();
             initUpdateManager();
             initUserMenu();
             initSearch();
             initContentAnimation();
             initTouchGestures();
             initPWA();
             initCleanup();
             
             console.log('KS Panel initialized successfully');
         });
      </script>
