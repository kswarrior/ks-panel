      <!-- PING - Enhanced smooth animation (already in style) -->
      <script>
      document.addEventListener('DOMContentLoaded', () => {
        const pingValue = document.getElementById('pingValue');
        const layer1 = document.getElementById('pingLayer1');
        const layer2 = document.getElementById('pingLayer2');
        const layer3 = document.getElementById('pingLayer3');
        const dot = document.getElementById('pingDot');

        function resetSignal() {
          [layer1, layer2, layer3, dot].forEach(el => {
            if (!el) return;
            el.style.opacity = "0.2";
            el.setAttribute("stroke", "#64748b");
          });
        }

        function setSignalColor(elements, color) {
          elements.forEach(el => {
            if (!el) return;
            el.style.opacity = "1";
            el.setAttribute("stroke", color);
          });
        }

        async function measurePing() {
          const startTime = performance.now();
          try {
            const response = await fetch('/ping', { cache: 'no-store' });
            const latency = Math.round(performance.now() - startTime);

            pingValue.textContent = latency;

            resetSignal();

            if (latency < 80) {
              setSignalColor([layer1, layer2, layer3, dot], "#22c55e");
            } else if (latency < 160) {
              setSignalColor([layer1, layer2, layer3], "#eab308");
              setSignalColor([dot], "#eab308");
            } else {
              setSignalColor([layer1, layer2], "#ef4444");
              setSignalColor([dot], "#ef4444");
            }
          } catch (error) {
            pingValue.textContent = "--";
            resetSignal();
            setSignalColor([layer1, dot], "#ef4444");
          }
        }

        measurePing();
        setInterval(measurePing, 2200);
      });
      </script>

      <!-- UPDATE MANAGER - Versions outside button -->
      <script>
      document.addEventListener('DOMContentLoaded', () => {
        const icon = document.getElementById('update-icon');
        const paths = icon.querySelectorAll('path');
        const dropdown = document.getElementById('update-dropdown');
        const actionButton = document.getElementById('action-button');
        const currentVerEl = document.getElementById('current-version');
        const latestVerEl = document.getElementById('latest-version');

        function toggleUpdateDropdown() {
          dropdown.classList.toggle('hidden');
        }

        icon.addEventListener('click', toggleUpdateDropdown);

        window.addEventListener('click', (e) => {
          if (!icon.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.classList.add('hidden');
          }
        });

        function performAction() {
          if (confirm('Are you sure? This may restart services.')) {
            fetch('/reinstall', { method: 'GET' })
              .then(res => res.ok ? alert('Reinstall / Update started') : alert('Error'))
              .catch(() => alert('Network error'));
          }
        }

        actionButton.addEventListener('click', performAction);

        function checkVersion() {
          fetch('/version')
            .then(response => response.json())
            .then(data => {
              currentVerEl.textContent = `v${data.currentVersion}`;
              latestVerEl.textContent = `v${data.latestVersion}`;

              if (data.status === 'outdated') {
                paths.forEach(p => p.setAttribute('stroke', '#FFC107'));
                actionButton.textContent = 'Update Now';
              } else {
                paths.forEach(p => p.setAttribute('stroke', '#4CAF50'));
                actionButton.textContent = 'Reinstall Now';
              }
            })
            .catch(() => {
              paths.forEach(p => p.setAttribute('stroke', '#808080'));
              actionButton.textContent = 'Check Failed';
            });
        }

        checkVersion();
        setInterval(checkVersion, 4800);
      });
      </script>

      <!-- RESOURCE MONITOR - 5-minute bar graphs -->
      <script>
      document.addEventListener('DOMContentLoaded', async () => {
        let ramHistory = [];
        let cpuHistory = [];
        let diskHistory = [];

        function getColor(percent) {
          if (percent > 95) return '#ef4444';
          if (percent > 75) return '#eab308';
          return '#22c55e';
        }

        function getColorClass(percent) {
          if (percent > 95) return 'bg-red-500';
          if (percent > 75) return 'bg-yellow-500';
          return 'bg-green-500';
        }

        function renderHistory(containerId, history) {
          const container = document.getElementById(containerId);
          if (!container) return;
          container.innerHTML = '';

          // Always show 5 bars (pad with 8% if not enough data yet)
          const displayHistory = [...history];
          while (displayHistory.length < 5) displayHistory.unshift(8);

          displayHistory.forEach((percent, i) => {
            const bar = document.createElement('div');
            bar.className = `history-bar flex-1 rounded-t-2xl ${getColorClass(percent)}`;
            bar.style.height = `${percent}%`;
            bar.style.animationDelay = `${i * 60}ms`;
            container.appendChild(bar);
          });
        }

        async function updateResourceData() {
          try {
            const response = await fetch('/resourceMonitor');
            const data = await response.json();

            // Update live icon bars
            const maxHeight = 16;
            const ramFill = document.getElementById('ram-fill');
            ramFill.setAttribute('height', (data.ram.percent / 100) * maxHeight);
            ramFill.setAttribute('y', 2 + maxHeight - (data.ram.percent / 100) * maxHeight);
            ramFill.setAttribute('fill', getColor(data.ram.percent));

            const cpuFill = document.getElementById('cpu-fill');
            cpuFill.setAttribute('height', (data.cpu.percent / 100) * maxHeight);
            cpuFill.setAttribute('y', 2 + maxHeight - (data.cpu.percent / 100) * maxHeight);
            cpuFill.setAttribute('fill', getColor(data.cpu.percent));

            const diskFill = document.getElementById('disk-fill');
            diskFill.setAttribute('height', (data.disk.percent / 100) * maxHeight);
            diskFill.setAttribute('y', 2 + maxHeight - (data.disk.percent / 100) * maxHeight);
            diskFill.setAttribute('fill', getColor(data.disk.percent));

            // Push to history (5-minute style - last 5 snapshots)
            ramHistory.push(data.ram.percent);
            cpuHistory.push(data.cpu.percent);
            diskHistory.push(data.disk.percent);

            if (ramHistory.length > 5) ramHistory.shift();
            if (cpuHistory.length > 5) cpuHistory.shift();
            if (diskHistory.length > 5) diskHistory.shift();

            // Render history graphs
            renderHistory('ram-history', ramHistory);
            renderHistory('cpu-history', cpuHistory);
            renderHistory('disk-history', diskHistory);

          } catch (error) {
            console.error('Resource fetch error:', error);
          }
        }

        // Click handler - show current values + already-rendered graphs
        const resourceLink = document.getElementById('resource-link');
        resourceLink.addEventListener('click', () => {
          const dropdown = document.getElementById('resource-dropdown');
          dropdown.classList.toggle('hidden');
        });

        // Live updates
        updateResourceData();
        setInterval(updateResourceData, 2400);
      });
      </script>

