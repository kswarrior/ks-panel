<!doctype html>
<html class="h-full w-full">
   <!--
     
   HEAD SECTION
     
   -->
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
   </head>
   <body 
  style="
    font-family: 'Public Sans';
    background:
      linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
      url('/assets/background.webp');
    background-position: center top;
    background-repeat: repeat-y; /* repeats vertically */
    background-size: 100% auto;  /* keeps full width */" >
      <!-- Todo : remove this style for tailwind css-->
      <style>

         .sidebar nav ul {
            position: relative;
         }
         .nav-link {
            position: relative;
            z-index: 1;
         }
         .nav-link.active {
            color: white;
            font-weight: 500;
         }
         @media (max-width: 1024px) {

  .sidebar {
    display: none;
    position: fixed;
    z-index: 50;
    height: 100%;
    width: 215px;
    backdrop-filter: blur(var(--backdrop-blur));
    background: rgba(0, 0, 0, 0.4);
    overflow-y: auto;

    /* Original transform */
    transform: translateX(-100%);

    /* Added smooth animation */
    opacity: 0;
    transition: 
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s ease;
  }

  .sidebar.open {
    display: block;
    transform: translateX(0);

    /* Added fade in */
    opacity: 1;
    animation: sidebarSlide 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sidebar.expanded {
    width: 100%;
  }

}

@media (max-width: 1024px) {
   .group-[.collapsed]:hidden {
      display: inline !important;
   }
   #pc-sidebar2 {
      overflow: visible !important;
   }
   .sidebar.open {
      width: 215px !important;   /* slightly wider for comfort */
   }
}

/* Animation */
@keyframes sidebarSlide {
  from {
    transform: translateX(-110%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}
      </style>

      <!--
     
      MOBILE TOGGLE SECTION
     
      -->
      <!-- Static sidebar for desktop -->
      <div id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out hidden lg:fixed lg:inset-y-0 lg:z-50 p-2 lg:flex lg:w-56 lg:flex-col group group-[.collapsed]:w-[4%]">
         <div id="pc-sidebar2" class="flex grow flex-col gap-y-5 overflow-hidden rounded-r-3xl rounded-l-lg bg-white/5 backdrop-blur-xl border border-white/10">
            <nav class="flex flex-1 flex-col">
                  <!--
     
      USER INFO SECTION
     
      -->
                  <div class="flex items-center space-x-4 py-4 px-4 border-b border-white/10">
                  <img class="w-7 h-7 rounded-full ring-1 ring-white/20"
     src="https://mc-heads.net/avatar/<%= user.username %>/64"
     alt="Profile">
                     <div class="lg:group-[.collapsed]:hidden">
                       <p class="text-sm font-medium text-white"><%= user.username %></p>
                       <p class="text-xs text-neutral-400 font-mono"><%= user.userId.substring(0, 6) %></p>
                     </div>
                  </div>
               <ul role="list" class="flex flex-1 flex-col gap-y-7 mt-4 px-3">
                  <li>
                     <ul role="list" class="-mx-2 space-y-1">
