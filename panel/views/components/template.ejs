<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
   </head>
   <body 
  style="
    font-family: 'Public Sans';
    background:
      linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
      url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://cdn.discordapp.com/attachments/1315671132203913218/1482722679101456599/image0.gif?ex=69b7fc9a&is=69b6ab1a&hm=8b71dec0f5da4a2fe26d74e104ddb078812e39780e8efbbbdf94517f1a2bfc52&" %>');
    background-position: center top;
    background-repeat: no-repeat;
    background-size: cover;
    background-attachment: fixed;
  ">
      
      <style>
         /* CSS Variables for consistent theming */
         :root {
            --sidebar-width: 14rem;
            --sidebar-collapsed-width: 4rem;
            --header-height: 4rem;
            --mobile-sidebar-width: 16rem;
            --transition-speed: 0.3s;
            --backdrop-blur: 12px;
         }

         /* Base styles */
         * {
            -webkit-tap-highlight-color: transparent;
         }

         /* Sidebar Styles */
         .sidebar {
            position: fixed;
            inset-y: 0;
            left: 0;
            z-index: 50;
            width: var(--sidebar-width);
            transition: all var(--transition-speed) cubic-bezier(0.22, 1, 0.36, 1);
            padding: 0.5rem;
         }

         .sidebar.collapsed {
            width: var(--sidebar-collapsed-width);
         }

         .sidebar.collapsed .nav-text,
         .sidebar.collapsed .section-title,
         .sidebar.collapsed .user-details {
            opacity: 0;
            transform: translateX(-10px);
            pointer-events: none;
         }

         /* Mobile Sidebar */
         @media (max-width: 1023px) {
            .sidebar {
               width: var(--mobile-sidebar-width);
               transform: translateX(-100%);
               opacity: 0;
               transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
            }

            .sidebar.open {
               transform: translateX(0);
               opacity: 1;
            }

            .sidebar.collapsed {
               width: var(--mobile-sidebar-width);
            }

            .sidebar.collapsed .nav-text,
            .sidebar.collapsed .section-title,
            .sidebar.collapsed .user-details {
               opacity: 1;
               transform: translateX(0);
               pointer-events: auto;
            }
         }

         /* Main Content Area */
         .main-content {
            padding-left: var(--sidebar-width);
            transition: padding-left var(--transition-speed) cubic-bezier(0.22, 1, 0.36, 1);
         }

         .sidebar.collapsed ~ .main-content {
            padding-left: var(--sidebar-collapsed-width);
         }

         @media (max-width: 1023px) {
            .main-content {
               padding-left: 0;
            }
            
            .sidebar.collapsed ~ .main-content {
               padding-left: 0;
            }
         }

         /* Navigation Items */
         .nav-link {
            position: relative;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            margin: 0.25rem 0.75rem;
            border-radius: 0.75rem;
            color: rgb(163 163 163);
            transition: all 0.2s ease;
            white-space: nowrap;
         }

         .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
         }

         .nav-link.active {
            color: white;
            font-weight: 500;
         }

         .nav-link svg {
            flex-shrink: 0;
            width: 1.25rem;
            height: 1.25rem;
            transition: transform 0.2s ease;
         }

         .nav-link:hover svg {
            transform: scale(1.1);
         }

         .nav-text {
            transition: opacity 0.2s ease, transform 0.2s ease;
         }

         /* Active Background Indicator */
         #active-background {
            position: absolute;
            left: 0.75rem;
            right: 0.75rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            pointer-events: none;
         }

         /* Section Titles */
         .section-title {
            padding-left: 2rem;
            padding-top: 1.5rem;
            padding-bottom: 0.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: white;
            transition: opacity 0.2s ease;
         }

         @media (max-width: 1023px) {
            .section-title {
               padding-left: 1.5rem;
            }
         }

         /* Header Styles */
         .top-header {
            position: sticky;
            top: 0;
            z-index: 40;
            height: var(--header-height);
            backdrop-filter: blur(var(--backdrop-blur));
            background: rgba(0, 0, 0, 0.2);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
         }

         /* Mobile Menu Button */
         .mobile-menu-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.05);
            color: white;
            transition: all 0.2s ease;
            cursor: pointer;
         }

         .mobile-menu-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.02);
         }

         .mobile-menu-btn:active {
            transform: scale(0.98);
         }

         @media (min-width: 1024px) {
            .mobile-menu-btn {
               display: none;
            }
         }

         /* Desktop Toggle Button */
         .desktop-toggle {
            display: none;
         }

         @media (min-width: 1024px) {
            .desktop-toggle {
               display: flex;
               align-items: center;
               justify-content: center;
               width: 2.5rem;
               height: 2.5rem;
               border-radius: 0.75rem;
               border: 1px solid rgba(255, 255, 255, 0.1);
               background: rgba(255, 255, 255, 0.05);
               color: white;
               transition: all 0.2s ease;
               cursor: pointer;
            }

            .desktop-toggle:hover {
               background: rgba(255, 255, 255, 0.1);
               transform: scale(1.05);
            }
         }

         /* User Profile Section */
         .user-profile {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 0.5rem;
         }

         .user-avatar {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.1);
            flex-shrink: 0;
         }

         .user-details {
            transition: opacity 0.2s ease;
         }

         /* Dropdown Menus */
         .dropdown-menu {
            position: absolute;
            right: 0;
            top: 100%;
            margin-top: 0.5rem;
            min-width: 14rem;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(var(--backdrop-blur));
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            padding: 0.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: scale(0.95) translateY(-10px);
            pointer-events: none;
            transition: all 0.2s ease;
         }

         .dropdown-menu.show {
            opacity: 1;
            transform: scale(1) translateY(0);
            pointer-events: auto;
         }

         @media (max-width: 640px) {
            .dropdown-menu {
               position: fixed;
               left: 1rem;
               right: 1rem;
               top: auto;
               bottom: 1rem;
               margin-top: 0;
            }
         }

         /* Resource Monitor Bars */
         .resource-bar-bg {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0.25rem;
            height: 0.5rem;
            overflow: hidden;
         }

         .resource-bar-fill {
            height: 100%;
            border-radius: 0.25rem;
            transition: width 0.3s ease, background-color 0.3s ease;
         }

         /* Overlay for mobile */
         .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 40;
            opacity: 0;
            transition: opacity 0.3s ease;
         }

         @media (max-width: 1023px) {
            .sidebar-overlay.show {
               display: block;
               opacity: 1;
            }
         }

         /* Scrollbar Styling */
         .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
         }

         .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
         }

         .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
         }

         .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
         }

         /* Touch-friendly improvements */
         @media (pointer: coarse) {
            .nav-link {
               padding: 0.625rem 1rem;
               margin: 0.375rem 0.75rem;
            }

            .nav-link svg {
               width: 1.5rem;
               height: 1.5rem;
            }
         }

         /* Animations */
         @keyframes slideIn {
            from {
               opacity: 0;
               transform: translateX(-20px);
            }
            to {
               opacity: 1;
               transform: translateX(0);
            }
         }

         @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
         }

         .animate-slide-in {
            animation: slideIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
         }

         .animate-fade-in {
            animation: fadeIn 0.3s ease;
         }

         /* Search Results */
         .search-results {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            margin-top: 0.5rem;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(var(--backdrop-blur));
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            max-height: 20rem;
            overflow-y: auto;
            z-index: 50;
         }

         /* Status Indicators */
         .status-dot {
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 50%;
            display: inline-block;
            margin-right: 0.5rem;
         }

         .status-online { background: #22c55e; box-shadow: 0 0 8px #22c55e; }
         .status-warning { background: #eab308; box-shadow: 0 0 8px #eab308; }
         .status-offline { background: #ef4444; box-shadow: 0 0 8px #ef4444; }

         /* Loading States */
         .skeleton {
            background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
            border-radius: 0.5rem;
         }

         @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
         }
      </style>

      <!-- Mobile Overlay -->
      <div id="sidebar-overlay" class="sidebar-overlay"></div>

      <!-- Sidebar -->
      <div id="sidebar" class="sidebar group">
         <div class="flex h-full flex-col rounded-r-3xl rounded-l-lg bg-black/40 backdrop-blur-xl border border-white/5 overflow-hidden">
            
            <!-- User Profile -->
            <div class="user-profile">
               <img class="user-avatar" src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
               <div class="user-details">
                  <p class="text-sm font-medium text-white"><%= user.username %></p>
                  <p class="text-xs text-neutral-400 font-mono"><%= user.userId.substring(0, 6) %></p>
               </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 overflow-y-auto custom-scrollbar relative">
               <ul role="list" class="space-y-1 relative">
                  <div id="active-background" class="hidden"></div>
                  
                  <!-- Main Navigation -->
                  <li>
                     <a href="/instances" class="nav-link <%= req.path === '/instances' ? 'active' : '' %>" data-search="container instances servers">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/>
                           <path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/>
                           <path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0 0,0,0,13.82Z"/>
                        </svg>
                        <span class="nav-text"><%= req.translations.instances %></span>
                     </a>
                  </li>

                  <li>
                     <a href="/account" class="nav-link <%= req.path === '/account' ? 'active' : '' %>" data-search="account profile <%= user.username %>">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                           <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                        </svg>
                        <span class="nav-text"><%= req.translations.account %></span>
                     </a>
                  </li>

                  <!-- Plugin Links -->
                  <% if (plugins && plugins.length > 0) { %>
                     <% plugins.forEach(plugin => { %>
                        <% if (plugin.sidebar) { %>
                           <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                              <li>
                                 <a href="<%= value.url %>" class="nav-link" data-search="<%= value.search_data || key %>">
                                    <% if (value.icon) { %>
                                       <span class="svg-icon" data-icon-url="<%= value.icon %>"></span>
                                    <% } else { %>
                                       <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                          <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                       </svg>
                                    <% } %>
                                    <span class="nav-text"><%= key %></span>
                                 </a>
                              </li>
                           <% }); %>
                        <% } %>
                     <% }); %>
                  <% } %>

                  <!-- Admin Section -->
                  <% if (user.admin == true) { %>
                     <li class="section-title">
                        <span class="nav-text">Admin Panel</span>
                     </li>

                     <li>
                        <a href="/admin/dashboard/overview" class="nav-link <%= req.path && req.path.includes('/admin/dashboard') ? 'active' : '' %>" data-search="admin overview control">
                           <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                              <rect width="256" height="256" fill="none"/>
