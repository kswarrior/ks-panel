                                 <path d="M220.8,169.6A8,8,0,0,0,216,168h-8V64a32,32,0,0,0-32-32H40A32,32,0,0,0,8,64C8,77.61,18.05,85.54,19.2,86.4h0A7.89,7.89,0,0,0,24,88a8,8,0,0,0,4.87-14.33h0C28.83,73.62,24,69.74,24,64a16,16,0,0,1,32,0V192a32,32,0,0,0,32,32H200a32,32,0,0,0,32-32C232,178.39,222,170.46,220.8,169.6ZM104,96h64a8,8,0,0,1,0,16H104a8,8,0,0,1,0-16Zm-8,40a8,8,0,0,1,8-8h64a8,8,0,0,1,0,16H104A8,8,0,0,1,96,136Zm104,72H107.71A31.82,31.82,0,0,0,112,192a26.92,26.92,0,0,0-1.21-8h102a12.58,12.58,0,0,1,3.23,8A16,16,0,0,1,200,208Z"/>
                              </svg>
                              <span class="nav-text whitespace-nowrap"><%= req.translations.auditLogs %></span>
                           </a>
                        </li>
                     <% } %>
                  </ul>
               </div>
               
               <!-- Logout -->
               <div class="shrink-0 border-t border-white/5 p-2">
                  <a href="/auth/logout" 
                     class="flex items-center gap-x-3 px-4 py-3 text-sm font-medium text-neutral-500 rounded-xl transition-all duration-200 hover:text-white hover:bg-white/5">
                     <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                     </svg>
                     <span class="nav-text whitespace-nowrap"><%= req.translations.signOut %></span>
                  </a>
               </div>
            </nav>
         </div>
      </div>

      <!-- Main Content -->
      <div id="colcont" class="min-h-screen flex flex-col">
         
         <!-- Header -->
         <header class="sticky top-0 z-30 flex h-16 shrink-0 items-center gap-x-4 bg-transparent backdrop-blur-sm px-4 sm:px-6 lg:px-8">
            
            <!-- Mobile Toggle Button -->
            <button id="mobile-header-toggle" 
                    type="button"
                    onclick="toggleMobileSidebar()"
                    class="flex items-center gap-x-2 px-3 py-2 rounded-xl border border-white/10 bg-white/5 text-white hover:bg-white/10 transition-all duration-200 active:scale-95 lg:hidden">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
               </svg>
               <% if (logo == true) { %>
                  <img src="/assets/logo.webp" class="h-5 w-5 object-contain rounded" alt="Logo">
               <% } %>
               <span class="font-medium text-sm"><%= name || 'KS Panel' %></span>
            </button>

            <!-- Desktop Header Content -->
            <div class="hidden lg:flex flex-1 items-center justify-between">
               <div class="flex items-center gap-x-4">
                  <!-- Desktop toggle removed as per original -->
               </div>
               
               <div class="flex items-center gap-x-4">
                  <!-- Search, Update, Ping, Resources, Profile -->
               </div>
            </div>

            <!-- Mobile Header Right Side -->
            <div class="flex lg:hidden flex-1 items-center justify-end gap-x-3">
               <!-- Update Icon -->
               <div class="relative cursor-pointer">
                  <svg id="update-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#808080" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                     <path d="M21 4v6h-6"/>
                     <path d="M3 20v-6h6"/>
                     <path d="M21 10a9 9 0 0 1 -9 9a9 9 0 0 1 -9 -9a9 9 0 0 1 9 -9"/>
                  </svg>
                  <div id="update-dropdown" class="hidden absolute right-0 mt-2 w-56 rounded-xl border border-white/10 shadow-xl overflow-hidden">
                     <div class="p-4">
                        <h2 class="text-lg font-semibold text-white mb-3">Update Manager</h2>
                        <button id="action-button" class="w-full bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded-lg transition-colors text-sm">Loading...</button>
                     </div>
                  </div>
               </div>

               <!-- Ping Display -->
               <span id="pingDisplay" class="flex flex-col items-center text-white">
                  <svg id="pingIcon" width="18" height="14" viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="transition-all duration-300">
                     <path id="pingLayer3" d="M2 6C7-1 17-1 22 6" opacity="0.2"/>
                     <path id="pingLayer2" d="M5 10C9 5 15 5 19 10" opacity="0.2"/>
                     <path id="pingLayer1" d="M8.5 14C10.5 12 13.5 12 15.5 14" opacity="0.2"/>
                     <circle id="pingDot" cx="12" cy="18" r="1.8" fill="currentColor" opacity="0.2"/>
                  </svg>
                  <span class="text-[8px] font-medium mt-0.5"><span id="pingValue">--</span></span>
               </span>

               <!-- Profile Menu -->
               <div class="relative">
                  <button type="button" onclick="toggleProfileDropdown()" class="flex items-center p-1.5 rounded-full hover:bg-white/10 transition-colors">
                     <svg width="26" height="26" viewBox="0 0 28 28" fill="none" stroke="#ffffff" stroke-width="2.2">
                        <circle cx="14" cy="14" r="11.5"/>
                        <path d="M3 14H25" stroke-linecap="round"/>
                        <path d="M14 2.5C10 7 10 21 14 25.5" stroke-linecap="round"/>
                        <path d="M14 2.5C18 7 18 21 14 25.5" stroke-linecap="round"/>
                     </svg>
                  </button>
                  
                  <div id="dropdown-menu" class="hidden absolute right-0 z-50 mt-2 w-56 bg-white rounded-xl shadow-lg ring-1 ring-black ring-opacity-5 transform opacity-0 scale-95 transition-all duration-200">
                     <div class="p-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Language</label>
                        <select id="language-selector" onchange="changeLanguage(this.value)" class="w-full bg-white border border-gray-300 rounded-lg py-2 px-3 text-sm focus:ring-2 focus:ring-gray-500 focus:border-gray-500">
                           <% languages.forEach(function(language) { %>
                              <option value="<%= language %>" <%= (req.cookies.lang ? req.cookies.lang : 'en') === language ? 'selected' : '' %>>
                                 <%= req.translations[language] || language %>
                              </option>
                           <% }); %>
                        </select>
                     </div>
                  </div>
               </div>
            </div>

            <!-- Desktop Right Side Icons -->
            <div class="hidden lg:flex items-center gap-x-3">
               <!-- Update -->
               <div class="relative cursor-pointer p-2 hover:bg-white/5 rounded-lg transition-colors">
                  <svg id="update-icon-desktop" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#808080" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                     <path d="M21 4v6h-6"/>
                     <path d="M3 20v-6h6"/>
                     <path d="M21 10a9 9 0 0 1 -9 9a9 9 0 0 1 -9 -9a9 9 0 0 1 9 -9"/>
                  </svg>
               </div>

               <!-- Ping -->
               <span id="pingDisplayDesktop" class="flex flex-col items-center text-white px-2">
                  <svg width="18" height="14" viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                     <path d="M2 6C7-1 17-1 22 6" opacity="0.2"/>
                     <path d="M5 10C9 5 15 5 19 10" opacity="0.2"/>
                     <path d="M8.5 14C10.5 12 13.5 12 15.5 14" opacity="0.2"/>
                     <circle cx="12" cy="18" r="1.8" fill="currentColor" opacity="0.2"/>
                  </svg>
                  <span class="text-[8px] font-medium mt-0.5">--</span>
               </span>

               <!-- Resources -->
               <div id="resource-link-desktop" class="relative cursor-pointer p-2 hover:bg-white/5 rounded-lg transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="w-5 h-5 text-neutral-400">
                     <rect x="1" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="ram-fill-desktop" x="1" y="2" width="3" height="0" fill="#22c55e"/>
                     <rect x="8" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="cpu-fill-desktop" x="8" y="2" width="3" height="0" fill="#22c55e"/>
                     <rect x="15" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="disk-fill-desktop" x="15" y="2" width="3" height="0" fill="#22c55e"/>
                  </svg>
               </div>

               <!-- Profile -->
               <div class="relative">
                  <button type="button" onclick="toggleProfileDropdown()" class="flex items-center p-1.5 rounded-full hover:bg-white/10 transition-colors">
                     <svg width="26" height="26" viewBox="0 0 28 28" fill="none" stroke="#ffffff" stroke-width="2.2">
                        <circle cx="14" cy="14" r="11.5"/>
                        <path d="M3 14H25" stroke-linecap="round"/>
                        <path d="M14 2.5C10 7 10 21 14 25.5" stroke-linecap="round"/>
                        <path d="M14 2.5C18 7 18 21 14 25.5" stroke-linecap="round"/>
                     </svg>
                  </button>
               </div>
            </div>
         </header>

         <!-- Page Content -->
         <main id="content" class="flex-1 p-4 sm:p-6 lg:p-8 transition-opacity duration-300">
            <!-- Content injected here -->
         </main>
      </div>

      <!-- Scripts -->
      <script src="/javascript/search/index.js"></script>
      <script src="/javascript/language/index.js"></script>
      
      <script>
         // ===== SIDEBAR MANAGEMENT =====
         const sidebar = document.getElementById('sidebar');
         const overlay = document.getElementById('sidebar-overlay');
         const colcont = document.getElementById('colcont');
         const activeBackground = document.getElementById('active-background');
         
         // Check if desktop
         const isDesktop = () => window.innerWidth >= 1024;
         
         // Mobile sidebar toggle
         function toggleMobileSidebar() {
            if (isDesktop()) return;
            
            const isOpen = sidebar.classList.contains('mobile-open');
            if (isOpen) {
               closeMobileSidebar();
            } else {
               openMobileSidebar();
            }
         }
         
         function openMobileSidebar() {
            sidebar.classList.add('mobile-open');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden'; // Prevent background scroll
         }
         
         function closeMobileSidebar() {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
         }
         
         // Close on escape key
         document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !isDesktop()) {
               closeMobileSidebar();
            }
         });
         
         // Handle resize
         let resizeTimer;
         window.addEventListener('resize', () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
               if (isDesktop()) {
                  closeMobileSidebar();
                  sidebar.classList.remove('mobile-open');
                  // Restore desktop state from cookie
                  const collapsed = getCookie('sidebar-collapsed') === 'true';
                  if (collapsed) {
                     sidebar.classList.add('collapsed');
                     colcont.classList.add('collapsed');
                  } else {
                     sidebar.classList.remove('collapsed');
                     colcont.classList.remove('collapsed');
                  }
               } else {
                  // Reset to mobile default
                  sidebar.classList.remove('collapsed');
                  colcont.classList.remove('collapsed');
               }
               updateActiveIndicator();
            }, 100);
         });
         
         // ===== COOKIE HELPERS =====
         function setCookie(name, value, days) {
            const date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            document.cookie = `${name}=${value};expires=${date.toUTCString()};path=/`;
         }
         
         function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
            return null;
         }
         
         // ===== NAVIGATION ACTIVE STATE =====
         function updateActiveIndicator() {
            const navLinks = document.querySelectorAll('.nav-link');
            const currentPath = window.location.pathname;
            let foundActive = false;
            
            navLinks.forEach(link => {
               const href = link.getAttribute('href');
               const normalizedPath = currentPath.replace('instance/', 'instances');
               
               if (normalizedPath.startsWith(href)) {
                  link.classList.add('active', 'text-white');
                  link.classList.remove('text-neutral-400');
                  
                  // Position indicator
                  const linkRect = link.getBoundingClientRect();
                  const navRect = link.closest('ul').getBoundingClientRect();
                  const topOffset = linkRect.top - navRect.top + link.closest('ul').scrollTop;
                  
                  activeBackground.style.height = `${linkRect.height}px`;
                  activeBackground.style.transform = `translateY(${topOffset}px)`;
                  activeBackground.classList.add('visible');
                  foundActive = true;
               } else {
                  link.classList.remove('active', 'text-white');
                  link.classList.add('text-neutral-400');
               }
            });
            
            if (!foundActive) {
               activeBackground.classList.remove('visible');
            }
         }
         
         // ===== PROFILE DROPDOWN =====
         function toggleProfileDropdown() {
            const menu = document.getElementById('dropdown-menu');
            const isHidden = menu.classList.contains('hidden');
            
            if (isHidden) {
               menu.classList.remove('hidden');
               // Trigger reflow
               void menu.offsetWidth;
               menu.style.opacity = '1';
               menu.style.transform = 'scale(1)';
            } else {
               menu.style.opacity = '0';
               menu.style.transform = 'scale(0.95)';
               setTimeout(() => menu.classList.add('hidden'), 200);
            }
         }
         
         // Close dropdown when clicking outside
         window.addEventListener('click', (e) => {
            const menu = document.getElementById('dropdown-menu');
            const button = e.target.closest('button[onclick="toggleProfileDropdown()"]');
            
            if (!button && !menu.contains(e.target)) {
               menu.style.opacity = '0';
               menu.style.transform = 'scale(0.95)';
               setTimeout(() => menu.classList.add('hidden'), 200);
            }
         });
         
         // ===== PLUGIN SVG ICONS =====
         document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.svg-icon').forEach(span => {
               const url = span.getAttribute('data-icon-url');
               if (!url) return;
               
               fetch(url)
                  .then(response => {
                     if (!response.ok) throw new Error('Network response was not ok');
                     return response.text();
                  })
                  .then(svgContent => {
                     if (svgContent.includes('<svg')) {
                        span.innerHTML = svgContent;
                        const svg = span.querySelector('svg');
                        if (svg) {
                           svg.classList.add('w-5', 'h-5', 'shrink-0');
                        }
                     }
                  })
                  .catch(error => {
                     console.error('Error loading SVG:', error);
                     // Fallback icon
                     span.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 shrink-0"><path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" /></svg>`;
                  });
            });
            
            // Initialize
            updateActiveIndicator();
            
            // Desktop state from cookie
            if (isDesktop()) {
               const collapsed = getCookie('sidebar-collapsed') === 'true';
               if (collapsed) {
                  sidebar.classList.add('collapsed');
                  colcont.classList.add('collapsed');
               }
            }
         });
         
         // ===== PING MONITOR =====
         async function measurePing() {
            const start = performance.now();
            try {
               const response = await fetch('/ping', { cache: 'no-store' });
               const latency = Math.round(performance.now() - start);
               
               document.querySelectorAll('#pingValue').forEach(el => el.textContent = latency);
               
               const color = latency < 100 ? '#22c55e' : latency < 200 ? '#eab308' : '#ef4444';
               const layers = latency < 100 ? 3 : latency < 200 ? 2 : 1;
               
               document.querySelectorAll('[id^="pingLayer"]').forEach((el, i) => {
                  el.style.opacity = i < layers ? '1' : '0.2';
                  el.style.stroke = i < layers ? color : 'currentColor';
                  el.style.filter = i < layers ? `drop-shadow(0 0 4px ${color})` : 'none';
               });
               
               document.querySelectorAll('#pingDot').forEach(el => {
                  el.style.opacity = '1';
                  el.style.fill = color;
                  el.style.filter = `drop-shadow(0 0 4px ${color})`;
               });
               
            } catch (error) {
               document.querySelectorAll('#pingValue').forEach(el => el.textContent = '--');
               document.querySelectorAll('[id^="ping"]').forEach(el => {
                  el.style.opacity = '0.2';
                  el.style.stroke = '#ef4444';
               });
            }
         }
         
         setInterval(measurePing, 2500);
         measurePing();
         
         // ===== UPDATE MANAGER =====
         function checkVersion() {
            fetch('/version')
               .then(response => response.json())
               .then(data => {
                  const buttons = document.querySelectorAll('#action-button');
                  buttons.forEach(btn => {
                     if (data.status === 'outdated') {
                        btn.textContent = `Update (v${data.currentVersion} → v${data.latestVersion})`;
                        btn.classList.remove('bg-blue-500');
                        btn.classList.add('bg-amber-500');
                     } else {
                        btn.textContent = `Reinstall (v${data.currentVersion})`;
                     }
                  });
               })
               .catch(console.error);
         }
         
         setInterval(checkVersion, 5000);
         checkVersion();
         
         // ===== RESOURCE MONITOR =====
         function getColor(percent) {
            if (percent > 95) return '#ef4444';
            if (percent > 75) return '#eab308';
            return '#22c55e';
         }
         
         async function updateResources() {
            try {
               const response = await fetch('/resourceMonitor');
               const data = await response.json();
               
               ['ram', 'cpu', 'disk'].forEach(type => {
                  const percent = data[type].percent;
                  const height = (percent / 100) * 16;
                  const y = 2 + (16 - height);
                  const color = getColor(percent);
                  
                  document.querySelectorAll(`[id^="${type}-fill"]`).forEach(el => {
                     el.setAttribute('height', height);
                     el.setAttribute('y', y);
                     el.setAttribute('fill', color);
                  });
               });
            } catch (error) {
               console.error('Resource monitor error:', error);
            }
         }
         
         setInterval(updateResources, 2500);
         updateResources();
      </script>
   </body>
</html>
