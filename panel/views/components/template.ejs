<script>
document.addEventListener('DOMContentLoaded', () => {
  const link = document.getElementById('update-link');
  const icon = document.getElementById('update-icon');
  const paths = icon.querySelectorAll('path');
  const dropdown = document.getElementById('update-dropdown');
  const actionButton = document.getElementById('action-button');
  const metricRows = dropdown.querySelectorAll('.metric-row');
  const statusDot = document.getElementById('status-dot');
  const statusText = document.getElementById('status-text');
  const currentVersion = document.getElementById('current-version');
  const lastCheck = document.getElementById('last-check');
  
  let isDropdownOpen = false;
  let versionData = null;

  function toggleDropdown() {
    isDropdownOpen = !isDropdownOpen;
    
    if (isDropdownOpen) {
      dropdown.classList.remove('invisible', 'pointer-events-none', 'opacity-0', 'scale-95', 'translate-y-2');
      dropdown.classList.add('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
      
      metricRows.forEach((row, index) => {
        setTimeout(() => {
          row.classList.remove('opacity-0', 'translate-x-4');
          row.classList.add('opacity-100', 'translate-x-0');
        }, index * 50);
      });
    } else {
      closeDropdown();
    }
  }

  function closeDropdown() {
    metricRows.forEach((row) => {
      row.classList.add('opacity-0', 'translate-x-4');
      row.classList.remove('opacity-100', 'translate-x-0');
    });
    
    setTimeout(() => {
      dropdown.classList.add('invisible', 'pointer-events-none', 'opacity-0', 'scale-95', 'translate-y-2');
      dropdown.classList.remove('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
    }, 200);
  }

  icon.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!link.contains(e.target) && isDropdownOpen) {
      isDropdownOpen = false;
      closeDropdown();
    }
  });

  function updateUI(data) {
    versionData = data;
    currentVersion.textContent = `v${data.currentVersion}`;
    
    if (data.status === 'outdated') {
      statusDot.className = 'w-2 h-2 rounded-full bg-yellow-500 animate-pulse transition-colors duration-300';
      statusText.textContent = 'Update Available';
      statusText.className = 'text-yellow-400 text-sm font-medium';
      
      actionButton.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
        </svg>
        <span>Update to v${data.latestVersion}</span>
      `;
      paths.forEach(path => path.setAttribute('stroke', '#eab308'));
    } else {
      statusDot.className = 'w-2 h-2 rounded-full bg-green-500 transition-colors duration-300';
      statusText.textContent = 'Up to Date';
      statusText.className = 'text-green-400 text-sm font-medium';
      
      actionButton.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span>Reinstall v${data.currentVersion}</span>
      `;
      paths.forEach(path => path.setAttribute('stroke', '#22c55e'));
    }
    
    const now = new Date();
    lastCheck.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function performAction() {
    const action = versionData && versionData.status === 'outdated' ? 'update' : 'reinstall';
    const confirmMessage = action === 'update' 
      ? `Are you sure you want to update to v${versionData.latestVersion}? This will restart the server.`
      : 'Are you sure you want to reinstall? This may restart the server.';
    
    if (confirm(confirmMessage)) {
      actionButton.disabled = true;
      actionButton.innerHTML = `
        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Processing...</span>
      `;
      
      fetch('/reinstall', { method: 'GET' })
        .then(res => {
          if (res.ok) {
            actionButton.innerHTML = `
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Started!</span>
            `;
            actionButton.classList.remove('from-blue-600', 'to-blue-500');
            actionButton.classList.add('from-green-600', 'to-green-500');
          } else {
            throw new Error('Failed to start');
          }
        })
        .catch(error => {
          actionButton.disabled = false;
          actionButton.innerHTML = `
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Try Again</span>
          `;
          alert('Error: ' + error.message);
        });
    }
  }

  actionButton.addEventListener('click', performAction);

  function checkVersion() {
    fetch('/version')
      .then(response => response.json())
      .then(data => {
        updateUI(data);
      })
      .catch(error => {
        console.error('Error fetching version status:', error);
        statusDot.className = 'w-2 h-2 rounded-full bg-red-500 transition-colors duration-300';
        statusText.textContent = 'Connection Error';
        statusText.className = 'text-red-400 text-sm font-medium';
        currentVersion.textContent = 'Unknown';
        actionButton.innerHTML = `
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Retry Connection</span>
        `;
        paths.forEach(path => path.setAttribute('stroke', '#ef4444'));
      });
  }

  checkVersion();
  setInterval(checkVersion, 5000);
});
</script>

   
   
   
   
   
   
