<script>
  function getColor(percent) {
    if (percent > 95) return '#ef4444';
    if (percent > 75) return '#eab308';
    return '#22c55e';
  }

  function getColorClass(percent) {
    if (percent > 95) return 'bg-red-500';
    if (percent > 75) return 'bg-yellow-500';
    return 'bg-green-500';
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const dropdown = document.getElementById('resource-dropdown');
    const link = document.getElementById('resource-link');
    const metricRows = document.querySelectorAll('.metric-row');
    let isDropdownOpen = false;
    let currentData = null;

    // Toggle dropdown on click
    link.addEventListener('click', (e) => {
      e.stopPropagation();
      isDropdownOpen = !isDropdownOpen;
      
      if (isDropdownOpen) {
        // Open animation
        dropdown.classList.remove('invisible', 'pointer-events-none', 'opacity-0', 'scale-95', 'translate-y-2');
        dropdown.classList.add('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
        
        // Animate metric rows with stagger
        metricRows.forEach((row, index) => {
          setTimeout(() => {
            row.classList.remove('opacity-0', 'translate-x-4');
            row.classList.add('opacity-100', 'translate-x-0');
          }, index * 50);
        });
        
        // Animate progress bars after dropdown opens
        if (currentData) {
          setTimeout(() => {
            updateProgressBars(currentData);
          }, 150);
        }
      } else {
        // Close animation
        closeDropdown();
      }
    });

    function closeDropdown() {
      // Reverse animate rows
      metricRows.forEach((row) => {
        row.classList.add('opacity-0', 'translate-x-4');
        row.classList.remove('opacity-100', 'translate-x-0');
      });
      
      // Reset progress bars
      document.getElementById('ram-bar').classList.add('w-0');
      document.getElementById('ram-bar').style.width = '0%';
      document.getElementById('cpu-bar').classList.add('w-0');
      document.getElementById('cpu-bar').style.width = '0%';
      document.getElementById('disk-bar').classList.add('w-0');
      document.getElementById('disk-bar').style.width = '0%';
      
      // Close dropdown after animation
      setTimeout(() => {
        dropdown.classList.add('invisible', 'pointer-events-none', 'opacity-0', 'scale-95', 'translate-y-2');
        dropdown.classList.remove('opacity-100', 'scale-100', 'translate-y-0', 'pointer-events-auto');
      }, 200);
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!link.contains(e.target) && isDropdownOpen) {
        isDropdownOpen = false;
        closeDropdown();
      }
    });

    function updateProgressBars(data) {
      // Update text
      document.getElementById('ram-used').textContent = `${data.ram.used.toFixed(1)} / ${data.ram.total.toFixed(1)} GB (${data.ram.percent.toFixed(0)}%)`;
      document.getElementById('cpu-percent').textContent = `${data.cpu.percent.toFixed(0)}%`;
      document.getElementById('disk-used').textContent = `${data.disk.used.toFixed(1)} / ${data.disk.total.toFixed(1)} GB (${data.disk.percent.toFixed(0)}%)`;
      
      // Animate bars width
      const ramBar = document.getElementById('ram-bar');
      const cpuBar = document.getElementById('cpu-bar');
      const diskBar = document.getElementById('disk-bar');
      
      ramBar.className = `h-full rounded-full transition-all duration-700 ease-out ${getColorClass(data.ram.percent)}`;
      cpuBar.className = `h-full rounded-full transition-all duration-700 ease-out ${getColorClass(data.cpu.percent)}`;
      diskBar.className = `h-full rounded-full transition-all duration-700 ease-out ${getColorClass(data.disk.percent)}`;
      
      // Remove w-0 to trigger animation, then set actual width
      requestAnimationFrame(() => {
        ramBar.classList.remove('w-0');
        cpuBar.classList.remove('w-0');
        diskBar.classList.remove('w-0');
        
        ramBar.style.width = `${data.ram.percent}%`;
        cpuBar.style.width = `${data.cpu.percent}%`;
        diskBar.style.width = `${data.disk.percent}%`;
      });
    }

    async function updateResourceData() {
      try {
        const response = await fetch('/resourceMonitor');
        const data = await response.json();
        currentData = data;

        const maxHeight = 17;
        const baseY = 20;

        // Update RAM icon
        let ramHeight = (data.ram.percent / 100) * maxHeight;
        let ramY = baseY - ramHeight;
        const ramFill = document.getElementById('ram-fill');
        ramFill.setAttribute('y', ramY);
        ramFill.setAttribute('height', ramHeight);
        ramFill.setAttribute('fill', getColor(data.ram.percent));

        // Update CPU icon
        let cpuHeight = (data.cpu.percent / 100) * maxHeight;
        let cpuY = baseY - cpuHeight;
        const cpuFill = document.getElementById('cpu-fill');
        cpuFill.setAttribute('y', cpuY);
        cpuFill.setAttribute('height', cpuHeight);
        cpuFill.setAttribute('fill', getColor(data.cpu.percent));

        // Update Disk icon
        let diskHeight = (data.disk.percent / 100) * maxHeight;
        let diskY = baseY - diskHeight;
        const diskFill = document.getElementById('disk-fill');
        diskFill.setAttribute('y', diskY);
        diskFill.setAttribute('height', diskHeight);
        diskFill.setAttribute('fill', getColor(data.disk.percent));

        // Update dropdown content if visible
        if (isDropdownOpen) {
          updateProgressBars(data);
        }

      } catch (error) {
        console.error('Error fetching resource data:', error);
      }
    }

    // Run immediately once
    updateResourceData();

    // Run every 2.5 seconds
    setInterval(updateResourceData, 2500);
  });
</script>


