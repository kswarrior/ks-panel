<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

      <style>
         :root {
            --sidebar-bg: rgba(10, 10, 10, 0.6);
            --header-bg: rgba(10, 10, 10, 0.4);
            --accent-color: #3b82f6;
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-blur: 16px;
         }

         body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
                        url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" %>');
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            background-attachment: fixed;
            color: #f8fafc;
         }

         /* Optimized Scrollbar */
         ::-webkit-scrollbar { width: 6px; height: 6px; }
         ::-webkit-scrollbar-track { background: transparent; }
         ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
         ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }

         /* Glassmorphism Classes */
         .glass {
            background: var(--sidebar-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
         }

         .nav-link {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
         }

         .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, rgba(59, 130, 246, 0.1), transparent);
            transition: width 0.3s ease;
            z-index: -1;
         }

         .nav-link:hover::before, .nav-link.active::before {
            width: 100%;
         }

         .nav-link.active {
            color: #fff;
            background: rgba(255, 255, 255, 0.05);
         }

         .nav-link.active svg {
            color: var(--accent-color);
            filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.5));
         }

         .sub-nav-link.active {
            color: #fff !important;
         }

         #active-background {
            pointer-events: none;
            z-index: 0;
            background: linear-gradient(90deg, var(--accent-color), transparent);
            opacity: 0.15;
            width: 4px;
            left: 0;
            border-radius: 0 4px 4px 0;
         }

         /* Content Entry Animation */
         @keyframes contentFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
         }

         #content {
            animation: contentFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
         }

         .animate-fade-in {
            animation: contentFadeIn 0.3s ease forwards;
         }

         /* Sidebar Link Animations */
         @keyframes sidebarIn {
            from { opacity: 0; transform: translateX(-15px); }
            to { opacity: 1; transform: translateX(0); }
         }

         .nav-link {
            animation: sidebarIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
         }

         .nav-link:nth-child(1) { animation-delay: 0.1s; }
         .nav-link:nth-child(2) { animation-delay: 0.15s; }
         .nav-link:nth-child(3) { animation-delay: 0.2s; }
         .nav-link:nth-child(4) { animation-delay: 0.25s; }
         .nav-link:nth-child(5) { animation-delay: 0.3s; }
         .nav-link:nth-child(6) { animation-delay: 0.35s; }
         .nav-link:nth-child(7) { animation-delay: 0.4s; }
         .nav-link:nth-child(8) { animation-delay: 0.45s; }
         .nav-link:nth-child(9) { animation-delay: 0.5s; }

         /* Mobile Sidebar */
         @media (max-width: 1024px) {
            .sidebar {
               transform: translateX(-100%);
               transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
               opacity: 0;
               visibility: hidden;
            }
            .sidebar.open {
               transform: translateX(0);
               opacity: 1;
               visibility: visible;
            }
         }

         /* Sidebar Toggle Animation */
         .sidebar-toggle-btn {
            transition: all 0.2s ease;
         }
         .sidebar-toggle-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: scale(1.05);
         }

         /* Icon Pulse */
         .pulse-icon:hover {
            animation: iconPulse 1s infinite;
         }
         @keyframes iconPulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
         }

         /* Smooth transition for layout changes */
         #colcont {
            transition: padding 0.3s cubic-bezier(0.4, 0, 0.2, 1);
         }
      </style>
   </head>
   <body class="h-full">
      <!-- Sidebar -->
      <aside id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out fixed inset-y-0 z-50 flex flex-col w-64 lg:w-64 glass border-r border-white/5 group group-[.collapsed]:w-20">
         <div class="flex flex-col h-full">
            <!-- User Profile Section -->
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="p-6 border-b border-white/5">
               <div class="flex items-center gap-4">
                  <div class="relative">
                     <img class="w-10 h-10 rounded-xl object-cover border border-white/10"
                          src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
                     <div class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-green-500 border-2 border-black rounded-full"></div>
                  </div>
                  <div class="flex flex-col overflow-hidden transition-all duration-300 group-[.collapsed]:w-0 group-[.collapsed]:opacity-0">
                     <span class="text-sm font-bold text-white truncate"><%= user.username %></span>
                     <span class="text-[10px] font-medium text-neutral-400 uppercase tracking-widest">
                        <%= user.owner ? 'Owner' : (user.admin ? 'Administrator' : 'User') %>
                     </span>
                  </div>
               </div>
            </div>
            <% } %>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-4 overflow-y-auto">
               <div id="active-background" class="absolute transition-all duration-300 ease-in-out"></div>

               <!-- Main Section -->
               <div>
                  <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Main</p>
                  <a href="/instances" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Instances</span>
                  </a>
               </div>

               <!-- Admin Section -->
               <% if (anyAdminPerm()) { %>
               <div class="space-y-4">
                  <!-- Administration Section -->
                  <div>
                     <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Administration</p>

                     <% if (hasPerm('manage_users')) { %>
                     <a href="/admin/users" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">User Management</span>
                     </a>
                     <a href="/admin/roles" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Role Management</span>
                     </a>
                     <a href="/admin/notifications" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Global Alerts</span>
                     </a>
                     <a href="/admin/tickets" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Support Control</span>
                     </a>
                     <% } %>
                  </div>

                  <!-- Resources Section -->
                  <div>
                     <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Resources</p>

                     <% if (hasPerm('create_instances')) { %>
                     <a href="/admin/instances/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Instance Registry</span>
                     </a>
                     <% } %>

                     <% if (hasPerm('manage_templates')) { %>
                     <a href="/admin/templates/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Template Editor</span>
                     </a>
                     <% } %>

                     <% if (hasPerm('manage_nodes')) { %>
                     <a href="/admin/nodes/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Network Nodes</span>
                     </a>
                     <% } %>
                  </div>

                  <!-- System Section -->
                  <div>
                     <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">System</p>

                     <% if (hasPerm('view_insights')) { %>
                     <a href="/admin/security/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Security Center</span>
                     </a>
                     <% } %>

                     <a href="/admin/analytics" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Analytics</span>
                     </a>

                     <a href="/admin/database" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Database</span>
                     </a>

                     <% if (hasPerm('view_audit_logs')) { %>
                     <a href="/admin/auditlogs" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Audit Logs</span>
                     </a>
                     <% } %>

                     <% if (hasPerm('manage_api_keys')) { %>
                     <a href="/admin/apikeys" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">API Access</span>
                     </a>
                     <% } %>

                     <% if (hasPerm('manage_plugins')) { %>
                     <a href="/admin/plugins/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
                        </svg>
                        <span class="group-[.collapsed]:hidden">Addons</span>
                     </a>
                     <% } %>
                  </div>

                  <!-- Settings Section (Dropdown) -->
                  <div>
                     <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Settings</p>

                     <% if (hasPerm('manage_settings')) { %>
                     <div class="relative">
                        <button onclick="toggleSettingsDropdown()" class="w-full nav-link group flex items-center justify-between gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white transition-all">
                           <div class="flex items-center gap-3">
                              <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                              </svg>
                              <span class="group-[.collapsed]:hidden">Panel Settings</span>
                           </div>
                           <svg id="settings-arrow" class="w-4 h-4 transition-transform duration-300 group-[.collapsed]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                           </svg>
                        </button>

                        <div id="settings-sub-menu" class="hidden mt-2 space-y-1 px-4 animate-fade-in group-[.collapsed]:hidden">
                           <a href="/admin/settings" class="sub-nav-link block px-4 py-2 rounded-lg text-xs font-medium text-neutral-500 hover:text-white hover:bg-white/5 transition-all">General Settings</a>
                           <a href="/admin/settings/smtp" class="sub-nav-link block px-4 py-2 rounded-lg text-xs font-medium text-neutral-500 hover:text-white hover:bg-white/5 transition-all">Mail Configuration</a>
                           <a href="/admin/settings/theme" class="sub-nav-link block px-4 py-2 rounded-lg text-xs font-medium text-neutral-500 hover:text-white hover:bg-white/5 transition-all">Theme Customizer</a>
                        </div>
                     </div>
                     <% } %>
                  </div>
               </div>
               <% } %>
            </nav>

            <!-- Bottom Actions -->
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="p-4 mt-auto border-t border-white/5">
               <div class="flex items-center justify-between gap-2 group-[.collapsed]:flex-col group-[.collapsed]:items-center">
                  <!-- Language -->
                  <div class="relative">
                     <button id="sidebar-lang-button" class="p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5 transition-colors" title="Language">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                     </button>
                     <div id="sidebar-lang-dropdown" class="absolute bottom-full left-0 mb-2 w-48 glass rounded-2xl p-2 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50">
                        <% languages.forEach(lang => { %>
                           <button onclick="changeLanguage('<%= lang %>')" class="w-full text-left px-4 py-2.5 rounded-xl text-[10px] font-bold hover:bg-white/5 transition-colors uppercase tracking-widest text-neutral-400 hover:text-white">
                              <%= req.translations[lang] %>
                           </button>
                        <% }) %>
                     </div>
                  </div>

                  <!-- Account -->
                  <a href="/account" class="flex-1 flex items-center justify-center gap-2 px-3 py-2 rounded-lg text-xs font-bold text-neutral-400 hover:text-white hover:bg-white/5 transition-all group-[.collapsed]:hidden">
                     <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                     </svg>
                     <span>Account</span>
                  </a>

                  <!-- Account Icon for Collapsed -->
                  <a href="/account" class="hidden group-[.collapsed]:flex p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5 transition-colors" title="Account">
                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                     </svg>
                  </a>

                  <!-- Logout -->
                  <a href="/auth/logout" class="p-2 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors" title="Logout">
                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                     </svg>
                  </a>
               </div>
            </div>
            <% } %>
         </div>
      </aside>

      <!-- Main Layout -->
      <div id="colcont" class="lg:pl-64 transition-all duration-300 ease-in-out group-[.collapsed]:pl-20">
         <!-- Header -->
         <header class="sticky top-0 z-40 h-16 glass border-b border-white/5 px-4 sm:px-6 lg:px-8 flex items-center justify-between">
            <div class="flex items-center gap-4">
               <button id="mobile-sidebar-toggle" class="lg:hidden p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                  </svg>
               </button>
               <button id="sidebar-toggle-desktop" class="hidden lg:flex p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5 transition-all">
                  <svg id="toggle-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                  </svg>
               </button>

               <div class="flex items-center gap-2 sm:gap-3">
                  <img src="/assets/logo.webp" class="w-6 h-6 sm:w-7 sm:h-7 object-contain" alt="Logo">
                  <h1 class="text-base sm:text-lg font-bold text-white tracking-tight truncate max-w-[100px] sm:max-w-none"><%= name || 'KS Panel' %></h1>
               </div>
            </div>

            <!-- Top bar Actions -->
            <div class="flex items-center gap-1.5 sm:gap-4">
               <!-- Tickets -->
               <a href="/tickets" class="p-2 rounded-lg hover:bg-white/5 transition-colors group" title="Support Tickets">
                  <svg class="w-5 h-5 text-neutral-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
               </a>

               <!-- Notifications -->
               <div id="notif-link" class="relative group cursor-pointer p-2 rounded-lg hover:bg-white/5 transition-colors">
                  <div class="relative">
                     <svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                     </svg>
                     <% if (notifications.filter(n => !n.read).length > 0) { %>
                        <span id="notif-count" class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-black text-white ring-2 ring-[#0a0a0a]">
                           <%= notifications.filter(n => !n.read).length %>
                        </span>
                     <% } %>
                  </div>
                  <!-- Dropdown -->
                  <div id="notif-dropdown" class="absolute right-0 mt-3 w-80 glass rounded-3xl p-2 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50 overflow-hidden">
                     <div class="px-4 py-3 flex items-center justify-between border-b border-white/5 mb-2">
                        <h3 class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Notifications</h3>
                        <button onclick="clearNotifs()" class="text-[10px] font-bold text-blue-400 hover:text-white uppercase transition-colors">Clear All</button>
                     </div>
                     <div id="notif-list" class="max-h-[400px] overflow-y-auto space-y-1">
                        <% if (notifications.length === 0) { %>
                           <div class="px-4 py-8 text-center">
                              <p class="text-xs text-neutral-600 font-medium">No system alerts found.</p>
                           </div>
                        <% } else { %>
                           <% notifications.forEach(n => { %>
                              <div class="p-3 rounded-2xl hover:bg-white/5 transition-all group border border-transparent hover:border-white/5">
                                 <div class="flex gap-3">
                                    <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 <%= n.type === 'error' ? 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]' : (n.type === 'warning' ? 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.5)]' : 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]') %>"></div>
                                    <div class="flex-1 min-w-0">
                                       <p class="text-xs text-neutral-200 leading-relaxed"><%= n.message %></p>
                                       <p class="text-[9px] text-neutral-600 font-bold mt-1 uppercase tracking-tighter"><%= new Date(n.timestamp).toLocaleString() %></p>
                                    </div>
                                 </div>
                              </div>
                           <% }) %>
                        <% } %>
                     </div>
                  </div>
               </div>

               <!-- Ping Monitor -->
               <div id="ping-link" class="relative group cursor-pointer px-2 py-1 rounded-lg hover:bg-white/5 transition-colors flex flex-col items-center">
                  <div class="relative">
                     <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071a10 10 0 0114.142 0M2.828 8.929a15 15 0 0121.214 0" />
                     </svg>
                     <span id="ping-dot-status" class="absolute -top-0.5 -right-0.5 w-1.5 h-1.5 bg-green-500 rounded-full border border-[#1a1a1a]"></span>
                  </div>
                  <span id="pingValue" class="text-[9px] font-mono text-neutral-500 font-black mt-0.5 leading-none">--</span>
                  <!-- Ping Dropdown -->
                  <div id="ping-dropdown" class="absolute right-0 mt-3 w-64 glass rounded-2xl p-4 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50">
                     <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-3">Latency Monitor</h3>
                     <div class="flex items-center justify-between">
                        <span class="text-sm text-white">Current Ping</span>
                        <span id="ping-dropdown-value" class="text-xl font-black text-blue-400">--ms</span>
                     </div>
                     <p id="ping-status-text" class="text-[10px] text-green-400 mt-2 font-bold uppercase">Optimal Connection</p>
                  </div>
               </div>

            </div>
         </header>

         <!-- Page Content -->
         <div id="page-container" class="relative">

      <!-- Scripts -->
      <script>
         document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('pc-sidebar');
            const desktopToggle = document.getElementById('sidebar-toggle-desktop');
            const mobileToggle = document.getElementById('mobile-sidebar-toggle');
            const colcont = document.getElementById('colcont');
            const toggleIcon = document.getElementById('toggle-icon');

            // --- Sidebar Toggle Logic ---
            function setSidebarState(collapsed) {
               if (collapsed) {
                  sidebar.classList.add('collapsed');
                  document.body.classList.add('collapsed');
                  toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />';
               } else {
                  sidebar.classList.remove('collapsed');
                  document.body.classList.remove('collapsed');
                  toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />';
               }
               localStorage.setItem('sidebar-collapsed', collapsed);
            }

            const savedState = localStorage.getItem('sidebar-collapsed') === 'true';
            setSidebarState(savedState);

            desktopToggle.addEventListener('click', () => {
               const isCollapsed = !sidebar.classList.contains('collapsed');
               setSidebarState(isCollapsed);
            });

            mobileToggle.addEventListener('click', (e) => {
               e.stopPropagation();
               sidebar.classList.toggle('open');
            });

            document.addEventListener('click', (e) => {
               if (window.innerWidth < 1024 && !sidebar.contains(e.target) && sidebar.classList.contains('open')) {
                  sidebar.classList.remove('open');
               }
            });

            // --- Active Background Indicator ---
            const navLinks = Array.from(document.querySelectorAll('.nav-link, .sub-nav-link'));
            const activeBg = document.getElementById('active-background');
            const nav = document.querySelector('nav');

            function updateActiveIndicator(el) {
               if (!el) return;
               const rect = el.getBoundingClientRect();
               const navRect = nav.getBoundingClientRect();
               activeBg.style.height = `${rect.height}px`;
               activeBg.style.top = `${rect.top - navRect.top}px`;
               activeBg.style.opacity = '1';
            }

            const currentPath = window.location.pathname;

            // Sort links by href length descending to match most specific first
            navLinks.sort((a, b) => (b.getAttribute('href')?.length || 0) - (a.getAttribute('href')?.length || 0));

            let matched = false;
            navLinks.forEach(link => {
               if (matched) return;
               const href = link.getAttribute('href');
               if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
                  link.classList.add('active');
                  updateActiveIndicator(link);
                  matched = true;

                  if (link.classList.contains('sub-nav-link')) {
                     const subMenu = document.getElementById('settings-sub-menu');
                     if (subMenu) {
                        subMenu.classList.remove('hidden');
                        document.getElementById('settings-arrow')?.classList.add('rotate-180');
                     }
                  }
               }
            });

            window.toggleSettingsDropdown = function() {
               const menu = document.getElementById('settings-sub-menu');
               const arrow = document.getElementById('settings-arrow');
               menu.classList.toggle('hidden');
               arrow.classList.toggle('rotate-180');
            };

            // --- Dropdowns Logic ---
            function setupDropdown(btnId, menuId) {
               const btn = document.getElementById(btnId);
               const menu = document.getElementById(menuId);
               if (!btn || !menu) return;

               btn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const isOpen = !menu.classList.contains('pointer-events-none');

                  // Close all other dropdowns
                  document.querySelectorAll('[id$="-dropdown"], #dropdown-menu').forEach(m => {
                     m.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
                  });

                  if (!isOpen) {
                     menu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
                  }
               });
            }

            setupDropdown('notif-link', 'notif-dropdown');
            setupDropdown('ping-link', 'ping-dropdown');
            setupDropdown('sidebar-lang-button', 'sidebar-lang-dropdown');

            document.addEventListener('click', () => {
               document.querySelectorAll('[id$="-dropdown"], #sidebar-lang-dropdown').forEach(m => {
                  m.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
               });
            });

            // --- Data Fetchers ---
            async function refreshNotifications() {
               try {
                  const res = await fetch('/api/notifications');
                  const notifs = await res.json();
                  const unreadCount = notifs.filter(n => !n.read).length;
                  const countEl = document.getElementById('notif-count');

                  if (unreadCount > 0) {
                     if (!countEl) {
                        const newCount = document.createElement('span');
                        newCount.id = 'notif-count';
                        newCount.className = 'absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-black text-white ring-2 ring-[#0a0a0a]';
                        newCount.textContent = unreadCount;
                        document.querySelector('#notif-link .relative').appendChild(newCount);
                     } else {
                        countEl.textContent = unreadCount;
                     }
                  } else if (countEl) {
                     countEl.remove();
                  }

                  const list = document.getElementById('notif-list');
                  if (notifs.length === 0) {
                     list.innerHTML = '<div class="px-4 py-8 text-center"><p class="text-xs text-neutral-600 font-medium">No system alerts found.</p></div>';
                  } else {
                     list.innerHTML = notifs.map(n => `
                        <div class="p-3 rounded-2xl hover:bg-white/5 transition-all group border border-transparent hover:border-white/5">
                           <div class="flex gap-3">
                              <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${n.type === 'error' ? 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]' : (n.type === 'warning' ? 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.5)]' : 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]')}"></div>
                              <div class="flex-1 min-w-0">
                                 <p class="text-xs text-neutral-200 leading-relaxed">${n.message}</p>
                                 <p class="text-[9px] text-neutral-600 font-bold mt-1 uppercase tracking-tighter">${new Date(n.timestamp).toLocaleString()}</p>
                              </div>
                           </div>
                        </div>
                     `).join('');
                  }
               } catch(e) {}
            }

            async function clearNotifs() {
               await fetch('/api/notifications/clear', { method: 'DELETE' });
               window.location.reload();
            }

            async function measurePing() {
               const start = performance.now();
               try {
                  await fetch('/ping', { cache: 'no-store' });
                  const latency = Math.round(performance.now() - start);
                  const el = document.getElementById('pingValue');
                  const dropEl = document.getElementById('ping-dropdown-value');
                  const dot = document.getElementById('ping-dot-status');

                  el.textContent = `${latency}`;
                  dropEl.textContent = `${latency}ms`;

                  if (latency < 100) { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-green-500 rounded-full border-2 border-[#1a1a1a]'; }
                  else if (latency < 250) { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-yellow-500 rounded-full border-2 border-[#1a1a1a]'; }
                  else { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-[#1a1a1a]'; }
               } catch(e) {}
            }

            setInterval(measurePing, 3000);
            setInterval(refreshNotifications, 10000);
            measurePing();
            refreshNotifications();
         });
      </script>
      <script src="/javascript/language/index.js"></script>
   </body>
</html>
