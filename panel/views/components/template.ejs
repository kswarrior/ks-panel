<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

      <style>
         :root {
            --sidebar-bg: rgba(10, 10, 10, 0.6);
            --header-bg: rgba(10, 10, 10, 0.4);
            --accent-color: #3b82f6;
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-blur: 16px;
         }

         body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
                        url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" %>');
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            background-attachment: fixed;
            color: #f8fafc;
         }

         /* Optimized Scrollbar */
         ::-webkit-scrollbar { width: 6px; height: 6px; }
         ::-webkit-scrollbar-track { background: transparent; }
         ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
         ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }

         /* Glassmorphism Classes */
         .glass {
            background: var(--sidebar-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
         }

         .nav-link {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
         }

         .nav-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, rgba(59, 130, 246, 0.1), transparent);
            transition: width 0.3s ease;
            z-index: -1;
         }

         .nav-link:hover::before, .nav-link.active::before {
            width: 100%;
         }

         .nav-link.active {
            color: #fff;
            background: rgba(255, 255, 255, 0.05);
         }

         .nav-link.active svg {
            color: var(--accent-color);
            filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.5));
         }

         #active-background {
            pointer-events: none;
            z-index: 0;
            background: linear-gradient(90deg, var(--accent-color), transparent);
            opacity: 0.15;
            width: 4px;
            left: 0;
            border-radius: 0 4px 4px 0;
         }

         /* Content Entry Animation */
         @keyframes contentFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
         }

         #content {
            animation: contentFadeIn 0.5s ease forwards;
         }

         /* Mobile Sidebar */
         @media (max-width: 1024px) {
            .sidebar {
               transform: translateX(-100%);
               transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
               opacity: 0;
               visibility: hidden;
            }
            .sidebar.open {
               transform: translateX(0);
               opacity: 1;
               visibility: visible;
            }
         }

         /* Sidebar Toggle Animation */
         .sidebar-toggle-btn {
            transition: all 0.2s ease;
         }
         .sidebar-toggle-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: scale(1.05);
         }

         /* Icon Pulse */
         .pulse-icon:hover {
            animation: iconPulse 1s infinite;
         }
         @keyframes iconPulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
         }

         /* Smooth transition for layout changes */
         #colcont {
            transition: padding 0.3s cubic-bezier(0.4, 0, 0.2, 1);
         }
      </style>
   </head>
   <body class="h-full">
      <!-- Sidebar -->
      <aside id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out fixed inset-y-0 z-50 flex flex-col w-64 lg:w-64 glass border-r border-white/5 group group-[.collapsed]:w-20">
         <div class="flex flex-col h-full">
            <!-- User Profile Section -->
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="p-6 border-b border-white/5">
               <div class="flex items-center gap-4">
                  <div class="relative">
                     <img class="w-10 h-10 rounded-xl object-cover border border-white/10"
                          src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
                     <div class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-green-500 border-2 border-black rounded-full"></div>
                  </div>
                  <div class="flex flex-col overflow-hidden transition-all duration-300 group-[.collapsed]:w-0 group-[.collapsed]:opacity-0">
                     <span class="text-sm font-bold text-white truncate"><%= user.username %></span>
                     <span class="text-[10px] font-medium text-neutral-400 uppercase tracking-widest">
                        <%= user.owner ? 'Owner' : (user.admin ? 'Administrator' : 'User') %>
                     </span>
                  </div>
               </div>
            </div>
            <% } %>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
               <div id="active-background" class="absolute transition-all duration-300 ease-in-out"></div>

               <!-- Dashboard Section -->
               <div class="mb-4">
                  <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Overview</p>
                  <a href="/instances" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                     </svg>
                     <span class="group-[.collapsed]:hidden"><%= req.translations.instances %></span>
                  </a>
                  <a href="/account" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden"><%= req.translations.account %></span>
                  </a>
               </div>

               <!-- Admin Section -->
               <% if (typeof user !== 'undefined' && user && user.admin) { %>
               <div class="pt-4 border-t border-white/5">
                  <p class="px-4 mb-2 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] group-[.collapsed]:hidden">Administration</p>
                  <a href="/admin/dashboard/console" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Insights</span>
                  </a>
                  <a href="/admin/settings" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden"><%= req.translations.settings %></span>
                  </a>
                  <a href="/admin/users" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden"><%= req.translations.users %></span>
                  </a>
                  <a href="/admin/instances/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">All Instances</span>
                  </a>
                  <a href="/admin/templates/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Templates</span>
                  </a>
                  <a href="/admin/nodes/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Nodes</span>
                  </a>
                  <a href="/admin/apikeys" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">API Keys</span>
                  </a>
                  <a href="/admin/plugins/overview" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Plugins</span>
                  </a>
                  <% if (user.permissions && (user.permissions['view_audit_logs'] === 'true' || user.permissions['view_audit_logs'] === true)) { %>
                  <a href="/admin/auditlogs" class="nav-link group flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-neutral-400 hover:text-white">
                     <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                     </svg>
                     <span class="group-[.collapsed]:hidden">Audit Logs</span>
                  </a>
                  <% } %>
               </div>
               <% } %>
            </nav>

            <!-- Bottom Actions -->
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="p-4 mt-auto border-t border-white/5">
               <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-red-400 hover:bg-red-500/10 transition-colors group">
                  <svg class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                  <span class="group-[.collapsed]:hidden">Sign Out</span>
               </a>
            </div>
            <% } %>
         </div>
      </aside>

      <!-- Main Layout -->
      <div id="colcont" class="lg:pl-64 transition-all duration-300 ease-in-out group-[.collapsed]:pl-20">
         <!-- Header -->
         <header class="sticky top-0 z-40 h-16 glass border-b border-white/5 px-4 sm:px-6 lg:px-8 flex items-center justify-between">
            <div class="flex items-center gap-4">
               <button id="mobile-sidebar-toggle" class="lg:hidden p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                  </svg>
               </button>
               <button id="sidebar-toggle-desktop" class="hidden lg:flex p-2 rounded-lg text-neutral-400 hover:text-white hover:bg-white/5 transition-all">
                  <svg id="toggle-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                  </svg>
               </button>

               <div class="flex items-center gap-3">
                  <img src="/assets/logo.webp" class="w-7 h-7 object-contain" alt="Logo">
                  <h1 class="text-lg font-bold text-white tracking-tight hidden sm:block"><%= name || 'KS Panel' %></h1>
               </div>
            </div>

            <!-- Top bar Actions -->
            <div class="flex items-center gap-2 sm:gap-4">
               <!-- Ping Monitor -->
               <div id="ping-link" class="relative group cursor-pointer p-2 rounded-lg hover:bg-white/5 transition-colors">
                  <div class="flex items-center gap-2">
                     <div class="relative">
                        <svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071a10 10 0 0114.142 0M2.828 8.929a15 15 0 0121.214 0" />
                        </svg>
                        <span id="ping-dot-status" class="absolute top-0 right-0 w-2 h-2 bg-green-500 rounded-full border-2 border-[#1a1a1a]"></span>
                     </div>
                     <span id="pingValue" class="text-xs font-mono text-neutral-400 font-bold">--ms</span>
                  </div>
                  <!-- Ping Dropdown -->
                  <div id="ping-dropdown" class="absolute right-0 mt-3 w-64 glass rounded-2xl p-4 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50">
                     <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-3">Latency Monitor</h3>
                     <div class="flex items-center justify-between">
                        <span class="text-sm text-white">Current Ping</span>
                        <span id="ping-dropdown-value" class="text-xl font-black text-blue-400">--ms</span>
                     </div>
                     <p id="ping-status-text" class="text-[10px] text-green-400 mt-2 font-bold uppercase">Optimal Connection</p>
                  </div>
               </div>

               <!-- Resource Monitor -->
               <div id="resource-link" class="relative group cursor-pointer p-2 rounded-lg hover:bg-white/5 transition-colors">
                  <svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                  <!-- Resource Dropdown -->
                  <div id="resource-dropdown" class="absolute right-0 mt-3 w-72 glass rounded-2xl p-5 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50">
                     <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-4">System Resources</h3>
                     <div class="space-y-4">
                        <div>
                           <div class="flex justify-between mb-1.5"><span class="text-xs text-neutral-400">Memory Usage</span><span id="ram-used" class="text-xs font-bold">--%</span></div>
                           <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"><div id="ram-bar" class="h-full bg-blue-500 transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                        <div>
                           <div class="flex justify-between mb-1.5"><span class="text-xs text-neutral-400">CPU Load</span><span id="cpu-percent" class="text-xs font-bold">--%</span></div>
                           <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"><div id="cpu-bar" class="h-full bg-emerald-500 transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                        <div>
                           <div class="flex justify-between mb-1.5"><span class="text-xs text-neutral-400">Disk I/O</span><span id="disk-used" class="text-xs font-bold">--%</span></div>
                           <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"><div id="disk-bar" class="h-full bg-purple-500 transition-all duration-500" style="width: 0%"></div></div>
                        </div>
                     </div>
                  </div>
               </div>

               <!-- Language & User -->
               <div class="relative">
                  <button id="user-menu-button" class="w-10 h-10 rounded-xl glass hover:bg-white/10 flex items-center justify-center transition-colors">
                     <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                     </svg>
                  </button>
                  <!-- Lang Dropdown -->
                  <div id="dropdown-menu" class="absolute right-0 mt-3 w-56 glass rounded-2xl p-2 shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-50">
                     <% languages.forEach(lang => { %>
                        <button onclick="changeLanguage('<%= lang %>')" class="w-full text-left px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-white/5 transition-colors uppercase tracking-widest text-neutral-400 hover:text-white">
                           <%= req.translations[lang] %>
                        </button>
                     <% }) %>
                  </div>
               </div>
            </div>
         </header>

         <!-- Page Content -->
         <div id="page-container" class="relative">

      <!-- Scripts -->
      <script>
         document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('pc-sidebar');
            const desktopToggle = document.getElementById('sidebar-toggle-desktop');
            const mobileToggle = document.getElementById('mobile-sidebar-toggle');
            const colcont = document.getElementById('colcont');
            const toggleIcon = document.getElementById('toggle-icon');

            // --- Sidebar Toggle Logic ---
            function setSidebarState(collapsed) {
               if (collapsed) {
                  sidebar.classList.add('collapsed');
                  document.body.classList.add('collapsed');
                  toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />';
               } else {
                  sidebar.classList.remove('collapsed');
                  document.body.classList.remove('collapsed');
                  toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />';
               }
               localStorage.setItem('sidebar-collapsed', collapsed);
            }

            const savedState = localStorage.getItem('sidebar-collapsed') === 'true';
            setSidebarState(savedState);

            desktopToggle.addEventListener('click', () => {
               const isCollapsed = !sidebar.classList.contains('collapsed');
               setSidebarState(isCollapsed);
            });

            mobileToggle.addEventListener('click', (e) => {
               e.stopPropagation();
               sidebar.classList.toggle('open');
            });

            document.addEventListener('click', (e) => {
               if (window.innerWidth < 1024 && !sidebar.contains(e.target) && sidebar.classList.contains('open')) {
                  sidebar.classList.remove('open');
               }
            });

            // --- Active Background Indicator ---
            const navLinks = document.querySelectorAll('.nav-link');
            const activeBg = document.getElementById('active-background');

            function updateActiveIndicator(el) {
               if (!el) return;
               const rect = el.getBoundingClientRect();
               const parentRect = el.parentElement.parentElement.getBoundingClientRect();
               activeBg.style.height = `${rect.height}px`;
               activeBg.style.top = `${rect.top - parentRect.top}px`;
               activeBg.style.opacity = '1';
            }

            const currentPath = window.location.pathname;
            navLinks.forEach(link => {
               if (currentPath.startsWith(link.getAttribute('href'))) {
                  link.classList.add('active');
                  updateActiveIndicator(link);
               }
            });

            // --- Dropdowns Logic ---
            function setupDropdown(btnId, menuId) {
               const btn = document.getElementById(btnId);
               const menu = document.getElementById(menuId);
               if (!btn || !menu) return;

               btn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const isOpen = !menu.classList.contains('pointer-events-none');

                  // Close all other dropdowns
                  document.querySelectorAll('[id$="-dropdown"], #dropdown-menu').forEach(m => {
                     m.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
                  });

                  if (!isOpen) {
                     menu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
                  }
               });
            }

            setupDropdown('ping-link', 'ping-dropdown');
            setupDropdown('resource-link', 'resource-dropdown');
            setupDropdown('user-menu-button', 'dropdown-menu');

            document.addEventListener('click', () => {
               document.querySelectorAll('[id$="-dropdown"], #dropdown-menu').forEach(m => {
                  m.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
               });
            });

            // --- Data Fetchers ---
            async function fetchStats() {
               try {
                  const res = await fetch('/resourceMonitor');
                  const data = await res.json();

                  // Update UI
                  document.getElementById('ram-used').textContent = `${data.ram.percent.toFixed(1)}%`;
                  document.getElementById('ram-bar').style.width = `${data.ram.percent}%`;

                  document.getElementById('cpu-percent').textContent = `${data.cpu.percent.toFixed(1)}%`;
                  document.getElementById('cpu-bar').style.width = `${data.cpu.percent}%`;

                  document.getElementById('disk-used').textContent = `${data.disk.percent.toFixed(1)}%`;
                  document.getElementById('disk-bar').style.width = `${data.disk.percent}%`;
               } catch(e) {}
            }

            async function measurePing() {
               const start = performance.now();
               try {
                  await fetch('/ping', { cache: 'no-store' });
                  const latency = Math.round(performance.now() - start);
                  const el = document.getElementById('pingValue');
                  const dropEl = document.getElementById('ping-dropdown-value');
                  const dot = document.getElementById('ping-dot-status');

                  el.textContent = `${latency}ms`;
                  dropEl.textContent = `${latency}ms`;

                  if (latency < 100) { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-green-500 rounded-full border-2 border-[#1a1a1a]'; }
                  else if (latency < 250) { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-yellow-500 rounded-full border-2 border-[#1a1a1a]'; }
                  else { dot.className = 'absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-[#1a1a1a]'; }
               } catch(e) {}
            }

            setInterval(fetchStats, 5000);
            setInterval(measurePing, 3000);
            fetchStats();
            measurePing();
         });
      </script>
      <script src="/javascript/language/index.js"></script>
   </body>
</html>
