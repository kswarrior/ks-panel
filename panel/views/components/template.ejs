   <!-- Main Content -->
   <div class="main-container" id="mainContainer">
      
      <!-- Header -->
      <header class="header">
         <!-- FIXED: Mobile toggle only visible on mobile -->
         <button class="menu-toggle" id="menuToggle" onclick="toggleSidebar()" aria-label="Toggle menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
               <path d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <div class="brand">
               <img src="/assets/logo.webp" class="brand-logo" alt="Logo">
               <span class="brand-name"><%= name || 'KS Panel' %></span>
            </div>
         </button>

         <!-- FIXED: Desktop brand only visible on desktop -->
         <div class="brand desktop-brand">
            <img src="/assets/logo.webp" class="brand-logo" alt="Logo">
            <span class="brand-name"><%= name || 'KS Panel' %></span>
         </div>

         <div class="header-actions">
            <!-- Update Icon -->
            <div style="position: relative;">
               <button class="icon-btn" id="updateBtn" aria-label="Update manager">
                  <svg id="updateIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                     <path d="M21 4v6h-6"/>
                     <path d="M3 20v-6h6"/>
                     <path d="M21 10a9 9 0 0 1 -9 9a9 9 0 0 1 -9 -9a9 9 0 0 1 9 -9"/>
                  </svg>
               </button>
               <div class="dropdown dropdown-wide" id="updateDropdown">
                  <h3 style="margin: 0 0 1rem; font-size: 1rem; font-weight: 600; color: white;">Update Manager</h3>
                  <button id="updateActionBtn" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2); cursor: pointer; font-size: 0.875rem; transition: all 0.2s;">Loading...</button>
               </div>
            </div>

            <!-- Ping Display -->
            <div class="ping-display" id="pingDisplay" title="Connection latency">
               <svg class="ping-icon" viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                  <path id="pingL3" d="M2 6C7-1 17-1 22 6" opacity="0.2"/>
                  <path id="pingL2" d="M5 10C9 5 15 5 19 10" opacity="0.2"/>
                  <path id="pingL1" d="M8.5 14C10.5 12 13.5 12 15.5 14" opacity="0.2"/>
                  <circle id="pingDot" cx="12" cy="18" r="1.8" fill="currentColor" opacity="0.2"/>
               </svg>
               <span id="pingValue">--</span>
            </div>

            <!-- Resource Monitor -->
            <div style="position: relative;">
               <button class="icon-btn" id="resourceBtn" aria-label="Resource monitor">
                  <svg class="resource-icon" viewBox="0 0 20 20">
                     <rect x="1" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="ramFill" x="1" y="18" width="3" height="0" fill="currentColor"/>
                     <rect x="8" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="cpuFill" x="8" y="18" width="3" height="0" fill="currentColor"/>
                     <rect x="15" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="diskFill" x="15" y="18" width="3" height="0" fill="currentColor"/>
                  </svg>
               </button>
               <div class="dropdown dropdown-wide" id="resourceDropdown">
                  <h3 style="margin: 0 0 1rem; font-size: 1rem; font-weight: 600; color: white;">Resource Monitor</h3>
                  
                  <div style="margin-bottom: 1rem;">
                     <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                        <span style="font-size: 0.875rem; color: rgba(255,255,255,0.9);">RAM</span>
                        <span id="ramText" style="font-size: 0.75rem; color: rgba(255,255,255,0.6);">--</span>
                     </div>
                     <div class="resource-bar-bg">
                        <div id="ramBar" class="resource-bar-fill" style="width: 0%; background: #22c55e;"></div>
                     </div>
                  </div>

                  <div style="margin-bottom: 1rem;">
                     <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                        <span style="font-size: 0.875rem; color: rgba(255,255,255,0.9);">CPU</span>
                        <span id="cpuText" style="font-size: 0.75rem; color: rgba(255,255,255,0.6);">--</span>
                     </div>
                     <div class="resource-bar-bg">
                        <div id="cpuBar" class="resource-bar-fill" style="width: 0%; background: #22c55e;"></div>
                     </div>
                  </div>

                  <div>
                     <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                        <span style="font-size: 0.875rem; color: rgba(255,255,255,0.9);">Disk</span>
                        <span id="diskText" style="font-size: 0.75rem; color: rgba(255,255,255,0.6);">--</span>
                     </div>
                     <div class="resource-bar-bg">
                        <div id="diskBar" class="resource-bar-fill" style="width: 0%; background: #22c55e;"></div>
                     </div>
                  </div>
               </div>
            </div>

            <!-- Language/User Menu -->
            <div style="position: relative;">
               <button class="icon-btn" id="userMenuBtn" aria-label="User menu" style="width: 2rem; height: 2rem;">
                  <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2.4">
                     <circle cx="14" cy="14" r="11.5"/>
                     <path d="M3 14H25" stroke-linecap="round"/>
                     <path d="M14 2.5C10 7 10 21 14 25.5" stroke-linecap="round"/>
                     <path d="M14 2.5C18 7 18 21 14 25.5" stroke-linecap="round"/>
                  </svg>
               </button>
               <div class="dropdown" id="userDropdown">
                  <label class="lang-label">Language</label>
                  <select class="lang-select" id="langSelect" onchange="changeLanguage(this.value)">
                     <% languages.forEach(function(language) { %>
                        <option value="<%= language %>" <%= (req.cookies.lang ? req.cookies.lang : 'en') === language ? 'selected' : '' %>>
                           <%= req.translations[language] %>
                        </option>
                     <% }); %>
                  </select>
               </div>
            </div>
         </div>
      </header>

      <!-- Page Content -->
      <main class="content" id="content">
         <!-- Content injected here -->
      </main>
   </div>

   <script>
      // Sidebar Toggle Logic - FIXED with body scroll lock
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');
      const mainContainer = document.getElementById('mainContainer');
      const body = document.body;
      let sidebarCollapsed = false;
      let scrollY = 0;

      function toggleSidebar() {
         if (window.innerWidth >= 1024) {
            // Desktop: toggle collapse
            sidebarCollapsed = !sidebarCollapsed;
            sidebar.classList.toggle('collapsed', sidebarCollapsed);
            mainContainer.classList.toggle('sidebar-collapsed', sidebarCollapsed);
            localStorage.setItem('sidebarCollapsed', sidebarCollapsed);
         } else {
            // Mobile: open drawer with body scroll lock [^6^]
            scrollY = window.scrollY;
            sidebar.classList.add('open');
            overlay.classList.add('active');
            body.classList.add('sidebar-open');
            body.style.top = `-${scrollY}px`;
         }
      }

      function closeSidebar() {
         sidebar.classList.remove('open');
         overlay.classList.remove('active');
         body.classList.remove('sidebar-open');
         body.style.top = '';
         window.scrollTo(0, scrollY);
      }

      // Restore desktop sidebar state
      if (window.innerWidth >= 1024) {
         sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
         sidebar.classList.toggle('collapsed', sidebarCollapsed);
         mainContainer.classList.toggle('sidebar-collapsed', sidebarCollapsed);
      }

      // Close sidebar on resize to mobile
      window.addEventListener('resize', () => {
         if (window.innerWidth < 1024) {
            sidebar.classList.remove('collapsed');
            mainContainer.classList.remove('sidebar-collapsed');
            if (sidebar.classList.contains('open')) {
               closeSidebar();
            }
         } else {
            sidebar.classList.toggle('collapsed', sidebarCollapsed);
            mainContainer.classList.toggle('sidebar-collapsed', sidebarCollapsed);
         }
      });

      // Dropdown Toggles
      function toggleDropdown(btnId, dropdownId) {
         const dropdown = document.getElementById(dropdownId);
         const isActive = dropdown.classList.contains('active');
         
         // Close all dropdowns
         document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
         
         if (!isActive) {
            dropdown.classList.add('active');
         }
      }

      // Update Dropdown
      document.getElementById('updateBtn').addEventListener('click', (e) => {
         e.stopPropagation();
         toggleDropdown('updateBtn', 'updateDropdown');
      });

      // Resource Dropdown
      document.getElementById('resourceBtn').addEventListener('click', (e) => {
         e.stopPropagation();
         toggleDropdown('resourceBtn', 'resourceDropdown');
      });

      // User Dropdown
      document.getElementById('userMenuBtn').addEventListener('click', (e) => {
         e.stopPropagation();
         toggleDropdown('userMenuBtn', 'userDropdown');
      });

      // Close dropdowns on outside click
      document.addEventListener('click', () => {
         document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
      });

      // Load plugin SVGs
      document.addEventListener('DOMContentLoaded', () => {
         document.querySelectorAll('.svg-icon').forEach(span => {
            const url = span.getAttribute('data-icon-url');
            if (url) {
               fetch(url)
                  .then(r => r.text())
                  .then(svg => {
                     span.innerHTML = svg;
                     const svgEl = span.querySelector('svg');
                     if (svgEl) {
                        svgEl.classList.add('nav-icon');
                        svgEl.style.width = '1.25rem';
                        svgEl.style.height = '1.25rem';
                     }
                  })
                  .catch(() => {
                     span.innerHTML = '<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/></svg>';
                  });
            }
         });
      });

      // Ping Monitor
      async function measurePing() {
         const start = performance.now();
         try {
            await fetch('/ping', { cache: 'no-store' });
            const latency = Math.round(performance.now() - start);
            
            document.getElementById('pingValue').textContent = latency;
            
            const l1 = document.getElementById('pingL1');
            const l2 = document.getElementById('pingL2');
            const l3 = document.getElementById('pingL3');
            const dot = document.getElementById('pingDot');
            
            const setSignal = (els, color) => {
               els.forEach(el => {
                  el.style.opacity = '1';
                  el.style.stroke = color;
                  el.style.filter = `drop-shadow(0 0 4px ${color})`;
               });
            };
            
            [l1, l2, l3, dot].forEach(el => {
               el.style.opacity = '0.2';
               el.style.stroke = 'currentColor';
               el.style.filter = 'none';
            });
            dot.style.fill = 'currentColor';
            
            if (latency < 100) {
               setSignal([l1, l2, l3, dot], '#22c55e');
               dot.style.fill = '#22c55e';
            } else if (latency < 200) {
               setSignal([l1, l2, dot], '#eab308');
               dot.style.fill = '#eab308';
            } else {
               setSignal([l1, dot], '#ef4444');
               dot.style.fill = '#ef4444';
            }
         } catch {
            document.getElementById('pingValue').textContent = '--';
         }
      }

      measurePing();
      setInterval(measurePing, 2500);

      // Resource Monitor
      function getColor(pct) {
         if (pct > 90) return '#ef4444';
         if (pct > 70) return '#eab308';
         return '#22c55e';
      }

      async function updateResources() {
         try {
            const res = await fetch('/resourceMonitor');
            const data = await res.json();
            
            // Update icon bars
            const maxH = 16;
            const updateIcon = (id, pct) => {
               const h = (pct / 100) * maxH;
               const y = 2 + (maxH - h);
               const el = document.getElementById(id);
               el.setAttribute('y', y);
               el.setAttribute('height', h);
               el.setAttribute('fill', getColor(pct));
            };
            
            updateIcon('ramFill', data.ram.percent);
            updateIcon('cpuFill', data.cpu.percent);
            updateIcon('diskFill', data.disk.percent);
            
            // Update dropdown if open
            if (document.getElementById('resourceDropdown').classList.contains('active')) {
               document.getElementById('ramText').textContent = `${data.ram.used.toFixed(1)} / ${data.ram.total.toFixed(1)} GB (${Math.round(data.ram.percent)}%)`;
               document.getElementById('ramBar').style.width = `${data.ram.percent}%`;
               document.getElementById('ramBar').style.background = getColor(data.ram.percent);
               
               document.getElementById('cpuText').textContent = `${Math.round(data.cpu.percent)}%`;
               document.getElementById('cpuBar').style.width = `${data.cpu.percent}%`;
               document.getElementById('cpuBar').style.background = getColor(data.cpu.percent);
               
               document.getElementById('diskText').textContent = `${data.disk.used.toFixed(1)} / ${data.disk.total.toFixed(1)} GB (${Math.round(data.disk.percent)}%)`;
               document.getElementById('diskBar').style.width = `${data.disk.percent}%`;
               document.getElementById('diskBar').style.background = getColor(data.disk.percent);
            }
         } catch (err) {
            console.error('Resource monitor error:', err);
         }
      }

      updateResources();
      setInterval(updateResources, 2500);

      // Update Checker
      function checkVersion() {
         fetch('/version')
            .then(r => r.json())
            .then(data => {
               const icon = document.getElementById('updateIcon');
               const btn = document.getElementById('updateActionBtn');
               
               if (data.status === 'outdated') {
                  icon.style.stroke = '#eab308';
                  btn.textContent = `Update v${data.currentVersion} → v${data.latestVersion}`;
                  btn.onclick = () => {
                     if (confirm('Update now? This will restart the server.')) {
                        fetch('/update', { method: 'POST' })
                           .then(() => alert('Update started'))
                           .catch(() => alert('Update failed'));
                     }
                  };
               } else {
                  icon.style.stroke = '#22c55e';
                  btn.textContent = `Reinstall v${data.currentVersion}`;
                  btn.onclick = () => {
                     if (confirm('Reinstall now? This will restart the server.')) {
                        fetch('/reinstall', { method: 'GET' })
                           .then(() => alert('Reinstall started'))
                           .catch(() => alert('Reinstall failed'));
                     }
                  };
               }
            })
            .catch(() => {
               document.getElementById('updateActionBtn').textContent = 'Error loading version';
            });
      }

      checkVersion();
      setInterval(checkVersion, 5000);

      // Language Change
      function changeLanguage(lang) {
         document.cookie = `lang=${lang};path=/;max-age=31536000`;
         location.reload();
      }

      // Active Link Handler
      document.querySelectorAll('.nav-link').forEach(link => {
         link.addEventListener('click', (e) => {
            const href = link.getAttribute('href');
            if (href && !href.startsWith('http')) {
               e.preventDefault();
               document.getElementById('content').style.opacity = '0';
               document.getElementById('content').style.transform = 'translateX(-10px)';
               setTimeout(() => {
                  window.location.href = href;
               }, 150);
            }
         });
      });
   </script>
   <script src="/javascript/search/index.js"></script>
