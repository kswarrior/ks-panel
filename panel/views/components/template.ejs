<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
      
      <!-- CRITICAL SIDEBAR STYLES - DO NOT MODIFY -->
      <style>
         /* Base sidebar styles */
         .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 215px;
            z-index: 50;
            transform: translateX(-100%);
            transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            pointer-events: none; /* Allow clicks through when closed */
         }
         
         /* Mobile open state */
         .sidebar.mobile-open {
            transform: translateX(0);
            pointer-events: auto;
         }
         
         /* Desktop styles */
         @media (min-width: 1024px) {
            .sidebar {
               position: fixed;
               display: flex;
               transform: none;
               pointer-events: auto;
               width: 14rem; /* 56 * 0.25rem */
            }
            
            .sidebar.collapsed {
               width: 4rem;
            }
            
            /* Hide mobile toggle on desktop */
            #mobile-header-toggle {
               display: none !important;
            }
         }
         
         /* Mobile overlay backdrop */
         .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 40;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s ease;
         }
         
         .sidebar-overlay.active {
            opacity: 1;
            visibility: visible;
         }
         
         /* Content area adjustments */
         #colcont {
            transition: padding-left 0.3s ease;
         }
         
         @media (min-width: 1024px) {
            #colcont {
               padding-left: 14rem;
            }
            
            #colcont.collapsed {
               padding-left: 4rem;
            }
         }
         
         /* Active nav indicator */
         #active-background {
            position: absolute;
            left: 1rem;
            right: 1rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            transition: transform 0.3s ease, height 0.3s ease, opacity 0.3s ease;
            pointer-events: none;
            opacity: 0;
         }
         
         #active-background.visible {
            opacity: 1;
         }
         
         /* Dropdown menus glassmorphism */
         #update-dropdown,
         #resource-dropdown,
         #dropdown-menu {
            backdrop-filter: blur(var(--backdrop-blur, 12px));
            -webkit-backdrop-filter: blur(var(--backdrop-blur, 12px));
            background: rgba(0, 0, 0, 0.6);
         }
         
         /* Mobile specific fixes */
         @media (max-width: 1023px) {
            .sidebar .nav-text {
               display: inline !important;
            }
            
            .sidebar nav ul {
               overflow-y: auto;
               -webkit-overflow-scrolling: touch;
            }
         }
         
         /* Safe area for mobile devices */
         @supports (padding-top: env(safe-area-inset-top)) {
            @media (max-width: 1023px) {
               .sidebar {
                  padding-top: env(safe-area-inset-top);
                  height: 100dvh; /* Dynamic viewport height */
               }
            }
         }
      </style>
   </head>
