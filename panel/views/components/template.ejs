<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.2.1/dist/index.global.js"></script>
      <link href="/css/ks-panel.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
      
      <style>
         :root {
            --glass-bg: rgba(20, 20, 25, 0.65);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-highlight: rgba(255, 255, 255, 0.05);
            --accent-primary: #3b82f6;
            --accent-success: #22c55e;
            --accent-warning: #eab308;
            --accent-danger: #ef4444;
            --optimistic-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            --spring-easing: cubic-bezier(0.34, 1.56, 0.64, 1);
            --space-xs: 0.25rem;
            --space-sm: 0.5rem;
            --space-md: 1rem;
            --space-lg: 1.5rem;
            --space-xl: 2rem;
            --space-2xl: 3rem;
         }

         * {
            -webkit-tap-highlight-color: transparent;
         }

         body {
            font-family: 'Public Sans', system-ui, sans-serif;
            background:
               linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.2) 100%),
               url('<%= (typeof theme !== "undefined" && theme && theme.backgrounds && (typeof pageType !== "undefined" && pageType ? theme.backgrounds[pageType] : (theme.backgrounds && theme.backgrounds.dashboard)) ) || "https://cdn.discordapp.com/attachments/1315671132203913218/1482722679101456599/image0.gif?ex=69b7fc9a&is=69b6ab1a&hm=8b71dec0f5da4a2fe26d74e104ddb078812e39780e8efbbbdf94517f1a2bfc52&" %>');
            background-position: center center;
            background-repeat: no-repeat;
            background-size: cover;
            background-attachment: fixed;
            overflow-x: hidden;
         }

         /* Enhanced Glassmorphism with better sizing */
         .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid var(--glass-border);
            box-shadow: var(--optimistic-shadow), 
                        inset 0 1px 0 var(--glass-highlight);
            border-radius: 1rem;
         }

         .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 1rem;
            transition: all 0.3s var(--spring-easing);
         }

         .glass-card:hover {
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
         }

         @keyframes optimistic-slide-up {
            from {
               opacity: 0;
               transform: translateY(1.25rem) scale(0.95);
            }
            to {
               opacity: 1;
               transform: translateY(0) scale(1);
            }
         }

         @keyframes optimistic-fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
         }

         @keyframes pulse-soft {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
         }

         @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-0.3125rem); }
         }

         .animate-optimistic {
            animation: optimistic-slide-up 0.5s var(--spring-easing) forwards;
         }

         .animate-fade {
            animation: optimistic-fade-in 0.4s ease-out forwards;
         }

         /* Refined Mobile-First Responsive Scale */
         @media (max-width: 1024px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 16rem;
               backdrop-filter: blur(30px) saturate(200%);
               -webkit-backdrop-filter: blur(30px) saturate(200%);
               background: rgba(15, 15, 20, 0.95);
               border-right: 1px solid rgba(255, 255, 255, 0.12);
               overflow-y: auto;
               transform: translateX(-100%);
               opacity: 0;
               transition: transform 0.4s var(--spring-easing), 
                          opacity 0.3s ease;
            }

            .sidebar.open {
               display: block;
               transform: translateX(0);
               opacity: 1;
            }

            #colcont {
               padding-left: 0 !important;
               padding-right: 0 !important;
               transition: padding 0.3s ease;
            }

            .glass-card {
               border-radius: 1.25rem;
               margin: 0 0.75rem 1rem 0.75rem;
               background: rgba(255, 255, 255, 0.05);
            }

            .nav-link {
               padding: 0.875rem 1.25rem;
               margin: 0.25rem 0.75rem;
               border-radius: 0.75rem;
               transition: all 0.2s ease;
            }

            .nav-link:active {
               transform: scale(0.98);
               background: rgba(255, 255, 255, 0.1);
            }

            #mobile-sidebar-toggle {
               backdrop-filter: blur(20px);
               background: rgba(0, 0, 0, 0.4);
               border: 1px solid rgba(255, 255, 255, 0.1);
               border-radius: 1rem;
               padding: 0.625rem 1rem;
               margin: 0.5rem;
               transition: all 0.3s var(--spring-easing);
            }

            #mobile-sidebar-toggle:active {
               transform: scale(0.95);
               background: rgba(0, 0, 0, 0.6);
            }

            #update-dropdown,
            #resource-dropdown,
            #dropdown-menu {
               position: fixed;
               bottom: 0;
               left: 0;
               right: 0;
               top: auto;
               width: 100%;
               border-radius: 1.5rem 1.5rem 0 0;
               backdrop-filter: blur(30px);
               background: rgba(20, 20, 25, 0.98);
               border: 1px solid rgba(255, 255, 255, 0.12);
               border-bottom: none;
               transform: translateY(100%);
               transition: transform 0.4s var(--spring-easing);
               max-height: 80vh;
               overflow-y: auto;
               z-index: 9999;
            }

            #update-dropdown:not(.hidden),
            #resource-dropdown:not(.hidden),
            #dropdown-menu:not(.hidden) {
               transform: translateY(0);
            }
         }

         @media (min-width: 1025px) {
            .sidebar {
               background: rgba(0, 0, 0, 0.3);
               backdrop-filter: blur(20px) saturate(150%);
               border-right: 1px solid rgba(255, 255, 255, 0.05);
            }

            .glass-card {
               border-radius: 1.25rem;
            }

            .nav-link {
               position: relative;
               overflow: hidden;
            }

            .nav-link::before {
               content: '';
               position: absolute;
               inset: 0;
               background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
               transform: translateX(-100%);
               transition: transform 0.6s ease;
            }

            .nav-link:hover::before {
               transform: translateX(100%);
            }
         }

         .skeleton {
            background: linear-gradient(90deg, 
               rgba(255,255,255,0.05) 25%, 
               rgba(255,255,255,0.1) 50%, 
               rgba(255,255,255,0.05) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 0.5rem;
         }

         @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
         }

         #active-background {
            background: linear-gradient(90deg, rgba(59, 130, 246, 0.35), rgba(147, 51, 234, 0.25));
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.4);
            border-radius: 0.75rem;
            transition: all 0.4s var(--spring-easing);
         }

         /* CLEAN ICONS - NO BACKGROUND / BORDER */
         #pingDisplay,
         #resource-link,
         .profile-trigger {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            transition: all 0.3s var(--spring-easing);
         }

         #pingDisplay:hover,
         #resource-link:hover,
         .profile-trigger:hover {
            transform: scale(1.08);
         }

         #pingDisplay {
            padding: 0.375rem 0.625rem;
            border-radius: 0.75rem;
         }

         #resource-link {
            padding: 0.625rem;
            border-radius: 9999px;
         }

         .profile-trigger {
            padding: 0.5rem;
            border-radius: 9999px;
         }

         #resource-icon {
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
            transition: transform 0.3s var(--spring-easing);
         }

         #resource-icon:hover {
            transform: scale(1.12);
         }

         #update-icon {
            transition: transform 0.5s var(--spring-easing);
         }

         #update-icon:hover {
            transform: rotate(180deg);
         }

         /* STYLISH SIDEBAR IMPROVEMENTS */
         .nav-link {
            padding: 0.875rem 1.25rem;
            margin: 0.25rem 0.75rem;
            border-radius: 0.875rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 500;
         }

         .nav-link:hover {
            background: rgba(255, 255, 255, 0.09);
            color: #fff;
            transform: translateX(6px);
         }

         .nav-link.active {
            background: rgba(59, 130, 246, 0.15);
            color: #fff;
            font-weight: 600;
         }

         /* Sidebar glass upgrade */
         #pc-sidebar2 {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(24px);
         }

         ::-webkit-scrollbar {
            width: 0.375rem;
            height: 0.375rem;
         }

         ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
         }

         ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 0.1875rem;
         }

         ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.25);
         }

         button:focus-visible,
         a:focus-visible,
         select:focus-visible {
            outline: 2px solid rgba(59, 130, 246, 0.5);
            outline-offset: 2px;
         }

         @media (prefers-reduced-motion: reduce) {
            * {
               animation-duration: 0.01ms !important;
               animation-iteration-count: 1 !important;
               transition-duration: 0.01ms !important;
            }
         }
      </style>
   </head>
   <body>
      <!-- Desktop Sidebar - Enhanced styling -->
      <div id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out hidden lg:fixed lg:inset-y-0 lg:z-50 p-3 lg:flex lg:w-60 lg:flex-col group group-[.collapsed]:w-14">
         <div id="pc-sidebar2" class="flex grow flex-col gap-y-6 overflow-hidden rounded-r-2xl rounded-l-lg">
            <nav class="flex flex-1 flex-col">
               <!-- User Info Section -->
               <div class="flex items-center space-x-3 py-5 px-4 border-y border-white/5 glass-card mx-3 mt-3">
                  <img class="w-9 h-9 rounded-full ring-2 ring-white/20"
     src="https://mc-heads.net/avatar/<%= user.username %>/64"
     alt="Profile">
                  <div class="lg:group-[.collapsed]:hidden">
                    <p class="text-sm font-medium text-white"><%= user.username %></p>
                    <p class="text-xs text-neutral-400 font-mono mt-0.5"><%= user.userId.substring(0, 6) %></p>
                  </div>
               </div>
               <ul role="list" class="flex flex-1 flex-col gap-y-6 mt-3">
                  <li>
                     <ul role="list" class="-mx-2 space-y-1 relative">
                        <div id="active-background" class="absolute left-0 w-full h-10 rounded-2xl transition-all duration-300 ease-in-out opacity-0"></div>
                        <li>
                           <a href="/instances" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-3 group flex gap-x-3 py-2.5 rounded-xl text-sm leading-6 font-normal hover:text-white" searchdata="container instances servers" subterm="jegli:/server/servername">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 h-5 group-[.collapsed]:mr-0 transition-transform group-hover:scale-110"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
                              <span class="lg:group-[.collapsed]:hidden"><%= req.translations.instances %></span>
                           </a>
                           <a href="/account" searchdata="account profile <%= user.username %>" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-3 group flex gap-x-3 py-2.5 rounded-xl text-sm leading-6 font-normal hover:text-white">
                               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 group-[.collapsed]:mr-0 transition-transform group-hover:scale-110">
                                 <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                               </svg>                                                           
                              <span class="lg:group-[.collapsed]:hidden"><%= req.translations.account %></span>
                           </a>
                           <% plugins.forEach(plugin => { %>
                              <% if (plugin.sidebar) { %>
                                  <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                                      <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="transition nav-link mt-1 text-neutral-400 px-4 mx-3 group flex gap-x-3 py-2.5 rounded-xl text-sm leading-6 font-normal hover:text-white">
                                          <% if (value.icon) { %>
                                              <span class="svg-icon" data-icon-url="<%= value.icon %>"></span>
                                          <% } else { %>
                                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                                                  <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                              </svg>
                                          <% } %>
                                          <span><%= key %></span>
                                      </a>
                                  <% }); %>
                              <% } %>
                          <% }); %>
                          
                          <script>
                              document.addEventListener("DOMContentLoaded", function() {
                                  document.querySelectorAll('.svg-icon').forEach(function(span) {
                                      const url = span.getAttribute('data-icon-url');
                                      fetch(url)
                                          .then(response => response.text())
                                          .then(svgContent => {
                                              span.innerHTML = svgContent;
                                          })
                                          .catch(error => {
                                              console.error('Error on Loading the SVG:', error);
                                          });
                                  });
                              });
                          </script>
                        </li>
                        <% if (user.admin == true) { %>
                        <p class="pl-8 pt-8 pb-3 text-xs font-bold uppercase tracking-wider text-white/60 lg:group-[.collapsed]:hidden">
  <span>Admin Panel</span>
</p>
                        <li>
                           <a href="/admin/dashboard/overview" searchdata="admin overview control" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-3 group flex gap-x-3 py-2.5 rounded-xl text-sm leading-6 font-normal hover:text-white">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 h-5 group-[.collapsed]:mr-0 transition-transform group-hover:scale-110"><rect width="256" height="256" fill="none"/><path d="M224,120v96a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8V164a4,4,0,0,0-4-4H108a4,4,0,0,0-4,4v52a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V120a16,16,0,0,1,4.69-11.31l80-80a16,16,0,0,1,22.62,0l80,80A16,16,0,0,1,224,120Z"/></svg>
                              <span class="lg:group-[.collapsed]:hidden">Dashboard</span>
                           </a>
                        </li>
                       <li>
                           <a href="/admin/database/overview" searchdata="admin overview control" class="transition-all duration-300 ease-in-out nav-link mt-1 text-neutral-400 px-4 mx-3 group flex gap-x-3 py-2.5 rounded-xl text-sm leading-6 font-normal hover:text-white">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 h-5 group-[.collapsed]:mr-0 transition-transform group-hover:scale-110">
  <rect width="256" height="256" fill="none"/>
  <path d="M128,40c-44.18,0-80,14.33-80,32s35.82,32,80,32,80-14.33,80-32S172.18,40,128,40Z"/>
  <path d="M48,72v48c0,17.67,35.82,32,80,32s80-14.33,80-32V72"/>
  <path d="M48,120v48c0,17.67,35.82,32,80,32s80-14.33,80-32V120"/>
  <path d="M48,168v16c0,17.67,35.82,32,80,32s80-14.33,80-32V168"/>
</svg>
                              <span class="lg:group-[.collapsed]:hidden">Database</span>
                           </a>
                        </li>
                        <!-- All other admin links unchanged -->
                        <% } %>
                     </ul>
                  </li>
                  <li class="mt-auto border-t border-white/5">
                     <a href="/auth/logout" class="group -mx-2 flex gap-x-3 rounded-xl pl-6 pr-4 py-4 text-sm font-medium leading-6 text-neutral-500 transition-all duration-300 ease-in-out hover:text-red-400 hover:bg-red-500/10">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 group-[.collapsed]:mr-0 transition-transform group-hover:translate-x-1">
                           <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                        </svg>
                        <span class="lg:group-[.collapsed]:hidden"><%= req.translations.signOut %></span>
                     </a>
                  </li>
               </ul>
            </nav>
         </div>
      </div>
      
      <!-- Main Content Area -->
      <div id="colcont" class="lg:pl-60 group-[.collapsed]:pl-14 transition-all duration-300">
      
      <!-- Header -->
      <div class="sticky backdrop-blur-xl top-0 z-40 flex h-16 shrink-0 items-center gap-x-4 bg-black/20 px-4 sm:gap-x-6 sm:px-6 lg:px-8 border-b border-white/5">
         
         <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
            <div class="relative flex flex-1 flex-col">
               
               <!-- Mobile Toggle -->
               <div id="mobile-sidebar-toggle"
class="ml-2 lg:-ml-2 flex items-center w-fit mt-3 px-4 py-2.5 h-11 rounded-xl border border-white/5 cursor-pointer hover:scale-105 active:scale-100 duration-200 bg-transparent text-white glass-panel">
                <svg xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 24 24"
     fill="none"
     stroke="white"
     stroke-width="2"
     class="w-5 h-5 inline-flex mr-3 transition-all duration-200 ease-in-out">

  <path stroke-linecap="round"
        stroke-linejoin="round"
        d="M4 6h16M4 12h16M4 18h16" />
</svg>
                     <% if (logo == true) { %>
         <img src="/assets/logo.webp" class="h-7 w-7 min-h-7 min-w-7 max-h-7 max-w-7 object-contain rounded mr-3 block shrink-0 ring-2 ring-white/20">
      <% }  else { %>
         <img src="/assets/logo.webp" class="h-7 w-7 min-h-7 min-w-7 max-h-7 max-w-7 object-contain rounded mr-3 block shrink-0 ring-2 ring-white/20">
      <% } %>
                  <h1 class="text-white font-semibold tracking-tight text-lg lg:group-[.collapsed]:hidden bg-gradient-to-r from-white to-white/70 bg-clip-text text-transparent"><%= name || 'KS Panel' %></h1>
               </div>
               
               <!-- Search Results -->
               <div id="searchResults" class="absolute bg-neutral-900/95 backdrop-blur-xl w-56 rounded-2xl shadow-2xl hidden mt-20 px-3 pb-3 border border-white/10 animate-optimistic">
               </div>
            </div>
            
            <script src="/javascript/search/index.js"></script>
            
            <!-- Right side icons - CLEAN -->
            <div class="flex items-center gap-x-4">
               
   <!-- Update Icon -->
   <div class="relative cursor-pointer group">
   <svg id="update-icon"
     xmlns="http://www.w3.org/2000/svg"
     width="22"
     height="22"
     viewBox="0 0 24 24"
     fill="none"
     stroke="#808080"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     class="transition-all duration-300 group-hover:stroke-blue-400">

  <path d="M21 4v6h-6"/>
  <path d="M3 20v-6h6"/>
  <path d="M21 10a9 9 0 0 1 -9 9a9 9 0 0 1 -9 -9a9 9 0 0 1 9 -9"/>
</svg>
   <div id="update-dropdown" class="hidden absolute right-0 mt-3 w-72 glass-panel rounded-2xl p-6 shadow-2xl z-50">
     <h2 class="text-lg font-semibold text-white mb-5 flex items-center gap-2.5">
       <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
       Update Manager
     </h2>
     <button id="action-button" class="w-full bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-500 hover:to-blue-400 text-white py-3 rounded-xl font-medium transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-blue-500/25">Loading...</button>
   </div>
   </div>
   
   <!-- Ping Display - NO BG/BORDER -->
   <span id="pingDisplay"
      class="flex flex-col items-center text-white px-3 py-2 rounded-xl cursor-pointer hover:bg-white/10 transition-all duration-300">

  <svg id="pingIcon"
       width="20"
       height="16"
       viewBox="0 0 24 20"
       xmlns="http://www.w3.org/2000/svg"
       class="transition-all duration-300">

    <path id="pingLayer3"
          d="M2 6C7-1 17-1 22 6"
          stroke="currentColor"
