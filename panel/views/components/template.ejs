<!doctype html>
<html>
   <!--
     
   HEAD SECTION
     
   -->
   <head>
      <title><%= name || 'KS Panel' %></title>
      <link rel="icon" href="/assets/logo.webp" type="image/webp">

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <link href="/css/ks-panel.css" rel="stylesheet">
   </head>
   <body class="body-base">
      <!--
     
      SIDEBAR (Desktop & Mobile Unified)
     
      -->
      <div id="sidebar" class="sidebar">
         <div class="sidebar-content">
            <nav class="nav">
               <!--
               
      USER INFO SECTION
               
               -->
               <div class="user-info">
                  <img class="avatar" src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Profile">
                  <div class="user-details collapsed-hidden">
                     <p class="username"><%= user.username %></p>
                     <p class="user-id"><%= user.userId.substring(0, 6) %></p>
                  </div>
               </div>
               <ul role="list" class="nav-list">
                  <div id="active-background" class="active-background"></div>
                  <li class="nav-item">
                     <a href="/instances" class="nav-link" searchdata="container instances servers" subterm="jegli:/server/servername">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/>
                           <path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/>
                           <path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.instances %></span>
                     </a>
                     <a href="/account" searchdata="account profile <%= user.username %>" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                        </svg>                                                           
                        <span class="nav-label collapsed-hidden"><%= req.translations.account %></span>
                     </a>
                     <% plugins.forEach(plugin => { %>
                        <% if (plugin.sidebar) { %>
                            <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                                <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="nav-link">
                                    <% if (value.icon) { %>
                                        <span class="svg-icon" data-icon-url="<%= value.icon %>"></span>
                                    <% } else { %>
                                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                            <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                        </svg>
                                    <% } %>
                                    <span class="nav-label collapsed-hidden"><%= key %></span>
                                </a>
                            <% }); %>
                        <% } %>
                    <% }); %>
                    
                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            document.querySelectorAll('.svg-icon').forEach(function(span) {
                                const url = span.getAttribute('data-icon-url');
                        
                                fetch(url)
                                    .then(response => {
                                        if (!response.ok) {
                                            throw new Error('Network response was not ok');
                                        } else if (response.status !== 200) {
                                            throw new Error(`Request failed with status ${response.status}`);
                                        } else if (!response.text().includes('<svg')) {
                                           throw new Error('Response does not contain an SVG');
                                        }
                                        return response.text();
                                    })
                                    .then(svgContent => {
                                        span.innerHTML = svgContent;
                                    })
                                    .catch(error => {
                                        console.error('Error on Loading the SVG:', error);
                                    });
                            });
                        });
                    </script>
                    
                  </li>
                  <% if (user.admin == true) { %>
                  <li class="admin-header">
                     <p class="section-title collapsed-hidden">Admin Panel</p>
                  </li>
                  <li class="nav-item">
                     <a href="/admin/overview" searchdata="admin overview control" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M224,120v96a8,8,0,0,1-8,8H160a8,8,0,0,1-8-8V164a4,4,0,0,0-4-4H108a4,4,0,0,0-4,4v52a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V120a16,16,0,0,1,4.69-11.31l80-80a16,16,0,0,1,22.62,0l80,80A16,16,0,0,1,224,120Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.overview %></span>
                     </a>
                     <a href="/admin/settings" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M237.94,107.21a8,8,0,0,0-3.89-5.4l-29.83-17-.12-33.62a8,8,0,0,0-2.83-6.08,111.91,111.91,0,0,0-36.72-20.67,8,8,0,0,0-6.46.59L128,41.85,97.88,25a8,8,0,0,0-6.47-.6A111.92,111.92,0,0,0,54.73,45.15a8,8,0,0,0-2.83,6.07l-.15,33.65-29.83,17a8,8,0,0,0-3.89,5.4,106.47,106.47,0,0,0,0,41.56,8,8,0,0,0,3.89,5.4l29.83,17,.12,33.63a8,8,0,0,0,2.83,6.08,111.91,111.91,0,0,0,36.72,20.67,8,8,0,0,0,6.46-.59L128,214.15,158.12,231a7.91,7.91,0,0,0,3.9,1,8.09,8.09,0,0,0,2.57-.42,112.1,112.1,0,0,0,36.68-20.73,8,8,0,0,0,2.83-6.07l.15-33.65,29.83-17a8,8,0,0,0,3.89-5.4A106.47,106.47,0,0,0,237.94,107.21ZM128,168a40,40,0,1,1,40-40A40,40,0,0,1,128,168Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.settings %></span>
                     </a>
                     <a href="/admin/users" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M7 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM14.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM1.615 16.428a1.224 1.224 0 0 1-.569-1.175 6.002 6.002 0 0 1 11.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 0 1 7 18a9.953 9.953 0 0 1-5.385-1.572ZM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 0 0-1.588-3.755 4.502 4.502 0 0 1 5.874 2.636.818.818 0 0 1-.36.98A7.465 7.465 0 0 1 14.5 16Z" />
                        </svg>                               
                        <span class="nav-label collapsed-hidden"><%= req.translations.users %></span>
                     </a>
                     <a href="/admin/instances" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M24,80a8,8,0,0,1,4-6.91l96-56a8,8,0,0,1,8.06,0l96,56a8,8,0,0,1,0,13.82l-96,56a8,8,0,0,1-8.06,0l-96-56A8,8,0,0,1,24,80Zm196,41.09-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09ZM232,192H216V176a8,8,0,0,0-16,0v16H184a8,8,0,0,0,0,16h16v16a8,8,0,0,0,16,0V208h16a8,8,0,0,0,0-16Zm-92,23.76-12,7L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l16-9.33A8,8,0,1,0,140,215.76Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.instances %></span>
                     </a>
                     <a href="/admin/templates/overview" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                           <path d="M4 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4zm2 2v3h12V6H6zm0 5v9h4v-9H6zm6 0v4h6v-4h-6zm0 6v3h6v-3h-6z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.templates %></span>
                     </a>
                     <a href="/admin/nodes" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM180,92a12,12,0,1,1,12-12A12,12,0,0,1,180,92Z"/>
                           <path d="M208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm-28,52a12,12,0,1,1,12-12A12,12,0,0,1,180,188Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.nodes %></span>
                     </a>
                     <a href="/admin/locations" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                           <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.location %></span>
                     </a>
                     <a href="/admin/plugins/overview" searchdata="addons plugins admin" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M165.78,224H208a16,16,0,0,0,16-16V170.35A8,8,0,0,0,212.94,163a23.37,23.37,0,0,1-8.94,1.77c-13.23,0-24-11.1-24-24.73s10.77-24.73,24-24.73a23.37,23.37,0,0,1,8.94,1.77A8,8,0,0,0,224,109.65V72a16,16,0,0,0-16-16H171.78a35.36,35.36,0,0,0,.22-4,36,36,0,0,0-72,0,35.36,35.36,0,0,0,.22,4H64A16,16,0,0,0,48,72v32.22a35.36,35.36,0,0,0-4-.22,36,36,0,0,0,0,72,35.36,35.36,0,0,0,4-.22V208a16,16,0,0,0,16,16h42.22"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.plugins %></span>
                     </a>
                     <a href="/admin/apikeys" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M216.57,39.43A80,80,0,0,0,83.91,120.78L28.69,176A15.86,15.86,0,0,0,24,187.31V216a16,16,0,0,0,16,16H72a8,8,0,0,0,8-8V208H96a8,8,0,0,0,8-8V184h16a8,8,0,0,0,5.66-2.34l9.56-9.57A79.73,79.73,0,0,0,160,176h.1A80,80,0,0,0,216.57,39.43ZM180,92a16,16,0,1,1,16-16A16,16,0,0,1,180,92Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.APIKeys %></span>
                     </a>
                     <a href="/admin/auditlogs" searchdata="audit logs admin" class="nav-link">
                        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                           <rect width="256" height="256" fill="none"/>
                           <path d="M220.8,169.6A8,8,0,0,0,216,168h-8V64a32,32,0,0,0-32-32H40A32,32,0,0,0,8,64C8,77.61,18.05,85.54,19.2,86.4h0A7.89,7.89,0,0,0,24,88a8,8,0,0,0,4.87-14.33h0C28.83,73.62,24,69.74,24,64a16,16,0,0,1,32,0V192a32,32,0,0,0,32,32H200a32,32,0,0,0,32-32C232,178.39,222,170.46,220.8,169.6ZM104,96h64a8,8,0,0,1,0,16H104a8,8,0,0,1,0-16Zm-8,40a8,8,0,0,1,8-8h64a8,8,0,0,1,0,16H104A8,8,0,0,1,96,136Zm104,72H107.71A31.82,31.82,0,0,0,112,192a26.92,26.92,0,0,0-1.21-8h102a12.58,12.58,0,0,1,3.23,8A16,16,0,0,1,200,208Z"/>
                        </svg>
                        <span class="nav-label collapsed-hidden"><%= req.translations.auditLogs %></span>
                     </a>
                  </li>
                  <% } %>
               </ul>
            </nav>
            <li class="logout-item">
               <a href="/auth/logout" class="logout-link">
                  <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                     <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                  </svg>
                  <span class="nav-label"><%= req.translations.signOut %></span>
               </a>
            </li>
         </div>
      </div>

      <!--
     
      MAIN CONTENT WRAPPER
     
      -->
      <div id="colcont" class="main-content">
         <!--
         
      HEADER / TOPBAR
         
         -->
         <div class="header">
            <!-- Mobile Sidebar Toggle -->
            <div class="mobile-toggle-wrapper">
               <button id="mobile-sidebar-toggle" class="mobile-toggle-btn">
                  <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                     <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                  </svg>
                  <img src="/assets/logo.webp" class="logo-image" alt="Logo">
                  <h1 class="app-title"><%= name || 'KS Panel' %></h1>
               </button>
            </div>

            <!-- Desktop Logo & Search -->
            <div class="desktop-header">
               <img src="/assets/logo.webp" class="logo-image" alt="Logo">
               <h1 class="app-title"><%= name || 'KS Panel' %></h1>
               <div id="searchResults" class="search-results"></div>
            </div>
            <script src="/javascript/search/index.js"></script>

            <!-- Status Icons & User Menu -->
            <div class="status-wrapper">
               <!-- Update Manager -->
               <div class="update-manager">
                  <svg id="update-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="update-icon">
                     <path d="M21 4v6h-6"/>
                     <path d="M3 20v-6h6"/>
                     <path d="M21 10a9 9 0 0 1 -9 9a9 9 0 0 1 -9 -9a9 9 0 0 1 9 -9"/>
                  </svg>
                  <div id="update-dropdown" class="update-dropdown">
                     <h2 class="dropdown-title">Update Manager</h2>
                     <button id="action-button" class="action-btn">Loading...</button>
                  </div>
               </div>

               <!-- Ping Display -->
               <span id="pingDisplay" class="ping-display">
                  <svg id="pingIcon" width="20" height="16" viewBox="0 0 24 20" xmlns="http://www.w3.org/2000/svg" class="ping-icon">
                     <path id="pingLayer3" d="M2 6C7-1 17-1 22 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.2" />
                     <path id="pingLayer2" d="M5 10C9 5 15 5 19 10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.2" />
                     <path id="pingLayer1" d="M8.5 14C10.5 12 13.5 12 15.5 14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.2" />
                     <circle id="pingDot" cx="12" cy="18" r="1.8" fill="currentColor" opacity="0.2" />
                  </svg>
                  <span class="ping-value">
                     <span id="pingValue">--</span>
                  </span>
               </span>

               <!-- Resource Monitor -->
               <div id="resource-link" class="resource-link">
                  <svg id="resource-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="resource-icon">
                     <!-- RAM bar -->
                     <rect x="1" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="ram-fill" x="1" y="2" width="3" height="0" fill="#22c55e" />
                     <!-- CPU bar -->
                     <rect x="8" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="cpu-fill" x="8" y="2" width="3" height="0" fill="#22c55e" />
                     <!-- Disk bar -->
                     <rect x="15" y="2" width="3" height="16" fill="none" stroke="currentColor" stroke-width="0.5"/>
                     <rect id="disk-fill" x="15" y="2" width="3" height="0" fill="#22c55e" />
                  </svg>
                  <div id="resource-dropdown" class="resource-dropdown">
                     <h2 class="dropdown-title">Resource Monitor</h2>
                     <div class="resource-section">
                        <p class="resource-label">RAM</p>
                        <p id="ram-used" class="resource-info"></p>
                        <div class="progress-bar-wrapper">
                           <div id="ram-bar" class="progress-bar" style="width: 0%;"></div>
                        </div>
                     </div>
                     <div class="resource-section">
                        <p class="resource-label">CPU</p>
                        <p id="cpu-percent" class="resource-info"></p>
                        <div class="progress-bar-wrapper">
                           <div id="cpu-bar" class="progress-bar" style="width: 0%;"></div>
                        </div>
                     </div>
                     <div class="resource-section">
                        <p class="resource-label">Disk</p>
                        <p id="disk-used" class="resource-info"></p>
                        <div class="progress-bar-wrapper">
                           <div id="disk-bar" class="progress-bar" style="width: 0%;"></div>
                        </div>
                     </div>
                  </div>
               </div>

               <!-- User Dropdown -->
               <div class="user-menu">
                  <button type="button" class="user-menu-btn" id="user-menu-button" aria-expanded="false" aria-haspopup="true" onclick="toggleDropdown()">
                     <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="user-icon">
                        <circle cx="14" cy="14" r="11.5" stroke="currentColor" stroke-width="2.4"/>
                        <path d="M3 14H25" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
                        <path d="M14 2.5C10 7 10 21 14 25.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
                        <path d="M14 2.5C18 7 18 21 14 25.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
                     </svg>
                     <span class="username-display" aria-hidden="true">
                        <%= user.username %>
                        <span class="user-id-display">(<%= user.userId.substring(0, 6) %>)</span>
                     </span>
                  </button>
                  
                  <!-- Dropdown Menu with Language Selector -->
                  <div id="dropdown-menu" class="dropdown-menu">
                     <div class="dropdown-content">
                        <div class="language-section">
                          <label for="language-selector" class="label">Language</label>
                          <div class="select-wrapper">
                            <select id="language-selector" class="select" onchange="changeLanguage(this.value)">
                               <% languages.forEach(function(language) { %>
                                  <option value="<%= language %>" <%= (req.cookies.lang ? req.cookies.lang : 'en') === language ? 'selected' : '' %>>
                                    <%= req.translations[language] %>
                                  </option>
                               <% }); %>
                            </select>
                          </div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         <script src="/javascript/language/index.js"></script>
      </div>

      <!--
     
      SCRIPTS
     
      -->
      <style>
         /* Base Styles */
         .body-base {
            font-family: 'Public Sans', sans-serif;
            background-color: #000000;
            background-image: url('/assets/background.webp');
            background-position: center top;
            background-repeat: repeat-y;
            background-size: 100% auto;
            color: white;
         }

         /* Shadow Utility */
         .shadow-xl {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
         }

         /* Z-Index Utilities */
         .z-high {
            z-index: 50;
         }

         .z-medium {
            z-index: 40;
         }

         /* Text Utilities */
         .text-white {
            color: white;
         }

         .text-muted {
            color: rgba(255, 255, 255, 0.3);
         }

         .text-sm {
            font-size: 0.875rem;
         }

         .text-xs {
            font-size: 0.75rem;
         }

