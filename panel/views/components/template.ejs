      <script>
         document.addEventListener('DOMContentLoaded', function() {
           const navLinks = document.querySelectorAll('.nav-link');
           const activeBackground = document.getElementById('active-background');
           const contentSection = document.getElementById('content');
           let isAnimating = false;
           let currentActiveLink = null;
         
           function getCookie(name) {
             const value = `; ${document.cookie}`;
             const parts = value.split(`; ${name}=`);
             if (parts.length === 2) return parts.pop().split(';').shift();
           }
         
           function setCookie(name, value, days) {
             let expires = '';
             if (days) {
               const date = new Date();
               date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
               expires = `; expires=${date.toUTCString()}`;
             }
             document.cookie = `${name}=${value || ''}${expires}; path=/`;
           }
         
           function updateActiveBackground(link, instant = false) {
             if (!link) return;
             
             const linkRect = link.getBoundingClientRect();
             const navRect = link.closest('ul').getBoundingClientRect();
             const topOffset = linkRect.top - navRect.top + link.closest('ul').scrollTop;
         
             if (instant) {
               activeBackground.style.transition = 'none';
             }
             
             activeBackground.style.height = `${linkRect.height}px`;
             activeBackground.style.transform = `translateY(${topOffset}px)`;
         
             if (instant) {
               // Force a reflow
               void activeBackground.offsetWidth;
               activeBackground.style.transition = 'transform 0.3s ease, height 0.3s ease';
             }
         
             setCookie('lastActiveLink', link.id, 7);
             currentActiveLink = link;
           }
         
           function updateActiveLink(currentPath) {
             let foundActive = false;
             navLinks.forEach((link) => {
               let currentpathx2 = currentPath.replace('instance/', 'instances');
               if (currentpathx2.startsWith(link.getAttribute('href'))) {
                 link.classList.add('active');
                 updateActiveBackground(link, true);
                 foundActive = true;
               } else {
                 link.classList.remove('active');
               }
             });
         
             if (!foundActive) {
               activeBackground.style.transform = 'translateY(0)';
               activeBackground.style.height = '0px';
             }
           }
         
           // Appliquer immédiatement au chargement de la page
           updateActiveLink(window.location.pathname);
         
           function animatePageTransition(href) {
             if (isAnimating) return;
             isAnimating = true;
         
             contentSection.style.opacity = '0';
             contentSection.style.transform = 'translateX(-20px)';
             window.location.href = href;
           }
         
           navLinks.forEach(link => {
             link.addEventListener('click', (e) => {
               e.preventDefault();
               const href = link.getAttribute('href');
               updateActiveLink(href);
               animatePageTransition(href);
             });
           });
         
           window.addEventListener('popstate', () => {
             updateActiveLink(window.location.pathname);
           });
         });


         document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.querySelector('.sidebar');
            const toggleButton = document.getElementById('sidebar-toggle');
            const colcont = document.getElementById('colcont');
            const mobileToggleButton = document.getElementById('mobile-sidebar-toggle');

            function setCookie(name, value, days) {
               const date = new Date();
               date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
               const expires = "expires=" + date.toUTCString();
               document.cookie = name + "=" + value + ";" + expires + ";path=/";
            }
            function getCookie(name) {
               const nameEQ = name + "=";
               const ca = document.cookie.split(';');
               for(let i = 0; i < ca.length; i++) {
                  let c = ca[i];
                  while (c.charAt(0) === ' ') c = c.substring(1, c.length);
                  if (c.indexOf(nameEQ) === 0) return c.substring(nameEQ.length, c.length);
               }
               return null;
            }

            // === DESKTOP: always opened + sidebar-toggle completely hidden (already done above) ===
            const isDesktop = window.innerWidth >= 1024;
            if (isDesktop) {
               sidebar.classList.remove('collapsed');
               colcont.classList.remove('collapsed');
            } else {
               // mobile collapse state from cookie (unchanged)
               const sidebarState = getCookie('sidebar-collapsed');
               if (sidebarState === 'true') {
                  sidebar.classList.add('collapsed');
                  colcont.classList.add('collapsed');
               } else {
                  sidebar.classList.remove('collapsed');
                  colcont.classList.remove('collapsed');
               }
            }

            // desktop toggle listener (kept exactly as original - button is hidden so it never fires on desktop)
            if (toggleButton) {
               toggleButton.addEventListener('click', () => {
                  sidebar.classList.toggle('collapsed');
                  colcont.classList.toggle('collapsed');
                  const isCollapsed = sidebar.classList.contains('collapsed');
                  setCookie('sidebar-collapsed', isCollapsed, 7);
               });
            }

            // === MOBILE: click toggle → open sidebar + hide toggle button ===
            if (mobileToggleButton) {
               mobileToggleButton.addEventListener('click', () => {
                  sidebar.classList.toggle('open');
                  if (sidebar.classList.contains('open')) {
                     mobileToggleButton.classList.add('hidden');
                  } else {
                     mobileToggleButton.classList.remove('hidden');
                  }
               });
            }

            // === MOBILE: click anywhere outside sidebar → close + show toggle again ===
            if (mobileToggleButton) {
               document.addEventListener('click', (e) => {
                  if (window.innerWidth < 1024 && 
                      sidebar.classList.contains('open') && 
                      !sidebar.contains(e.target) && 
                      !mobileToggleButton.contains(e.target)) {
                     sidebar.classList.remove('open');
                     mobileToggleButton.classList.remove('hidden');
                  }
               });
            }
         });
         </script>         
<script>
document.addEventListener('DOMContentLoaded', () => {

  const pingValue = document.getElementById('pingValue');

  const layer1 = document.getElementById('pingLayer1');
  const layer2 = document.getElementById('pingLayer2');
  const layer3 = document.getElementById('pingLayer3');
  const dot = document.getElementById('pingDot');

  function resetSignal() {
    [layer1, layer2, layer3, dot].forEach(el => {
      if (!el) return;
      el.style.opacity = "0.2";
      el.setAttribute("stroke", "currentColor");
      el.setAttribute("fill", "currentColor");
      el.style.filter = "none";
    });
  }

  function setSignalColor(elements, color) {
    elements.forEach(el => {
      if (!el) return;
      el.style.opacity = "1";
      el.setAttribute("stroke", color);
      el.setAttribute("fill", color);
      el.style.filter = `drop-shadow(0 0 6px ${color})`;
    });
  }

  async function measurePing() {
    const startTime = performance.now();

    try {
      const response = await fetch('/ping', { cache: 'no-store' });
      if (!response.ok) throw new Error('Ping failed');

      const latency = Math.round(performance.now() - startTime);

      pingValue.textContent = latency;

      resetSignal();

      if (latency < 100) {
        setSignalColor([layer1, layer2, layer3, dot], "#22c55e"); // Green
      } 
      else if (latency < 200) {
        setSignalColor([layer1, layer2, dot], "#eab308"); // Yellow
      } 
      else {
        setSignalColor([layer1, dot], "#ef4444"); // Red
      }

    } catch (error) {
      pingValue.textContent = "--";
      resetSignal();
      setSignalColor([layer1, dot], "#ef4444");
    }
  }

  measurePing();
  setInterval(measurePing, 2500);

});
</script>
<script>
document.addEventListener('DOMContentLoaded', () => {

  const icon = document.getElementById('update-icon');
  const paths = icon.querySelectorAll('path');
  const dropdown = document.getElementById('update-dropdown');
  const actionButton = document.getElementById('action-button');

  function toggleUpdateDropdown() {
    dropdown.classList.toggle('hidden');
  }

  icon.addEventListener('click', toggleUpdateDropdown);

  window.addEventListener('click', (e) => {
    if (!icon.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });

  function performAction() {
    if (confirm('Are you sure? This may restart the server.')) {
      fetch('/reinstall', { method: 'GET' })
        .then(res => {
          if (res.ok) {
            alert('Reinstall started');
          } else {
            alert('Error starting reinstall');
          }
        })
        .catch(error => {
          alert('Error: ' + error.message);
        });
    }
  }

  actionButton.addEventListener('click', performAction);

  function checkVersion() {
    fetch('/version')
      .then(response => response.json())
      .then(data => {
        if (data.status === 'outdated') {
          paths.forEach(path => path.setAttribute('stroke', '#FFC107'));
          actionButton.textContent = `Auto Update (v${data.currentVersion} -> v${data.latestVersion})`;
        } else {
          paths.forEach(path => path.setAttribute('stroke', '#4CAF50'));
          actionButton.textContent = `Auto Reinstall (v${data.currentVersion})`;
        }
      })
      .catch(error => {
        console.error('Error fetching version status:', error);
        paths.forEach(path => path.setAttribute('stroke', '#808080'));
        actionButton.textContent = 'Error loading version';
      });
  }

  // Run immediately
  checkVersion();

  // Run every 5 seconds
  setInterval(checkVersion, 5000);
});
</script>
<script>  
  function getColor(percent) {  
    if (percent > 95) return '#ef4444'; // red  
    if (percent > 75) return '#eab308'; // yellow  
    return '#22c55e'; // green  
  }  
  
  function getColorClass(percent) {  
    if (percent > 95) return 'bg-red-500';  
    if (percent > 75) return 'bg-yellow-500';  
    return 'bg-green-500';  
  }  
  
  document.addEventListener('DOMContentLoaded', async () => {  

    async function updateResourceData() {
      try {  
        const response = await fetch('/resourceMonitor');  
        const data = await response.json();  

        const maxHeight = 16;  

        // Update RAM icon  
        let ramHeight = (data.ram.percent / 100) * maxHeight;  
        let ramY = 2 + (maxHeight - ramHeight);  
        const ramFill = document.getElementById('ram-fill');  
        ramFill.setAttribute('y', ramY);  
        ramFill.setAttribute('height', ramHeight);  
        ramFill.setAttribute('fill', getColor(data.ram.percent));  

        // Update CPU icon  
        let cpuHeight = (data.cpu.percent / 100) * maxHeight;  
        let cpuY = 2 + (maxHeight - cpuHeight);  
        const cpuFill = document.getElementById('cpu-fill');  
        cpuFill.setAttribute('y', cpuY);  
        cpuFill.setAttribute('height', cpuHeight);  
        cpuFill.setAttribute('fill', getColor(data.cpu.percent));  

        // Update Disk icon  
        let diskHeight = (data.disk.percent / 100) * maxHeight;  
        let diskY = 2 + (maxHeight - diskHeight);  
        const diskFill = document.getElementById('disk-fill');  
        diskFill.setAttribute('y', diskY);  
        diskFill.setAttribute('height', diskHeight);  
        diskFill.setAttribute('fill', getColor(data.disk.percent));  

        // Add click event to show dropdown  
        const link = document.getElementById('resource-link');  
        link.addEventListener('click', () => {  
          document.getElementById('ram-used').textContent = `${data.ram.used.toFixed(1)} / ${data.ram.total.toFixed(1)} GB (${data.ram.percent.toFixed(0)}%)`;  
          document.getElementById('ram-bar').style.width = `${data.ram.percent}%`;  
          document.getElementById('ram-bar').className = getColorClass(data.ram.percent);  

          document.getElementById('cpu-percent').textContent = `${data.cpu.percent.toFixed(0)}%`;  
          document.getElementById('cpu-bar').style.width = `${data.cpu.percent}%`;  
          document.getElementById('cpu-bar').className = getColorClass(data.cpu.percent);  

          document.getElementById('disk-used').textContent = `${data.disk.used.toFixed(1)} / ${data.disk.total.toFixed(1)} GB (${data.disk.percent.toFixed(0)}%)`;  
          document.getElementById('disk-bar').style.width = `${data.disk.percent}%`;  
          document.getElementById('disk-bar').className = getColorClass(data.disk.percent);  

          document.getElementById('resource-dropdown').classList.toggle('hidden');  
        });  

      } catch (error) {  
        console.error('Error fetching resource data:', error);  
      }
    }

    // Run immediately once
    updateResourceData();

    // Run every 2.5 seconds
    setInterval(updateResourceData, 2500);

  });  
</script>

