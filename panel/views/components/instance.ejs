<script>
  (function() {
    'use strict';
    
    // Scoped variables to prevent global conflicts
    const navScroll = document.querySelector('[data-nav-scroll]');
    const navBg = document.querySelector('[data-nav-bg]');
    const navLinks = document.querySelectorAll('[data-nav-link]');
    const currentPath = window.location.pathname;
    
    if (!navScroll || !navBg || navLinks.length === 0) return;
    
    // Update scroll fade indicators
    function updateFadeIndicators() {
      const scrollLeft = navScroll.scrollLeft;
      const maxScroll = navScroll.scrollWidth - navScroll.clientWidth;
      
      navScroll.classList.toggle('has-left', scrollLeft > 5);
      navScroll.classList.toggle('has-right', scrollLeft < maxScroll - 5);
    }
    
    // Initial check
    updateFadeIndicators();
    
    // Passive scroll listener
    navScroll.addEventListener('scroll', updateFadeIndicators, { passive: true });
    
    // Resize handler
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        updateFadeIndicators();
        updateActiveState();
      }, 100);
    });
    
    // Find best matching link
    function findActiveLink() {
      let bestMatch = null;
      let maxLength = 0;
      
      navLinks.forEach(function(link) {
        const href = link.getAttribute('href');
        if (!href) return;
        
        // Exact match or starts with (for nested paths)
        if (currentPath === href || currentPath.startsWith(href + '/')) {
          if (href.length > maxLength) {
            bestMatch = link;
            maxLength = href.length;
          }
        }
      });
      
      return bestMatch;
    }
    
    // Update active state
    function updateActiveState() {
      const activeLink = findActiveLink();
      
      // Clear all active states
      navLinks.forEach(function(link) {
        link.classList.remove('is-active');
      });
      
      if (activeLink) {
        // Set active class
        activeLink.classList.add('is-active');
        
        // Position background
        const navRect = activeLink.closest('[data-inst-nav]').getBoundingClientRect();
        const linkRect = activeLink.getBoundingClientRect();
        
        const width = linkRect.width;
        const left = linkRect.left - navRect.left;
        
        navBg.style.width = width + 'px';
        navBg.style.transform = 'translateX(' + left + 'px)';
        navBg.classList.add('active');
        
        // Mobile: scroll into view
        if (window.innerWidth < 1024) {
          const scrollRect = navScroll.getBoundingClientRect();
          const linkLeft = linkRect.left - scrollRect.left;
          const linkRight = linkLeft + linkRect.width;
          
          if (linkLeft < 20 || linkRight > scrollRect.width - 20) {
            activeLink.scrollIntoView({ 
              behavior: 'smooth', 
              inline: 'center', 
              block: 'nearest' 
            });
          }
        }
      } else {
        navBg.classList.remove('active');
      }
    }
    
    // Initial activation
    updateActiveState();
    
    // Click handlers
    navLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        // Update visual state immediately
        navLinks.forEach(function(l) {
          l.classList.remove('is-active');
        });
        this.classList.add('is-active');
        
        // Move background
        const navRect = this.closest('[data-inst-nav]').getBoundingClientRect();
        const linkRect = this.getBoundingClientRect();
        
        navBg.style.width = linkRect.width + 'px';
        navBg.style.transform = 'translateX(' + (linkRect.left - navRect.left) + 'px)';
      });
    });
    
    // Handle browser back/forward
    window.addEventListener('popstate', updateActiveState);
  })();
</script>

