<script>
  (function() {
    const navWrapper = document.getElementById('navWrapper');
    const slidingBg = document.getElementById('slidingBackground');
    const navLinks = document.querySelectorAll('.nav-link');
    const currentPath = window.location.pathname;
    
    // Update scroll indicators
    function updateScrollIndicators() {
      const canScrollLeft = navWrapper.scrollLeft > 0;
      const canScrollRight = navWrapper.scrollLeft < (navWrapper.scrollWidth - navWrapper.clientWidth - 1);
      
      navWrapper.classList.toggle('can-scroll-left', canScrollLeft);
      navWrapper.classList.toggle('can-scroll-right', canScrollRight);
    }
    
    // Initial check
    updateScrollIndicators();
    
    // Update on scroll
    navWrapper.addEventListener('scroll', updateScrollIndicators, { passive: true });
    
    // Update on resize
    window.addEventListener('resize', updateScrollIndicators);
    
    // Find and activate current nav item
    function updateActiveNav() {
      let activeLink = null;
      let maxMatchLength = 0;
      
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        // Find the most specific match (longest matching prefix)
        if (currentPath.startsWith(href) && href.length > maxMatchLength) {
          activeLink = link;
          maxMatchLength = href.length;
        }
      });
      
      if (activeLink) {
        // Remove active class from all
        navLinks.forEach(link => {
          link.classList.remove('active', 'text-white', 'font-medium');
        });
        
        // Add active class to current
        activeLink.classList.add('active', 'text-white', 'font-medium');
        
        // Update sliding background position
        const navRect = activeLink.closest('nav').getBoundingClientRect();
        const linkRect = activeLink.getBoundingClientRect();
        
        slidingBg.style.width = linkRect.width + 'px';
        slidingBg.style.transform = `translateX(${linkRect.left - navRect.left}px)`;
        slidingBg.style.opacity = '1';
        
        // Scroll active item into view on mobile
        if (window.innerWidth < 1024) {
          const wrapperRect = navWrapper.getBoundingClientRect();
          const linkLeft = linkRect.left - wrapperRect.left;
          const linkRight = linkLeft + linkRect.width;
          
          if (linkLeft < 0 || linkRight > wrapperRect.width) {
            activeLink.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          }
        }
      } else {
        slidingBg.style.opacity = '0';
      }
    }
    
    // Initial activation
    updateActiveNav();
    
    // Handle clicks with smooth transition
    navLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Don't prevent default - let it navigate naturally
        // Just update visual state immediately for perceived performance
        
        navLinks.forEach(l => l.classList.remove('active', 'text-white', 'font-medium'));
        this.classList.add('active', 'text-white', 'font-medium');
        
        const navRect = this.closest('nav').getBoundingClientRect();
        const linkRect = this.getBoundingClientRect();
        
        slidingBg.style.width = linkRect.width + 'px';
        slidingBg.style.transform = `translateX(${linkRect.left - navRect.left}px)`;
      });
    });
    
    // Handle popstate (back/forward buttons)
    window.addEventListener('popstate', function() {
      // Update current path and re-activate
      const newPath = window.location.pathname;
      // Re-run activation logic with new path
      let activeLink = null;
      let maxMatchLength = 0;
      
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (newPath.startsWith(href) && href.length > maxMatchLength) {
          activeLink = link;
          maxMatchLength = href.length;
        }
      });
      
      if (activeLink) {
        navLinks.forEach(link => {
          link.classList.remove('active', 'text-white', 'font-medium');
        });
        activeLink.classList.add('active', 'text-white', 'font-medium');
        
        const navRect = activeLink.closest('nav').getBoundingClientRect();
        const linkRect = activeLink.getBoundingClientRect();
        slidingBg.style.width = linkRect.width + 'px';
        slidingBg.style.transform = `translateX(${linkRect.left - navRect.left}px)`;
      }
    });
    
    // Hide sliding background when resizing to prevent visual glitches
    let resizeTimeout;
    window.addEventListener('resize', function() {
      slidingBg.style.transition = 'none';
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function() {
        slidingBg.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
        updateActiveNav();
      }, 100);
    });
  })();
</script>
