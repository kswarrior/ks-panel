<%- include('../components/template') %>

<style>
  /* ===== INSTANCE SIDEBAR NAVIGATION - OPTIMIZED RESPONSIVE ===== */
  
  /* Container */
  .instance-nav-container {
    margin-top: 1.5rem;
    margin-left: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .instance-nav-container {
      margin-left: 2rem;
      margin-bottom: 2rem;
    }
  }

  /* Scrollable wrapper with optimized scrolling */
  .instance-nav-wrapper {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
    scroll-snap-type: x proximity;
    scroll-padding-left: 0.5rem;
    scroll-padding-right: 0.5rem;
  }

  /* Custom scrollbar styling */
  .instance-nav-wrapper::-webkit-scrollbar {
    height: 4px;
  }

  .instance-nav-wrapper::-webkit-scrollbar-track {
    background: transparent;
    margin: 0 0.5rem;
  }

  .instance-nav-wrapper::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
  }

  .instance-nav-wrapper::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  @media (min-width: 1024px) {
    .instance-nav-wrapper {
      overflow-x: visible;
      scrollbar-width: none;
    }
    
    .instance-nav-wrapper::-webkit-scrollbar {
      display: none;
    }
  }

  /* Navigation container */
  .instance-nav {
    display: flex;
    position: relative;
    min-width: max-content;
    padding: 0.375rem 0.5rem;
  }

  @media (min-width: 640px) {
    .instance-nav {
      padding: 0.375rem 0;
    }
  }

  /* Sliding background indicator - preserved blur effect */
  .nav-sliding-bg {
    position: absolute;
    height: 2.25rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 0.75rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 0;
  }

  @media (min-width: 640px) {
    .nav-sliding-bg {
      height: 2.5rem;
    }
  }

  /* Navigation list */
  .nav-list {
    display: flex;
    margin-top: 0.375rem;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .nav-list {
      gap: 0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .nav-list {
      gap: 0.75rem;
    }
  }

  /* Navigation items */
  .nav-item {
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  /* Navigation links - optimized touch targets */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5rem;
    color: rgb(163, 163, 163);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 0.75rem;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .nav-link {
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
    }
  }

  @media (min-width: 1024px) {
    .nav-link {
      padding: 0.625rem 1.125rem;
    }
  }

  /* Hover state - preserved colors */
  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: transparent;
    color: rgb(255, 255, 255);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  /* Active state - preserved colors */
  .nav-link.active {
    color: rgb(255, 255, 255);
    font-weight: 500;
  }

  /* Touch feedback */
  @media (hover: none) and (pointer: coarse) {
    .nav-link {
      min-height: 44px;
      padding: 0.625rem 1rem;
    }
    
    .nav-link:active {
      transform: scale(0.96);
      background: rgba(255, 255, 255, 0.08);
    }
  }

  /* Icon styling */
  .nav-icon {
    display: inline-flex;
    width: 1rem;
    height: 1rem;
    margin-bottom: 0.125rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  @media (min-width: 640px) {
    .nav-icon {
      width: 1.125rem;
      height: 1.125rem;
    }
  }

  .nav-link:hover .nav-icon {
    transform: translateY(-1px);
  }

  /* Text label - show/hide optimization */
  .nav-text {
    display: inline;
  }

  /* Fade indicators for scroll hints */
  .scroll-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2rem;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .scroll-indicator-left {
    left: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.3), transparent);
  }

  .scroll-indicator-right {
    right: 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.3), transparent);
  }

  .instance-nav-wrapper.can-scroll-left .scroll-indicator-left,
  .instance-nav-wrapper.can-scroll-right .scroll-indicator-right {
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .scroll-indicator {
      display: none;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .nav-sliding-bg,
    .nav-link,
    .nav-icon,
    .scroll-indicator {
      transition: none;
    }
    
    .nav-link:active {
      transform: none;
    }
  }
</style>

