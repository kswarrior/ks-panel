<style>
  /* ===== INSTANCE NAVIGATION - ISOLATED STYLES ===== */
  
  /* Scoped container to prevent conflicts */
  .inst-nav-wrapper {
    margin-top: 1.5rem;
    margin-left: 1rem;
    margin-right: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .inst-nav-wrapper {
      margin-left: 2rem;
      margin-right: 2rem;
    }
  }

  /* Scroll container */
  .inst-nav-scroll {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0.5rem;
    scroll-padding-right: 0.5rem;
  }

  .inst-nav-scroll::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 1024px) {
    .inst-nav-scroll {
      overflow-x: visible;
    }
  }

  /* Navigation container */
  .inst-nav {
    display: flex;
    position: relative;
    min-width: max-content;
    padding: 0.25rem;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .inst-nav {
      gap: 0.5rem;
      padding: 0.375rem 0;
    }
  }

  @media (min-width: 1024px) {
    .inst-nav {
      gap: 0.75rem;
    }
  }

  /* Sliding background - isolated */
  .inst-nav-bg {
    position: absolute;
    height: 2.25rem;
    top: 0.25rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 0.75rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }

  @media (min-width: 640px) {
    .inst-nav-bg {
      height: 2.5rem;
      top: 0.375rem;
    }
  }

  .inst-nav-bg.active {
    opacity: 1;
  }

  /* Navigation list */
  .inst-nav-list {
    display: flex;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .inst-nav-list {
      gap: 0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .inst-nav-list {
      gap: 0.75rem;
    }
  }

  /* Navigation items */
  .inst-nav-item {
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  /* Navigation links */
  .inst-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.25rem;
    color: rgb(163, 163, 163);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 0.75rem;
    border: 1px solid transparent;
    transition: all 0.2s ease;
    position: relative;
    background: transparent;
  }

  @media (min-width: 640px) {
    .inst-nav-link {
      padding: 0.625rem 0.875rem;
      font-size: 0.875rem;
      gap: 0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .inst-nav-link {
      padding: 0.625rem 1rem;
    }
  }

  /* Hover state */
  .inst-nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: rgb(255, 255, 255);
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
  }

  /* Active state */
  .inst-nav-link.is-active {
    color: rgb(255, 255, 255);
    font-weight: 500;
  }

  /* Touch optimizations */
  @media (hover: none) and (pointer: coarse) {
    .inst-nav-link {
      min-height: 44px;
    }
    
    .inst-nav-link:active {
      transform: scale(0.96);
      background: rgba(255, 255, 255, 0.08);
    }
  }

  /* Icons */
  .inst-nav-icon {
    display: inline-flex;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  @media (min-width: 640px) {
    .inst-nav-icon {
      width: 1.125rem;
      height: 1.125rem;
    }
  }

  .inst-nav-link:hover .inst-nav-icon {
    transform: translateY(-1px);
  }

  /* Text labels - responsive */
  .inst-nav-text {
    display: inline;
  }

  /* Scroll fade indicators */
  .inst-nav-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.5rem;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .inst-nav-fade-left {
    left: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.4), transparent);
  }

  .inst-nav-fade-right {
    right: 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.4), transparent);
  }

  .inst-nav-scroll.has-left .inst-nav-fade-left,
  .inst-nav-scroll.has-right .inst-nav-fade-right {
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .inst-nav-fade {
      display: none;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .inst-nav-bg,
    .inst-nav-link,
    .inst-nav-icon,
    .inst-nav-fade {
      transition: none;
    }
    
    .inst-nav-link:active {
      transform: none;
    }
  }
</style>

