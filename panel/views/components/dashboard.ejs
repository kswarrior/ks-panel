<!-- ===================== DASHBOARD NAVIGATION ===================== -->
<style>
  /* ===== DASHBOARD NAVIGATION - ISOLATED STYLES ===== */
  .dash-nav-wrapper {
    margin-top: 1.5rem;
    margin-left: 1rem;
    margin-right: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .dash-nav-wrapper {
      margin-left: 2rem;
      margin-right: 2rem;
    }
  }

  .dash-nav-scroll {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
  }

  .dash-nav-scroll::-webkit-scrollbar { display: none; }

  .dash-nav {
    display: flex;
    position: relative;
    min-width: max-content;
    padding: 0.25rem;
    gap: 0.5rem;
  }

  @media (min-width: 1024px) {
    .dash-nav { gap: 0.75rem; }
  }

  .dash-nav-bg {
    position: absolute;
    height: 2.5rem;
    top: 0.25rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }

  .dash-nav-bg.active { opacity: 1; }

  .dash-nav-list {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .dash-nav-item { flex-shrink: 0; }

  .dash-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(163, 163, 163);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 9999px;
    transition: all 0.2s ease;
    position: relative;
  }

  .dash-nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: white;
  }

  .dash-nav-link.is-active {
    color: white;
    font-weight: 600;
  }

  .dash-nav-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
  }
</style>

<div class="dash-nav-wrapper">
  <div class="dash-nav-scroll" id="dash-nav-scroll">
    <nav class="dash-nav">
      <div class="dash-nav-bg" id="dash-nav-bg"></div>
      <ul class="dash-nav-list">
        <!-- Console -->
        <li class="dash-nav-item">
          <a href="/admin/dashboard/console" class="dash-nav-link" data-dash-link="console">
            <svg xmlns="http://www.w3.org/2000/svg" class="dash-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span>Console</span>
          </a>
        </li>

        <!-- Analytics -->
        <li class="dash-nav-item">
          <a href="/admin/dashboard/analytics" class="dash-nav-link" data-dash-link="analytics">
            <svg xmlns="http://www.w3.org/2000/svg" class="dash-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-9 9-4-4-6 6"/>
            </svg>
            <span>Analytics</span>
          </a>
        </li>

        <!-- Database -->
        <li class="dash-nav-item">
          <a href="/admin/dashboard/database" class="dash-nav-link" data-dash-link="database">
            <svg xmlns="http://www.w3.org/2000/svg" class="dash-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
            </svg>
            <span>Database</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>

<script>
  // Dashboard Navigation Script (isolated)
  (function() {
    const navScroll = document.getElementById('dash-nav-scroll');
    const navBg = document.getElementById('dash-nav-bg');
    const links = document.querySelectorAll('.dash-nav-link');
    const currentPath = window.location.pathname;

    if (!navScroll || !navBg) return;

    function updateActive() {
      let activeLink = null;

      links.forEach(link => {
        const href = link.getAttribute('href');
        link.classList.remove('is-active');

        if (currentPath === href || currentPath.startsWith(href + '/')) {
          activeLink = link;
        }
      });

      if (activeLink) {
        activeLink.classList.add('is-active');

        const rect = activeLink.getBoundingClientRect();
        const navRect = activeLink.closest('.dash-nav').getBoundingClientRect();

        navBg.style.width = `${rect.width}px`;
        navBg.style.transform = `translateX(${rect.left - navRect.left}px)`;
        navBg.classList.add('active');
      } else {
        navBg.classList.remove('active');
      }
    }

    // Initial activation
    updateActive();

    // Click handler
    links.forEach(link => {
      link.addEventListener('click', () => {
        links.forEach(l => l.classList.remove('is-active'));
        link.classList.add('is-active');

        const rect = link.getBoundingClientRect();
        const navRect = link.closest('.dash-nav').getBoundingClientRect();

        navBg.style.width = `${rect.width}px`;
        navBg.style.transform = `translateX(${rect.left - navRect.left}px)`;
      });
    });

    // Mobile scroll fade (optional)
    function updateScrollFade() {
      const scrollLeft = navScroll.scrollLeft;
      const maxScroll = navScroll.scrollWidth - navScroll.clientWidth;
      navScroll.classList.toggle('has-left', scrollLeft > 10);
      navScroll.classList.toggle('has-right', scrollLeft < maxScroll - 10);
    }

    navScroll.addEventListener('scroll', updateScrollFade, { passive: true });
    window.addEventListener('resize', updateActive);
  })();
</script>
