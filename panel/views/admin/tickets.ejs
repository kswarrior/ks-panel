<%- include('../components/template') %>
<main id="content" class="min-h-screen p-4 md:p-8">
   <div class="max-w-7xl mx-auto">
      <header class="mb-10">
         <h1 class="text-4xl font-black text-white tracking-tight">Ticket Management</h1>
         <p class="text-neutral-400 mt-2 font-medium">Respond to user inquiries and maintain service quality.</p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
         <!-- Sidebar: Ticket List -->
         <div class="lg:col-span-1 space-y-4">
            <div class="flex items-center justify-between mb-4 px-2">
               <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.2em]">All Tickets</h2>
               <span class="bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full"><%= tickets.length %></span>
            </div>

            <div class="space-y-2 max-h-[700px] overflow-y-auto pr-2 custom-scrollbar">
               <% if (tickets.length === 0) { %>
                  <p class="text-xs text-neutral-600 italic text-center py-10">No tickets found.</p>
               <% } else { %>
                  <% tickets.forEach(ticket => { %>
                     <button onclick="loadTicket('<%= ticket.id %>')" class="w-full text-left backdrop-blur-xl bg-white/5 border border-white/10 rounded-2xl p-4 hover:bg-white/10 transition-all group relative overflow-hidden">
                        <div class="flex items-center justify-between mb-2">
                           <span class="text-[9px] font-black uppercase tracking-tighter <%= ticket.status === 'open' ? 'text-green-400' : (ticket.status === 'closed' ? 'text-red-400' : 'text-yellow-400') %>">
                              <%= ticket.status %>
                           </span>
                           <span class="text-[9px] text-white/20 font-mono"><%= ticket.priority %></span>
                        </div>
                        <h3 class="text-sm font-bold text-white truncate"><%= ticket.subject %></h3>
                        <div class="flex items-center gap-2 mt-2">
                           <img src="https://mc-heads.net/avatar/<%= ticket.username %>/16" class="w-4 h-4 rounded">
                           <span class="text-[10px] text-neutral-400"><%= ticket.username %></span>
                        </div>
                     </button>
                  <% }) %>
               <% } %>
            </div>
         </div>

         <!-- Chat & Action Hub -->
         <div class="lg:col-span-3">
            <div id="ticketDisplay" class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-[2.5rem] h-[750px] flex flex-col hidden overflow-hidden shadow-2xl">
               <!-- Header -->
               <div class="p-8 border-b border-white/10 flex items-center justify-between bg-white/[0.02]">
                  <div>
                     <div class="flex items-center gap-3 mb-1">
                        <h2 id="displaySubject" class="text-2xl font-black text-white tracking-tight"></h2>
                        <span id="displayPriority" class="px-2 py-0.5 rounded bg-white/10 text-[9px] font-black text-white/60 uppercase"></span>
                     </div>
                     <p id="displayUser" class="text-xs text-blue-400 font-bold"></p>
                  </div>
                  <div class="flex items-center gap-3">
                     <select id="statusSelect" onchange="updateStatus()" class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-xs font-bold text-white focus:outline-none transition-all">
                        <option value="open">Mark as Open</option>
                        <option value="pending">Mark as Pending</option>
                        <option value="closed">Close Ticket</option>
                     </select>
                  </div>
               </div>

               <!-- Messages -->
               <div id="messageContainer" class="flex-1 overflow-y-auto p-8 space-y-6 bg-black/40"></div>

               <!-- Admin Reply -->
               <form id="replyForm" class="p-8 border-t border-white/10 bg-white/[0.01]">
                  <div class="flex gap-4">
                     <textarea id="replyInput" rows="1" placeholder="Enter your response..." class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none"></textarea>
                     <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-black px-10 py-4 rounded-2xl transition-all shadow-lg shadow-blue-600/20 active:scale-95">
                        REPLY
                     </button>
                  </div>
               </form>
            </div>

            <!-- Empty State -->
            <div id="emptyDisplay" class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-[2.5rem] h-[750px] flex items-center justify-center shadow-2xl">
               <div class="text-center">
                  <div class="bg-white/5 w-24 h-24 rounded-[2rem] flex items-center justify-center mx-auto mb-8 transform -rotate-6 border border-white/5">
                     <svg class="w-12 h-12 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
                     </svg>
                  </div>
                  <h2 class="text-2xl font-black text-white mb-3">Awaiting Selection</h2>
                  <p class="text-neutral-500 max-w-sm mx-auto font-medium text-sm">Select a ticket from the left sidebar to begin managing the conversation and resolving issues.</p>
               </div>
            </div>
         </div>
      </div>
   </div>
</main>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>

<script>
let currentTicketId = null;
const ticketsData = <%- JSON.stringify(tickets) %>;

function loadTicket(id) {
   currentTicketId = id;
   const ticket = ticketsData.find(t => t.id === id);
   if (!ticket) return;

   document.getElementById('emptyDisplay').classList.add('hidden');
   document.getElementById('ticketDisplay').classList.remove('hidden');

   document.getElementById('displaySubject').textContent = ticket.subject;
   document.getElementById('displayPriority').textContent = ticket.priority;
   document.getElementById('displayUser').textContent = `USER: ${ticket.username} (${ticket.userId})`;
   document.getElementById('statusSelect').value = ticket.status;

   renderMessages(ticket.messages);
}

function renderMessages(messages) {
   const container = document.getElementById('messageContainer');
   container.innerHTML = messages.map(msg => `
      <div class="flex flex-col ${msg.isAdmin ? 'items-end' : 'items-start'}">
         <div class="max-w-[75%] rounded-[1.5rem] px-6 py-4 shadow-xl ${
            msg.isAdmin
            ? 'bg-blue-600 text-white'
            : 'bg-white/10 text-white border border-white/5'
         }">
            <p class="text-sm leading-relaxed">${msg.text}</p>
            <div class="flex items-center gap-3 mt-3 opacity-50">
               <span class="text-[9px] font-black uppercase tracking-widest">${msg.senderName} ${msg.isAdmin ? '(Staff)' : ''}</span>
               <span class="text-[9px] font-bold">${new Date(msg.timestamp).toLocaleString()}</span>
            </div>
         </div>
      </div>
   `).join('');
   container.scrollTop = container.scrollHeight;
}

async function updateStatus() {
   if (!currentTicketId) return;
   const status = document.getElementById('statusSelect').value;
   try {
      const res = await fetch(`/admin/tickets/status/${currentTicketId}`, {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify({ status })
      });
      if (res.ok) {
         alert('Status updated');
         location.reload();
      }
   } catch(e) { alert('Error updating status'); }
}

document.getElementById('replyForm').addEventListener('submit', async (e) => {
   e.preventDefault();
   if (!currentTicketId) return;
   const message = document.getElementById('replyInput').value;
   if (!message) return;

   try {
      const res = await fetch(`/tickets/reply/${currentTicketId}`, {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify({ message })
      });
      if (res.ok) {
         document.getElementById('replyInput').value = '';
         location.reload();
      }
   } catch(e) { alert('Error sending reply'); }
});
</script>
