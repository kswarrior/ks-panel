<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

.form-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  width: 100%;
}

.field-long,
.field-short {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex-grow: 1;
}

.field-long {
  flex-basis: 420px;
  min-width: 260px;
}

.field-short {
  flex-basis: 180px;
  min-width: 160px;
}

@media (min-width: 1024px) {
  .form-row {
    gap: 2rem;
  }
  .field-long { flex: 2 1 420px; }
  .field-short { flex: 1 1 180px; }
}

.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
}

.hidden { display: none; }
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">Create Local Node</h1>
        <p class="mt-1 text-sm text-neutral-400">One-click localhost setup • Auto-install/reinstall Wings • Node comes online instantly</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/admin/nodes/overview'" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          ← Back to Nodes
        </button>
        
        <button onclick="window.location.href='/admin/nodes/create'"
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          Normal Node
        </button>
      </div>
    </header>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Form -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 lg:p-12">
        <form id="createLocalForm">

          <!-- BASIC -->
          <div class="flex items-center gap-4 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">BASIC INFORMATION</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">NODE NAME <span class="text-red-400">*</span></label>
              <input id="name" required type="text" class="input-field" placeholder="My Local Node">
            </div>
          </div>

          <div class="form-row">
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">DAEMON PORT <span class="text-red-400">*</span></label>
              <input id="daemon_port" required type="number" value="8080" class="input-field" min="1" max="65535">
            </div>
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">SFTP PORT</label>
              <input id="sftp_port" type="number" value="2022" class="input-field" min="1" max="65535">
            </div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">LOCATION (optional)</label>
              <select id="location_id" class="input-field">
                <option value="">No location / Skip</option>
                <% locations.forEach(function(loc) { %>
                <option value="<%= loc.id %>"><%= loc.name %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <!-- RESOURCES (always manual - no auto mode) -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">RESOURCE LIMITS</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">CPU LIMIT (%)</label>
              <input id="cpu_limit" type="number" value="200" class="input-field">
            </div>
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">MEMORY LIMIT (MB)</label>
              <input id="memory_limit" type="number" value="8192" class="input-field">
            </div>
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">DISK LIMIT (GB)</label>
              <input id="disk_limit" type="number" value="100" class="input-field">
            </div>
          </div>

          <!-- INITIAL ALLOCATIONS -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">INITIAL ALLOCATIONS</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">IP FOR ALLOCATIONS <span class="text-neutral-500">(not fixed)</span></label>
              <input id="alloc_ip" type="text" value="127.0.0.1" class="input-field">
            </div>
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">IP ALIAS / LABEL</label>
              <input id="alloc_alias" type="text" class="input-field" placeholder="e.g. Local Servers">
            </div>
          </div>

          <div class="form-row">
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">PORT RANGE START <span class="text-red-400">*</span></label>
              <input id="alloc_start" required type="number" value="20000" class="input-field" min="1" max="65535">
            </div>
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">PORT RANGE END <span class="text-red-400">*</span></label>
              <input id="alloc_end" required type="number" value="30000" class="input-field" min="1" max="65535">
            </div>
          </div>

          <!-- SUBMIT -->
          <div class="mt-12">
            <button type="button" onclick="createLocalNode()" 
                    class="w-full py-5 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold text-lg rounded-[10px] transition-all active:scale-95 shadow-lg flex items-center justify-center gap-3">
              🚀 Create Local Node &amp; Auto-Setup Wings
            </button>
          </div>

        </form>
      </div>

      <!-- Live Progress Console -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-white">Setup Progress (Live)</h2>
          <button onclick="clearConsole()" 
                  class="text-xs px-4 py-1.5 bg-neutral-800 hover:bg-neutral-700 rounded-lg text-neutral-400 transition">Clear Log</button>
        </div>
        
        <div id="console-log" class="log-terminal flex-1 font-mono text-xs leading-relaxed">
          Ready. Fill the form and click the button above to begin automatic setup...
        </div>
      </div>
    </div>
  </div>

  <!-- Notification -->
  <div id="notification" 
       class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
    <span id="notification-text"></span>
  </div>

  <script>
  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;
    
    notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  let currentLog = "Ready. Fill the form and click the button above to begin automatic setup...\n";

  function appendLog(text) {
    currentLog += `[${new Date().toLocaleTimeString()}] ${text}\n`;
    const logEl = document.getElementById('console-log');
    logEl.textContent = currentLog;
    logEl.scrollTop = logEl.scrollHeight;
  }

  function clearConsole() {
    currentLog = "";
    document.getElementById('console-log').textContent = "Console cleared.\n";
  }

  async function createLocalNode() {
    const formData = {
      name: document.getElementById('name').value.trim(),
      daemon_port: parseInt(document.getElementById('daemon_port').value),
      sftp_port: parseInt(document.getElementById('sftp_port').value),
      location_id: document.getElementById('location_id').value ? parseInt(document.getElementById('location_id').value) : null,
      cpu_limit: parseInt(document.getElementById('cpu_limit').value) || 200,
      memory_limit: parseInt(document.getElementById('memory_limit').value) || 8192,
      disk_limit: parseInt(document.getElementById('disk_limit').value) || 100,
      allocation_ip: document.getElementById('alloc_ip').value.trim() || "127.0.0.1",
      alloc_alias: document.getElementById('alloc_alias').value.trim(),
      allocation_start: parseInt(document.getElementById('alloc_start').value),
      allocation_end: parseInt(document.getElementById('alloc_end').value)
    };

    if (!formData.name || !formData.allocation_start || !formData.allocation_end) {
      showNotification('Please fill all required fields', 'error');
      return;
    }

    appendLog('🚀 Starting automatic local node creation...');
    appendLog('Step 1: Creating node record (127.0.0.1, no proxy)');

    try {
      const res = await fetch('/admin/nodes/localnode/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (!res.ok) throw new Error('HTTP ' + res.status);

      const data = await res.json();
      
      if (data.log) {
        appendLog(data.log);
      } else {
        appendLog('Node record created successfully');
      }

      appendLog('🔄 Reinstalling Wings...');
      appendLog('🔑 Auto-configuring with panel token...');
      appendLog('▶️ Starting Wings service...');
      appendLog('✅ Allocations created');
      appendLog('Node is now ONLINE automatically');

      showNotification('Local node created & Wings setup complete!', 'success');

      setTimeout(() => {
        appendLog('✅ Redirecting to overview...');
        window.location.href = '/admin/nodes/overview';
      }, 3500);

    } catch (err) {
      appendLog(`ERROR: ${err.message}`);
      showNotification('Failed to create local node – check logs', 'error');
      console.error(err);
    }
  }
  </script>
</main>
