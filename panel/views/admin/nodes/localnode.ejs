<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 380px;
  overflow-y: auto;
  white-space: pre-wrap;
}
</style>
<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header Section -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">
          <%= req.translations.localNode || 'Local Node Manager' %>
        </h1>
        <p class="mt-1 text-sm text-neutral-400">
          <%= req.translations.localNodeText || 'Install, configure, and control the Wings daemon on this machine' %>
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/admin/nodes/overview'" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          ← Back to Nodes
        </button>
        
        <button onclick="window.location.href='/admin/nodes/localnode'"
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          Local Node
        </button>
      </div>
    </header>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Controls Card -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8">
        <h2 class="text-lg font-semibold text-white mb-6">Daemon Controls</h2>
        
        <div class="space-y-6">
          <!-- Status -->
          <div class="flex items-center justify-between bg-neutral-800/50 rounded-lg p-4">
            <div class="flex items-center gap-3">
              <div id="status-indicator" class="w-3 h-3 rounded-full bg-yellow-500 animate-pulse"></div>
              <span id="status-text" class="text-sm font-medium text-neutral-300">Checking status...</span>
            </div>
            <button onclick="checkStatus()" 
                    class="px-5 py-2 text-xs font-medium bg-neutral-700 hover:bg-neutral-600 rounded-[10px] transition-all">
              Refresh Status
            </button>
          </div>

          <!-- Configure -->
          <div>
            <label class="text-xs font-medium text-neutral-400 block mb-2">
              Configure Command (from node setup)
            </label>
            <input id="configuration" type="text" 
                   class="input-field font-mono text-sm" 
                   placeholder="npm run configure -- --panel https://yourpanel.com --key xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx">
            <p class="mt-2 text-xs text-neutral-500">
              Paste the full command shown in Admin → Nodes → [Your Node] → Configure
            </p>
          </div>

          <!-- Action Buttons -->
          <div class="grid grid-cols-2 gap-3">
            <button onclick="installWings()" 
                    class="py-4 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-[10px] transition-all active:scale-95">
              🚀 Install Wings
            </button>
            <button onclick="configureWings()" 
                    class="py-4 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-[10px] transition-all active:scale-95">
              ⚙️ Import Configure
            </button>
          </div>

          <div class="grid grid-cols-3 gap-3 pt-4 border-t border-white/10">
            <button onclick="startWings()" 
                    class="py-3 bg-green-500 hover:bg-green-600 text-white font-medium rounded-[10px] transition-all active:scale-95">Start</button>
            <button onclick="restartWings()" 
                    class="py-3 bg-amber-500 hover:bg-amber-600 text-white font-medium rounded-[10px] transition-all active:scale-95">Restart</button>
            <button onclick="stopWings()" 
                    class="py-3 bg-red-500 hover:bg-red-600 text-white font-medium rounded-[10px] transition-all active:scale-95">Stop</button>
          </div>
        </div>
      </div>

      <!-- Live Log Card -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-white">Live Console Output</h2>
          <button onclick="clearConsole()" 
                  class="text-xs px-4 py-1.5 bg-neutral-800 hover:bg-neutral-700 rounded-lg text-neutral-400 transition">Clear Log</button>
        </div>
        
        <div id="console-log" 
             class="log-terminal flex-1 font-mono text-xs leading-relaxed">
          Ready. Click any action above to begin...
        </div>
      </div>
    </div>
  </div>

  <!-- Notification -->
  <div id="notification" 
       class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
    <span id="notification-text"></span>
  </div>

  <script>
  // ============== Notification System (same as nodes.ejs & create.ejs) ==============
  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;
    
    notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  // ============== Status ==============
  function updateStatus(running, pid = null) {
    const indicator = document.getElementById('status-indicator');
    const text = document.getElementById('status-text');
    
    if (running) {
      indicator.className = 'w-3 h-3 rounded-full bg-emerald-500 animate-pulse';
      text.textContent = `Running (PID: ${pid || 'Unknown'})`;
    } else {
      indicator.className = 'w-3 h-3 rounded-full bg-red-500';
      text.textContent = 'Stopped';
    }
  }

  async function checkStatus() {
    try {
      const res = await fetch('/admin/nodes/localnode/status', { method: 'POST' });
      const data = await res.json();
      updateStatus(data.running, data.pid);
    } catch (e) {
      console.warn('Status check failed');
    }
  }

  // ============== Console ==============
  let currentLog = "Ready. Click any action above to begin...\n";

  function appendLog(text) {
    currentLog += `[${new Date().toLocaleTimeString()}] ${text}\n`;
    const logEl = document.getElementById('console-log');
    logEl.textContent = currentLog;
    logEl.scrollTop = logEl.scrollHeight;
  }

  function clearConsole() {
    currentLog = "";
    document.getElementById('console-log').textContent = "Console cleared.\n";
  }

  // ============== Actions ==============
  async function runAction(endpoint, actionName) {
    const configValue = document.getElementById('configuration').value.trim();
    appendLog(`Executing ${actionName}...`);

    try {
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ configuration: configValue })
      });

      const data = await res.json();
      appendLog(data.log || 'No output received.');
      
      showNotification(`${actionName} completed`, 'success');
      setTimeout(checkStatus, 1500);
    } catch (err) {
      appendLog(`ERROR: ${err.message}`);
      showNotification(`Failed to ${actionName.toLowerCase()}`, 'error');
    }
  }

  function installWings()    { runAction('/admin/nodes/localnode/install', 'Install Wings'); }
  function configureWings()  { runAction('/admin/nodes/localnode/configure', 'Import Configure'); }
  function startWings()      { runAction('/admin/nodes/localnode/start', 'Start Wings'); }
  function restartWings()    { runAction('/admin/nodes/localnode/restart', 'Restart Wings'); }
  function stopWings()       { runAction('/admin/nodes/localnode/stop', 'Stop Wings'); }

  // ============== Init ==============
  document.addEventListener('DOMContentLoaded', () => {
    checkStatus();
    setInterval(checkStatus, 10000); // auto refresh every 10s
  });
  </script>
</main>
