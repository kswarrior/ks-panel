<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 380px;
  overflow-y: auto;
  white-space: pre-wrap;
}

.resource-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header Section -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">
          <%= req.translations.createLocalNode || 'Create Local Node' %>
        </h1>
        <p class="mt-1 text-sm text-neutral-400">
          <%= req.translations.createLocalNodeText || 'One-click setup: creates the node on localhost, installs/reinstalls Wings, configures automatically, and brings it online instantly. No IP, proxy, or manual command needed.' %>
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/admin/nodes/overview'" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          ← Back to Nodes
        </button>
      </div>
    </header>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Create Form Card -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8">
        <h2 class="text-lg font-semibold text-white mb-6">Local Node Details</h2>
        
        <form id="create-form" class="space-y-6">
          <!-- Basic Info -->
          <div>
            <label class="text-xs font-medium text-neutral-400 block mb-2">Node Name</label>
            <input id="name" type="text" required 
                   class="input-field" 
                   placeholder="My Local Node">
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-medium text-neutral-400 block mb-2">Daemon Port</label>
              <input id="daemon_port" type="number" value="8080" required 
                     class="input-field" min="1" max="65535">
            </div>
            <div>
              <label class="text-xs font-medium text-neutral-400 block mb-2">SFTP Port</label>
              <input id="sftp_port" type="number" value="2022" required 
                     class="input-field" min="1" max="65535">
            </div>
          </div>

          <!-- Location -->
          <div>
            <label class="text-xs font-medium text-neutral-400 block mb-2">Location</label>
            <select id="location_id" required class="input-field">
              <option value="">Loading locations...</option>
            </select>
          </div>

          <!-- Resource Limits (custom fields for your panel) -->
          <div>
            <label class="text-xs font-medium text-neutral-400 block mb-3">Resource Limits (node capacity defaults)</label>
            <div class="resource-grid">
              <div>
                <label class="text-xs text-neutral-400 block mb-1">CPU Limit (%)</label>
                <input id="cpu_limit" type="number" value="200" 
                       class="input-field" placeholder="200">
              </div>
              <div>
                <label class="text-xs text-neutral-400 block mb-1">Memory Limit (MB)</label>
                <input id="memory_limit" type="number" value="8192" 
                       class="input-field" placeholder="8192">
              </div>
              <div>
                <label class="text-xs text-neutral-400 block mb-1">Disk Limit (GB)</label>
                <input id="disk_limit" type="number" value="100" 
                       class="input-field" placeholder="100">
              </div>
            </div>
          </div>

          <!-- Initial Allocations -->
          <div>
            <label class="text-xs font-medium text-neutral-400 block mb-2">Initial Allocations (localhost only)</label>
            <div class="bg-neutral-800/50 rounded-lg p-4 space-y-4">
              <div>
                <label class="text-xs text-neutral-400 block mb-1">IP Address (fixed)</label>
                <input type="text" value="127.0.0.1" readonly 
                       class="input-field bg-neutral-700 cursor-not-allowed">
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="text-xs text-neutral-400 block mb-1">Port Range Start</label>
                  <input id="alloc_start" type="number" value="20000" required 
                         class="input-field" min="1" max="65535">
                </div>
                <div>
                  <label class="text-xs text-neutral-400 block mb-1">Port Range End</label>
                  <input id="alloc_end" type="number" value="30000" required 
                         class="input-field" min="1" max="65535">
                </div>
              </div>
              <p class="text-xs text-neutral-500">A range of ports will be automatically allocated on 127.0.0.1</p>
            </div>
          </div>

          <!-- Action Button -->
          <button type="button" onclick="createLocalNode()" 
                  class="w-full py-5 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold text-lg rounded-[10px] transition-all active:scale-95 shadow-lg flex items-center justify-center gap-3">
            🚀 Create Local Node &amp; Auto-Setup Wings
          </button>
        </form>
      </div>

      <!-- Live Log Card -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-white">Setup Progress</h2>
          <button onclick="clearConsole()" 
                  class="text-xs px-4 py-1.5 bg-neutral-800 hover:bg-neutral-700 rounded-lg text-neutral-400 transition">Clear Log</button>
        </div>
        
        <div id="console-log" 
             class="log-terminal flex-1 font-mono text-xs leading-relaxed">
          Ready. Fill the form and click Create to begin automatic setup...
        </div>
      </div>
    </div>
  </div>

  <!-- Notification -->
  <div id="notification" 
       class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
    <span id="notification-text"></span>
  </div>

  <script>
  // Reuse notification from your manager
  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;
    
    notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  let currentLog = "Ready. Fill the form and click Create to begin automatic setup...\n";

  function appendLog(text) {
    currentLog += `[${new Date().toLocaleTimeString()}] ${text}\n`;
    const logEl = document.getElementById('console-log');
    logEl.textContent = currentLog;
    logEl.scrollTop = logEl.scrollHeight;
  }

  function clearConsole() {
    currentLog = "";
    document.getElementById('console-log').textContent = "Console cleared.\n";
  }

  // Load locations (adjust endpoint if your panel uses a different one)
  async function loadLocations() {
    const select = document.getElementById('location_id');
    try {
      // Common endpoints in Pterodactyl-like panels; try the one that works for you
      const res = await fetch('/api/admin/locations', { method: 'GET' });
      const data = await res.json();
      
      select.innerHTML = '<option value="">Select Location</option>';
      data.forEach(loc => {
        const opt = document.createElement('option');
        opt.value = loc.id;
        opt.textContent = `${loc.long_name || loc.name} (${loc.short_code || ''})`;
        select.appendChild(opt);
      });
    } catch (e) {
      select.innerHTML = '<option value="">Error loading locations – check console</option>';
      console.error('Locations fetch failed', e);
    }
  }

  async function createLocalNode() {
    const formData = {
      name: document.getElementById('name').value.trim(),
      daemon_port: parseInt(document.getElementById('daemon_port').value),
      sftp_port: parseInt(document.getElementById('sftp_port').value),
      location_id: parseInt(document.getElementById('location_id').value),
      cpu_limit: parseInt(document.getElementById('cpu_limit').value) || 200,
      memory_limit: parseInt(document.getElementById('memory_limit').value) || 8192,
      disk_limit: parseInt(document.getElementById('disk_limit').value) || 100,
      allocation_ip: '127.0.0.1',
      allocation_start: parseInt(document.getElementById('alloc_start').value),
      allocation_end: parseInt(document.getElementById('alloc_end').value)
    };

    if (!formData.name || !formData.location_id || !formData.allocation_start || !formData.allocation_end) {
      showNotification('Please fill all required fields', 'error');
      return;
    }

    appendLog('🚀 Starting automatic local node creation...');
    appendLog('Step 1: Creating node record in panel (localhost, no proxy)');

    try {
      const res = await fetch('/admin/nodes/localnode/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (!res.ok) throw new Error('HTTP ' + res.status);

      const data = await res.json();
      
      // Stream any progressive logs from backend
      if (data.log) {
        appendLog(data.log);
      } else {
        appendLog('Node record created successfully (IP: 127.0.0.1)');
      }

      // Backend should now handle: install Wings (or reinstall), auto-configure with generated token,
      // start Wings, create initial allocations, and wait for Wings to connect → node goes online
      appendLog('Step 2: Installing/Reinstalling Wings daemon...');
      appendLog('Step 3: Auto-configuring with panel token...');
      appendLog('Step 4: Starting Wings service...');
      appendLog('Step 5: Creating initial port allocations on 127.0.0.1...');
      appendLog('Step 6: Waiting for Wings to register → node will be ONLINE automatically');

      showNotification('Local node created & Wings setup complete!', 'success');

      // Auto-refresh status and redirect after 4 seconds (backend already made it online)
      setTimeout(() => {
        appendLog('✅ All done! Redirecting to node overview...');
        window.location.href = '/admin/nodes/overview';
      }, 4000);

    } catch (err) {
      appendLog(`ERROR: ${err.message}`);
      showNotification('Failed to create local node – check logs', 'error');
      console.error(err);
    }
  }

  // Auto-load locations on page load
  document.addEventListener('DOMContentLoaded', () => {
    loadLocations();
    // Optional: you can also call checkStatus() here if you want live status preview
  });
  </script>
</main>
