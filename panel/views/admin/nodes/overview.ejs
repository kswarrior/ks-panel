<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

/* Smooth scrollbar for webkit */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Prevent zoom on iOS inputs */
@supports (-webkit-touch-callout: none) {
  input, select, textarea {
    font-size: 16px;
  }
}

/* Loading animation */
@keyframes spin {
  to { transform: rotate(360deg); }
}

.animate-spin-slow {
  animation: spin 3s linear infinite;
}

/* Mobile cards - hidden on sm and up */
.mobile-cards {
  display: block;
}

/* Desktop table - hidden below sm */
.desktop-table {
  display: none;
}

@media (min-width: 640px) {
  .mobile-cards {
    display: none;
  }
  .desktop-table {
    display: block;
  }
}
</style>

<main id="content" class="min-h-screen pb-20">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    
    <!-- Header Section -->
    <header class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 lg:gap-6 pb-6 sm:pb-8 border-b border-white/10">
      <div class="space-y-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= req.translations.nodes %></h1>
        <p class="text-sm text-neutral-400 max-w-xl"><%= req.translations.nodesText %></p>
      </div>

      <div class="flex flex-wrap gap-2 sm:gap-3">
        <button onclick="radarcheck()" 
                class="flex items-center justify-center gap-2 px-4 sm:px-5 py-2.5 rounded-xl bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-lg hover:shadow-xl hover:border-white/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256" class="sm:w-5 sm:h-5">
            <path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"></path>
          </svg>
          <span class="hidden sm:inline">Radar Scan</span>
          <span class="sm:hidden">Scan</span>
        </button>
        
        <button onclick="window.location.href='/admin/nodes/create'"
                class="px-4 sm:px-6 py-2.5 rounded-xl bg-white text-black font-semibold text-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center gap-2">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          <span class="hidden sm:inline"><%= req.translations.createNewNode %></span>
          <span class="sm:hidden">Create</span>
        </button>

        <button onclick="window.location.href='/admin/nodes/localnode'"
                class="px-4 sm:px-6 py-2.5 rounded-xl bg-white/10 hover:bg-white/20 text-white font-semibold text-sm border border-white/10 shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center gap-2">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <span class="hidden sm:inline">Local Node</span>
          <span class="sm:hidden">Local</span>
        </button>
      </div>
    </header>

    <!-- Stats Section -->
    <section id="stats" class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mt-6 sm:mt-8">
      <article class="relative overflow-hidden rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 p-5 sm:p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.07] group shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-emerald-500/20 transition-all duration-500"></div>
        <div class="relative flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              Total Nodes
            </p>
            <p class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-2 tracking-tight"><%= nodes.length %></p>
          </div>
          <div class="w-12 h-12 sm:w-14 sm:h-14 bg-emerald-500/10 rounded-xl sm:rounded-2xl flex items-center justify-center text-2xl sm:text-3xl border border-emerald-500/20 group-hover:scale-110 transition-transform duration-300">📡</div>
        </div>
        <div class="relative mt-4 sm:mt-6 flex items-center gap-4 text-sm">
          <span class="text-neutral-400">Online: <span class="text-emerald-400 font-semibold"><%= nodes.filter(node => node.status === 'Online').length %></span></span>
          <span class="w-px h-4 bg-white/10"></span>
          <span class="text-neutral-400">Offline: <span class="text-red-400 font-semibold"><%= nodes.filter(node => node.status === 'Offline').length %></span></span>
        </div>
      </article>

      <article class="relative overflow-hidden rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 p-5 sm:p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.07] group shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-blue-500/20 transition-all duration-500"></div>
        <div class="relative flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-blue-500"></span>
              Server Count
            </p>
            <p class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mt-2 tracking-tight"><%= Object.values(set).reduce((a, b) => a + b, 0) %></p>
          </div>
          <div class="w-12 h-12 sm:w-14 sm:h-14 bg-blue-500/10 rounded-xl sm:rounded-2xl flex items-center justify-center text-2xl sm:text-3xl border border-blue-500/20 group-hover:scale-110 transition-transform duration-300">🖥️</div>
        </div>
        <% if (nodes.length > 0) { %>
          <p class="relative mt-4 sm:mt-6 text-sm text-neutral-400">
            Avg. Density: <span class="font-mono text-white font-semibold bg-white/10 px-2 py-1 rounded-lg"><%= (Object.values(set).reduce((a, b) => a + b, 0) / nodes.length).toFixed(2) %></span> servers/node
          </p>
        <% } else { %>
          <p class="relative mt-4 sm:mt-6 text-sm text-neutral-400">No nodes configured yet</p>
        <% } %>
      </article>
    </section>

    <!-- Success Banners -->
    <% if (req.query.err == "none") { %>
    <div class="mt-6 sm:mt-8 bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 sm:p-5 flex gap-3 sm:gap-4 items-start shadow-lg backdrop-blur-sm">
      <div class="flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-emerald-400 text-sm sm:text-base">Success!</p>
        <p class="text-sm text-emerald-300/80 mt-1">The action was successfully completed.</p>
      </div>
      <button onclick="this.parentElement.remove()" class="flex-shrink-0 text-emerald-400/60 hover:text-emerald-400 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <% } %>

    <% if (req.query.err == "EDITED") { %>
    <div class="mt-6 sm:mt-8 bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 sm:p-5 flex gap-3 sm:gap-4 items-start shadow-lg backdrop-blur-sm">
      <div class="flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-emerald-400 text-sm sm:text-base">Changes Saved!</p>
        <p class="text-sm text-emerald-300/80 mt-1">The node was edited successfully.</p>
      </div>
      <button onclick="this.parentElement.remove()" class="flex-shrink-0 text-emerald-400/60 hover:text-emerald-400 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <% } %>

    <!-- Table Section - Desktop Only (sm and up) -->
    <section class="mt-6 sm:mt-8 desktop-table">
      <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl overflow-hidden" id="nodeTable">
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left text-white">
            <thead class="bg-neutral-950/80 text-neutral-400 text-xs uppercase tracking-wider">
              <tr>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold">Node</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden md:table-cell">Connection</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden lg:table-cell">Tunnel</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden sm:table-cell">Location</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold text-center">Instances</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden xl:table-cell">RAM</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden xl:table-cell">CPU</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold hidden xl:table-cell">Disk</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold text-right hidden lg:table-cell">Upload</th>
                <th class="py-4 px-4 sm:py-5 sm:px-6 font-semibold text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% nodes.forEach(function(node) { %>
              <tr class="hover:bg-white/[0.03] transition-colors duration-200 group">
                <!-- Name & Status -->
                <td class="py-4 px-4 sm:py-5 sm:px-6">
                  <div class="flex items-center gap-3">
                    <div class="relative flex-shrink-0">
                      <% if (node.status === "Online") { %>
                        <span class="relative flex h-3 w-3">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                        </span>
                      <% } else if (node.status === "Offline") { %>
                        <span class="relative flex h-3 w-3">
                          <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-500"></span>
                        </span>
                      <% } else { %>
                        <span class="relative flex h-3 w-3">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
                        </span>
                      <% } %>
                    </div>
                    <div class="min-w-0">
                      <span class="font-semibold text-white block truncate max-w-[120px] sm:max-w-[180px]"><%= node.name %></span>
                    </div>
                  </div>
                </td>

                <!-- Connection -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden md:table-cell">
                  <div class="font-mono text-xs text-neutral-400 bg-neutral-800/50 px-3 py-1.5 rounded-lg inline-block border border-white/5">
                    <%= node.address %><span class="text-neutral-600">:</span><%= node.port %>
                    <% if (node.behindProxy) { %>
                      <span class="ml-2 text-amber-400 text-[10px] bg-amber-500/10 px-1.5 py-0.5 rounded">PROXY</span>
                    <% } %>
                  </div>
                </td>

                <!-- Tunnel -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden lg:table-cell">
                  <% if (node.useCloudflareTunnel) { %>
                    <span class="inline-flex items-center gap-2 text-emerald-400 text-xs font-semibold bg-emerald-500/10 px-3 py-1.5 rounded-lg border border-emerald-500/20">
                      <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                      CF TUNNEL
                    </span>
                  <% } else { %>
                    <span class="text-neutral-500 text-xs">—</span>
                  <% } %>
                </td>

                <!-- Location -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden sm:table-cell">
                  <% let locName = 'Unknown'; %>
                  <% locations.forEach(function(loc) { %>
                    <% if (loc.id === node.location) locName = loc.name; %>
                  <% }); %>
                  <span class="text-sm text-neutral-300 bg-white/5 px-3 py-1 rounded-lg border border-white/5"><%= locName %></span>
                </td>

                <!-- Instances -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 text-center">
                  <span class="inline-flex items-center justify-center min-w-[2rem] bg-neutral-800 px-3 py-1.5 rounded-lg text-xs font-semibold text-white border border-white/10 shadow-sm">
                    <%= set[node.id] || 0 %>
                  </span>
                </td>

                <!-- RAM -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden xl:table-cell">
                  <div class="flex items-center gap-3 min-w-[140px]">
                    <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                      <div id="ram-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-700 ease-out"
                           style="width: 0%; background: linear-gradient(90deg, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="ram-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-16 text-right">--</span>
                  </div>
                </td>

                <!-- CPU -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden xl:table-cell">
                  <div class="flex items-center gap-3 min-w-[100px]">
                    <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                      <div id="cpu-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-700 ease-out"
                           style="width: 0%; background: linear-gradient(90deg, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="cpu-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-10 text-right">0%</span>
                  </div>
                </td>

                <!-- Disk -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 hidden xl:table-cell">
                  <div class="flex items-center gap-3 min-w-[140px]">
                    <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                      <div id="disk-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-700 ease-out"
                           style="width: 0%; background: linear-gradient(90deg, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="disk-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-16 text-right">--</span>
                  </div>
                </td>

                <!-- Upload -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 text-right hidden lg:table-cell">
                  <span class="text-sm text-neutral-300 font-medium bg-white/5 px-3 py-1.5 rounded-lg border border-white/5"><%= node.uploadSize || 500 %> MB</span>
                </td>

                <!-- Actions -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button onclick="configure('<%= node.id %>')" 
                            class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all duration-200 active:scale-95 border border-white/10">
                      CONFIG
                    </button>
                    <a href="/admin/node/<%= node.id %>">
                      <button class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all duration-200 active:scale-95 border border-white/10">
                        EDIT
                      </button>
                    </a>
                    <button onclick="deletenode('<%= node.id %>')" 
                            class="px-3 py-1.5 text-xs font-medium bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-xl transition-all duration-200 active:scale-95 border border-red-500/20">
                      DELETE
                    </button>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Mobile Cards View - Mobile Only (below sm) -->
    <section class="mt-6 mobile-cards">
      <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl overflow-hidden divide-y divide-white/5">
        <% nodes.forEach(function(node) { %>
        <div class="p-4 bg-neutral-900/30 hover:bg-neutral-900/50 transition-colors duration-200">
          <!-- Header: Name, Status, Instances -->
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2 min-w-0">
              <% if (node.status === "Online") { %>
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
              <% } else if (node.status === "Offline") { %>
                <span class="w-2.5 h-2.5 rounded-full bg-neutral-500 flex-shrink-0"></span>
              <% } else { %>
                <span class="w-2.5 h-2.5 rounded-full bg-amber-500 flex-shrink-0"></span>
              <% } %>
              <span class="font-semibold text-white truncate"><%= node.name %></span>
            </div>
            <span class="text-xs text-neutral-400 bg-neutral-800 px-2 py-1 rounded-lg border border-white/10 flex-shrink-0"><%= set[node.id] || 0 %> instances</span>
          </div>
          
          <!-- Connection Info -->
          <div class="font-mono text-xs text-neutral-500 mb-3 bg-neutral-800/30 px-3 py-2 rounded-lg border border-white/5">
            <%= node.address %>:<%= node.port %>
            <% if (node.behindProxy) { %>
              <span class="text-amber-400 ml-1">(proxy)</span>
            <% } %>
          </div>

          <!-- Location & Tunnel -->
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            <% let locName = 'Unknown'; %>
            <% locations.forEach(function(loc) { %>
              <% if (loc.id === node.location) locName = loc.name; %>
            <% }); %>
            <span class="text-xs text-neutral-300 bg-white/5 px-2 py-1 rounded border border-white/10"><%= locName %></span>
            <% if (node.useCloudflareTunnel) { %>
              <span class="text-xs text-emerald-400 bg-emerald-500/10 px-2 py-1 rounded border border-emerald-500/20">CF Tunnel</span>
            <% } %>
          </div>

          <!-- Resource Bars (Simplified) -->
          <div class="space-y-2 mb-4">
            <div class="flex items-center gap-2">
              <span class="text-xs text-neutral-500 w-8">RAM</span>
              <div class="flex-1 h-1.5 bg-neutral-700 rounded-full overflow-hidden">
                <div id="ram-bar-mobile-<%= node.id %>" class="h-full bg-emerald-500 rounded-full transition-all duration-700" style="width: 0%"></div>
              </div>
              <span id="ram-text-mobile-<%= node.id %>" class="text-xs text-neutral-400 w-12 text-right font-mono">--</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-neutral-500 w-8">CPU</span>
              <div class="flex-1 h-1.5 bg-neutral-700 rounded-full overflow-hidden">
                <div id="cpu-bar-mobile-<%= node.id %>" class="h-full bg-blue-500 rounded-full transition-all duration-700" style="width: 0%"></div>
              </div>
              <span id="cpu-text-mobile-<%= node.id %>" class="text-xs text-neutral-400 w-12 text-right font-mono">0%</span>
            </div>
          </div>

          <!-- Actions -->
          <div class="grid grid-cols-3 gap-2">
            <button onclick="configure('<%= node.id %>')" class="py-2.5 bg-white/5 hover:bg-white/10 text-white text-xs font-medium rounded-xl border border-white/10 transition-all duration-200 active:scale-95 flex items-center justify-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
              Config
            </button>
            <a href="/admin/node/<%= node.id %>" class="block">
              <button class="w-full py-2.5 bg-white/5 hover:bg-white/10 text-white text-xs font-medium rounded-xl border border-white/10 transition-all duration-200 active:scale-95 flex items-center justify-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit
              </button>
            </a>
            <button onclick="deletenode('<%= node.id %>')" class="py-2.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium rounded-xl border border-red-500/20 transition-all duration-200 active:scale-95 flex items-center justify-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
              Delete
            </button>
          </div>
        </div>
        <% }); %>
      </div>
    </section>

    <%- include('../../components/pagination', { pagination }) %>

    <!-- Notification Toast -->
    <div id="notification" 
         class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 hidden items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 rounded-xl shadow-2xl text-sm font-medium z-50 transition-all duration-300 transform translate-y-2 opacity-0">
      <span id="notification-icon"></span>
      <span id="notification-text"></span>
    </div>

  </div>

  <script>
  function getBarColor(percent) {
    if (percent > 90) return '#ef4444';
    if (percent > 70) return '#eab308';
    return '#22c55e';
  }

  async function updateNodeResources(nodeId) {
    try {
      const res = await fetch(`/admin/node/${nodeId}/resourceMonitor`);
      if (!res.ok) throw new Error('Failed to fetch');
      const data = await res.json();

      // Update desktop bars
      ['ram','cpu','disk'].forEach(key => {
        const bar = document.getElementById(key + '-bar-' + nodeId);
        const text = document.getElementById(key + '-text-' + nodeId);
        if (!bar || !text) return;
        
        const val = data[key];
        if (!val) return;
        
        const p = parseFloat(val.percent || (val.used / val.total * 100));
        const color = getBarColor(p);
        
        bar.style.width = `${Math.min(p, 100)}%`;
        bar.style.background = `linear-gradient(90deg, ${color} 0%, ${color}dd 100%)`;
        
        text.textContent = key === 'cpu' 
          ? `${val.percent}%` 
          : `${val.used}/${val.total}GB`;
        text.className = `font-mono text-xs w-${key === 'cpu' ? '10' : '16'} text-right ${p > 90 ? 'text-red-400' : p > 70 ? 'text-amber-400' : 'text-emerald-400'}`;
      });

      // Update mobile bars
      const ramBarMobile = document.getElementById('ram-bar-mobile-' + nodeId);
      const ramTextMobile = document.getElementById('ram-text-mobile-' + nodeId);
      const cpuBarMobile = document.getElementById('cpu-bar-mobile-' + nodeId);
      const cpuTextMobile = document.getElementById('cpu-text-mobile-' + nodeId);

      if (data.ram && ramBarMobile && ramTextMobile) {
        const ramP = parseFloat(data.ram.percent || (data.ram.used / data.ram.total * 100));
        ramBarMobile.style.width = `${Math.min(ramP, 100)}%`;
        ramBarMobile.style.backgroundColor = getBarColor(ramP);
        ramTextMobile.textContent = `${data.ram.used}/${data.ram.total}GB`;
        ramTextMobile.className = `text-xs w-12 text-right font-mono ${ramP > 90 ? 'text-red-400' : ramP > 70 ? 'text-amber-400' : 'text-emerald-400'}`;
      }

      if (data.cpu && cpuBarMobile && cpuTextMobile) {
        const cpuP = parseFloat(data.cpu.percent);
        cpuBarMobile.style.width = `${Math.min(cpuP, 100)}%`;
        cpuBarMobile.style.backgroundColor = getBarColor(cpuP);
        cpuTextMobile.textContent = `${cpuP}%`;
        cpuTextMobile.className = `text-xs w-12 text-right font-mono ${cpuP > 90 ? 'text-red-400' : cpuP > 70 ? 'text-amber-400' : 'text-emerald-400'}`;
      }
    } catch(e) {
      console.warn(`Resource update failed for ${nodeId}:`, e);
    }
  }

  async function deletenode(nodeId) { 
    if (!confirm('Are you sure you want to delete this node? This action cannot be undone.')) return;
    
    try {
      const res = await fetch('/admin/nodes/delete', { 
        method: 'POST', 
        headers: {'Content-Type':'application/json'}, 
        body: JSON.stringify({nodeId}) 
      });
      
      if (res.ok) { 
        showNotification('Node deleted successfully', 'success'); 
        setTimeout(() => location.reload(), 1000); 
      } else {
        const err = await res.text();
        throw new Error(err);
      }
    } catch(e) { 
      showNotification(e.message || 'Failed to delete node', 'error'); 
    }
  }

  async function configure(nodeId) {
    try {
      const res = await fetch(`/admin/nodes/node/${nodeId}/configure-command`);
      const { configureCommand } = await res.json();
      await navigator.clipboard.writeText(configureCommand);
      showNotification('Configure command copied to clipboard!', 'success');
    } catch(e) { 
      showNotification('Failed to copy command', 'error'); 
    }
  }

  async function radarcheck() {
    try {
      await fetch('/admin/nodes/overview/radar/check', { method: 'POST' });
      showNotification('Radar scan initiated', 'success');
    } catch(e) {
      showNotification('Radar scan failed', 'error');
    }
  }

  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    const iconEl = document.getElementById('notification-icon');
    
    textEl.textContent = message;
    
    const iconSvg = type === 'error' 
      ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>'
      : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
    
    iconEl.innerHTML = iconSvg;
    
    notification.className = `fixed bottom-4 right-4 sm:bottom-6 sm:right-6 flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 rounded-xl shadow-2xl text-sm font-medium z-50 transition-all duration-300 ${
      type === 'error' 
        ? 'bg-red-500/90 text-white border border-red-400/50' 
        : 'bg-emerald-500/90 text-white border border-emerald-400/50'
    }`;
    
    notification.classList.remove('hidden');
    requestAnimationFrame(() => {
      notification.classList.remove('translate-y-2', 'opacity-0');
    });

    setTimeout(() => {
      notification.classList.add('translate-y-2', 'opacity-0');
      setTimeout(() => {
        notification.classList.add('hidden');
      }, 300);
    }, 3000);
  }

  // Initialize resources
  document.addEventListener('DOMContentLoaded', () => {
    <% nodes.forEach(node => { %>
      updateNodeResources('<%= node.id %>');
    <% }); %>
    
    setInterval(() => {
      <% nodes.forEach(node => { %>
        updateNodeResources('<%= node.id %>');
      <% }); %>
    }, 15000);
  });
  </script>
</main>
