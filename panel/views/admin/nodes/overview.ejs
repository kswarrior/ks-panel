<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}
</style>
<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header Section -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight"><%= req.translations.nodes %></h1>
        <p class="mt-1 text-sm text-neutral-400"><%= req.translations.nodesText %></p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="radarcheck()" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256"><path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"></path></svg>
          Radar Scan
        </button>
        
        <button onclick="window.location.href='/admin/nodes/create'"
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          <%= req.translations.createNewNode %>
        </button>

        <button onclick="window.location.href='/admin/localnode'"
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          Local Node
        </button>
      </div>
    </header>

    <!-- Stats Section -->
    <section id="stats" class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <article class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 transition-all duration-200 hover:border-white/20 group shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400">Total Nodes</p>
            <p class="text-4xl md:text-5xl font-semibold text-white mt-2"><%= nodes.length %></p>
          </div>
          <div class="w-12 h-12 bg-emerald-500/10 rounded-lg flex items-center justify-center text-3xl">📡</div>
        </div>
        <p class="mt-6 text-sm text-neutral-400">
          Online: <span class="text-emerald-400 font-medium"><%= nodes.filter(node => node.status === 'Online').length %></span>
        </p>
      </article>

      <article class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 transition-all duration-200 hover:border-white/20 group shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400">Server Count</p>
            <p class="text-4xl md:text-5xl font-semibold text-white mt-2"><%= Object.values(set).reduce((a, b) => a + b, 0) %></p>
          </div>
          <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center text-3xl">🖥️</div>
        </div>
        <% if (nodes.length > 0) { %>
          <p class="mt-6 text-sm text-neutral-400">
            Avg. Density: <span class="font-mono"><%= (Object.values(set).reduce((a, b) => a + b, 0) / nodes.length).toFixed(2) %></span>
          </p>
        <% } else { %>
          <p class="mt-6 text-sm text-neutral-400">No nodes yet</p>
        <% } %>
      </article>
    </section>

    <!-- Success Banners -->
    <% if (req.query.err == "none") { %>
    <div class="mt-8 mx-1 bg-emerald-900/30 border border-emerald-500/30 rounded-lg p-5 flex gap-4 items-start">
      <div class="mt-0.5 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7" />
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-medium text-emerald-400">Success!</p>
        <p class="text-sm text-emerald-300/80">The action was successfully completed.</p>
      </div>
    </div>
    <% } %>

    <% if (req.query.err == "EDITED") { %>
    <div class="mt-8 mx-1 bg-emerald-900/30 border border-emerald-500/30 rounded-lg p-5 flex gap-4 items-start">
      <div class="mt-0.5 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7" />
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-medium text-emerald-400">Success!</p>
        <p class="text-sm text-emerald-300/80">The node was edited successfully.</p>
      </div>
    </div>
    <% } %>

    <!-- Table Section -->
    <section class="mt-8">
      <div class="overflow-x-auto rounded-lg border border-white/10 bg-neutral-900/50 shadow-2xl" id="nodeTable">
        <table class="min-w-full text-sm text-left text-white divide-y divide-white/10">
          <thead class="bg-neutral-950/70">
            <tr>
              <th class="py-4 pl-6 pr-2 font-semibold text-neutral-300 text-xs sm:py-5 sm:pl-8">NODE</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">CONNECTION</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">TUNNEL</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">LOCATION</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5 text-center">INSTANCES</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">RAM</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">CPU</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">DISK</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5 text-right">UPLOAD</th>
              <th class="py-4 pr-2 pl-2 font-semibold text-neutral-300 text-xs sm:pr-6 sm:pl-4 sm:py-5 text-right">ACTIONS</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% nodes.forEach(function(node) { %>
            <tr class="hover:bg-white/5 transition-colors duration-200 group">
              <!-- Name -->
              <td class="pl-6 py-4 sm:pl-8 sm:py-6">
                <div class="flex items-center gap-3">
                  <% if (node.status === "Online") { %>
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                    </span>
                  <% } else if (node.status === "Offline") { %>
                    <span class="relative flex h-3 w-3">
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-neutral-500"></span>
                    </span>
                  <% } else { %>
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-amber-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
                    </span>
                  <% } %>
                  <span class="font-semibold text-white truncate max-w-[180px]"><%= node.name %></span>
                </div>
              </td>

              <!-- Connection -->
              <td class="px-2 py-4 font-mono text-xs text-neutral-400 sm:px-4 sm:py-6">
                <%= node.address %><span class="text-neutral-500">:</span><%= node.port %>
                <% if (node.behindProxy) { %><span class="ml-2 text-amber-400 text-[10px]">(proxy)</span><% } %>
              </td>

              <!-- Tunnel -->
              <td class="px-2 py-4 sm:px-4 sm:py-6">
                <% if (node.useCloudflareTunnel) { %>
                  <span class="inline-flex items-center gap-1.5 text-emerald-400 text-xs font-medium">
                    <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                    CF TUNNEL
                  </span>
                <% } else { %>
                  <span class="text-neutral-500 text-xs">—</span>
                <% } %>
              </td>

              <!-- Location -->
              <td class="px-2 py-4 text-sm text-neutral-400 sm:px-4 sm:py-6">
                <% let locName = 'unknown'; %>
                <% locations.forEach(function(loc) { %>
                  <% if (loc.id === node.location) locName = loc.name; %>
                <% }); %>
                <%= locName %>
              </td>

              <!-- Instances -->
              <td class="px-2 py-4 text-center sm:px-4 sm:py-6">
                <span class="inline-block bg-neutral-800 px-3 py-1 rounded-[10px] text-xs font-medium">
                  <%= set[node.id] || 0 %>
                </span>
              </td>

              <!-- RAM -->
              <td class="px-2 py-4 sm:px-4 sm:py-6">
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                    <div id="ram-bar-<%= node.id %>" 
                         class="h-full rounded-full transition-all duration-700"
                         style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                  </div>
                  <span id="ram-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-20 text-right hidden sm:inline">--</span>
                </div>
              </td>

              <!-- CPU -->
              <td class="px-2 py-4 sm:px-4 sm:py-6">
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                    <div id="cpu-bar-<%= node.id %>" 
                         class="h-full rounded-full transition-all duration-700"
                         style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                  </div>
                  <span id="cpu-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-12 text-right hidden sm:inline">0%</span>
                </div>
              </td>

              <!-- Disk -->
              <td class="px-2 py-4 sm:px-4 sm:py-6">
                <div class="flex items-center gap-3">
                  <div class="flex-1 h-2 bg-neutral-700 rounded-full overflow-hidden">
                    <div id="disk-bar-<%= node.id %>" 
                         class="h-full rounded-full transition-all duration-700"
                         style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                  </div>
                  <span id="disk-text-<%= node.id %>" class="font-mono text-xs text-neutral-400 w-20 text-right hidden sm:inline">--</span>
                </div>
              </td>

              <!-- Upload -->
              <td class="px-2 py-4 text-right text-sm text-neutral-400 font-medium sm:px-4 sm:py-6">
                <%= node.uploadSize || 500 %> MB
              </td>

              <!-- Actions -->
              <td class="pr-2 py-4 text-right sm:pr-6 sm:py-6">
                <div class="flex items-center gap-2 justify-end flex-wrap">
                  <button onclick="configure('<%= node.id %>')" 
                          class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0">
                    CONFIGURE
                  </button>
                  <a href="/admin/node/<%= node.id %>">
                    <button class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0">
                      EDIT
                    </button>
                  </a>
                  <button onclick="deletenode('<%= node.id %>')" 
                          class="px-3 py-1.5 text-xs font-medium bg-red-600/80 hover:bg-red-600 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0">
                    DELETE
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>

    <%- include('../components/pagination', { pagination }) %>

    <!-- Notification -->
    <div id="notification" 
         class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
      <span id="notification-text"></span>
    </div>
  </div>

  <script>
  function getBarColor(percent) {
    if (percent > 95) return '#ef4444';
    if (percent > 75) return '#eab308';
    return '#22c55e';
  }

  async function updateNodeResources(nodeId) {
    try {
      const res = await fetch(`/admin/node/${nodeId}/resourceMonitor`);
      if (!res.ok) throw new Error();
      const data = await res.json();

      ['ram','cpu','disk'].forEach(key => {
        const bar = document.getElementById(key + '-bar-' + nodeId);
        const text = document.getElementById(key + '-text-' + nodeId);
        if (!bar || !text) return;
        const val = data[key];
        if (!val) return;
        const p = parseFloat(val.percent || val.used / val.total * 100);
        bar.style.width = `${p}%`;
        bar.style.background = `linear-gradient(to right, ${getBarColor(p)}, ${getBarColor(p*1.2)})`;
        text.textContent = key === 'cpu' 
          ? `${val.percent}%` 
          : `${val.used} / ${val.total} GB (${p.toFixed(0)}%)`;
      });
    } catch(e) {
      console.warn(`Resource update failed for ${nodeId}`);
    }
  }

  // Helper functions
  async function deletenode(nodeId) { 
    if (!confirm('Delete this node?')) return;
    try {
      const res = await fetch('/admin/nodes/delete', { 
        method: 'POST', 
        headers: {'Content-Type':'application/json'}, 
        body: JSON.stringify({nodeId}) 
      });
      if (res.ok) { 
        showNotification('Node deleted', 'success'); 
        location.reload(); 
      } else throw new Error('Failed');
    } catch(e) { 
      showNotification('Delete failed', 'error'); 
    }
  }

  async function configure(nodeId) {
    try {
      const res = await fetch(`/admin/nodes/node/${nodeId}/configure-command`);
      const { configureCommand } = await res.json();
      await navigator.clipboard.writeText(configureCommand);
      showNotification('Configure command copied!', 'success');
    } catch(e) { 
      showNotification('Failed to copy command', 'error'); 
    }
  }

  async function radarcheck() {
    await fetch('/admin/nodes/overview/radar/check', { method: 'POST' });
    showNotification('Radar check started', 'success');
  }

  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;
    
    notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  // Init resources (runs on load + every 15 seconds)
  document.addEventListener('DOMContentLoaded', () => {
    <% nodes.forEach(node => { %>
      updateNodeResources('<%= node.id %>');
    <% }); %>
    setInterval(() => {
      <% nodes.forEach(node => { %>
        updateNodeResources('<%= node.id %>');
      <% }); %>
    }, 15000);
  });
  </script>
</main>
