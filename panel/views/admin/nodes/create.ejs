<style>
.input-field{
  width:100%;
  padding:1rem 1.5rem;
  background-color:#1c3b54;
  border:1px solid rgba(255,255,255,0.1);
  border-radius:10px;
  color:white;
  outline:none;
  transition:all .2s ease;
  box-sizing:border-box;
}

.input-field:focus{
  border-color:rgba(255,255,255,0.3);
  box-shadow:0 0 0 2px rgba(255,255,255,0.1);
}

.form-row{
  display:grid;
  grid-template-columns:1fr;
  gap:1.5rem;
}

@media(min-width:1024px){

  .form-row.auto{
    display:grid;
    grid-template-columns:repeat(12,minmax(0,1fr));
    gap:1.5rem;
    width:100%;
  }

  .field-long{
    grid-column:span 6;
    min-width:0;
  }

  .field-short{
    grid-column:span 3;
    min-width:0;
  }

  .field-full{
    grid-column:span 12;
    min-width:0;
  }

  .form-row.auto > *{
    flex-grow:1;
  }
}

.radio-group{
  display:flex;
  flex-direction:column;
  gap:.5rem;
}

.radio-option{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:.5rem;
  background-color:rgba(255,255,255,0.05);
  border-radius:.5rem;
  cursor:pointer;
  transition:background-color .2s ease;
}

.radio-option:hover{
  background-color:rgba(255,255,255,0.1);
}

.proxy-checkbox{
  display:flex;
  align-items:center;
  justify-content:center;
  padding:.75rem;
  background-color:rgba(75,85,99,.3);
  border-radius:.5rem;
  gap:.75rem;
}
</style>

<!-- BASIC -->
<div class="form-row auto">

<div class="field-long">
<label class="text-xs font-medium text-neutral-400 block mb-2">NODE NAME <span class="text-red-400">*</span></label>
<input id="nodeName" required type="text" class="input-field" placeholder="Main Node">
</div>

<div class="field-long">
<label class="text-xs font-medium text-neutral-400 block mb-2">FQDN / IP OR TUNNEL HOSTNAME <span class="text-red-400">*</span></label>
<input id="nodeAddress" required type="text" class="input-field" placeholder="node1.example.com">
</div>

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">DAEMON PORT <span class="text-red-400">*</span></label>
<input id="nodePort" required type="number" value="3002" class="input-field">
</div>

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">SFTP PORT</label>
<input id="nodeSftpPort" type="number" value="2022" class="input-field">
</div>

<div class="field-long">
<label class="text-xs font-medium text-neutral-400 block mb-2">LOCATION <span class="text-red-400">*</span></label>
<select id="nodeLocation" required class="input-field">
<option value="">Select location...</option>
<% locations.forEach(function(loc){ %>
<option value="<%= loc.id %>"><%= loc.name %></option>
<% }) %>
</select>
</div>

</div>

<!-- RESOURCE LIMITS -->
<div id="manualResources" class="hidden form-row auto col-span-1 lg:col-span-2">

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">TOTAL RAM (GB) <span class="text-red-400">*</span></label>
<input id="nodeRam" type="number" class="input-field" placeholder="32">
</div>

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">TOTAL DISK (GB) <span class="text-red-400">*</span></label>
<input id="nodeDisk" type="number" class="input-field" placeholder="500">
</div>

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">MEMORY OVERALLOCATE (%)</label>
<input id="nodeMemoryOver" type="number" value="0" class="input-field">
</div>

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">DISK OVERALLOCATE (%)</label>
<input id="nodeDiskOver" type="number" value="0" class="input-field">
</div>

</div>

<div class="form-row auto">

<div class="field-short">
<label class="text-xs font-medium text-neutral-400 block mb-2">MAX UPLOAD SIZE (MB)</label>
<input id="nodeUploadSize" type="number" value="500" class="input-field">
</div>

</div>

<!-- PROXY -->
<div class="form-row auto">

<div class="field-short">
<div class="proxy-checkbox">
<input id="behindProxy" type="checkbox" class="w-5 h-5 accent-white rounded">
<label for="behindProxy" class="text-sm text-white cursor-pointer select-none">Behind Proxy (Nginx / Cloudflare)</label>
</div>
</div>

<div class="field-long">
<div class="p-3 bg-neutral-800/30 rounded-lg">
<label class="text-xs font-medium text-neutral-400 block mb-3 text-center">CONNECTION PROTOCOL <span class="text-red-400">*</span></label>
<div class="radio-group">
<label class="radio-option">
<input type="radio" name="connectionProtocol" value="http" checked class="w-5 h-5 accent-white rounded mr-2">
<span class="text-sm text-white select-none">Use HTTP Connection</span>
</label>
<label class="radio-option">
<input type="radio" name="connectionProtocol" value="https" class="w-5 h-5 accent-white rounded mr-2">
<span class="text-sm text-white select-none">Use SSL Connection (Communicate Over SSL)</span>
</label>
</div>
</div>
</div>

</div>

<!-- ALLOCATIONS -->
<div class="form-row auto">

<div class="field-long">
<label class="text-xs font-medium text-neutral-400 block mb-2">IP FOR ALLOCATIONS</label>
<input id="allocIp" type="text" class="input-field" placeholder="Leave blank = node address">
</div>

<div class="field-long">
<label class="text-xs font-medium text-neutral-400 block mb-2">IP ALIAS / LABEL</label>
<input id="allocAlias" type="text" class="input-field" placeholder="e.g. Game Servers">
</div>

<div class="field-full">
<label class="text-xs font-medium text-neutral-400 block mb-2">PORTS (COMMA OR RANGES)</label>
<textarea id="allocPorts" rows="3" class="input-field" placeholder="25565,27015-27030"></textarea>
</div>

</div>
            </div>

            <!-- Submit -->
            <div class="col-span-1 lg:col-span-2 mt-8">
              <button id="createNodeBtn" type="button"
                      class="w-full py-4 bg-white text-black font-semibold text-lg rounded-[10px] hover:bg-neutral-100 active:scale-[0.985] transition-all duration-200 shadow-xl">
                CREATE NODE
              </button>
            </div>
          </div>
        </form>
      </div>
    </section>

    <!-- Notification -->
    <div id="notification" 
         class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
      <span id="notification-text"></span>
    </div>
  </div>

  <script>
  function toggleResourceFields() {
    const mode = document.getElementById('resourceMode').value;
    const manualDiv = document.getElementById('manualResources');
    if (mode === 'auto') {
      manualDiv.classList.add('hidden');
    } else {
      manualDiv.classList.remove('hidden');
    }
  }

  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;
    
    notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  // Create Node handler
  document.getElementById('createNodeBtn').addEventListener('click', async () => {
    const btn = document.getElementById('createNodeBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Creating Node...';

    try {
      const resourceMode = document.getElementById('resourceMode').value;
      let ram = document.getElementById('nodeRam').value;
      let disk = document.getElementById('nodeDisk').value;

      if (resourceMode === 'manual') {
        if (!ram || !disk) {
          throw new Error('RAM and Disk are required in Manual mode');
        }
      } else {
        ram = 0; // Auto-detect flag
        disk = 0;
      }

      const data = {
        name: document.getElementById('nodeName').value.trim(),
        address: document.getElementById('nodeAddress').value.trim(),
        port: document.getElementById('nodePort').value,
        sftpPort: document.getElementById('nodeSftpPort').value,
        location: document.getElementById('nodeLocation').value,
        resourceMode: resourceMode,
        ram: ram,
        disk: disk,
        memoryOverallocate: document.getElementById('nodeMemoryOver').value,
        diskOverallocate: document.getElementById('nodeDiskOver').value,
        uploadSize: document.getElementById('nodeUploadSize').value,
        behindProxy: document.getElementById('behindProxy').checked,
        connectionProtocol: document.querySelector('input[name="connectionProtocol"]:checked').value,
        allocIp: document.getElementById('allocIp').value.trim(),
        allocAlias: document.getElementById('allocAlias').value.trim(),
        portsInput: document.getElementById('allocPorts').value.trim()
      };

      const res = await fetch('/admin/nodes/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to create node');
      }

      showNotification('Node created successfully!', 'success');
      setTimeout(() => window.location.href = '/admin/nodes/overview?err=none', 800);
    } catch (e) {
      showNotification(e.message, 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  });
  </script>
</main>
