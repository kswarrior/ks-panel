</div>

<script>
// Initialize Choices.js
let choiceInstances = {};
function initSearchableSelects() {
  document.querySelectorAll('.searchable-select').forEach(el => {
    if (el.dataset.choicesInit) return;
    const instance = new Choices(el, {
      searchEnabled: true,
      itemSelectText: '',
      shouldSort: false,
      removeItemButton: false,
    });
    choiceInstances[el.id || el.name] = instance;
    el.dataset.choicesInit = "true";
  });
}

document.addEventListener('DOMContentLoaded', initSearchableSelects);

async function addCategory() {
  const name = prompt("Enter new Category name:");
  if (!name?.trim()) return;

  try {
    const res = await fetch('/admin/templates/category', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (data.success) {
      const select = document.getElementById('meta-category');
      choiceInstances['meta-category'].setChoices([{ value: name, label: name, selected: true }], 'value', 'label', false);
      showNotification("Category added!");
    } else {
      showNotification(data.error || "Failed to add category", "error");
    }
  } catch (e) {
    showNotification("Network error", "error");
  }
}

async function deleteCategory() {
  const select = document.getElementById('meta-category');
  const name = select.value;
  if (!name || !confirm(`Delete category "${name}"?`)) return;

  try {
    const res = await fetch('/admin/templates/category', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (data.success) {
      choiceInstances['meta-category'].removeActiveItems();
      choiceInstances['meta-category'].setChoices(data.categories.map(c => ({ value: c, label: c })), 'value', 'label', true);
      showNotification("Category deleted");
    }
  } catch (e) {
    showNotification("Delete failed", "error");
  }
}

async function deleteType() {
  const select = document.getElementById('meta-type');
  const name = select.value;
  if (!name || !confirm(`Delete type "${name}"?`)) return;

  try {
    const res = await fetch('/admin/templates/type', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (data.success) {
      choiceInstances['meta-type'].removeActiveItems();
      choiceInstances['meta-type'].setChoices(data.types.map(t => ({ value: t, label: t })), 'value', 'label', true);
      showNotification("Type deleted");
    }
  } catch (e) {
    showNotification("Delete failed", "error");
  }
}

async function addType() {
