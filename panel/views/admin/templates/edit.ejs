      </div>
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Name</label>
        <input type="text" name="variables[${idx}].name" value="${v.name||''}" class="tf-input" placeholder="Variable Name">
      </div>
    </div>

    <div class="tf-row mt-3">
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Description</label>
        <input type="text" name="variables[${idx}].description" value="${v.description||''}" class="tf-input" placeholder="Description shown to user">
      </div>
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">User Editable</label>
        <select name="variables[${idx}].user_editable" class="tf-input">
          <option value="true" ${v.user_editable !== "false" ? "selected" : ""}>Yes</option>
          <option value="false" ${v.user_editable === "false" ? "selected" : ""}>No</option>
        </select>
      </div>
    </div>

    <div class="tf-row mt-3">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Type <span class="text-red-400">*</span></label>
        <select name="variables[${idx}].type" class="tf-input var-type-select" data-idx="${idx}">
          ${variableTypes.map(t => `<option value="${t.value}" ${v.type === t.value ? "selected" : ""}>${t.label}</option>`).join("")}
        </select>
      </div>
      <div id="default-section-${idx}" class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Default Value</label>
        <input type="text" name="variables[${idx}].default_value" value="${v.default_value || v.default || ''}" class="tf-input" placeholder="Default value">
      </div>
    </div>

    <div id="options-section-${idx}" class="mt-4 tf-hidden">
      <div class="flex items-center justify-between mb-2">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Options</label>
        <button type="button" class="tf-btn tf-btn-accent text-xs py-1.5 px-3 add-option-btn">+ Add Option</button>
      </div>
      <div id="options-list-${idx}" class="space-y-2"></div>
    </div>

    <button type="button" onclick="this.closest('.tf-card').remove()" class="tf-remove-btn">×</button>
  `;
  document.getElementById("variablesContainer").appendChild(div);

  const typeSelect = div.querySelector(".var-type-select");
  const defaultSection = document.getElementById(`default-section-${idx}`);
  const optionsSection = document.getElementById(`options-section-${idx}`);
  const optionsList = document.getElementById(`options-list-${idx}`);

  function toggleFields() {
    const isOption = typeSelect.value === "option";
    defaultSection.classList.toggle("tf-hidden", isOption);
    optionsSection.classList.toggle("tf-hidden", !isOption);
  }

  typeSelect.addEventListener("change", toggleFields);

  div.querySelector(".add-option-btn").onclick = () => {
    const optIdx = optionsList.children.length;
    addOptionItem(idx, optIdx);
  };

  if (v.type === "option") {
    optionsSection.classList.remove("tf-hidden");
    if (Array.isArray(v.options)) {
      v.options.forEach((opt, i) => addOptionItem(idx, i, opt));
    }
  }
  toggleFields();
}

