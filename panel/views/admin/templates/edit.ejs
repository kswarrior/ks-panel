<%- include('../../components/template') %>

<style>
    /* EXACT same style block */
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">Server Templates</h1>
        <p class="mt-1 text-sm text-neutral-400">Powerful Pterodactyl / PufferPanel-style templates with typed Install Steps &amp; Actions</p>
      </div>
      <div>
        <a href="/admin/templates/overview" 
           class="px-6 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
          ← Overview
        </a>
      </div>
    </header>

    <!-- Form Section (visible) - EXACT same HTML as create.ejs -->
    <div id="templateFormSection" class="px-4 md:px-6 lg:px-8 pb-12 mt-12">
      <div class="rounded-2xl border border-white/10 bg-neutral-900/50 shadow-2xl overflow-hidden">
        <!-- form header, form, footer - 100% identical -->
        <input type="hidden" id="hiddenFilename" value="<%= filename %>">
        <!-- ... all form content ... -->
      </div>
    </div>
  </div>

  <!-- Notification same -->
</main>

<script>
/* EXACT same full JS as create.ejs (all functions) */

document.getElementById("btnSaveTemplate").onclick = async () => { /* same as above, redirects to overview */ };
document.getElementById("btnCancelForm").onclick = () => window.location.href = '/admin/templates/overview';
/* addCategory, addVar, addAction, addInstallStep listeners - same */

// NO import button on edit page

// Initialize Edit
const templateData = <%= JSON.stringify(template) %>;
document.getElementById("hiddenFilename").value = "<%= filename %>";
fillForm(templateData);
modeSelect.value = "form";
modeSelect.onchange();
showForm(`Edit: ${templateData.meta?.name || templateData.meta?.display_name || 'Template'}`);
</script>

<%- include('../../components/footer') %>
