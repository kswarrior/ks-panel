// ====================== CONFIG ======================
let varIndex = 0, actionIndex = 0, installIndex = 0, pageIndex = 0;
let isInitialLoad = true;

// ====================== REINDEX HELPERS ======================
function reindexDynamicList(container, listType) {
  const itemClass = listType === 'options' ? '.tf-sub-item' : '.tf-sub-item';
  const items = container.querySelectorAll(itemClass);
  items.forEach((item, newIdx) => {
    item.querySelectorAll('input[name], select[name], textarea[name]').forEach(field => {
      if (field.name) {
        const regex = new RegExp(`\\.${listType}\\[\\d+\\]`, 'g');
        field.name = field.name.replace(regex, `.${listType}[${newIdx}]`);
      }
    });
  });
}

function removeAndReindex(btn, listType) {
  const item = btn.closest('.tf-sub-item');
  if (!item) return;
  const container = item.parentElement;
  item.remove();
  reindexDynamicList(container, listType);
}

// ====================== NOTIFICATION ======================
function hideForm() {
  window.location.href = "/admin/templates/overview";
}

function showNotification(message, type = 'success') {
  const notification = document.getElementById('tf-notification');
  const textEl = document.getElementById('tf-notification-text');
  textEl.textContent = message;
  
  notification.className = 'fixed flex items-center gap-3 px-4 py-3 rounded-lg shadow-2xl text-sm font-medium z-[9999] transition-all duration-300 ' +
    (type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white');
  
  notification.classList.add('tf-show');
  
  setTimeout(() => {
    notification.classList.add('opacity-0', 'translate-y-2');
    setTimeout(() => {
      notification.classList.remove('tf-show', 'opacity-0', 'translate-y-2');
    }, 300);
  }, 2800);
}

// ====================== MODE SWITCH (BIDIRECTIONAL - FIXED) ======================
const modeSelect = document.getElementById("modeSelect");
const formArea = document.getElementById("templateForm");
const jsonArea = document.getElementById("jsonArea");
const jsonEditor = document.getElementById("jsonEditor");
const submitSection = document.getElementById("submitSection");

modeSelect.onchange = () => {
  const isJson = modeSelect.value === "json";

  if (isJson) {
    // Hide visual form, show JSON
    Array.from(formArea.children).forEach(el => {
      if (el.id !== 'jsonArea' && el.id !== 'submitSection') {
        el.classList.add('tf-hidden');
      }
    });
    jsonArea.classList.remove("tf-hidden");

    try { 
      jsonEditor.value = JSON.stringify(collectFormData(), null, 2); 
    } catch(e) {
      jsonEditor.value = "{}";
    }
  } else {
    // Show visual form, hide JSON + LOAD JSON INTO FORM (this was the missing part)
    Array.from(formArea.children).forEach(el => {
      if (el.id !== 'jsonArea') {
        el.classList.remove('tf-hidden');
      }
    });
    jsonArea.classList.add("tf-hidden");

    try {
      const parsed = JSON.parse(jsonEditor.value.trim() || "{}");
      fillForm(parsed);
      if (!isInitialLoad) {
        showNotification("✅ JSON loaded into visual form", "success");
      }
    } catch (e) {
      showNotification("Invalid JSON! Fix it before switching to Visual Form.", "error");
      modeSelect.value = "json"; // stay in JSON mode
      return;
    }
    isInitialLoad = false;
  }
  submitSection.style.display = "flex";
};

