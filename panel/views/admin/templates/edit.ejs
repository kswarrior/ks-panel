// ====================== CUSTOM PAGES (FIXED - no escaping) ======================
function toggleTile(id) {
  const checkbox = document.getElementById(`toggle-${id}`);
  checkbox.checked = !checkbox.checked;
  checkbox.dispatchEvent(new Event('change'));

  const tile = document.getElementById(`tile-${id}`);
  const status = tile.querySelector('.tile-status');

  if (checkbox.checked) {
    tile.classList.add('active');
    status.textContent = 'ENABLED';
  } else {
    tile.classList.remove('active');
    status.textContent = 'DISABLED';
  }
}

function addPage(p = {}) {
  const container = document.getElementById('pagesContainer');
  let type = p.type || (typeof p === 'string' ? p : 'generic');

  // Backward compatibility / normalization
  if (type === 'ports') type = 'network';
  if (type === 'backups') type = 'archives';
  if (type === 'schedules') type = 'automations';
  if (type === 'databases') type = 'db';

  const existing = container.querySelector(`[data-core-type="${type}"]`);
  const coreKeys = Object.keys(coreTemplates);

  if (coreKeys.includes(type) && existing) return;

  const idx = pageIndex++;
  const div = document.createElement("div");

  if (coreKeys.includes(type)) {
    div.innerHTML = coreTemplates[type].replace(/IDX/g, idx);
    const card = div.firstElementChild;
    if (typeof p === 'object' && p.id) {
       const idField = card.querySelector('[name*=".id"]');
       if (idField) idField.value = p.id;
       const nameField = card.querySelector('[name*=".name"]');
       if (nameField) nameField.value = p.name || nameField.value;
    }
    container.appendChild(card);
    const toggle = document.getElementById(`toggle-${type}`);
    if (toggle) {
      toggle.checked = true;
      const tile = document.getElementById(`tile-${type}`);
      if (tile) {
        tile.classList.add('active');
        tile.querySelector('.tile-status').textContent = 'ENABLED';
      }
    }
  } else {
    div.className = "tf-card tf-page-card group";
    div.innerHTML = `
      <div class="tf-row">
        <div class="tf-field-short">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Page ID <span class="text-red-400">*</span></label>
          <input type="text" name="pages[${idx}].id" value="${p.id || ''}" required class="tf-input font-mono" placeholder="plugins">
        </div>
        <div class="tf-field-long">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Display Name</label>
          <input type="text" name="pages[${idx}].name" value="${p.name || ''}" class="tf-input" placeholder="Plugin Manager">
        </div>
      </div>
      <div class="mt-4">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider block mb-2">EJS Content (HTML)</label>
        <textarea name="pages[${idx}].ejsContent" rows="10" class="tf-input" placeholder="<div>Your HTML</div>">${p.ejsContent || ''}</textarea>
      </div>
      <div class="mt-4">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider block mb-2">JS Handler (Optional)</label>
        <textarea name="pages[${idx}].jsContent" rows="6" class="tf-input" placeholder="module.exports = {};">${p.jsContent || ''}</textarea>
      </div>
      <button type="button" onclick="this.closest('.tf-card').remove()" class="tf-remove-btn">×</button>
    `;
    container.appendChild(div);
  }
}

function syncCorePage(type) {
  let targetType = type;
  if (type === 'ports') targetType = 'network';
  if (type === 'backups') targetType = 'archives';
  if (type === 'schedules') targetType = 'automations';
  if (type === 'databases') targetType = 'db';

  const toggle = document.getElementById(`toggle-${type}`);
  if (!toggle) return;
  const isChecked = toggle.checked;
  const container = document.getElementById('pagesContainer');
  const existing = container.querySelector(`[data-core-type="${targetType}"]`);

  if (isChecked) {
    if (!existing) addPage(targetType);
  } else {
    if (existing) existing.remove();
  }
}

function toggleOffFeature(type) {
  const toggle = document.getElementById(`toggle-${type}`);
  if (toggle) {
    toggle.checked = false;
    const tile = document.getElementById(`tile-${type}`);
    if (tile) {
      tile.classList.remove('active');
      tile.querySelector('.tile-status').textContent = 'DISABLED';
    }
    syncCorePage(type);
  } else {
    const existing = document.getElementById('pagesContainer').querySelector(`[data-core-type="${type}"]`);
    if (existing) existing.remove();
  }
}

// ====================== COLLECT FORM DATA ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { 
    meta: {}, 
    environment: { limits: {}, feature_limits: {} },
    install_steps: [],
    variables: [], 
    actions: [], 
    pages: [], 
    features: {},
    category: "" 
  };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) {
      data.meta[key.split(".")[1]] = value;
    }
    else if (key === "category") {
      data.category = value;
    }
    else if (key.startsWith("environment.limits.")) {
       data.environment.limits[key.split("limits.")[1]] = parseInt(value) || 0;
    }
    else if (key.startsWith("environment.feature_limits.")) {
       data.environment.feature_limits[key.split("feature_limits.")[1]] = parseInt(value) || 0;
    }
    else if (key === "environment.docker_image") {
      data.environment.docker_image = value;
    }
    else if (key === "environment.instance_type") {
      data.environment.instance_type = value;
    }
    else if (key === "environment.start_code") {
      data.environment.start_code = value;
    }
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        if (key.includes(".options[")) {
          const optMatch = key.match(/variables\[(\d+)\]\.options\[(\d+)\]\.(.+)/);
          if (optMatch) {
            const optI = parseInt(optMatch[2]);
            if (!data.variables[i].options) data.variables[i].options = [];
            if (!data.variables[i].options[optI]) data.variables[i].options[optI] = {};
            data.variables[i].options[optI][optMatch[3]] = value;
          }
        } else {
          data.variables[i][match[2]] = value;
        }
      }
    }
    else if (key.startsWith("actions[")) {
      const opMatch = key.match(/actions\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
        if (!data.actions[i].operations[j]) data.actions[i].operations[j] = {};
        data.actions[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/actions\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
          data.actions[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("install_steps[")) {
      const opMatch = key.match(/install_steps\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.install_steps[i]) data.install_steps[i] = { name: "", operations: [] };
        if (!data.install_steps[i].operations[j]) data.install_steps[i].operations[j] = {};
        data.install_steps[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/install_steps\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.install_steps[i]) data.install_steps[i] = { name: "", operations: [] };
          data.install_steps[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("pages[")) {
      const match = key.match(/pages\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.pages[i]) data.pages[i] = {};
        data.pages[i][match[2]] = value;
      }
    }
  }

  // Features (checkboxes not in FormData if unchecked)
  ['console', 'files', 'users', 'network', 'archives', 'automations', 'db', 'ftp', 'settings', 'startup'].forEach(f => {
    const el = document.getElementById(`toggle-${f}`);
    if (el) data.features[f] = el.checked;
  });

  // Clean arrays
  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  data.environment.install_steps = data.environment.install_steps.filter(Boolean);
  data.pages = data.pages.filter(Boolean);

  // Clean nested arrays
  data.actions.forEach(a => { 
    if (a.operations) a.operations = a.operations.filter(Boolean); 
  });
  data.environment.install_steps.forEach(s => { 
    if (s.operations) s.operations = s.operations.filter(Boolean); 
  });
  data.variables.forEach(v => { 
    if (v.options) v.options = v.options.filter(Boolean); 
  });

  return data;
}

function fillForm(data) { 
  // Robust field mapping for old templates
  const meta = data.meta || {};
  document.querySelector('[name="meta.name"]').value = meta.name || data.name || "";
  document.querySelector('[name="meta.display_name"]').value = meta.display_name || meta.name || data.name || "";
  document.querySelector('[name="meta.description"]').value = meta.description || data.description || "";
  document.querySelector('[name="category"]').value = data.category || "";

  const env = data.environment || {};
  document.querySelector('[name="environment.instance_type"]').value = env.instance_type || "docker";
  document.querySelector('[name="environment.docker_image"]').value = env.docker_image || data.docker_image || data.image || "";
  document.querySelector('[name="environment.start_code"]').value = env.start_code || data.startup || "";

  // Fill limits with fallbacks
  const limits = env.limits || data.limits || {};
  document.querySelector('[name="environment.limits.memory"]').value = limits.memory || data.memory || 1024;
  document.querySelector('[name="environment.limits.cpu"]').value = limits.cpu || data.cpu || 100;
  document.querySelector('[name="environment.limits.disk"]').value = limits.disk || data.disk || 5120;
  document.querySelector('[name="environment.limits.swap"]').value = limits.swap || data.swap || 0;

  const fLimits = env.feature_limits || data.feature_limits || {};
  document.querySelector('[name="environment.feature_limits.databases"]').value = fLimits.databases || data.databases || 0;
  document.querySelector('[name="environment.feature_limits.backups"]').value = fLimits.backups || data.backups || 0;
  document.querySelector('[name="environment.feature_limits.allocations"]').value = fLimits.allocations || data.allocations || 1;

  // Fill features
  if (data.features) {
    Object.keys(data.features).forEach(f => {
      let featureId = f;
      // Map old feature keys to new IDs
      if (f === 'ports') featureId = 'network';
      if (f === 'backups') featureId = 'archives';
      if (f === 'schedules') featureId = 'automations';
      if (f === 'databases') featureId = 'db';

      const toggle = document.getElementById(`toggle-${featureId}`);
      if (toggle) {
        // If multiple old keys map to one new key (unlikely but safe), respect any true value
        if (!!data.features[f]) {
          toggle.checked = true;
          const tile = document.getElementById(`tile-${featureId}`);
          if (tile) {
             tile.classList.add('active');
             tile.querySelector('.tile-status').textContent = 'ENABLED';
          }
        }
      }
    });
  }

  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  let vars = data.variables || [];
  if (vars && !Array.isArray(vars)) vars = Object.entries(vars).map(([id, v]) => ({ id, ...v }));
  (vars || []).forEach(v => addVariable(v));

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  let actions = data.actions || [];
  if (actions && !Array.isArray(actions)) actions = Object.entries(actions).map(([id, a]) => ({ id, ...a }));
  (actions || []).forEach(a => addAction(a));

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  let installSteps = data.install_steps || (data.environment && data.environment.install_steps) || [];
  if (installSteps && !Array.isArray(installSteps)) installSteps = Object.values(installSteps);
  (installSteps || []).forEach(s => addInstallStep(s));

  document.getElementById("pagesContainer").innerHTML = "";
  pageIndex = 0;
  (data.pages || []).forEach(p => addPage(p));

  jsonEditor.value = JSON.stringify(data, null, 2);
}

// ====================== SAVE ======================
const handleSave = async () => {
  let payload;
  try {
    payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();
  } catch(e) {
    showNotification("Invalid JSON format!", "error");
    return;
  }

  const filename = document.getElementById("hiddenFilename").value;
  const url = `/admin/templates/${filename}`;
  const method = "PUT";

  try {
    const res = await fetch(url, {
      method,
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(payload)
    });

    if (res.ok) {
      showNotification("✅ Template updated successfully!", "success");
      setTimeout(() => window.location.href = "/admin/templates/overview", 1200);
    } else {
      const err = await res.text();
      showNotification("Error: " + err.substring(0, 100), "error");
    }
  } catch (err) {
    showNotification("Network error!", "error");
  }
};

document.getElementById("btnSaveTemplate").onclick = handleSave;
const bottomBtn = document.getElementById("btnSaveTemplateBottom");
if (bottomBtn) bottomBtn.onclick = handleSave;

// ====================== BUTTON HANDLERS ======================
document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable();
document.getElementById("btnAddAction").onclick = () => addAction();
document.getElementById("btnAddInstallStep").onclick = () => addInstallStep();
document.getElementById("btnAddPage").onclick = () => addPage();


// ====================== IMPORT JSON ======================
document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file";
  input.accept = ".json,application/json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        fillForm(data);
        showNotification("JSON imported successfully!", "success");
      } catch(e) {
        showNotification("Invalid JSON file!", "error");
      }
    };
    reader.readAsText(file);
  };
  input.click();
};

document.getElementById("btnExportJson").onclick = () => {
  const data = collectFormData();
  const filename = (data.meta?.name || 'template') + '.json';
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
  showNotification("Template exported!");
};

// Ensure initial setup
document.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => {
    ['console', 'files', 'users', 'ports', 'backups', 'schedules', 'databases', 'ftp', 'settings', 'startup', 'network', 'archives', 'automations', 'db'].forEach(t => {
      const toggle = document.getElementById(`toggle-${t}`);
      if (toggle && toggle.checked) syncCorePage(t);
    });
  }, 100);
});

// ====================== INIT + LOAD TEMPLATE.JSON ======================
const templateData = <%= JSON.stringify(template) %>;
fillForm(templateData);
modeSelect.value = "form";
modeSelect.onchange();
</script>

