function addAction(a = {}) {
  const idx = actionIndex++;
  const div = document.createElement("div");
  div.className = "tf-card";
  div.innerHTML = `
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">ID <span class="text-red-400">*</span></label>
        <input type="text" name="actions[${idx}].id" value="${a.id || ''}" required class="tf-input font-mono" placeholder="action_id">
      </div>
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Action Name</label>
        <input type="text" name="actions[${idx}].name" value="${a.name || ''}" class="tf-input" placeholder="Start Server">
      </div>
    </div>
    <div class="mt-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Operations</span>
        <button type="button" class="tf-btn tf-btn-accent text-xs py-1.5 px-3 add-op-btn">+ Add Operation</button>
      </div>
