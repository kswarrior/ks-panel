<div class="space-y-6">
  <div class="tf-card">
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Instance Type <span class="text-red-400">*</span></label>
        <select id="instanceType" class="tf-input">
          <option value="docker">Docker (Container)</option>
          <option value="lxd">LXD (Container)</option>
          <option value="multipass">Multipass (VM)</option>
          <option value="kvm">KVM (VM)</option>
          <option value="proxmox">Proxmox (VM/LXC)</option>
        </select>
      </div>
      <div class="tf-field-long" id="imageContainer">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Docker Image <span class="text-red-400">*</span></label>
        <input id="environment-image" type="text" class="tf-input" placeholder="ghcr.io/parkervcp/yolks:debian">
      </div>
    </div>
  </div>

  <div class="tf-card">
    <h3 class="text-xs font-medium text-neutral-400 uppercase mb-3">Lifecycle Commands</h3>
    <div class="space-y-4">
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Start Command</label>
        <input id="environment-start_command" type="text" class="tf-input font-mono" placeholder="java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}">
        <p class="text-[10px] text-neutral-500 mt-1">Use {{VARIABLE_NAME}} to reference variables.</p>
      </div>
      <div class="tf-row">
        <div class="tf-field-short">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Stop Command</label>
          <input id="environment-stop_command" type="text" class="tf-input font-mono" placeholder="stop">
        </div>
        <div class="tf-field-short">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Stop Signal</label>
          <input id="environment-stop_signal" type="text" class="tf-input font-mono" placeholder="SIGINT" value="SIGINT">
        </div>
      </div>
    </div>
  </div>

  <div class="tf-card">
    <h3 class="text-xs font-medium text-neutral-400 uppercase mb-3">Resource Limits (Default)</h3>
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Memory (MB)</label>
        <input id="limits-memory" type="number" value="1024" class="tf-input">
      </div>
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">CPU Threads (%)</label>
        <input id="limits-cpu" type="number" value="100" class="tf-input">
      </div>
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Disk (MB)</label>
        <input id="limits-disk" type="number" value="5120" class="tf-input">
      </div>
    </div>
  </div>
</div>

<script>
function updateImageField() {
  const type = document.getElementById('instanceType').value;
  const container = document.getElementById('imageContainer');
  if (type === 'docker') {
    container.innerHTML = `<label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Docker Image <span class="text-red-400">*</span></label><input id="environment-image" type="text" class="tf-input" placeholder="ghcr.io/parkervcp/yolks:debian">`;
  } else if (type === 'lxd' || type === 'multipass') {
    container.innerHTML = `<label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Distribution</label><select id="environment-distribution" class="tf-input"><option value="ubuntu:22.04">Ubuntu 22.04</option><option value="ubuntu:20.04">Ubuntu 20.04</option><option value="debian:11">Debian 11</option></select>`;
  } else {
    container.innerHTML = `<label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">ISO / Image Path</label><input id="environment-image" type="text" class="tf-input" placeholder="/var/lib/vz/template/iso/ubuntu.iso">`;
  }
}
document.getElementById('instanceType').addEventListener('change', updateImageField);
</script>
