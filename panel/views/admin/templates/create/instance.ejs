<div class="space-y-6">
  <div class="tf-card">
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Instance Type <span class="text-red-400">*</span></label>
        <select id="instanceType" class="tf-input">
          <option value="docker">Docker</option>
          <option value="lxd">LXD</option>
          <option value="multipass">Multipass</option>
          <option value="kvm">KVM</option>
          <option value="proxmox">Proxmox</option>
        </select>
      </div>
      <div class="tf-field-long" id="imageContainer"></div>
    </div>
  </div>

  <div class="tf-card">
    <h3 class="text-xs font-medium text-neutral-400 uppercase mb-3">Resource Limits</h3>
    <div class="tf-row">
      <div class="tf-field-short"><label>Memory (MB)</label><input id="limits-memory" type="number" value="4096" class="tf-input"></div>
      <div class="tf-field-short"><label>CPU Threads</label><input id="limits-cpu" type="number" value="200" class="tf-input"></div>
      <div class="tf-field-short"><label>Disk (GB)</label><input id="limits-disk" type="number" value="20" class="tf-input"></div>
    </div>
  </div>

  <button onclick="saveInstanceSection()" class="tf-btn tf-btn-accent w-full">💾 Save Environment (environment.json)</button>
</div>

<script>
function updateImageField() {
  // same logic as before (kept short for brevity)
  const type = document.getElementById('instanceType').value;
  const container = document.getElementById('imageContainer');
  container.innerHTML = type === 'docker' || type === 'kvm' || type === 'proxmox' 
    ? `<label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Image <span class="text-red-400">*</span></label><input id="environment-image" type="text" class="tf-input" placeholder="eclipse-temurin:21-jre">`
    : `<label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Distribution</label><select id="environment-distribution" class="tf-input"><option value="ubuntu">Ubuntu</option></select>`;
}
document.getElementById('instanceType').addEventListener('change', updateImageField);
updateImageField();

window.saveInstanceSection = async () => {
  const data = {
    instance_type: document.getElementById('instanceType').value,
    image: document.getElementById('environment-image') ? document.getElementById('environment-image').value : '',
    limits: {
      memory: parseInt(document.getElementById('limits-memory').value),
      cpu: parseInt(document.getElementById('limits-cpu').value),
      disk: parseInt(document.getElementById('limits-disk').value)
    }
  };
  await fetch('/admin/templates/save-environment', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(data)
  });
  showNotification('Environment saved as environment.json', 'success');
};
</script>
