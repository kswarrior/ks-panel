<div id="actionsContainer" class="space-y-4 mb-6"></div>
<button onclick="addAction()" class="tf-btn tf-btn-secondary text-xs">+ Add Lifecycle Action</button>

<template id="actionTemplate">
  <div class="tf-card group">
    <button type="button" class="tf-remove-btn opacity-0 group-hover:opacity-100 transition-opacity" onclick="this.parentElement.remove()">×</button>
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-[10px] font-semibold text-neutral-500 uppercase">Trigger Event</label>
        <select name="trigger" class="tf-input text-sm">
          <option value="startup">On Startup</option>
          <option value="shutdown">On Shutdown</option>
          <option value="crash">On Crash</option>
          <option value="install_success">On Install Success</option>
        </select>
      </div>
      <div class="tf-field-long">
        <label class="text-[10px] font-semibold text-neutral-500 uppercase">Action Name</label>
        <input type="text" name="name" class="tf-input" placeholder="Notify Discord">
      </div>
    </div>

    <div class="mt-4 space-y-3" name="operationsContainer"></div>
    <button type="button" onclick="addOperation(this.previousElementSibling)" class="tf-btn tf-btn-secondary text-[10px] mt-2">+ Add Operation</button>
  </div>
</template>

<template id="operationTemplate">
  <div class="bg-black/20 rounded-md p-3 border border-white/5 relative">
    <button type="button" class="absolute top-2 right-2 text-neutral-500 hover:text-red-400" onclick="this.parentElement.remove()">×</button>
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-[10px] text-neutral-500 uppercase">Type</label>
        <select name="type" class="tf-input py-1 text-xs" onchange="updateOpFields(this)">
          <option value="command">Run Command</option>
          <option value="webhook">Webhook (Discord/Slack)</option>
          <option value="file_edit">Edit File</option>
          <option value="script">Custom Script</option>
        </select>
      </div>
      <div class="tf-field-long" name="opFields">
        <label class="text-[10px] text-neutral-500 uppercase">Command</label>
        <input type="text" name="value" class="tf-input py-1 text-xs font-mono" placeholder="echo 'Server starting...'">
      </div>
    </div>
  </div>
</template>

<script>
function addAction() {
  const container = document.getElementById('actionsContainer');
  const temp = document.getElementById('actionTemplate');
  container.appendChild(temp.content.cloneNode(true));
}

function addOperation(container) {
  const temp = document.getElementById('operationTemplate');
  container.appendChild(temp.content.cloneNode(true));
}

function updateOpFields(select) {
  const container = select.parentElement.nextElementSibling;
  const type = select.value;
  if (type === 'webhook') {
    container.innerHTML = `<label class="text-[10px] text-neutral-500 uppercase">Webhook URL</label><input type="text" name="value" class="tf-input py-1 text-xs" placeholder="https://discord.com/api/webhooks/...">`;
  } else if (type === 'file_edit') {
    container.innerHTML = `<div class="grid grid-cols-2 gap-2">
      <input type="text" name="file" class="tf-input py-1 text-xs" placeholder="server.properties">
      <input type="text" name="find" class="tf-input py-1 text-xs" placeholder="motd=">
    </div>`;
  } else {
    container.innerHTML = `<label class="text-[10px] text-neutral-500 uppercase">Value / Command</label><input type="text" name="value" class="tf-input py-1 text-xs font-mono" placeholder="bash start.sh">`;
  }
}
</script>
