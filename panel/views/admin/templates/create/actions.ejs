<div id="actionsContainer" class="space-y-3"></div>
<button onclick="addAction()" class="tf-btn tf-btn-accent text-xs mb-4">+ Add Action</button>
<button onclick="saveActionsSection()" class="tf-btn tf-btn-accent w-full">💾 Save Actions (actions.json)</button>

<script>
