    <button type="button" class="text-right text-[10px] text-neutral-600 hover:text-red-400" onclick="confirmRemoval(this)">Remove</button>
  </div>
</template>

<script>
function confirmRemoval(btn) {
  const target = btn.classList.contains('tf-remove-btn') || btn.parentElement.classList.contains('tf-card') ? btn.closest('.tf-card') : btn.parentElement;
  if (btn.dataset.confirmed === "true") {
    target.remove();
  } else {
    btn.dataset.confirmed = "true";
    const oldHtml = btn.innerHTML;
    btn.innerHTML = "<span class='text-[10px] font-bold'>CONFIRM?</span>";
    btn.classList.add('text-red-500');
    setTimeout(() => {
      btn.dataset.confirmed = "false";
      btn.innerHTML = oldHtml;
      btn.classList.remove('text-red-500');
    }, 3000);
  }
}

function toggleTile(id) {
  const checkbox = document.getElementById(`toggle-${id}`);
  checkbox.checked = !checkbox.checked;
  checkbox.dispatchEvent(new Event('change'));

  const tile = document.getElementById(`tile-${id}`);
  const status = tile.querySelector('.tile-status');

  if (checkbox.checked) {
    tile.classList.add('active');
    status.textContent = 'ENABLED';
  } else {
    tile.classList.remove('active');
    status.textContent = 'DISABLED';
  }
}

function addPage(type) {
  const container = document.getElementById('pagesContainer');
  const existing = container.querySelector(`[data-core-type="${type}"]`);
  const coreTypes = ['console', 'files', 'network', 'db', 'archives', 'users', 'automations', 'startup', 'settings', 'ftp'];
  if (coreTypes.includes(type) && existing) return;

  let tempId = 'genericPageTemplate';
  if (type === 'console') tempId = 'consolePageTemplate';
  else if (type === 'files') tempId = 'filesPageTemplate';
  else if (type === 'network') tempId = 'portsPageTemplate';
  else if (type === 'db') tempId = 'databasesPageTemplate';
  else if (type === 'archives') tempId = 'backupsPageTemplate';
  else if (type === 'users') tempId = 'usersPageTemplate';
  else if (type === 'automations') tempId = 'schedulesPageTemplate';
  else if (type === 'startup') tempId = 'startupPageTemplate';
  else if (type === 'settings') tempId = 'settingsPageTemplate';
  else if (type === 'ftp') tempId = 'ftpPageTemplate';

  const clone = document.getElementById(tempId).content.cloneNode(true);
  container.appendChild(clone);

  if (coreTypes.includes(type)) {
    const toggle = document.getElementById(`toggle-${type}`);
    if (toggle) {
      toggle.checked = true;
      const tile = document.getElementById(`tile-${type}`);
      if (tile) {
        tile.classList.add('active');
        tile.querySelector('.tile-status').textContent = 'ENABLED';
      }
    }
  }

  if (typeof initSearchableSelects === 'function') initSearchableSelects();
}

function syncCorePage(type) {
  const toggle = document.getElementById(`toggle-${type}`);
  if (!toggle) return;
  const isChecked = toggle.checked;
  const container = document.getElementById('pagesContainer');
  const existing = container.querySelector(`[data-core-type="${type}"]`);

  if (isChecked) {
    if (!existing) addPage(type);
  } else {
    if (existing) existing.remove();
  }
}

function toggleOffFeature(type) {
  const toggle = document.getElementById(`toggle-${type}`);
  if (toggle) {
    toggle.checked = false;
    const tile = document.getElementById(`tile-${type}`);
    if (tile) {
      tile.classList.remove('active');
      tile.querySelector('.tile-status').textContent = 'DISABLED';
    }
    syncCorePage(type);
  } else {
    const existing = document.getElementById('pagesContainer').querySelector(`[data-core-type="${type}"]`);
    if (existing) existing.remove();
  }
}

// Ensure initial setup
document.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => {
    syncCorePage('console');
    syncCorePage('files');
    syncCorePage('users');
    syncCorePage('network');
    syncCorePage('archives');
    syncCorePage('automations');
    syncCorePage('db');
    syncCorePage('ftp');
    syncCorePage('settings');
    syncCorePage('startup');
  }, 100);
});

function addConsoleBtn(btn) {
  const container = btn.parentElement.nextElementSibling;
  container.appendChild(document.getElementById('consoleBtnTemplate').content.cloneNode(true));
  if (typeof initSearchableSelects === 'function') initSearchableSelects();
}

function addQuickCode(btn) {
  const container = btn.parentElement.nextElementSibling;
  container.appendChild(document.getElementById('quickCodeTemplate').content.cloneNode(true));
}
</script>
