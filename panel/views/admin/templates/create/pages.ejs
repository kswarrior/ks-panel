<style>
.feature-tile {
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 0.75rem;
  cursor: pointer;
  user-select: none;
  background: rgba(255, 255, 255, 0.02);
}

.feature-tile:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
}

.feature-tile.active {
  border-color: rgba(16, 185, 129, 0.3);
  background: linear-gradient(145deg, rgba(16, 185, 129, 0.1), rgba(16, 185, 129, 0.02));
}

.feature-tile.active .tile-status {
  color: #34d399;
}

.feature-tile.active .tile-check {
  opacity: 1;
  transform: scale(1);
}

.tile-check {
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  width: 1.1rem;
  height: 1.1rem;
  background: #10b981;
  color: white;
  border-radius: 9999px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.3s ease;
  font-size: 0.6rem;
  font-weight: bold;
}
</style>

<div class="tf-card mb-8 border-white/5 bg-transparent p-0">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest">Core Features (Enable/Disable)</h3>
    <span class="text-[10px] text-amber-400 font-medium">Card tiles automatically sync visual pages</span>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
    <%
      const features = [
        { id: 'console', name: 'Console', icon: '⚡' },
        { id: 'files', name: 'Files', icon: '📁' },
        { id: 'users', name: 'Users', icon: '👥' },
        { id: 'network', name: 'Network', icon: '🌐' },
        { id: 'archives', name: 'Archives', icon: '🗄️' },
        { id: 'automations', name: 'Automations', icon: '⏰' },
        { id: 'db', name: 'Databases', icon: '💾' },
        { id: 'ftp', name: 'FTP', icon: '📤' },
        { id: 'settings', name: 'Settings', icon: '⚙️' },
        { id: 'startup', name: 'Startup', icon: '🚀' }
      ];
    %>

    <% features.forEach(f => { %>
      <div onclick="toggleTile('<%= f.id %>')" id="tile-<%= f.id %>" class="feature-tile p-4 flex flex-col items-center justify-center gap-2 <%= f.id === 'console' ? 'active' : '' %>">
        <div class="tile-check">✓</div>
        <span class="text-2xl mb-1"><%= f.icon %></span>
        <div class="text-center">
          <p class="text-[10px] font-bold text-white uppercase tracking-tighter"><%= f.name %></p>
          <p class="tile-status text-[9px] text-neutral-500 font-medium transition-colors"><%= f.id === 'console' ? 'ENABLED' : 'DISABLED' %></p>
        </div>
        <input type="checkbox" id="toggle-<%= f.id %>" name="feature-<%= f.id %>" <%= f.id === 'console' ? 'checked' : '' %> class="hidden" onchange="syncCorePage('<%= f.id %>')">
      </div>
    <% }) %>
  </div>
</div>

<div id="pagesContainer" class="space-y-6 mb-6"></div>
<div class="flex gap-3">
  <div class="relative group inline-block">
    <button type="button" class="tf-btn tf-btn-accent text-xs">+ Add New Page</button>
    <div class="absolute bottom-full left-0 mb-2 hidden group-hover:block w-48 bg-neutral-900 border border-white/10 rounded-lg shadow-xl overflow-hidden z-50">
      <button type="button" onclick="addPage('generic')" class="w-full text-left px-4 py-2 text-[10px] text-neutral-300 hover:bg-white/5 hover:text-white uppercase font-bold tracking-widest border-b border-white/5">Custom Page</button>
      <button type="button" onclick="addPage('console')" class="w-full text-left px-4 py-2 text-[10px] text-emerald-400 hover:bg-white/5 hover:text-emerald-300 uppercase font-bold tracking-widest border-b border-white/5">Console</button>
      <button type="button" onclick="addPage('files')" class="w-full text-left px-4 py-2 text-[10px] text-blue-400 hover:bg-white/5 hover:text-blue-300 uppercase font-bold tracking-widest border-b border-white/5">Files</button>
      <button type="button" onclick="addPage('users')" class="w-full text-left px-4 py-2 text-[10px] text-cyan-400 hover:bg-white/5 hover:text-cyan-300 uppercase font-bold tracking-widest border-b border-white/5">Users</button>
      <button type="button" onclick="addPage('network')" class="w-full text-left px-4 py-2 text-[10px] text-amber-400 hover:bg-white/5 hover:text-amber-300 uppercase font-bold tracking-widest border-b border-white/5">Network</button>
      <button type="button" onclick="addPage('archives')" class="w-full text-left px-4 py-2 text-[10px] text-purple-400 hover:bg-white/5 hover:text-purple-300 uppercase font-bold tracking-widest border-b border-white/5">Archives</button>
      <button type="button" onclick="addPage('automations')" class="w-full text-left px-4 py-2 text-[10px] text-orange-400 hover:bg-white/5 hover:text-orange-300 uppercase font-bold tracking-widest border-b border-white/5">Automations</button>
      <button type="button" onclick="addPage('db')" class="w-full text-left px-4 py-2 text-[10px] text-red-400 hover:bg-white/5 hover:text-red-300 uppercase font-bold tracking-widest border-b border-white/5">Databases</button>
      <button type="button" onclick="addPage('ftp')" class="w-full text-left px-4 py-2 text-[10px] text-sky-400 hover:bg-white/5 hover:text-sky-300 uppercase font-bold tracking-widest border-b border-white/5">FTP</button>
      <button type="button" onclick="addPage('settings')" class="w-full text-left px-4 py-2 text-[10px] text-slate-400 hover:bg-white/5 hover:text-slate-300 uppercase font-bold tracking-widest border-b border-white/5">Settings</button>
      <button type="button" onclick="addPage('startup')" class="w-full text-left px-4 py-2 text-[10px] text-indigo-400 hover:bg-white/5 hover:text-indigo-300 uppercase font-bold tracking-widest border-b border-white/5">Startup</button>
    </div>
  </div>
</div>

