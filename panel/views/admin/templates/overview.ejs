<%- include('../../components/template') %>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">Server Templates</h1>
        <p class="mt-1 text-sm text-neutral-400">Manage egg-style server templates (Pterodactyl / PufferPanel like)</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <button id="btnNewTemplate" 
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          + New Template
        </button>
        <button id="btnImportJson" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          Import JSON
        </button>
      </div>
    </header>

    <!-- Table -->
    <div class="mt-8">
      <div class="overflow-x-auto rounded-lg border border-white/10 bg-neutral-900/50 shadow-2xl">
        <table class="min-w-full divide-y divide-white/10 text-sm text-left text-white">
          <thead class="bg-neutral-950/70">
            <tr>
              <th class="py-4 pl-6 pr-3 font-semibold text-neutral-300 text-xs">Name</th>
              <th class="py-4 px-3 font-semibold text-neutral-300 text-xs">Category</th>
              <th class="py-4 px-3 font-semibold text-neutral-300 text-xs">Docker Image</th>
              <th class="py-4 pr-6 pl-3 text-right font-semibold text-neutral-300 text-xs">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% if (templates.length === 0) { %>
              <tr><td colspan="4" class="py-16 text-center text-neutral-500">No templates created yet.</td></tr>
            <% } else { %>
              <% templates.forEach(t => { %>
                <tr class="hover:bg-white/5 transition-colors duration-200 group">
                  <td class="py-4 pl-6 pr-3">
                    <div class="font-medium text-white"><%= t.meta.display_name || t.meta.name %></div>
                    <div class="text-xs text-neutral-500"><%= t.meta.name %></div>
                  </td>
                  <td class="py-4 px-3 text-neutral-300"><%= t.category || '—' %></td>
                  <td class="py-4 px-3 font-mono text-neutral-400 truncate"><%= t.environment?.docker_image || '—' %></td>
                  <td class="py-4 pr-6 pl-3 text-right whitespace-nowrap">
                    <a href="/admin/templates/download/<%= t.filename %>" 
                       class="inline-block px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0 mr-2">
                      Download
                    </a>
                    <button class="btnEdit px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0 mr-2"
                      data-filename="<%= t.filename %>" data-template='<%= JSON.stringify(t).replace(/'/g, "&apos;") %>'>Edit</button>
                    <button class="btnDelete px-3 py-1.5 text-xs font-medium bg-red-600/80 hover:bg-red-600 text-white rounded-[10px] transition-all duration-200 active:scale-95 flex-shrink-0"
                      data-filename="<%= t.filename %>">Delete</button>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Optimized Form -->
  <div id="templateFormSection" class="hidden px-4 md:px-6 lg:px-8 pb-12">
    <div class="mt-8 rounded-2xl border border-white/10 bg-neutral-900/50 shadow-2xl overflow-hidden">
      
      <!-- Form Header -->
      <div class="px-8 py-6 border-b border-white/10 bg-neutral-950/70 flex items-center justify-between">
        <h5 id="formTitle" class="text-2xl font-semibold text-white tracking-tight">Create New Template</h5>
        <div class="flex items-center gap-4">
          <span class="text-sm text-neutral-400">Editor Mode:</span>
          <select id="modeSelect" 
                  class="bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-2 text-sm text-white focus:border-white/30 transition-all">
            <option value="form">Visual Form</option>
            <option value="json">Raw JSON</option>
          </select>
        </div>
      </div>

      <form id="templateForm" class="p-8 space-y-10">
        <input type="hidden" id="hiddenFilename">

        <!-- FORM MODE – Optimized Sections -->
        <div id="formArea" class="space-y-10">

          <!-- Section 1: General -->
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-2 h-2 rounded-full bg-white"></div>
              <h4 class="font-semibold text-white text-lg tracking-tight">General Information</h4>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-neutral-300 mb-2">Template Name <span class="text-red-400">*</span></label>
                <input type="text" name="meta.name" required 
                       class="w-full bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3.5 text-white focus:border-white/30 transition-all">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-300 mb-2">Display Name</label>
                <input type="text" name="meta.display_name" 
                       class="w-full bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3.5 text-white focus:border-white/30 transition-all">
              </div>
            </div>
            <div class="mt-6">
              <label class="block text-sm font-medium text-neutral-300 mb-2">Description</label>
              <textarea name="meta.description" rows="3" 
                        class="w-full bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3.5 text-white focus:border-white/30 transition-all"></textarea>
            </div>
          </div>

          <!-- Section 2: Environment -->
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
              <h4 class="font-semibold text-white text-lg tracking-tight">Environment</h4>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-neutral-300 mb-2">Category <span class="text-red-400">*</span></label>
                <div class="flex gap-3">
                  <select name="category" required 
                          class="flex-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3.5 text-white focus:border-white/30 transition-all">
                    <% categories.forEach(cat => { %><option value="<%= cat %>"><%= cat %></option><% }) %>
                  </select>
                  <button type="button" id="btnAddCategory" 
                          class="px-6 py-3 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
                    + Add
                  </button>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-300 mb-2">Docker Image <span class="text-red-400">*</span></label>
                <input type="text" name="environment.docker_image" required placeholder="itzg/minecraft-server:latest" 
                       class="w-full bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3.5 text-white focus:border-white/30 transition-all">
              </div>
            </div>
          </div>

          <!-- Section 3: Variables -->
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-indigo-400"></div>
                <h4 class="font-semibold text-white text-lg tracking-tight">Variables</h4>
              </div>
              <button type="button" id="btnAddVar" 
                      class="px-5 py-2 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
                + Add Variable
              </button>
            </div>
            <div id="variablesContainer" class="space-y-4"></div>
          </div>

          <!-- Section 4: Actions -->
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                <h4 class="font-semibold text-white text-lg tracking-tight">Actions</h4>
              </div>
              <button type="button" id="btnAddAction" 
                      class="px-5 py-2 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
                + Add Action
              </button>
            </div>
            <div id="actionsContainer" class="space-y-4"></div>
          </div>

          <!-- Section 5: Install Script -->
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-2 h-2 rounded-full bg-violet-400"></div>
              <h4 class="font-semibold text-white text-lg tracking-tight">Install Script</h4>
            </div>
            <textarea name="environment.install_script" rows="12" 
                      class="w-full bg-neutral-900 border border-white/10 rounded-[10px] p-5 font-mono text-white focus:border-white/30 transition-all resize-y"></textarea>
          </div>

        </div>

        <!-- JSON MODE -->
        <div id="jsonArea" class="hidden">
          <div class="rounded-2xl border border-white/10 bg-neutral-900/60 p-6">
            <textarea id="jsonEditor" 
                      class="w-full h-[70vh] bg-neutral-950 border border-white/10 rounded-[10px] p-6 font-mono text-white focus:border-white/30 transition-all"></textarea>
          </div>
        </div>
      </form>

      <!-- Footer -->
      <div class="px-8 py-6 border-t border-white/10 bg-neutral-950/70 flex justify-end gap-4">
        <button id="btnCancelForm" 
                class="px-8 py-3 bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 rounded-[10px] text-sm font-medium transition-all duration-200 active:scale-95">
          Cancel
        </button>
        <button id="btnSaveTemplate" 
                class="px-10 py-3 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          Save Template
        </button>
      </div>
    </div>
  </div>
</main>

<script>
// ====================== CONFIG ======================
let varIndex = 0, actionIndex = 0;

// ====================== SHOW/HIDE ======================
function showForm(title) {
  document.getElementById("formTitle").textContent = title;
  document.getElementById("btnSaveTemplate").textContent = title.includes("Edit") ? "Update Template" : "Save Template";
  document.getElementById("templateFormSection").classList.remove("hidden");
}
function hideForm() {
  document.getElementById("templateFormSection").classList.add("hidden");
}

// ====================== MODE SWITCH ======================
const modeSelect = document.getElementById("modeSelect");
const formArea = document.getElementById("formArea");
const jsonArea = document.getElementById("jsonArea");
const jsonEditor = document.getElementById("jsonEditor");

modeSelect.onchange = () => {
  const isJson = modeSelect.value === "json";
  formArea.classList.toggle("hidden", isJson);
  jsonArea.classList.toggle("hidden", !isJson);
  if (isJson) jsonEditor.value = JSON.stringify(collectFormData(), null, 2);
};

// ====================== VARIABLES ======================
function addVariable(v = {}) {
  const idx = varIndex++;
  const div = document.createElement("div");
  div.className = "rounded-2xl border border-white/10 bg-neutral-900/60 p-6 relative";
  div.innerHTML = `
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      <div class="md:col-span-2">
        <label class="text-xs text-neutral-400">ID <span class="text-rose-400">*</span></label>
        <input type="text" name="variables[${idx}].id" value="${v.id||''}" required 
               class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white font-mono focus:border-white/30 transition-all">
      </div>
      <div class="md:col-span-2">
        <label class="text-xs text-neutral-400">Name</label>
        <input type="text" name="variables[${idx}].name" value="${v.name||''}" required 
               class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white focus:border-white/30 transition-all">
      </div>
      <div class="md:col-span-4">
        <label class="text-xs text-neutral-400">Description</label>
        <input type="text" name="variables[${idx}].description" value="${v.description||''}" 
               class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white focus:border-white/30 transition-all">
      </div>
      <div class="md:col-span-3">
        <label class="text-xs text-neutral-400">Default Value</label>
        <input type="text" name="variables[${idx}].default" value="${v.default||''}" 
               class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white focus:border-white/30 transition-all">
      </div>
    </div>
    <button type="button" onclick="this.closest('div').remove()" 
            class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300 transition-colors">×</button>
  `;
  document.getElementById("variablesContainer").appendChild(div);
}

// ====================== ACTIONS ======================
function addAction(a = {}) {
  const idx = actionIndex++;
  const div = document.createElement("div");
  div.className = "rounded-2xl border border-white/10 bg-neutral-900/60 p-6 relative grid grid-cols-1 sm:grid-cols-5 gap-6";
  div.innerHTML = `
    <div class="sm:col-span-1">
      <label class="text-xs text-neutral-400">Action Name</label>
      <input type="text" name="actions[${idx}].name" value="${a.name||''}" required placeholder="start" 
             class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white focus:border-white/30 transition-all">
    </div>
    <div class="sm:col-span-4">
      <label class="text-xs text-neutral-400">Command</label>
      <input type="text" name="actions[${idx}].command" value="${a.command||''}" required placeholder="docker start {{container_name}}" 
             class="w-full mt-1 bg-neutral-900 border border-white/10 rounded-[10px] px-5 py-3 text-white focus:border-white/30 transition-all">
    </div>
    <button type="button" onclick="this.closest('div').remove()" 
            class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300 transition-colors">×</button>
  `;
  document.getElementById("actionsContainer").appendChild(div);
}

// ====================== COLLECT DATA ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { meta: {}, environment: {}, variables: [], actions: [], category: "" };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) data.meta[key.split(".")[1]] = value;
    else if (key.startsWith("environment.")) data.environment[key.split(".")[1]] = value;
    else if (key === "category") data.category = value;
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        data.variables[i][match[2]] = value;
      }
    } else if (key.startsWith("actions[")) {
      const match = key.match(/actions\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.actions[i]) data.actions[i] = {};
        data.actions[i][match[2]] = value;
      }
    }
  }
  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  return data;
}

// ====================== FILL FORM ======================
function fillForm(data) {
  document.querySelector('[name="meta.name"]').value = data.meta?.name || "";
  document.querySelector('[name="meta.display_name"]').value = data.meta?.display_name || "";
  document.querySelector('[name="meta.description"]').value = data.meta?.description || "";
  document.querySelector('[name="category"]').value = data.category || "";
  document.querySelector('[name="environment.docker_image"]').value = data.environment?.docker_image || "";
  document.querySelector('[name="environment.install_script"]').value = data.environment?.install_script || "";

  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  (data.variables || []).forEach(v => addVariable(v));

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  (data.actions || []).forEach(addAction);

  jsonEditor.value = JSON.stringify(data, null, 2);
}

function loadDefaultForm() {
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  [{name:"start",command:"docker start {{container_name}}"},
   {name:"stop",command:"docker stop {{container_name}}"},
   {name:"restart",command:"docker restart {{container_name}}"}].forEach(addAction);
}

// ====================== SAVE ======================
document.getElementById("btnSaveTemplate").onclick = async () => {
  let payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();

  const filename = document.getElementById("hiddenFilename").value;
  const url = filename ? `/admin/templates/${filename}` : "/admin/templates";
  const method = filename ? "PUT" : "POST";

  const res = await fetch(url, {
    method,
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(payload)
  });

  if (res.ok) {
    alert("✅ Template saved!");
    hideForm();
    location.reload();
  } else {
    const err = await res.text();
    alert("❌ Error: " + err.substring(0, 150));
  }
};

// ====================== BUTTONS ======================
document.getElementById("btnNewTemplate").onclick = () => {
  document.getElementById("hiddenFilename").value = "";
  document.getElementById("templateForm").reset();
  modeSelect.value = "form";
  modeSelect.onchange();
  loadDefaultForm();
  showForm("Create New Template");
};

document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file"; input.accept = ".json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        document.getElementById("hiddenFilename").value = "";
        modeSelect.value = "json";
        modeSelect.onchange();
        jsonEditor.value = JSON.stringify(data, null, 2);
        showForm("Import Template");
      } catch { alert("Invalid JSON"); }
    };
    reader.readAsText(file);
  };
  input.click();
};

document.getElementById("btnAddCategory").onclick = async () => {
  const name = prompt("New category name:");
  if (!name?.trim()) return;
  const res = await fetch("/admin/templates/category", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({name: name.trim()})
  });
  if (res.ok) {
    const {categories} = await res.json();
    const select = document.querySelector('[name="category"]');
    select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join("");
    select.value = name.trim();
  } else alert("Failed to add category");
};

document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable();
document.getElementById("btnAddAction").onclick = () => addAction();

// ====================== EDIT / DELETE ======================
document.querySelectorAll(".btnEdit").forEach(btn => {
  btn.onclick = () => {
    const data = JSON.parse(btn.dataset.template);
    document.getElementById("hiddenFilename").value = btn.dataset.filename;
    fillForm(data);
    modeSelect.value = "form";
    modeSelect.onchange();
    showForm(`Edit: ${data.meta.name}`);
  };
});

document.querySelectorAll(".btnDelete").forEach(btn => {
  btn.onclick = async () => {
    if (!confirm("Delete this template permanently?")) return;
    await fetch(`/admin/templates/${btn.dataset.filename}`, {method: "DELETE"});
    location.reload();
  };
});
</script>
