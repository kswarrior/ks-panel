        <span class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Operations</span>
        <button type="button" class="btn btn-accent text-xs py-1.5 px-3 add-op-btn">+ Add Operation</button>
      </div>
      <div class="operations-list space-y-2" id="ops-install-${idx}" data-sub-count="0"></div>
    </div>
    <button type="button" onclick="this.closest('.card-item').remove()" class="remove-btn">×</button>
