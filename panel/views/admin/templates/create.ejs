    <div class="tf-row">
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Command <span class="text-red-400">*</span></label>
        <input type="text" name="terminal.allowed_commands[${idx}]" value="${cmd}" class="tf-input font-mono" placeholder="ls or node index.js">
      </div>
    </div>
    <button type="button" onclick="this.closest('.tf-card').remove()" class="tf-remove-btn">×</button>
  `;
