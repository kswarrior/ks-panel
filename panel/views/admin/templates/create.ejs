      swap: parseInt(document.getElementById('limits-swap').value) || 0
    },
    feature_limits: {
      databases: parseInt(document.getElementById('limits-databases').value) || 0,
      backups: parseInt(document.getElementById('limits-backups').value) || 0,
      allocations: parseInt(document.getElementById('limits-allocations').value) || 0
    },
    ports: Array.from(document.querySelectorAll('#portsContainer > div')).map(row => ({
      host: parseInt(row.querySelector('[name="port-host"]').value),
