          <option value="ro" ${v.mode === "ro" ? "selected" : ""}>Read Only</option>
        </select>
      </div>
    </div>
    <button type="button" onclick="this.closest('.tf-card').remove()" class="tf-remove-btn">×</button>
  `;
  document.getElementById("volumesContainer").appendChild(div);
}

// ====================== ALLOWED TERMINAL COMMANDS ======================
function addAllowedCommand(cmd = "") {
