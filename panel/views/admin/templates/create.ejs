<%- include('../../components/template') %>

<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

.form-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  width: 100%;
}

.field-long,
.field-short {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex-grow: 1;
}

.field-long {
  flex-basis: 420px;
  min-width: 260px;
}

.field-short {
  flex-basis: 180px;
  min-width: 160px;
}

@media (min-width: 1024px) {
  .form-row {
    gap: 2rem;
  }

  .field-long {
    flex: 2 1 420px;
  }

  .field-short {
    flex: 1 1 180px;
  }
}

/* checkbox / radio */
.proxy-checkbox,
.radio-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.proxy-checkbox input[type="checkbox"] {
  accent-color: #3b82f6;
}

.radio-group input[type="radio"] {
  accent-color: #3b82f6;
}

.radio-option {
  display: flex;
  align-items: center;
  padding: 0.75rem;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 0.5rem;
  cursor: pointer;
  transition: background-color 0.2s ease;
  gap: 0.75rem;
}

.radio-option:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

.proxy-checkbox {
  align-items: flex-start;
  padding: 0.75rem;
  background-color: rgba(75, 85, 99, 0.3);
  border-radius: 0.5rem;
  gap: 0.75rem;
}

/* select textarea */
textarea.input-field,
select.input-field {
  resize: vertical;
  min-height: 3rem;
}

/* hidden */
.hidden {
  display: none;
}

/* NEW: Sub-operation styling */
.operation-item {
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.03);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 1rem;
  position: relative;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">Create New Template</h1>
        <p class="mt-1 text-sm text-neutral-400">Powerful Pterodactyl / PufferPanel-style templates with typed Install Steps &amp; Actions</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button id="btnImportJson" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          Import JSON
        </button>
        <a href="/admin/templates/overview" 
           class="px-6 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
          ← Back to Overview
        </a>
      </div>
    </header>

    <section class="mt-12">
      <div class="max-w-5xl mx-auto bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 lg:p-12 shadow-sm">
        <form id="templateForm" class="space-y-10">

          <!-- GENERAL INFORMATION -->
          <div class="flex items-center gap-4 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">GENERAL INFORMATION</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">TEMPLATE NAME <span class="text-red-400">*</span></label>
              <input type="text" name="meta.name" required class="input-field">
            </div>
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">DISPLAY NAME</label>
              <input type="text" name="meta.display_name" class="input-field">
            </div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">DESCRIPTION</label>
              <textarea name="meta.description" rows="3" class="input-field"></textarea>
            </div>
          </div>

          <!-- ENVIRONMENT -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">ENVIRONMENT</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">CATEGORY <span class="text-red-400">*</span></label>
              <div class="flex gap-3">
                <select name="category" required class="input-field">
                  <% categories.forEach(cat => { %><option value="<%= cat %>"><%= cat %></option><% }) %>
                </select>
                <button type="button" id="btnAddCategory" 
                        class="px-6 py-3 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
                  + Add
                </button>
              </div>
            </div>
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">DOCKER IMAGE <span class="text-red-400">*</span></label>
              <input type="text" name="environment.docker_image" required placeholder="itzg/minecraft-server:latest" class="input-field">
            </div>
          </div>

          <!-- VARIABLES -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">VARIABLES</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="flex justify-end mb-4">
            <button type="button" id="btnAddVar" 
                    class="px-5 py-2 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
              + Add Variable
            </button>
          </div>
          <div id="variablesContainer" class="space-y-4"></div>

          <!-- RUNTIME ACTIONS - NOW SUPPORT MULTIPLE TYPES IN ONE -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">RUNTIME ACTIONS (Start/Stop/etc.)</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="flex justify-end mb-4">
            <button type="button" id="btnAddAction" 
                    class="px-5 py-2 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
              + Add Action
            </button>
          </div>
          <div id="actionsContainer" class="space-y-4"></div>

          <!-- INSTALL STEPS - NOW SUPPORT MULTIPLE TYPES IN ONE -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">INSTALL STEPS (Download + Git + Command + etc.)</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="flex justify-end mb-4">
            <button type="button" id="btnAddInstallStep" 
                    class="px-5 py-2 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95">
              + Add Install Step
            </button>
          </div>
          <div id="installStepsContainer" class="space-y-4"></div>

          <!-- JSON EDITOR -->
          <div id="jsonArea" class="hidden mt-10">
            <div class="flex items-center gap-4 mb-6">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
              <h2 class="text-lg font-semibold text-white tracking-wide">RAW JSON EDITOR</h2>
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            </div>
            <textarea id="jsonEditor" class="input-field h-[70vh]"></textarea>
          </div>

          <!-- SUBMIT -->
          <div class="mt-12 pt-6 border-t border-white/10 flex gap-4">
            <button id="btnCancelForm" 
                    type="button"
                    class="flex-1 px-8 py-3 bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 rounded-[10px] text-sm font-medium transition-all duration-200 active:scale-95">
              Cancel
            </button>
            <button id="btnSaveTemplate" 
                    type="button"
                    class="flex-1 px-10 py-3 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
              Save Template
            </button>
          </div>

          <input type="hidden" id="hiddenFilename" value="">
        </form>
      </div>
    </section>

    <!-- Notification -->
    <div id="notification" 
         class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
      <span id="notification-text"></span>
    </div>
  </div>
</main>

<script>
// ====================== CONFIG ======================
let varIndex = 0, actionIndex = 0, installIndex = 0;

// ====================== SHOW/HIDE & NOTIFICATION ======================
function hideForm() {
  window.location.href = "/admin/templates/overview";
}
function showNotification(message, type = 'success') {
  const notification = document.getElementById('notification');
  const textEl = document.getElementById('notification-text');
  textEl.textContent = message;
  notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
    type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
  }`;
  notification.classList.remove('hidden');
  notification.classList.add('flex');
  setTimeout(() => {
    notification.classList.add('opacity-0', 'translate-y-2');
    setTimeout(() => {
      notification.classList.add('hidden');
      notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
    }, 300);
  }, 2800);
}

// ====================== MODE SWITCH ======================
const modeSelect = document.createElement("select");
modeSelect.id = "modeSelect";
modeSelect.className = "input-field";
modeSelect.innerHTML = `<option value="form">Visual Form</option><option value="json">Raw JSON</option>`;
modeSelect.style.cssText = "position:absolute;top:20px;right:20px;z-index:10;width:180px;";
document.querySelector(".max-w-5xl").appendChild(modeSelect);

const formArea = document.getElementById("templateForm");
const jsonArea = document.getElementById("jsonArea");
const jsonEditor = document.getElementById("jsonEditor");

modeSelect.onchange = () => {
  const isJson = modeSelect.value === "json";
  if (isJson) {
    formArea.querySelectorAll("div:not(#jsonArea)").forEach(el => el.style.display = "none");
    jsonArea.classList.remove("hidden");
    try { jsonEditor.value = JSON.stringify(collectFormData(), null, 2); } catch(e) {}
  } else {
    formArea.querySelectorAll("div:not(#jsonArea)").forEach(el => el.style.display = "block");
    jsonArea.classList.add("hidden");
  }
};

// ====================== VARIABLES ======================
function addVariable(v = {}) {
  const idx = varIndex++;
  const div = document.createElement("div");
  div.className = "rounded-2xl border border-white/10 bg-neutral-900/60 p-6 relative";
  div.innerHTML = `
    <div class="form-row">
      <div class="field-long">
        <label class="text-xs text-neutral-400">ID <span class="text-rose-400">*</span></label>
        <input type="text" name="variables[${idx}].id" value="${v.id||''}" required class="input-field mt-1 font-mono">
      </div>
      <div class="field-long">
        <label class="text-xs text-neutral-400">Name</label>
        <input type="text" name="variables[${idx}].name" value="${v.name||''}" required class="input-field mt-1">
      </div>
    </div>
    <div class="form-row mt-4">
      <div class="field-long">
        <label class="text-xs text-neutral-400">Description</label>
        <input type="text" name="variables[${idx}].description" value="${v.description||''}" class="input-field">
      </div>
      <div class="field-short">
        <label class="text-xs text-neutral-400">Default Value</label>
        <input type="text" name="variables[${idx}].default" value="${v.default||''}" class="input-field">
      </div>
    </div>
    <button type="button" onclick="this.closest('div').remove()" class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300">×</button>
  `;
  document.getElementById("variablesContainer").appendChild(div);
}

// ====================== ITEM TYPES & FIELD CONFIGS ======================
const itemTypes = [
  { value: "command",   label: "Run Shell Command" },
  { value: "download",  label: "Download File" },
  { value: "git_clone", label: "Git Clone" },
  { value: "create_file", label: "Create File" },
  { value: "unzip",     label: "Unzip Archive" },
  { value: "mkdir",     label: "Create Directory" },
  { value: "chmod",     label: "Change Permissions" }
];

const fieldConfigs = {
  command: [{ key: "run_code", label: "Shell Script", type: "textarea", rows: 10, placeholder: "apt-get update && ..." }],
  download: [
    { key: "url", label: "URL", type: "text", placeholder: "https://..." },
    { key: "filename", label: "Filename (-O)", type: "text", placeholder: "file.jar" },
    { key: "path", label: "Save Path", type: "text", placeholder: "/data" }
  ],
  git_clone: [
    { key: "repo", label: "Repository URL", type: "text", placeholder: "https://github.com/..." },
    { key: "path", label: "Clone Path", type: "text", placeholder: "/app" },
    { key: "branch", label: "Branch (optional)", type: "text", placeholder: "main" }
  ],
  create_file: [
    { key: "filename", label: "Filename", type: "text", placeholder: "config.yml" },
    { key: "path", label: "Path", type: "text", placeholder: "/data" },
    { key: "content", label: "File Content", type: "textarea", rows: 8, placeholder: "server:\n  port: 25565" }
  ],
  unzip: [
    { key: "source", label: "Source Archive", type: "text", placeholder: "archive.zip" },
    { key: "destination", label: "Extract To", type: "text", placeholder: "/data" }
  ],
  mkdir: [{ key: "path", label: "Directory Path", type: "text", placeholder: "/data/backups" }],
  chmod: [
    { key: "target", label: "Target", type: "text", placeholder: "/data/server.jar" },
    { key: "mode", label: "Permissions", type: "text", placeholder: "755" }
  ]
};

// ====================== RENDER SUB-OPERATION FIELDS (NEW MULTI SUPPORT) ======================
function renderSubDynamicFields(mainIdx, subIdx, type, data = {}, prefix) {
  const container = document.getElementById(`dynamic-sub-${prefix}-${mainIdx}-${subIdx}`);
  if (!container) return;
  const config = fieldConfigs[type] || fieldConfigs.command;
  let html = `<div class="form-row">`;
  config.forEach(f => {
    const val = data[f.key] || "";
    html += `
      <div class="${f.type === 'textarea' ? 'field-long' : 'field-short'}">
        <label class="text-xs text-neutral-400">${f.label}</label>
        ${f.type === "textarea" ? 
          `<textarea name="${prefix}[${mainIdx}].operations[${subIdx}].${f.key}" rows="${f.rows}" class="input-field mt-1 font-mono" placeholder="${f.placeholder || ''}">${val}</textarea>` :
          `<input type="text" name="${prefix}[${mainIdx}].operations[${subIdx}].${f.key}" value="${val}" class="input-field mt-1" placeholder="${f.placeholder}">`
        }
      </div>`;
  });
  html += `</div>`;
  container.innerHTML = html;
}

// ====================== ADD SUB-OPERATION (NEW) ======================
function addSubOperation(opsContainer, prefix, mainIdx, subData = {}) {
  const subIdx = parseInt(opsContainer.dataset.subCount || 0);
  opsContainer.dataset.subCount = subIdx + 1;

  const div = document.createElement("div");
  div.className = "operation-item";
  div.innerHTML = `
    <div class="flex justify-between items-center mb-4">
      <span class="text-xs font-medium text-neutral-400">Operation #${subIdx + 1}</span>
      <button type="button" onclick="this.closest('.operation-item').remove()" class="text-red-400 text-2xl leading-none">×</button>
    </div>
    <div class="form-row">
      <div class="field-short">
        <label class="text-xs text-neutral-400">Type <span class="text-rose-400">*</span></label>
        <select name="${prefix}[${mainIdx}].operations[${subIdx}].type" class="input-field sub-type-select" data-main="${mainIdx}" data-sub="${subIdx}">
          ${itemTypes.map(t => `<option value="${t.value}">${t.label}</option>`).join("")}
        </select>
      </div>
      <div class="field-long dynamic-sub" id="dynamic-sub-${prefix}-${mainIdx}-${subIdx}"></div>
    </div>
  `;
  opsContainer.appendChild(div);

  const defaultType = subData.type || "command";
  const select = div.querySelector(".sub-type-select");
  select.value = defaultType;
  renderSubDynamicFields(mainIdx, subIdx, defaultType, subData, prefix);

  select.addEventListener("change", (e) => {
    const newType = e.target.value;
    renderSubDynamicFields(mainIdx, subIdx, newType, {}, prefix);
  });
}

// ====================== RUNTIME ACTIONS (MULTI-TYPE SUPPORT) ======================
function addAction(a = {}) {
  const idx = actionIndex++;
  const div = document.createElement("div");
  div.className = "rounded-2xl border border-white/10 bg-neutral-900/60 p-6 relative";
  div.innerHTML = `
    <div class="form-row">
      <div class="field-short">
        <label class="text-xs text-neutral-400">ID <span class="text-rose-400">*</span></label>
        <input type="text" name="actions[${idx}].id" value="${a.id || ''}" required class="input-field font-mono">
      </div>
      <div class="field-long">
        <label class="text-xs text-neutral-400">Action Name</label>
        <input type="text" name="actions[${idx}].name" value="${a.name || ''}" class="input-field">
      </div>
    </div>
    <div class="mt-6">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-neutral-400">Operations (you can add many types)</span>
        <button type="button" class="add-op-btn px-5 py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white text-xs rounded-[8px]">+ Add Operation</button>
      </div>
      <div class="operations-list space-y-3" id="ops-actions-${idx}" data-sub-count="0"></div>
    </div>
    <button type="button" onclick="this.closest('div').remove()" class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300">×</button>
  `;
  document.getElementById("actionsContainer").appendChild(div);

  const opsContainer = div.querySelector(`#ops-actions-${idx}`);
  const ops = a.operations || [{ type: "command", run_code: "echo 'Action started'" }];

  ops.forEach(op => addSubOperation(opsContainer, "actions", idx, op));

  div.querySelector(".add-op-btn").onclick = () => addSubOperation(opsContainer, "actions", idx);
}

// ====================== INSTALL STEPS (MULTI-TYPE SUPPORT) ======================
function addInstallStep(s = {}) {
  const idx = installIndex++;
  const div = document.createElement("div");
  div.className = "rounded-2xl border border-white/10 bg-neutral-900/60 p-6 relative";
  div.innerHTML = `
    <div class="form-row">
      <div class="field-long">
        <label class="text-xs text-neutral-400">Step Name</label>
        <input type="text" name="install_steps[${idx}].name" value="${s.name || ''}" class="input-field">
      </div>
    </div>
    <div class="mt-6">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-neutral-400">Operations (you can add many types)</span>
        <button type="button" class="add-op-btn px-5 py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white text-xs rounded-[8px]">+ Add Operation</button>
      </div>
      <div class="operations-list space-y-3" id="ops-install-${idx}" data-sub-count="0"></div>
    </div>
    <button type="button" onclick="this.closest('div').remove()" class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300">×</button>
  `;
  document.getElementById("installStepsContainer").appendChild(div);

  const opsContainer = div.querySelector(`#ops-install-${idx}`);
  const ops = s.operations || [{ type: "command", run_code: "echo 'Installing...'" }];

  ops.forEach(op => addSubOperation(opsContainer, "install_steps", idx, op));

  div.querySelector(".add-op-btn").onclick = () => addSubOperation(opsContainer, "install_steps", idx);
}

// ====================== COLLECT FORM DATA (UPDATED FOR MULTI-OPS) ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { meta: {}, environment: { install_steps: [] }, variables: [], actions: [], category: "" };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) data.meta[key.split(".")[1]] = value;
    else if (key === "category") data.category = value;
    else if (key === "environment.docker_image") data.environment.docker_image = value;

    // Variables
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        data.variables[i][match[2]] = value;
      }
    }

    // Actions with operations
    else if (key.startsWith("actions[")) {
      const opMatch = key.match(/actions\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]);
        const j = parseInt(opMatch[2]);
        if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
        if (!data.actions[i].operations[j]) data.actions[i].operations[j] = {};
        data.actions[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/actions\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
          data.actions[i][simpleMatch[2]] = value;
        }
      }
    }

    // Install steps with operations
    else if (key.startsWith("install_steps[")) {
      const opMatch = key.match(/install_steps\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]);
        const j = parseInt(opMatch[2]);
        if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
        if (!data.environment.install_steps[i].operations[j]) data.environment.install_steps[i].operations[j] = {};
        data.environment.install_steps[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/install_steps\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
          data.environment.install_steps[i][simpleMatch[2]] = value;
        }
      }
    }
  }

  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  data.environment.install_steps = data.environment.install_steps.filter(Boolean);

  // Clean empty operations
  data.actions.forEach(a => { if (a.operations) a.operations = a.operations.filter(Boolean); });
  data.environment.install_steps.forEach(s => { if (s.operations) s.operations = s.operations.filter(Boolean); });

  return data;
}

// ====================== FILL FORM (UPDATED) ======================
function fillForm(data) {
  document.querySelector('[name="meta.name"]').value = data.meta?.name || "";
  document.querySelector('[name="meta.display_name"]').value = data.meta?.display_name || "";
  document.querySelector('[name="meta.description"]').value = data.meta?.description || "";
  document.querySelector('[name="category"]').value = data.category || "";
  document.querySelector('[name="environment.docker_image"]').value = data.environment?.docker_image || "";

  // Variables
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  (data.variables || []).forEach(v => addVariable(v));

  // Actions
  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  (data.actions || []).forEach(a => addAction(a));

  // Install Steps
  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  (data.environment?.install_steps || []).forEach(s => addInstallStep(s));

  jsonEditor.value = JSON.stringify(data, null, 2);
}

function loadDefaultForm() {
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  [
    { 
      id: "start", 
      name: "Start Server", 
      operations: [
        { type: "create_file", filename: "start.sh", path: "/data", content: "#!/bin/bash\necho Starting server..." },
        { type: "command", run_code: "chmod +x /data/start.sh && /data/start.sh" }
      ]
    },
    { 
      id: "stop",  
      name: "Stop Server",  
      operations: [{ type: "command", run_code: "docker stop {{container_name}}" }]
    }
  ].forEach(addAction);

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  [
    { 
      name: "Install Server Files", 
      operations: [
        { type: "download", url: "https://example.com/server.jar", filename: "server.jar", path: "/data" },
        { type: "command", run_code: "echo 'Server downloaded'" }
      ]
    }
  ].forEach(addInstallStep);
}

// ====================== SAVE ======================
document.getElementById("btnSaveTemplate").onclick = async () => {
  let payload;
  try {
    payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();
  } catch(e) {
    showNotification("Invalid JSON!", "error");
    return;
  }

  const filename = document.getElementById("hiddenFilename").value;
  const url = filename ? `/admin/templates/${filename}` : "/admin/templates";
  const method = filename ? "PUT" : "POST";

  const res = await fetch(url, {
    method,
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(payload)
  });

  if (res.ok) {
    showNotification("✅ Template saved successfully!", "success");
    setTimeout(() => window.location.href = "/admin/templates/overview", 800);
  } else {
    const err = await res.text();
    showNotification("❌ Error: " + err.substring(0, 120), "error");
  }
};

// ====================== BUTTONS ======================
document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable();
document.getElementById("btnAddAction").onclick = () => addAction();
document.getElementById("btnAddInstallStep").onclick = () => addInstallStep();

document.getElementById("btnAddCategory").onclick = async () => {
  const name = prompt("New category name:");
  if (!name?.trim()) return;
  const res = await fetch("/admin/templates/category", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({name: name.trim()})
  });
  if (res.ok) {
    const {categories} = await res.json();
    const select = document.querySelector('[name="category"]');
    select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join("");
    select.value = name.trim();
    showNotification("Category added!", "success");
  } else {
    showNotification("Failed to add category", "error");
  }
};

// ====================== IMPORT JSON ======================
document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file"; input.accept = ".json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        document.getElementById("hiddenFilename").value = "";
        modeSelect.value = "json";
        modeSelect.onchange();
        jsonEditor.value = JSON.stringify(data, null, 2);
        showNotification("JSON imported – switch to Raw JSON mode", "success");
      } catch(e) {
        showNotification("Invalid JSON file!", "error");
      }
    };
    reader.readAsText(file);
  };
  input.click();
};

// ====================== INIT ======================
loadDefaultForm();
modeSelect.value = "form";
modeSelect.onchange();
</script>

