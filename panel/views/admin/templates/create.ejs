      </div>
      <div class="operations-list space-y-2" id="sub-ops-${parentIdx}-${subIdx}" data-sub-count="0"></div>
    </div>
    <button type="button" onclick="this.closest('.tf-card').remove()" class="tf-remove-btn">×</button>
  `;
  parentContainer.appendChild(nestedDiv);

  const subOpsContainer = nestedDiv.querySelector(`#sub-ops-${parentIdx}-${subIdx}`);
