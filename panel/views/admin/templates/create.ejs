// ====================== TERMINAL CONDITIONS (enhanced with Actions + Allowed Commands) ======================
function getCurrentActions() {
  const actions = [];
  document.querySelectorAll('#actionsContainer .tf-card').forEach(card => {
    const idInput = card.querySelector('input[name$=".id"]');
    const nameInput = card.querySelector('input[name$=".name"]');
    if (idInput && idInput.value) {
      actions.push({
        id: idInput.value,
        name: nameInput ? nameInput.value : idInput.value,
        type: "action"
      });
    }
  });
  return actions;
}

function getAllowedCommands() {
  const cmds = [];
  document.querySelectorAll('#allowedCommandsContainer input[name^="terminal.allowed_commands"]').forEach(input => {
    if (input.value.trim()) {
      cmds.push({ id: input.value.trim(), name: input.value.trim(), type: "command" });
    }
  });
  return cmds;
}

function refreshTerminalActionOptions() {
  const selects = document.querySelectorAll('#terminalConditionsContainer select[name$=".action"]');
  const currentActions = getCurrentActions();
  const allowedCmds = getAllowedCommands();
  const allOptions = [...currentActions, ...allowedCmds];

  selects.forEach(select => {
    const currentValue = select.value;
    select.innerHTML = `<option value="">Select Action or Command...</option>`;
    allOptions.forEach(item => {
      const opt = document.createElement("option");
      opt.value = item.id;
      opt.textContent = item.type === "action" 
        ? `Action: ${item.name} (${item.id})` 
        : `Cmd: ${item.name}`;
      select.appendChild(opt);
    });
    if (currentValue && allOptions.some(item => item.id === currentValue)) select.value = currentValue;
  });
}

function addTerminalCondition(c = {}) {
  const idx = conditionIndex++;
  const div = document.createElement("div");
  div.className = "tf-sub-item";
  div.innerHTML = `
    <div class="flex justify-between items-center mb-2">
      <span class="text-xs font-medium text-neutral-400">Condition #${idx + 1}</span>
      <button type="button" onclick="this.closest('.tf-sub-item').remove();refreshTerminalActionOptions()" class="tf-remove-btn">×</button>
    </div>
    <div class="tf-row">
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Attach Action / Command</label>
        <select name="terminal.conditions[${idx}].action" class="tf-input"></select>
      </div>
      <div class="tf-field-long">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">When</label>
        <select name="terminal.conditions[${idx}].when" class="tf-input">
          <option value="running" ${c.when === "running" ? "selected" : ""}>Action Running</option>
          <option value="ended" ${c.when === "ended" ? "selected" : ""}>Action Ended</option>
        </select>
      </div>
    </div>
  `;
  document.getElementById("terminalConditionsContainer").appendChild(div);
  
  const actionSelect = div.querySelector('select[name$=".action"]');
  refreshTerminalActionOptions(); // will populate the new select too
  if (c.action) actionSelect.value = c.action;
}

