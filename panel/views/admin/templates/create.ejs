// ====================== COLLECT FORM DATA (updated for new action fields) ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { 
    meta: {}, 
    environment: { install_steps: [], ports: [], volumes: [], limits: {} }, 
    terminal: { conditions: [] },
    variables: [], 
    actions: [], 
    pages: [], 
    category: "" 
  };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) {
      data.meta[key.split(".")[1]] = value;
    }
    else if (key === "category") {
      data.category = value;
    }
    else if (key === "environment.instance_type") {
      data.environment.instance_type = value;
    }
    else if (key === "environment.image") {
      data.environment.image = value;
    }
    else if (key.startsWith("environment.ports[")) {
      const match = key.match(/environment\.ports\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.environment.ports[i]) data.environment.ports[i] = {};
        data.environment.ports[i][match[2]] = value;
      }
    }
    else if (key.startsWith("environment.volumes[")) {
      const match = key.match(/environment\.volumes\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.environment.volumes[i]) data.environment.volumes[i] = {};
        data.environment.volumes[i][match[2]] = value;
      }
    }
    else if (key.startsWith("environment.limits.")) {
      const field = key.split(".")[2];
      data.environment.limits[field] = value;
    }
    else if (key.startsWith("terminal.")) {
      if (key.includes("conditions[")) {
        const match = key.match(/terminal\.conditions\[(\d+)\]\.(.+)/);
        if (match) {
          const i = parseInt(match[1]);
          if (!data.terminal.conditions[i]) data.terminal.conditions[i] = {};
          data.terminal.conditions[i][match[2]] = value;
        }
      } else if (key.startsWith("terminal.allowed_commands[")) {
        const match = key.match(/terminal\.allowed_commands\[(\d+)\]/);
        if (match) {
          const i = parseInt(match[1]);
          if (!data.terminal.allowed_commands) data.terminal.allowed_commands = [];
          data.terminal.allowed_commands[i] = value;
        }
      } else {
        const field = key.split(".")[1];
        data.terminal[field] = value;
      }
    }
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        if (key.includes(".options[")) {
          const optMatch = key.match(/variables\[(\d+)\]\.options\[(\d+)\]\.(.+)/);
          if (optMatch) {
            const optI = parseInt(optMatch[2]);
            if (!data.variables[i].options) data.variables[i].options = [];
            if (!data.variables[i].options[optI]) data.variables[i].options[optI] = {};
            data.variables[i].options[optI][optMatch[3]] = value;
          }
        } else {
          data.variables[i][match[2]] = value;
        }
      }
    }
    else if (key.startsWith("actions[")) {
      // Handle normal action fields
      const opMatch = key.match(/actions\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.actions[i]) data.actions[i] = { id: "", name: "", type: "normal", svg: "", bgColor: "", textColor: "", operations: [] };
        if (!data.actions[i].operations[j]) data.actions[i].operations[j] = {};
        data.actions[i].operations[j][opMatch[3]] = value;
      } 
      // Handle subActions for menu type
      else if (key.includes(".subActions[")) {
        const subMatch = key.match(/actions\[(\d+)\]\.subActions\[(\d+)\]\.(.+)/);
        if (subMatch) {
          const i = parseInt(subMatch[1]), s = parseInt(subMatch[2]);
          if (!data.actions[i]) data.actions[i] = { id: "", name: "", type: "normal", svg: "", bgColor: "", textColor: "", operations: [], subActions: [] };
          if (!data.actions[i].subActions[s]) data.actions[i].subActions[s] = { id: "", name: "", operations: [] };
          const field = subMatch[3];
          if (field.startsWith("operations[")) {
            // nested operation inside subAction
            const opSubMatch = field.match(/operations\[(\d+)\]\.(.+)/);
            if (opSubMatch) {
              const j = parseInt(opSubMatch[1]);
              if (!data.actions[i].subActions[s].operations[j]) data.actions[i].subActions[s].operations[j] = {};
              data.actions[i].subActions[s].operations[j][opSubMatch[2]] = value;
            }
          } else {
            data.actions[i].subActions[s][field] = value;
          }
        }
      } 
      else {
        const simpleMatch = key.match(/actions\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.actions[i]) data.actions[i] = { id: "", name: "", type: "normal", svg: "", bgColor: "", textColor: "", operations: [] };
          data.actions[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("install_steps[")) {
      const opMatch = key.match(/install_steps\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
        if (!data.environment.install_steps[i].operations[j]) data.environment.install_steps[i].operations[j] = {};
        data.environment.install_steps[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/install_steps\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
          data.environment.install_steps[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("pages[")) {
      const match = key.match(/pages\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.pages[i]) data.pages[i] = {};
        data.pages[i][match[2]] = value;
      }
    }
  }

  // Clean arrays
  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  data.environment.install_steps = data.environment.install_steps.filter(Boolean);
  data.environment.ports = data.environment.ports.filter(Boolean);
  data.environment.volumes = data.environment.volumes.filter(Boolean);
  data.pages = data.pages.filter(Boolean);
  data.terminal.conditions = data.terminal.conditions.filter(Boolean);
  if (!data.terminal.allowed_commands) data.terminal.allowed_commands = [];
  data.terminal.allowed_commands = data.terminal.allowed_commands.filter(Boolean);

  // Clean nested
  data.actions.forEach(a => { 
    if (a.operations) a.operations = a.operations.filter(Boolean); 
    if (a.subActions) a.subActions = a.subActions.filter(Boolean); 
  });
  data.environment.install_steps.forEach(s => { 
    if (s.operations) s.operations = s.operations.filter(Boolean); 
  });
  data.variables.forEach(v => { 
    if (v.options) v.options = v.options.filter(Boolean); 
  });

  return data;
}

function fillForm(data) { 
  document.querySelector('[name="meta.id"]').value = data.meta?.id || "";
  document.querySelector('[name="meta.name"]').value = data.meta?.name || "";
  document.querySelector('[name="meta.display_name"]').value = data.meta?.display_name || "";
  document.querySelector('[name="meta.type"]').value = data.meta?.type || "";
  document.querySelector('[name="meta.description"]').value = data.meta?.description || "";
  document.querySelector('[name="category"]').value = data.category || "";
  document.querySelector('[name="environment.instance_type"]').value = data.environment?.instance_type || "docker";
  document.querySelector('[name="environment.image"]').value = data.environment?.image || "";
  document.querySelector('[name="terminal.maximum"]').value = data.terminal?.maximum || "5";
  document.querySelector('[name="terminal.input_able"]').value = data.terminal?.input_able || "true";

  if (data.environment?.limits) {
    document.querySelector('[name="environment.limits.memory"]').value = data.environment.limits.memory || "4096";
    document.querySelector('[name="environment.limits.cpu"]').value = data.environment.limits.cpu || "200";
    document.querySelector('[name="environment.limits.disk"]').value = data.environment.limits.disk || "20";
  }

  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  (data.variables || []).forEach(v => addVariable(v));

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  (data.actions || []).forEach(a => addAction(a));

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  (data.environment?.install_steps || []).forEach(s => addInstallStep(s));

  document.getElementById("pagesContainer").innerHTML = "";
  pageIndex = 0;
  (data.pages || []).forEach(p => addPage(p));

  document.getElementById("terminalConditionsContainer").innerHTML = "";
  conditionIndex = 0;
  if (data.terminal?.conditions && data.terminal.conditions.length > 0) {
    data.terminal.conditions.forEach(c => addTerminalCondition(c));
  }

  document.getElementById("portsContainer").innerHTML = "";
  portIndex = 0;
  (data.environment?.ports || []).forEach(p => addPort(p));

  document.getElementById("volumesContainer").innerHTML = "";
  volumeIndex = 0;
  (data.environment?.volumes || []).forEach(v => addVolume(v));

  document.getElementById("allowedCommandsContainer").innerHTML = "";
  allowedCommandIndex = 0;
  if (data.terminal?.allowed_commands && Array.isArray(data.terminal.allowed_commands)) {
    data.terminal.allowed_commands.forEach(cmd => addAllowedCommand(cmd));
  }

  jsonEditor.value = JSON.stringify(data, null, 2);
  refreshTerminalActionOptions();
}

function loadDefaultForm() {
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  
  addAction({ id: "start", name: "Start Server", type: "normal", operations: [{ type: "instance", command: "start" }] });
  addAction({ id: "restart", name: "Restart Server", type: "normal", operations: [{ type: "instance", command: "restart" }] });
  addAction({ id: "stop", name: "Stop Server", type: "normal", operations: [{ type: "instance", command: "stop" }] });

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  [
    { 
      name: "Install Server", 
      operations: [
        { type: "download", url: "https://example.com/server.jar", filename: "server.jar", path: "/data" },
        { type: "command", run_code: "echo 'Installation complete'" }
      ]
    }
  ].forEach(addInstallStep);

  document.getElementById("pagesContainer").innerHTML = "";
  pageIndex = 0;

  document.querySelector('[name="environment.instance_type"]').value = "docker";
  document.querySelector('[name="environment.image"]').value = "eclipse-temurin:21-jre";
  document.querySelector('[name="terminal.maximum"]').value = "5";
  document.querySelector('[name="terminal.input_able"]').value = "true";

  document.getElementById("terminalConditionsContainer").innerHTML = "";
  conditionIndex = 0;
  addTerminalCondition({ action: "start", when: "running" });

  document.getElementById("portsContainer").innerHTML = "";
  portIndex = 0;
  addPort({ internal: 25565, external: 25565, protocol: "tcp" });

  document.getElementById("volumesContainer").innerHTML = "";
  volumeIndex = 0;
  addVolume({ host: "/data/server", container: "/data", mode: "rw" });

  document.getElementById("allowedCommandsContainer").innerHTML = "";
  allowedCommandIndex = 0;
  addAllowedCommand("ls");
  addAllowedCommand("node");
}

// ====================== SAVE ======================
document.getElementById("btnSaveTemplate").onclick = async () => {
  let payload;
  try {
    payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();
  } catch(e) {
    showNotification("Invalid JSON format!", "error");
    return;
  }

  const filename = document.getElementById("hiddenFilename").value;
  const url = filename ? `/admin/templates/${filename}` : "/admin/templates";
  const method = filename ? "PUT" : "POST";

  try {
    const res = await fetch(url, {
      method,
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(payload)
    });

    if (res.ok) {
      showNotification("Template saved successfully!", "success");
      setTimeout(() => window.location.href = "/admin/templates/overview", 1200);
    } else {
      const err = await res.text();
      showNotification("Error: " + err.substring(0, 100), "error");
    }
  } catch (err) {
    showNotification("Network error!", "error");
  }
};

// ====================== BUTTON HANDLERS ======================
document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable();
document.getElementById("btnAddAction").onclick = () => addAction();
document.getElementById("btnAddInstallStep").onclick = () => addInstallStep();
document.getElementById("btnAddPage").onclick = () => addPage();
document.getElementById("btnAddPort").onclick = () => addPort();
document.getElementById("btnAddVolume").onclick = () => addVolume();
document.getElementById("btnAddAllowedCommand").onclick = () => addAllowedCommand();

document.getElementById("btnAddCategory").onclick = async () => {
  const name = prompt("New category name:");
  if (!name?.trim()) return;
  
  try {
    const res = await fetch("/admin/templates/category", { 
      method: "POST", 
      headers: {"Content-Type": "application/json"}, 
      body: JSON.stringify({name: name.trim()}) 
    });
    
    if (res.ok) {
      const {categories} = await res.json();
      const select = document.querySelector('[name="category"]');
      select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join("");
      select.value = name.trim();
      showNotification("Category added!", "success");
    } else {
      showNotification("Failed to add category", "error");
    }
  } catch (err) {
    showNotification("Network error!", "error");
  }
};

document.getElementById("btnAddType").onclick = () => {
  const name = prompt("New type name:");
  if (!name?.trim()) return;
  const select = document.getElementById("typeSelect");
  const option = document.createElement("option");
  option.value = name.trim().toLowerCase();
  option.textContent = name.trim();
  select.appendChild(option);
  select.value = name.trim().toLowerCase();
  showNotification("Type added!", "success");
};

// Terminal condition handler
document.getElementById("btnAddTerminalCondition").onclick = () => addTerminalCondition();

// Show/hide terminal conditions based on Input Able
const terminalInputAble = document.getElementById("terminalInputAble");
const terminalConditionsSection = document.getElementById("terminalConditionsSection");

function toggleTerminalConditions() {
  if (terminalInputAble.value === "true") {
    terminalConditionsSection.classList.remove("tf-hidden");
  } else {
    terminalConditionsSection.classList.add("tf-hidden");
  }
}

terminalInputAble.addEventListener("change", toggleTerminalConditions);

// ====================== IMPORT HANDLERS ======================
document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file";
  input.accept = ".json,application/json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        document.getElementById("hiddenFilename").value = "";
        modeSelect.value = "json";
        modeSelect.onchange();
        jsonEditor.value = JSON.stringify(data, null, 2);
        showNotification("JSON imported successfully!", "success");
      } catch(e) {
        showNotification("Invalid JSON file!", "error");
      }
    };
    reader.readAsText(file);
  };
  input.click();
};

document.getElementById("btnImportPages").onclick = () => {
  showNotification("Use Edit mode to import pages from existing templates", "success");
};

// ====================== INIT ======================
loadDefaultForm();
modeSelect.value = "form";
modeSelect.onchange();
toggleTerminalConditions();
updateImageField();
</script>

