  const variables = Array.from(document.querySelectorAll('#variablesContainer .tf-card')).map(card => ({
    id: card.querySelector('[name="id"]').value,
    name: card.querySelector('[name="name"]').value,
    description: card.querySelector('[name="description"]').value,
    default_value: card.querySelector('[name="default_value"]').value,
    user_viewable: card.querySelector('[name="user_viewable"]').checked,
    user_editable: card.querySelector('[name="user_editable"]').checked,
    required: card.querySelector('[name="required"]').checked
  }));

  const install_steps = Array.from(document.querySelectorAll('#installStepsContainer .tf-card')).map(card => {
    const type = card.querySelector('[name="type"]').value;
    const data = { type };
    if (type === 'download') {
      data.url = card.querySelector('[name="url"]').value;
      data.output = card.querySelector('[name="output"]').value;
    } else if (type === 'extract' || type === 'write') {
      data.path = card.querySelector('[name="path"]').value;
      if (type === 'write') data.content = card.querySelector('[name="content"]').value;
    } else {
      data.command = card.querySelector('[name="command"]').value;
    }
    return data;
  });

  const pages = Array.from(document.querySelectorAll('#pagesContainer > div.tf-card')).map(card => {
    const type = card.querySelector('[name="page-type"]').value;
    const p = {
      id: card.querySelector('[name="page-id"]').value,
      name: card.querySelector('[name="page-name"]').value,
      type: type,
      ejsContent: card.querySelector('[name="page-ejs"]')?.value || "",
      jsContent: card.querySelector('[name="page-js"]')?.value || "",
      config: {}
    };

    if (type === 'console') {
      p.config = {
        buttons: Array.from(card.querySelectorAll('.console-btns-container > div')).map(row => ({
          label: row.querySelector('[name="btn-label"]').value,
          command: row.querySelector('[name="btn-cmd"]').value,
          type: row.querySelector('[name="btn-type"]').value,
          style: row.querySelector('[name="btn-style"]').value
        })),
        macros: Array.from(card.querySelectorAll('.quick-codes-container > div')).map(row => ({
          name: row.querySelector('[name="code-name"]').value,
          body: row.querySelector('[name="code-body"]').value
        })),
        conditions: {
          overload: card.querySelector('[name="overload-condition"]').value,
          log_trigger: card.querySelector('[name="log-trigger"]').value
        },
        features: {
           graphs: card.querySelector('[name="show-graphs"]').checked,
           info: card.querySelector('[name="show-info"]').checked
        }
      };
    }
    return p;
  });

  const features = {};
  ['console', 'files', 'users', 'network', 'archives', 'automations', 'db', 'ftp', 'settings', 'startup'].forEach(f => {
    features[f] = document.getElementById(`toggle-${f}`)?.checked || false;
  });

  const payload = {
    meta,
    category: meta.category,
    environment: { ...environment, docker_image: environment.image || environment.distribution },
    variables,
    install_steps,
    pages,
    features
  };

  try {
    const res = await fetch('/admin/templates', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const result = await res.json();
    if (result.success) {
      showNotification("Template published successfully!");
      setTimeout(() => window.location.href = '/admin/templates/overview', 1000);
    } else {
      showNotification(result.error || "Publication failed", "error");
    }
  } catch (err) {
    showNotification("Network error", "error");
  }
}
</script>

<%- include('../../components/footer') %>
