// ====================== COLLECT FORM DATA ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { 
    meta: {}, 
    environment: { install_steps: [] }, 
    variables: [], 
    actions: [], 
    pages: [], 
    category: "" 
  };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) {
      data.meta[key.split(".")[1]] = value;
    }
    else if (key === "category") {
      data.category = value;
    }
    else if (key === "environment.docker_image") {
      data.environment.docker_image = value;
    }
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        if (key.includes(".options[")) {
          const optMatch = key.match(/variables\[(\d+)\]\.options\[(\d+)\]\.(.+)/);
          if (optMatch) {
            const optI = parseInt(optMatch[2]);
            if (!data.variables[i].options) data.variables[i].options = [];
            if (!data.variables[i].options[optI]) data.variables[i].options[optI] = {};
            data.variables[i].options[optI][optMatch[3]] = value;
          }
        } else {
          data.variables[i][match[2]] = value;
        }
      }
    }
    else if (key.startsWith("actions[")) {
      const opMatch = key.match(/actions\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
        if (!data.actions[i].operations[j]) data.actions[i].operations[j] = {};
        data.actions[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/actions\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.actions[i]) data.actions[i] = { id: "", name: "", operations: [] };
          data.actions[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("install_steps[")) {
      const opMatch = key.match(/install_steps\[(\d+)\]\.operations\[(\d+)\]\.(.+)/);
      if (opMatch) {
        const i = parseInt(opMatch[1]), j = parseInt(opMatch[2]);
        if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
        if (!data.environment.install_steps[i].operations[j]) data.environment.install_steps[i].operations[j] = {};
        data.environment.install_steps[i].operations[j][opMatch[3]] = value;
      } else {
        const simpleMatch = key.match(/install_steps\[(\d+)\]\.(.+)/);
        if (simpleMatch) {
          const i = parseInt(simpleMatch[1]);
          if (!data.environment.install_steps[i]) data.environment.install_steps[i] = { name: "", operations: [] };
          data.environment.install_steps[i][simpleMatch[2]] = value;
        }
      }
    }
    else if (key.startsWith("pages[")) {
      const match = key.match(/pages\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.pages[i]) data.pages[i] = {};
        data.pages[i][match[2]] = value;
      }
    }
  }

  // Clean arrays
  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  data.environment.install_steps = data.environment.install_steps.filter(Boolean);
  data.pages = data.pages.filter(Boolean);

  // Clean nested arrays
  data.actions.forEach(a => { 
    if (a.operations) a.operations = a.operations.filter(Boolean); 
  });
  data.environment.install_steps.forEach(s => { 
    if (s.operations) s.operations = s.operations.filter(Boolean); 
  });
  data.variables.forEach(v => { 
    if (v.options) v.options = v.options.filter(Boolean); 
  });

  return data;
}

function fillForm(data) { 
  document.querySelector('[name="meta.name"]').value = data.meta?.name || "";
  document.querySelector('[name="meta.display_name"]').value = data.meta?.display_name || "";
  document.querySelector('[name="meta.description"]').value = data.meta?.description || "";
  document.querySelector('[name="category"]').value = data.category || "";
  document.querySelector('[name="environment.docker_image"]').value = data.environment?.docker_image || "";

  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  (data.variables || []).forEach(v => addVariable(v));

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  (data.actions || []).forEach(a => addAction(a));

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  (data.environment?.install_steps || []).forEach(s => addInstallStep(s));

  document.getElementById("pagesContainer").innerHTML = "";
  pageIndex = 0;
  (data.pages || []).forEach(p => addPage(p));

  jsonEditor.value = JSON.stringify(data, null, 2);
}

function loadDefaultForm() {
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  [
    { 
      id: "start", 
      name: "Start", 
      operations: [{ 
        type: "command", 
        run_code: "java -Xms4G -Xmx4G -jar server.jar --nogui" 
      }]
    },
    { 
      id: "stop", 
      name: "Stop", 
      operations: [{ 
        type: "command", 
        run_code: "stop" 
      }]
    }
  ].forEach(addAction);

  document.getElementById("installStepsContainer").innerHTML = "";
  installIndex = 0;
  [
    { 
      name: "Install Server", 
      operations: [
        { 
          type: "download", 
          url: "https://example.com/server.jar", 
          filename: "server.jar", 
          path: "/data" 
        },
        { 
          type: "command", 
          run_code: "echo 'Installation complete'" 
        }
      ]
    }
  ].forEach(addInstallStep);

  document.getElementById("pagesContainer").innerHTML = "";
  pageIndex = 0;
}

// ====================== SAVE ======================
document.getElementById("btnSaveTemplate").onclick = async () => {
  let payload;
  try {
    payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();
  } catch(e) {
    showNotification("Invalid JSON format!", "error");
    return;
  }

  const filename = document.getElementById("hiddenFilename").value;
  const url = filename ? `/admin/templates/${filename}` : "/admin/templates";
  const method = filename ? "PUT" : "POST";

  try {
    const res = await fetch(url, {
      method,
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(payload)
    });

    if (res.ok) {
      showNotification("Template saved successfully!", "success");
      setTimeout(() => window.location.href = "/admin/templates/overview", 1200);
    } else {
      const err = await res.text();
      showNotification("Error: " + err.substring(0, 100), "error");
    }
  } catch (err) {
    showNotification("Network error!", "error");
  }
};

// ====================== BUTTON HANDLERS ======================
document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable();
document.getElementById("btnAddAction").onclick = () => addAction();
document.getElementById("btnAddInstallStep").onclick = () => addInstallStep();
document.getElementById("btnAddPage").onclick = () => addPage();

document.getElementById("btnAddCategory").onclick = async () => {
  const name = prompt("New category name:");
  if (!name?.trim()) return;
  
  try {
    const res = await fetch("/admin/templates/category", { 
      method: "POST", 
      headers: {"Content-Type": "application/json"}, 
      body: JSON.stringify({name: name.trim()}) 
    });
    
    if (res.ok) {
      const {categories} = await res.json();
      const select = document.querySelector('[name="category"]');
      select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join("");
      select.value = name.trim();
      showNotification("Category added!", "success");
    } else {
      showNotification("Failed to add category", "error");
    }
  } catch (err) {
    showNotification("Network error!", "error");
  }
};

// ====================== IMPORT HANDLERS ======================
document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file";
  input.accept = ".json,application/json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        document.getElementById("hiddenFilename").value = "";
        modeSelect.value = "json";
        modeSelect.onchange();
        jsonEditor.value = JSON.stringify(data, null, 2);
        showNotification("JSON imported successfully!", "success");
      } catch(e) {
        showNotification("Invalid JSON file!", "error");
      }
    };
    reader.readAsText(file);
  };
  input.click();
};

document.getElementById("btnImportPages").onclick = () => {
  showNotification("Use Edit mode to import pages from existing templates", "success");
};

// ====================== INIT ======================
loadDefaultForm();
modeSelect.value = "form";
modeSelect.onchange();
</script>

