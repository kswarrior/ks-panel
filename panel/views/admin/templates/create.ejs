// ====================== SUB-OPERATION ======================
function renderSubDynamicFields(mainIdx, subIdx, type, data = {}, prefix) {
  const container = document.getElementById(`dynamic-sub-${prefix}-${mainIdx}-${subIdx}`);
  if (!container) return;
  const config = fieldConfigs[type] || fieldConfigs.command;
  
  let html = `<div class="tf-row mt-3">`;
  config.forEach(f => {
    const val = data[f.key] || "";
    if (f.type === "select") {
      html += `
        <div class="tf-field-long">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">${f.label}</label>
          <select name="${prefix}[${mainIdx}].operations[${subIdx}].${f.key}" class="tf-input">
            ${f.options.map(opt => `<option value="${opt}" ${val === opt ? "selected" : ""}>${opt.charAt(0).toUpperCase() + opt.slice(1)}</option>`).join("")}
          </select>
        </div>`;
    } else {
      const isTextarea = f.type === "textarea";
      html += `
        <div class="${isTextarea ? 'tf-field-long' : 'tf-field-short'}">
          <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">${f.label}</label>
          ${isTextarea ? 
            `<textarea name="${prefix}[${mainIdx}].operations[${subIdx}].${f.key}" rows="${f.rows}" class="tf-input font-mono mt-1" placeholder="${f.placeholder || ''}">${val}</textarea>` :
            `<input type="text" name="${prefix}[${mainIdx}].operations[${subIdx}].${f.key}" value="${val}" class="tf-input mt-1" placeholder="${f.placeholder}">`
          }
        </div>`;
    }
  });
  html += `</div>`;
  container.innerHTML = html;
}

function addSubOperation(opsContainer, prefix, mainIdx, subData = {}) {
  const subIdx = parseInt(opsContainer.dataset.subCount || 0);
  opsContainer.dataset.subCount = subIdx + 1;

  const div = document.createElement("div");
  div.className = "tf-sub-item";
  div.innerHTML = `
    <div class="flex justify-between items-center mb-2">
      <span class="text-xs font-medium text-neutral-400">Operation #${subIdx + 1}</span>
      <button type="button" onclick="removeAndReindex(this, 'operations')" class="tf-remove-btn">×</button>
    </div>
    <div class="tf-row">
      <div class="tf-field-short">
        <label class="text-xs font-medium text-neutral-400 uppercase tracking-wider">Type <span class="text-red-400">*</span></label>
        <select name="${prefix}[${mainIdx}].operations[${subIdx}].type" class="tf-input sub-type-select" data-main="${mainIdx}" data-sub="${subIdx}">
          ${itemTypes.map(t => `<option value="${t.value}" ${subData.type === t.value ? "selected" : ""}>${t.label}</option>`).join("")}
        </select>
      </div>
      <div class="tf-field-long dynamic-sub" id="dynamic-sub-${prefix}-${mainIdx}-${subIdx}"></div>
    </div>
  `;
  opsContainer.appendChild(div);

  const defaultType = subData.type || "command";
  const select = div.querySelector(".sub-type-select");
  select.value = defaultType;
  renderSubDynamicFields(mainIdx, subIdx, defaultType, subData, prefix);

  select.addEventListener("change", (e) => {
    renderSubDynamicFields(mainIdx, subIdx, e.target.value, {}, prefix);
  });
}

