<%- include('../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-6">
  <div class="max-w-2xl mx-auto">

    <!-- Card Container -->
    <div class="space-y-6 bg-neutral-800/30 border border-white/10 rounded-2xl p-6 md:p-8 shadow-xl shadow-black/10">

      <!-- Header -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-white"><%= req.translations.editUser %></h2>
          <p class="text-sm text-neutral-400 mt-0.5"><%= req.translations.editUserDetails %></p>
        </div>
      </div>

      <!-- Form -->
      <form action="/admin/users/edit/<%= editUser.userId %>" method="POST" class="space-y-6">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Username -->
          <div class="md:col-span-2">
            <label class="block text-sm text-neutral-400 mb-2 font-medium">
              <%= req.translations.username %>
            </label>
            <input
              type="text"
              name="username"
              value="<%= editUser.username %>"
              placeholder="<%= req.translations.usernamePlaceholder || 'username' %>"
              class="w-full rounded-xl bg-neutral-800/50 border border-white/10 px-4 py-2.5 text-sm text-white placeholder:text-neutral-500 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all"
              required
            />
          </div>

          <!-- Email -->
          <div class="md:col-span-2">
            <label class="block text-sm text-neutral-400 mb-2 font-medium">
              <%= req.translations.email %>
            </label>
            <input
              type="email"
              name="email"
              value="<%= editUser.email %>"
              placeholder="<%= req.translations.emailPlaceholder || 'user@example.com' %>"
              class="w-full rounded-xl bg-neutral-800/50 border border-white/10 px-4 py-2.5 text-sm text-white placeholder:text-neutral-500 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all"
              required
            />
          </div>

          <!-- Password (optional - leave blank to keep current) -->
          <div class="md:col-span-2">
            <label class="block text-sm text-neutral-400 mb-2 font-medium">
              <%= req.translations.passwordLabel %>
              <span class="text-xs text-neutral-500 ml-2">(leave blank to keep current)</span>
            </label>
            <input
              type="password"
              name="password"
              placeholder="••••••••"
              class="w-full rounded-xl bg-neutral-800/50 border border-white/10 px-4 py-2.5 text-sm text-white placeholder:text-neutral-500 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all"
            />
          </div>

          <!-- Admin Toggle -->
          <div>
            <label class="block text-sm text-neutral-400 mb-2 font-medium">
              <%= req.translations.admin %>
            </label>
            <select
              name="admin"
              class="w-full rounded-xl bg-neutral-800/50 border border-white/10 px-4 py-2.5 text-sm text-white focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all appearance-none"
            >
              <option value="true"  <%= editUser.admin  ? 'selected' : '' %>><%= req.translations.true %></option>
              <option value="false" <%= !editUser.admin ? 'selected' : '' %>><%= req.translations.false %></option>
            </select>
          </div>

          <!-- Verified Toggle -->
          <div>
            <label class="block text-sm text-neutral-400 mb-2 font-medium">
              <%= req.translations.verifiedStatus %>
            </label>
            <select
              name="verified"
              class="w-full rounded-xl bg-neutral-800/50 border border-white/10 px-4 py-2.5 text-sm text-white focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition-all appearance-none"
            >
              <option value="true"  <%= editUser.verified  ? 'selected' : '' %>><%= req.translations.true %></option>
              <option value="false" <%= !editUser.verified ? 'selected' : '' %>><%= req.translations.false %></option>
            </select>
          </div>

        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-white/5 mt-2">
          <button
            type="submit"
            class="flex-1 rounded-xl bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-400 text-white px-6 py-3 text-sm font-medium shadow-lg shadow-indigo-500/20 transition-all hover:shadow-xl hover:shadow-indigo-500/30 active:scale-[0.98]"
          >
            <%= req.translations.saveChanges %>
          </button>

          <a
            href="/admin/users"
            class="flex-1 sm:flex-none rounded-xl bg-neutral-700/60 hover:bg-neutral-700 border border-white/10 px-6 py-3 text-sm font-medium text-white text-center transition-all hover:border-white/20"
          >
            <%= req.translations.cancel || 'Cancel' %>
          </a>
        </div>

      </form>

    </div>
  </div>
</main>

<%- include('../components/footer') %>
