<%- include('../../components/template') %>

<style>
/* === PREMIUM GLASSMORPHIC CARDS === */
.stat-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 1.5rem;
  transition: all 0.3s ease;
}

.stat-card:hover {
  transform: translateY(-4px);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.2);
}

.glass-panel {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
}

/* === TABLE STYLES === */
.table-row-hover {
  transition: all 0.2s ease;
}
.table-row-hover:hover {
  background: rgba(255, 255, 255, 0.04);
}
</style>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <header class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-10">
      <div>
        <h1 class="text-4xl font-black text-white tracking-tight">User Management</h1>
        <p class="mt-2 text-neutral-400 font-medium">Oversee accounts, assigned roles, and security policies.</p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <!-- Search & Filter Toggles -->
        <div class="flex bg-white/5 border border-white/10 rounded-2xl p-1.5 mr-2">
          <button onclick="toggleSearchBar()" id="searchToggle"
                  class="p-2.5 rounded-xl transition-all hover:bg-white/5 <%= filters.search ? 'text-blue-400 bg-blue-400/10' : 'text-neutral-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
          <button onclick="toggleFilterBar()" id="filterToggle"
                  class="p-2.5 rounded-xl transition-all hover:bg-white/5 <%= (filters.role || filters.status) ? 'text-emerald-400 bg-emerald-400/10' : 'text-neutral-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
          </button>
        </div>

        <a href="/admin/roles"
           class="inline-flex items-center justify-center px-6 py-3 rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-sm hover:bg-white/10 transition-all">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Roles
        </a>
        <a href="/admin/users/create"
           class="inline-flex items-center justify-center px-6 py-3 rounded-2xl bg-blue-600 text-white font-bold text-sm shadow-xl shadow-blue-600/20 hover:bg-blue-500 hover:scale-[1.02] active:scale-[0.98] transition-all">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          New User
        </a>
      </div>
    </header>

    <!-- Search Bar (Collapsible) -->
    <div id="searchBar" class="<%= filters.search ? 'block' : 'hidden' %> animate-fade-in mb-6">
      <form action="/admin/users" method="GET" class="relative group">
        <input type="hidden" name="role" value="<%= filters.role %>">
        <input type="hidden" name="status" value="<%= filters.status %>">
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-500 group-focus-within:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" name="search" value="<%= filters.search %>" placeholder="Search by name, email, or unique ID..."
               class="w-full pl-14 pr-6 py-4 rounded-2xl bg-white/5 border border-white/10 text-white placeholder:text-neutral-500 focus:outline-none focus:border-white/20 focus:bg-white/[0.07] transition-all shadow-2xl">
        <% if (filters.search) { %>
          <a href="/admin/users?role=<%= filters.role %>&status=<%= filters.status %>" class="absolute right-5 top-1/2 -translate-y-1/2 p-1.5 rounded-lg bg-white/10 text-neutral-400 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </a>
        <% } %>
      </form>
    </div>

    <!-- Filter Bar (Collapsible) -->
    <div id="filterBar" class="<%= (filters.role || filters.status) ? 'block' : 'hidden' %> animate-fade-in mb-8">
      <div class="glass-panel p-6 shadow-2xl">
        <form action="/admin/users" method="GET" class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <input type="hidden" name="search" value="<%= filters.search %>">

          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Account Role</label>
            <select name="role" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500/50 transition-all appearance-none cursor-pointer">
              <option value="" class="bg-[#111]">All Roles</option>
              <option value="owner" <%= filters.role === 'owner' ? 'selected' : '' %> class="bg-[#111]">Owner</option>
              <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %> class="bg-[#111]">Administrator</option>
              <option value="user" <%= filters.role === 'user' ? 'selected' : '' %> class="bg-[#111]">Standard User</option>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>" <%= filters.role === role.id ? 'selected' : '' %> class="bg-[#111]"><%= role.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Status</label>
            <select name="status" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-blue-500/50 transition-all appearance-none cursor-pointer">
              <option value="" class="bg-[#111]">All Statuses</option>
              <option value="verified" <%= filters.status === 'verified' ? 'selected' : '' %> class="bg-[#111]">Verified</option>
              <option value="unverified" <%= filters.status === 'unverified' ? 'selected' : '' %> class="bg-[#111]">Unverified</option>
            </select>
          </div>

          <div class="flex items-end gap-3">
            <button type="submit" class="flex-1 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold transition-all shadow-lg shadow-blue-600/20">
              Apply Filters
            </button>
            <a href="/admin/users" class="px-5 py-3 rounded-xl bg-white/5 hover:bg-white/10 text-white text-sm font-bold border border-white/10 transition-all">
              Reset
            </a>
          </div>
        </form>
      </div>
    </div>

    <!-- Desktop Table -->
    <div class="hidden lg:block glass-panel overflow-hidden shadow-2xl">
      <table class="w-full text-left border-collapse">
        <thead class="bg-white/5 border-b border-white/10">
          <tr>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em]"><%= req.translations.name %></th>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em]"><%= req.translations.email %></th>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em]"><%= req.translations.information %></th>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em]">Role & Permissions</th>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em]"><%= req.translations.verificationStatus %></th>
            <th class="py-5 px-6 text-[10px] font-bold text-neutral-500 uppercase tracking-[0.2em] text-right"><%= req.translations.actions %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <% users.forEach(function(user) { %>
          <tr class="table-row-hover">
            <td class="py-5 px-6">
              <div class="flex items-center gap-4">
                <div class="relative">
                  <img class="w-10 h-10 rounded-xl object-cover border border-white/10"
                       src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Avatar">
                  <div class="absolute -bottom-1 -right-1 w-3 h-3 <%= user.verified ? 'bg-green-500' : 'bg-red-500' %> border-2 border-[#0a0a0a] rounded-full"></div>
                </div>
                <span class="text-sm font-bold text-white"><%= user.username %></span>
              </div>
            </td>
            <td class="py-5 px-6">
              <span class="text-sm text-neutral-400 font-medium"><%= user.email %></span>
            </td>
            <td class="py-5 px-6">
              <span class="text-xs text-neutral-500 font-mono bg-white/5 px-2 py-1 rounded-lg border border-white/5"><%= user.userId %></span>
            </td>
            <td class="py-5 px-6">
              <div class="flex flex-wrap gap-2">
                <% if (user.owner) { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-amber-500/10 text-amber-500 border border-amber-500/20 uppercase tracking-wider">
                    Owner
                  </span>
                <% } else if (user.admin) { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-wider">
                    Administrator
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-neutral-500/10 text-neutral-400 border border-white/5 uppercase tracking-wider">
                    User
                  </span>
                <% } %>

                <% if (user.roleId) { %>
                  <% const role = roles.find(r => r.id === user.roleId); %>
                  <% if (role) { %>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold border uppercase tracking-wider" style="background-color: <%= role.color %>1A; color: <%= role.color %>; border-color: <%= role.color %>33;">
                      <div class="w-1.5 h-1.5 rounded-full shadow-[0_0_5px_currentColor]" style="background-color: <%= role.color %>;"></div>
                      <%= role.name %>
                    </span>
                  <% } %>
                <% } %>
              </div>
            </td>
            <td class="py-5 px-6">
              <% if (user.verified) { %>
                <span class="inline-flex items-center text-emerald-400 text-xs font-bold gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-400"></div>
                  Verified
                </span>
              <% } else { %>
                <span class="inline-flex items-center text-red-400 text-xs font-bold gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-red-400"></div>
                  Unverified
                </span>
              <% } %>
            </td>
            <td class="py-5 px-6 text-right">
              <div class="flex justify-end gap-2">
                <a href="/admin/users/edit/<%= user.userId %>"
                   class="p-2 rounded-lg bg-white/5 hover:bg-white/10 text-white transition-colors border border-white/5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                </a>
                <button type="button" class="removeButton p-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-400 transition-colors border border-red-500/10" data-user-id="<%= user.userId %>">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Mobile Cards -->
    <div class="lg:hidden grid grid-cols-1 md:grid-cols-2 gap-4">
      <% users.forEach(function(user) { %>
      <div class="stat-card">
        <div class="flex items-start justify-between mb-6">
          <div class="flex items-center gap-4">
            <div class="relative">
              <img class="w-12 h-12 rounded-xl object-cover border border-white/10"
                   src="https://mc-heads.net/avatar/<%= user.username %>/64" alt="Avatar">
              <div class="absolute -bottom-1 -right-1 w-3.5 h-3.5 <%= user.verified ? 'bg-green-500' : 'bg-red-500' %> border-2 border-[#0a0a0a] rounded-full"></div>
            </div>
            <div>
              <h3 class="text-white font-bold text-lg"><%= user.username %></h3>
              <p class="text-xs text-neutral-500 font-mono"><%= user.userId.substring(0, 8) %>...</p>
            </div>
          </div>
          <div class="flex gap-2">
            <a href="/admin/users/edit/<%= user.userId %>" class="p-2.5 rounded-xl bg-white/5 text-white border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            </a>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex flex-col gap-1">
            <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Email Address</span>
            <span class="text-sm text-neutral-300 truncate"><%= user.email %></span>
          </div>
          <div class="flex items-center justify-between pt-4 border-t border-white/5">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Role</span>
              <div class="flex flex-wrap gap-2">
                <% if (user.owner) { %>
                  <span class="text-xs font-bold text-amber-500 uppercase tracking-wider">Owner</span>
                <% } else if (user.admin) { %>
                  <span class="text-xs font-bold text-blue-400 uppercase tracking-wider">Administrator</span>
                <% } else { %>
                  <span class="text-xs font-bold text-neutral-400 uppercase tracking-wider">User</span>
                <% } %>

                <% if (user.roleId) { %>
                  <% const role = roles.find(r => r.id === user.roleId); %>
                  <% if (role) { %>
                    <span class="text-xs font-bold uppercase tracking-wider" style="color: <%= role.color %>;"><%= role.name %></span>
                  <% } %>
                <% } %>
              </div>
            </div>
            <button type="button" class="removeButton px-4 py-2 rounded-xl bg-red-500/10 text-red-400 text-xs font-bold border border-red-500/10" data-user-id="<%= user.userId %>">
              Remove User
            </button>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

  </div>
</main>

<script>
  function toggleSearchBar() {
    const bar = document.getElementById('searchBar');
    const toggle = document.getElementById('searchToggle');
    const isHidden = bar.classList.contains('hidden');

    // Close other bars
    document.getElementById('filterBar').classList.add('hidden');

    if(isHidden) {
      bar.classList.remove('hidden');
      bar.querySelector('input[name="search"]').focus();
      toggle.classList.add('text-blue-400', 'bg-blue-400/10');
    } else {
      bar.classList.add('hidden');
      if(!'<%= filters.search %>') toggle.classList.remove('text-blue-400', 'bg-blue-400/10');
    }
  }

  function toggleFilterBar() {
    const bar = document.getElementById('filterBar');
    const toggle = document.getElementById('filterToggle');
    const isHidden = bar.classList.contains('hidden');

    // Close other bars
    document.getElementById('searchBar').classList.add('hidden');

    if(isHidden) {
      bar.classList.remove('hidden');
      toggle.classList.add('text-emerald-400', 'bg-emerald-400/10');
    } else {
      bar.classList.add('hidden');
      if(!'<%= filters.role %>' && !'<%= filters.status %>') toggle.classList.remove('text-emerald-400', 'bg-emerald-400/10');
    }
  }

  document.querySelectorAll('.removeButton').forEach(button => {
    button.addEventListener('click', function() {
      const userId = this.dataset.userId;
      const currentUserId = '<%= user.userId %>';
      if (userId === currentUserId) return alert('You cannot delete your own account.');

      if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) return;

      fetch('/user/delete', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId })
      })
      .then(res => res.ok ? window.location.reload() : alert('Failed to delete user'))
      .catch(err => alert('Error: ' + err.message));
    });
  });
</script>

    <div class="mt-8">
      <%- include('../../components/pagination', { pagination: pagination }) %>
    </div>

  </div>
</main>

<%- include('../../components/footer') %>
