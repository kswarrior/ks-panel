<%- include('../../components/template') %>

<style>
/* === NODES-STYLE CARDS (backdrop blur, premium feel) === */
.stat-card {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 1.75rem;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  height: 100%;
  display: flex;
  flex-direction: column;
}

.stat-card:hover {
  transform: translateY(-6px);
  border-color: rgba(255,255,255,0.25);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
}

.stat-number {
  font-size: clamp(2rem, 5vw, 3.25rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.025em;
  margin-top: 0.5rem;
  word-break: break-word;
}

/* Header button style (exact match to Nodes) */
.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 10px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: #a1a1aa;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.refresh-btn:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.2);
  color: white;
}

/* Notification (exact copy from Nodes) */
#notification {
  transition: all 0.3s ease;
}

/* Icon sizing */
.stat-icon {
  width: clamp(2.5rem, 6vw, 3rem);
  height: clamp(2.5rem, 6vw, 3rem);
  font-size: clamp(1.5rem, 4vw, 2rem);
  flex-shrink: 0;
}

/* Card content spacing */
.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* Mobile optimizations */
@media (max-width: 640px) {
  .stat-card { 
    padding: 1.25rem;
    border-radius: 12px;
  }
  
  .header-actions {
    width: 100%;
    flex-wrap: wrap;
  }
  
  .refresh-btn {
    flex: 1;
    justify-content: center;
    min-width: 120px;
  }
  
  .live-badge {
    flex: 1;
    justify-content: center;
  }
  
  .version-badge {
    width: 100%;
    text-align: center;
  }
}

/* Tablet adjustments */
@media (min-width: 641px) and (max-width: 1024px) {
  .stat-number {
    font-size: 2.5rem;
  }
}

/* Large screen optimizations */
@media (min-width: 1536px) {
  .stat-card {
    padding: 2rem;
  }
  
  .stat-number {
    font-size: 3.5rem;
  }
}

/* Ensure text doesn't overflow */
.truncate-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.break-text {
  word-break: break-word;
  overflow-wrap: anywhere;
}
</style>

<main id="content" class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 py-4 sm:py-6 lg:py-8">
  
  <!-- Header (styled exactly like Nodes) -->
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-4 sm:py-6 gap-4 border-b border-white/10">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl sm:text-3xl font-semibold text-white tracking-tight truncate">Database Overview</h1>
      <p class="mt-1 text-xs sm:text-sm text-neutral-400 truncate">Users • Instances • Nodes • API Keys • Plugins + Full Database Info</p>
    </div>

    <div class="flex items-center gap-2 sm:gap-3 header-actions">
      <!-- LIVE badge -->
      <div class="live-badge flex items-center justify-center gap-2 bg-emerald-500/10 text-emerald-400 px-3 sm:px-5 py-2 rounded-[10px] text-xs sm:text-sm font-medium">
        <div class="w-2 h-2 sm:w-3 sm:h-3 bg-emerald-400 rounded-full animate-pulse flex-shrink-0"></div>
        <span class="hidden sm:inline">LIVE</span>
        <span class="sm:hidden">●</span>
      </div>

      <!-- Refresh button (styled like Radar Scan) -->
      <button onclick="refreshDatabase()" 
              class="refresh-btn">
        <span class="inline-block transition-transform">↻</span>
        <span class="hidden sm:inline">Refresh Now</span>
        <span class="sm:hidden">Refresh</span>
      </button>

      <span class="version-badge bg-white/5 px-3 sm:px-5 py-2 rounded-[10px] text-xs text-neutral-400 whitespace-nowrap">v<%= version %></span>
    </div>
  </header>

  <!-- DATABASE STATISTICS (8 cards – exact Nodes article style) -->
  <div class="mt-6 sm:mt-10">
    <div class="flex items-center justify-between mb-4 sm:mb-6">
      <h2 class="text-xl sm:text-2xl font-semibold text-white">Database Statistics</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-4 gap-4 sm:gap-6">
      
      <!-- Users -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Users</p>
            <p id="users-text" class="stat-number text-blue-400"><%= usersTotal %></p>
          </div>
          <div class="stat-icon bg-blue-500/10 rounded-2xl flex items-center justify-center">👥</div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">
          Admins: <span id="admins-text" class="text-emerald-400 font-medium"><%= adminsTotal %></span>
        </p>
      </article>

      <!-- Instances -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Instances</p>
            <p id="instances-text" class="stat-number text-purple-400"><%= instancesTotal %></p>
          </div>
          <div class="stat-icon bg-purple-500/10 rounded-2xl flex items-center justify-center">📦</div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">
          Suspended: <span id="suspended-text" class="text-red-400 font-medium"><%= suspendedTotal %></span>
        </p>
      </article>

      <!-- Nodes -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Nodes</p>
            <p id="nodes-text" class="stat-number text-orange-400"><%= nodesTotal %></p>
          </div>
          <div class="stat-icon bg-orange-500/10 rounded-2xl flex items-center justify-center">🖥️</div>
        </div>
        <div class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 flex flex-col sm:flex-row sm:justify-between gap-1">
          <span>Online: <span id="online-text" class="text-emerald-400 font-medium"><%= onlineNodes %></span></span>
          <span>Offline: <span id="offline-text" class="text-red-400 font-medium"><%= offlineNodes %></span></span>
        </div>
      </article>

      <!-- Templates -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Templates</p>
            <p id="templates-text" class="stat-number text-cyan-400"><%= templatesTotal %></p>
          </div>
          <div class="stat-icon bg-cyan-500/10 rounded-2xl flex items-center justify-center">📋</div>
        </div>
      </article>

      <!-- Locations -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Locations</p>
            <p id="locations-text" class="stat-number text-amber-400"><%= locationsTotal %></p>
          </div>
          <div class="stat-icon bg-amber-500/10 rounded-2xl flex items-center justify-center">🌍</div>
        </div>
      </article>

      <!-- API Keys -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">API Keys</p>
            <p id="apikeys-text" class="stat-number text-pink-400"><%= apiKeysTotal %></p>
          </div>
          <div class="stat-icon bg-pink-500/10 rounded-2xl flex items-center justify-center">🔑</div>
        </div>
      </article>

      <!-- Plugins -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Plugins</p>
            <p id="plugins-text" class="stat-number text-violet-400"><%= pluginsTotal %></p>
          </div>
          <div class="stat-icon bg-violet-500/10 rounded-2xl flex items-center justify-center">🧩</div>
        </div>
      </article>

      <!-- Requests -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Requests</p>
            <p id="requests-text" class="stat-number text-emerald-400"><%= totalRequests %></p>
          </div>
          <div class="stat-icon bg-emerald-500/10 rounded-2xl flex items-center justify-center">📡</div>
        </div>
        <div class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 space-y-1">
          <div class="flex justify-between">
            <span>Visitors:</span>
            <span id="visitors-text" class="text-white font-medium"><%= uniqueVisitors %></span>
          </div>
          <div class="flex justify-between">
            <span>Avg/hour:</span>
            <span id="avg-text" class="text-white font-medium"><%= avgRequestsPerHour %></span>
          </div>
        </div>
      </article>

    </div>
  </div>

  <!-- DATABASE INFORMATION (5 cards – same premium style) -->
  <div class="mt-8 sm:mt-12">
    <h2 class="text-xl sm:text-2xl font-semibold text-white mb-4 sm:mb-6">Database Information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 sm:gap-6">

      <!-- DB Type -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Database Type</p>
            <p id="dbtype-text" class="stat-number text-emerald-400 break-text"><%= dbType %></p>
          </div>
          <div class="stat-icon bg-emerald-500/10 rounded-2xl flex items-center justify-center">🗄️</div>
        </div>
      </article>

      <!-- Size -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Database Size</p>
            <p id="dbsize-text" class="stat-number text-cyan-400"><%= dbSize %></p>
          </div>
          <div class="stat-icon bg-cyan-500/10 rounded-2xl flex items-center justify-center">📦</div>
        </div>
      </article>

      <!-- URL -->
      <article class="stat-card sm:col-span-2 lg:col-span-1 xl:col-span-1">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Connection URL</p>
            <p id="dburl-text" class="mt-2 sm:mt-4 font-mono text-xs sm:text-sm text-amber-400 break-all leading-relaxed"><%= dbUrlMasked %></p>
          </div>
          <div class="stat-icon bg-amber-500/10 rounded-2xl flex items-center justify-center flex-shrink-0">🔗</div>
        </div>
      </article>

      <!-- Table -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Table Name</p>
            <p id="dbtable-text" class="stat-number text-violet-400 break-text"><%= dbTable %></p>
          </div>
          <div class="stat-icon bg-violet-500/10 rounded-2xl flex items-center justify-center">📋</div>
        </div>
      </article>

      <!-- Total Keys -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Keys</p>
            <p id="dbkeys-text" class="stat-number text-pink-400"><%= totalKeys %></p>
          </div>
          <div class="stat-icon bg-pink-500/10 rounded-2xl flex items-center justify-center">🔑</div>
        </div>
      </article>

    </div>
  </div>

</main>

<!-- Notification (exact Nodes style) -->
<div id="notification" 
     class="fixed bottom-4 sm:bottom-6 right-4 sm:right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl shadow-2xl text-xs sm:text-sm font-medium z-50 max-w-[calc(100vw-2rem)]">
  <span id="notification-text" class="break-text"></span>
</div>

<script>
  let els = {};

  function updateStats(data) {
    // All original stats
    els.users.textContent = data.usersTotal;
    els.admins.textContent = data.adminsTotal;
    els.instances.textContent = data.instancesTotal;
    els.suspended.textContent = data.suspendedTotal;
    els.templates.textContent = data.templatesTotal;
    els.nodes.textContent = data.nodesTotal;
    els.online.textContent = data.onlineNodes;
    els.offline.textContent = data.offlineNodes;
    els.locations.textContent = data.locationsTotal;
    els.apikeys.textContent = data.apiKeysTotal;
    els.plugins.textContent = data.pluginsTotal;
    els.requests.textContent = data.totalRequests;
    els.visitors.textContent = data.uniqueVisitors;
    els.avg.textContent = data.avgRequestsPerHour;

    // New DB info
    els.dbtype.textContent = data.dbType;
    els.dbsize.textContent = data.dbSize;
    els.dburl.textContent = data.dbUrlMasked;
    els.dbtable.textContent = data.dbTable;
    els.dbkeys.textContent = data.totalKeys;
  }

  async function fetchDatabaseStats() {
    try {
      const res = await fetch('/admin/api/database/stats');
      const data = await res.json();
      updateStats(data);
      return true;
    } catch (e) {
      console.error("Database stats failed", e);
      return false;
    }
  }

  async function refreshDatabase() {
    const btn = event.currentTarget;
    btn.style.opacity = 0.6;
    const success = await fetchDatabaseStats();
    btn.style.opacity = 1;

    if (success) {
      showNotification('Database statistics refreshed successfully!', 'success');
    } else {
      showNotification('Refresh failed – check console', 'error');
    }
  }

  function showNotification(message, type = 'success') {
    const notification = document.getElementById('notification');
    const textEl = document.getElementById('notification-text');
    textEl.textContent = message;

    notification.className = `fixed bottom-4 sm:bottom-6 right-4 sm:right-6 flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl shadow-2xl text-xs sm:text-sm font-medium z-50 max-w-[calc(100vw-2rem)] transition-all duration-300 ${
      type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
    }`;
    notification.classList.remove('hidden');
    notification.classList.add('flex');

    setTimeout(() => {
      notification.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => {
        notification.classList.add('hidden');
        notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
      }, 300);
    }, 2800);
  }

  window.onload = () => {
    els = {
      users: document.getElementById('users-text'),
      admins: document.getElementById('admins-text'),
      instances: document.getElementById('instances-text'),
      suspended: document.getElementById('suspended-text'),
      templates: document.getElementById('templates-text'),
      nodes: document.getElementById('nodes-text'),
      online: document.getElementById('online-text'),
      offline: document.getElementById('offline-text'),
      locations: document.getElementById('locations-text'),
      apikeys: document.getElementById('apikeys-text'),
      plugins: document.getElementById('plugins-text'),
      requests: document.getElementById('requests-text'),
      visitors: document.getElementById('visitors-text'),
      avg: document.getElementById('avg-text'),
      // New DB
      dbtype: document.getElementById('dbtype-text'),
      dbsize: document.getElementById('dbsize-text'),
      dburl: document.getElementById('dburl-text'),
      dbtable: document.getElementById('dbtable-text'),
      dbkeys: document.getElementById('dbkeys-text')
    };

    // Initial live fetch (will match server-rendered numbers)
    fetchDatabaseStats();
    setInterval(fetchDatabaseStats, 15000);
  };
</script>
