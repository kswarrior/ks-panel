<%- include('../../components/template') %>

<style>
.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
  scrollbar-width: thin;
}

.stat-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 2rem;
  transition: all 0.3s ease;
}

.stat-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.3);
}

.stat-number {
  font-size: 3.5rem;
  font-weight: 700;
  line-height: 1;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-3xl font-semibold text-white tracking-tight">Database Overview</h1>
        <p class="mt-1 text-sm text-neutral-400">Users • Instances • Nodes • API Keys • Plugins + Analytics</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-5 py-2 rounded-[10px] text-sm font-medium">
          <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
          LIVE
        </div>
        <span class="bg-white/5 px-5 py-2 rounded-[10px] text-xs text-neutral-400">v<%= version %></span>
      </div>
    </header>

    <!-- DATABASE STATISTICS -->
    <div class="mt-10">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Database Statistics</h2>
        <button onclick="refreshDatabase()" 
                class="flex items-center gap-2 text-emerald-400 hover:text-emerald-300 text-sm font-medium transition-all">
          <span class="inline-block transition-transform">↻</span>
          Refresh Now
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        
        <!-- Users -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">👥</div>
            <div>
              <p class="text-neutral-400 text-sm">Total Users</p>
              <p id="users-text" class="stat-number text-blue-400">0</p>
            </div>
          </div>
          <div class="flex justify-between text-xs">
            <span>Admins: <span id="admins-text" class="text-emerald-400 font-medium">0</span></span>
          </div>
        </div>

        <!-- Instances -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">📦</div>
            <div>
              <p class="text-neutral-400 text-sm">Instances</p>
              <p id="instances-text" class="stat-number text-purple-400">0</p>
            </div>
          </div>
          <div class="flex justify-between text-xs">
            <span>Suspended: <span id="suspended-text" class="text-red-400 font-medium">0</span></span>
          </div>
        </div>

        <!-- Nodes -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🖥️</div>
            <div>
              <p class="text-neutral-400 text-sm">Nodes</p>
              <p id="nodes-text" class="stat-number text-orange-400">0</p>
            </div>
          </div>
          <div class="flex justify-between text-xs">
            <span class="text-emerald-400">Online: <span id="online-text">0</span></span>
            <span class="text-red-400">Offline: <span id="offline-text">0</span></span>
          </div>
        </div>

        <!-- Templates -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">📋</div>
            <div>
              <p class="text-neutral-400 text-sm">Templates</p>
              <p id="templates-text" class="stat-number text-cyan-400">0</p>
            </div>
          </div>
        </div>

        <!-- Locations -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🌍</div>
            <div>
              <p class="text-neutral-400 text-sm">Locations</p>
              <p id="locations-text" class="stat-number text-amber-400">0</p>
            </div>
          </div>
        </div>

        <!-- API Keys -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🔑</div>
            <div>
              <p class="text-neutral-400 text-sm">API Keys</p>
              <p id="apikeys-text" class="stat-number text-pink-400">0</p>
            </div>
          </div>
        </div>

        <!-- Plugins -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🧩</div>
            <div>
              <p class="text-neutral-400 text-sm">Plugins</p>
              <p id="plugins-text" class="stat-number text-violet-400">0</p>
            </div>
          </div>
        </div>

        <!-- Requests -->
        <div class="stat-card">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">📡</div>
            <div>
              <p class="text-neutral-400 text-sm">Total Requests</p>
              <p id="requests-text" class="stat-number text-emerald-400">0</p>
            </div>
          </div>
          <div class="text-xs text-neutral-400">
            Unique Visitors: <span id="visitors-text" class="text-white">0</span><br>
            Avg/hour: <span id="avg-text" class="text-white">0</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>

<script>
  let els = {};

  function updateStats(data) {
    els.users.textContent = data.usersTotal;
    els.admins.textContent = data.adminsTotal;
    els.instances.textContent = data.instancesTotal;
    els.suspended.textContent = data.suspendedTotal;
    els.templates.textContent = data.templatesTotal;
    els.nodes.textContent = data.nodesTotal;
    els.online.textContent = data.onlineNodes;
    els.offline.textContent = data.offlineNodes;
    els.locations.textContent = data.locationsTotal;
    els.apikeys.textContent = data.apiKeysTotal;
    els.plugins.textContent = data.pluginsTotal;
    els.requests.textContent = data.totalRequests;
    els.visitors.textContent = data.uniqueVisitors;
    els.avg.textContent = data.avgRequestsPerHour;
  }

  async function fetchDatabaseStats() {
    try {
      const res = await fetch('/admin/api/database/stats');
      const data = await res.json();
      updateStats(data);
    } catch (e) {
      console.error("Database stats failed", e);
    }
  }

  function refreshDatabase() {
    const btn = event.currentTarget;
    btn.style.opacity = 0.6;
    fetchDatabaseStats().finally(() => btn.style.opacity = 1);
  }

  window.onload = () => {
    els = {
      users: document.getElementById('users-text'),
      admins: document.getElementById('admins-text'),
      instances: document.getElementById('instances-text'),
      suspended: document.getElementById('suspended-text'),
      templates: document.getElementById('templates-text'),
      nodes: document.getElementById('nodes-text'),
      online: document.getElementById('online-text'),
      offline: document.getElementById('offline-text'),
      locations: document.getElementById('locations-text'),
      apikeys: document.getElementById('apikeys-text'),
      plugins: document.getElementById('plugins-text'),
      requests: document.getElementById('requests-text'),
      visitors: document.getElementById('visitors-text'),
      avg: document.getElementById('avg-text')
    };

    fetchDatabaseStats();
    setInterval(fetchDatabaseStats, 15000);
  };
</script>
