<%- include('../../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-[1600px] mx-auto">

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-white/5 space-y-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-black text-white tracking-tight">Database Infrastructure</h1>
          <p class="text-neutral-400 mt-2 font-medium">Real-time health monitoring and capacity planning for PostgreSQL.</p>
        </div>
        <div class="flex gap-3">
          <div class="px-4 py-2 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-bold flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            Healthy Connection
          </div>
        </div>
      </div>
      <%- include('../../components/dashboard') %>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-8">
      <div class="glass p-8 rounded-[2.5rem] lg:col-span-1">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-2">Engine</p>
        <h3 class="text-3xl font-black text-white"><%= dbType %></h3>
        <p class="text-xs text-neutral-600 mt-4 font-mono break-all"><%= dbUrlMasked %></p>
      </div>
      <div class="glass p-8 rounded-[2.5rem] lg:col-span-1 border-blue-500/10 bg-blue-600/5">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-2">Total Size</p>
        <h3 class="text-3xl font-black text-white"><%= dbSize %></h3>
        <p class="text-xs text-blue-400 mt-4 font-bold uppercase tracking-widest">Optimized</p>
      </div>
      <div class="glass p-8 rounded-[2.5rem] lg:col-span-1">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-2">Key Count</p>
        <h3 class="text-3xl font-black text-white"><%= totalKeys %></h3>
        <p class="text-xs text-neutral-500 mt-4 font-bold uppercase tracking-widest">Records found</p>
      </div>
      <div class="glass p-8 rounded-[2.5rem] lg:col-span-1">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-2">Active Conns</p>
        <h3 class="text-3xl font-black text-white"><%= dbStats.activeConnections || 0 %></h3>
        <p class="text-xs text-neutral-500 mt-4 font-bold uppercase tracking-widest">Live queries</p>
      </div>
    </div>

    <div class="glass p-8 rounded-[3rem]">
      <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-8">Table Distribution</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-white/5">
              <th class="pb-4 text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Table Identifier</th>
              <th class="pb-4 text-[10px] font-bold text-neutral-500 uppercase tracking-widest text-right">Data Weight</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% (dbStats.tableSizes || []).forEach(t => { %>
              <tr class="group hover:bg-white/5 transition-colors">
                <td class="py-5 font-mono text-sm text-neutral-300 group-hover:text-white transition-colors"><%= t.table %></td>
                <td class="py-5 text-sm font-black text-white text-right"><%= t.total_size %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<%- include('../../components/footer') %>
