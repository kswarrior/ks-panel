<%- include('../../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-[1600px] mx-auto">

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-white/5 space-y-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-3 mb-2 flex-wrap">
            <h1 class="text-3xl font-bold text-white tracking-tight truncate">System Console</h1>
            <div class="px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
              Live Stream
            </div>
          </div>
          <p class="text-neutral-400">Monitor real-time system logs and resource utilization across the panel.</p>
        </div>

        <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
          <button onclick="clearLogs()" class="flex-1 sm:flex-none px-4 py-2.5 rounded-xl bg-white/5 text-white font-bold text-xs sm:text-sm border border-white/10 hover:bg-white/10 transition-all">
            Clear
          </button>
          <button id="log-btn" onclick="toggleStream()" class="flex-1 sm:flex-none px-4 py-2.5 rounded-xl bg-white text-black font-bold text-xs sm:text-sm shadow-xl shadow-white/5 hover:scale-[1.02] active:scale-[0.98] transition-all whitespace-nowrap">
            Stop Stream
          </button>
        </div>
      </div>

      <%- include('../../components/dashboard') %>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 sm:gap-8">

      <!-- Terminal View -->
      <div class="lg:col-span-3 order-2 lg:order-1">
        <div class="bg-[#0a0a0a]/80 backdrop-blur-2xl rounded-2xl sm:rounded-3xl overflow-hidden border border-white/10 shadow-2xl flex flex-col h-[400px] sm:h-[600px] lg:h-[700px]">
          <div class="px-4 sm:px-6 py-3 sm:py-4 bg-white/5 border-b border-white/5 flex items-center justify-between">
            <div class="flex gap-1 sm:gap-1.5">
              <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-500/50"></div>
              <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-amber-500/50"></div>
              <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-emerald-500/50"></div>
            </div>
            <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-[0.1em] sm:tracking-[0.2em] truncate ml-2">daemon.log</span>
          </div>
          <div id="logs" class="flex-1 p-3 sm:p-6 overflow-y-auto font-mono text-[10px] sm:text-xs md:text-sm leading-relaxed scrollbar-thin">
            <div class="text-neutral-500 italic">Initializing connection...</div>
          </div>
        </div>
        <input id="input" type="text" placeholder="Type a command..." autocomplete="off"
               class="mt-4 w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all font-mono text-sm">
      </div>

      <!-- Resource Sidebar -->
      <div class="space-y-4 sm:space-y-6 order-1 lg:order-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4 sm:gap-6">
          <!-- CPU -->
          <div class="bg-white/5 backdrop-blur-xl p-4 sm:p-6 rounded-2xl sm:rounded-3xl border border-white/10 shadow-xl">
            <div class="flex items-center justify-between mb-3 sm:mb-4">
              <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">CPU Load</span>
              <span class="text-base sm:text-lg font-bold text-orange-400" id="cpu-text">0%</span>
            </div>
            <div class="h-1.5 sm:h-2 w-full bg-white/5 rounded-full overflow-hidden mb-2">
              <div id="cpu-bar" class="h-full bg-orange-400 transition-all duration-500 shadow-[0_0_10px_rgba(251,146,60,0.5)]" style="width: 0%"></div>
            </div>
            <p class="text-[9px] sm:text-[10px] text-neutral-500 text-right" id="cpu-cores">0 Cores Active</p>
          </div>

          <!-- RAM -->
          <div class="bg-white/5 backdrop-blur-xl p-4 sm:p-6 rounded-2xl sm:rounded-3xl border border-white/10 shadow-xl">
            <div class="flex items-center justify-between mb-3 sm:mb-4">
              <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Memory</span>
              <span class="text-base sm:text-lg font-bold text-blue-400" id="ram-text">0%</span>
            </div>
            <div class="h-1.5 sm:h-2 w-full bg-white/5 rounded-full overflow-hidden mb-2">
              <div id="ram-bar" class="h-full bg-blue-400 transition-all duration-500 shadow-[0_0_10px_rgba(96,165,250,0.5)]" style="width: 0%"></div>
            </div>
            <div class="flex justify-between text-[9px] sm:text-[10px] font-medium">
              <span class="text-neutral-500" id="ram-used">0 GB</span>
              <span class="text-neutral-500" id="ram-total">0 GB</span>
            </div>
          </div>

          <!-- Disk -->
          <div class="bg-white/5 backdrop-blur-xl p-4 sm:p-6 rounded-2xl sm:rounded-3xl border border-white/10 shadow-xl">
            <div class="flex items-center justify-between mb-3 sm:mb-4">
              <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Disk Usage</span>
              <span class="text-base sm:text-lg font-bold text-emerald-400" id="disk-text">0%</span>
            </div>
            <div class="h-1.5 sm:h-2 w-full bg-white/5 rounded-full overflow-hidden mb-2">
              <div id="disk-bar" class="h-full bg-emerald-400 transition-all duration-500 shadow-[0_0_10px_rgba(52,211,153,0.5)]" style="width: 0%"></div>
            </div>
            <p class="text-[9px] sm:text-[10px] text-neutral-500 text-right truncate" id="disk-used">0 GB / 0 GB</p>
          </div>

          <!-- Network -->
          <div class="bg-white/5 backdrop-blur-xl p-4 sm:p-6 rounded-2xl sm:rounded-3xl border border-white/10 shadow-xl sm:col-span-2 lg:col-span-1">
            <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest block mb-3 sm:mb-4">Network I/O</span>
            <div class="flex items-center gap-3 sm:gap-4 mb-2 sm:mb-4">
              <div class="p-2 sm:p-3 rounded-xl bg-purple-500/10 text-purple-400 border border-purple-500/20 flex-shrink-0">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg>
              </div>
              <div class="min-w-0">
                <p class="text-lg sm:text-xl font-bold text-white truncate" id="net-text">0 MB/s</p>
                <p class="text-[9px] sm:text-[10px] text-neutral-500 uppercase tracking-widest font-bold truncate" id="net-peak">Peak: 0 MB/s</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<script>
let eventSource = null;
let isStreaming = true;

function appendLog(text) {
  const container = document.getElementById('logs');
  if(container.children.length === 1 && container.innerText.includes('Initializing')) container.innerHTML = '';
  
  const div = document.createElement('div');
  div.className = 'mb-1 flex gap-3 sm:gap-4 hover:bg-white/5 transition-colors px-1 sm:px-2 py-0.5 sm:py-1 rounded group';
  const time = new Date().toLocaleTimeString('en-US', { hour12: false });
  div.innerHTML = `<span class="text-neutral-600 flex-shrink-0 font-bold group-hover:text-neutral-400 transition-colors whitespace-nowrap">${time}</span><span class="text-neutral-300 break-all">${text}</span>`;
  container.appendChild(div);
  
  if (container.scrollHeight - container.scrollTop < 800) container.scrollTop = container.scrollHeight;
  while (container.children.length > 500) container.removeChild(container.firstChild);
}

function startStream() {
  if (eventSource) eventSource.close();
  eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
  eventSource.onmessage = e => appendLog(e.data);
  eventSource.onerror = () => {
    appendLog('<span class="text-red-500 font-bold">[!] Reconnecting...</span>');
    setTimeout(startStream, 3000);
  };
}

function toggleStream() {
  const btn = document.getElementById('log-btn');
  if (isStreaming) {
    eventSource?.close();
    btn.textContent = 'Resume';
    btn.className = "flex-1 sm:flex-none px-4 py-2.5 rounded-xl bg-emerald-600 text-white font-bold text-xs sm:text-sm shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all";
  } else {
    startStream();
    btn.textContent = 'Stop';
    btn.className = "flex-1 sm:flex-none px-4 py-2.5 rounded-xl bg-white text-black font-bold text-xs sm:text-sm shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all";
  }
  isStreaming = !isStreaming;
}

function clearLogs() {
  document.getElementById('logs').innerHTML = '<div class="text-neutral-500 italic text-center py-10 text-xs sm:text-sm">Console buffer cleared.</div>';
}

let netPeak = 0;
async function fetchResources() {
  try {
    const res = await fetch('/resourceMonitor');
    const data = await res.json();

    const cpu = Math.round(data.cpu?.percent || 0);
    const ram = Math.round(data.ram?.percent || 0);
    const disk = Math.round(data.disk?.percent || 0);
    const net = ((data.network?.rx || 0) + (data.network?.tx || 0)) / (1024 * 1024);

    if(net > netPeak) netPeak = net;

    document.getElementById('cpu-text').textContent = cpu + '%';
    document.getElementById('cpu-bar').style.width = cpu + '%';
    document.getElementById('cpu-cores').textContent = (data.cpu?.cores || 0) + ' Cores Active';

    document.getElementById('ram-text').textContent = ram + '%';
    document.getElementById('ram-bar').style.width = ram + '%';
    document.getElementById('ram-used').textContent = (data.ram?.used || 0).toFixed(1) + ' GB';
    document.getElementById('ram-total').textContent = (data.ram?.total || 0).toFixed(1) + ' GB';

    document.getElementById('disk-text').textContent = disk + '%';
    document.getElementById('disk-bar').style.width = disk + '%';
    document.getElementById('disk-used').textContent = (data.disk?.used || 0).toFixed(1) + ' / ' + (data.disk?.total || 0).toFixed(1) + ' GB';

    document.getElementById('net-text').textContent = net.toFixed(2) + ' MB/s';
    document.getElementById('net-peak').textContent = 'Peak: ' + netPeak.toFixed(2) + ' MB/s';
  } catch (e) { console.error(e); }
}

window.onload = () => {
  startStream();
  fetchResources();
  setInterval(fetchResources, 3000);
};
</script>

<%- include('../../components/footer') %>
