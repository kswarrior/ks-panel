<%- include('../../components/template') %>

<style>
.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
  scrollbar-width: thin;
}

/* OPTIMISTIC SMOOTH BAR GRAPH */
.bar-graph {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 58px;
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
  padding: 6px;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
}

.bar-graph .bar {
  width: 5px;
  background: linear-gradient(to bottom, transparent, currentColor);
  border-radius: 9999px;
  transition: height 650ms cubic-bezier(0.34, 1.56, 0.64, 1); /* bouncy optimistic feel */
  box-shadow: 0 0 8px currentColor;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-3xl font-semibold text-white tracking-tight">
          System Monitor
        </h1>
        <p class="mt-1 text-sm text-neutral-400">
          Real-time CPU • RAM • Disk + Live PM2 logs
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-5 py-2 rounded-[10px] text-sm font-medium">
          <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
          LIVE
        </div>
        <span class="bg-white/5 px-5 py-2 rounded-[10px] text-xs text-neutral-400">v<%= version %></span>
      </div>
    </header>

    <!-- LIVE PM2 LOGS - TOP -->
    <div class="mt-10 bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Live PM2 Logs (kspanel)</h2>
        <div class="flex gap-3">
          <button onclick="clearLogs()" 
                  class="px-6 py-2.5 bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 rounded-[10px] text-sm font-medium">
            🗑️ Clear
          </button>
          <button onclick="toggleStream()" id="log-btn"
                  class="px-6 py-2.5 bg-red-500 hover:bg-red-600 rounded-[10px] text-sm font-medium">
            ⏹️ Stop Stream
          </button>
        </div>
      </div>
      
      <div id="logs" class="log-terminal flex-1">
        Connecting to PM2 logs...
      </div>
    </div>

    <!-- RESOURCES MONITOR - BELOW (OPTIMISTIC SMOOTH 25-BAR GRAPH) -->
    <div class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Resources Monitor</h2>
        <button onclick="refreshResources()" 
                class="flex items-center gap-2 text-emerald-400 hover:text-emerald-300 text-sm font-medium">
          ↻ Refresh Now
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- CPU -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">⚡</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">CPU Usage</p>
              <p id="cpu-text" class="text-6xl font-bold text-orange-400">0%</p>
            </div>
          </div>
          <div id="cpu-graph" class="bar-graph"></div>
          <p id="cpu-status" class="text-xs text-neutral-500 mt-4">Normal</p>
        </div>

        <!-- RAM -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🧠</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">RAM Usage</p>
              <p id="ram-text" class="text-6xl font-bold text-blue-400">0%</p>
            </div>
          </div>
          <div id="ram-graph" class="bar-graph"></div>
          <div class="flex justify-between text-xs text-neutral-400 mt-6">
            <span id="ram-used">0 GB</span>
            <span id="ram-total">0 GB</span>
          </div>
        </div>

        <!-- Disk -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">💾</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">Disk Usage</p>
              <p id="disk-text" class="text-6xl font-bold text-emerald-400">0%</p>
            </div>
          </div>
          <div id="disk-graph" class="bar-graph"></div>
          <div class="flex justify-between text-xs text-neutral-400 mt-6">
            <span id="disk-used">0 GB</span>
            <span id="disk-total">0 GB</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>

<script>
  // ================ OPTIMISTIC SMOOTH BAR GRAPH (25 bars) ================
  const NUM_BARS = 25;

  function updateBarGraph(graphId, percent, gradientClass) {
    const graph = document.getElementById(graphId);
    const targetHeight = Math.max(4, Math.min(100, Math.round(percent))) + '%';

    // Create bars only once
    if (graph.children.length === 0) {
      graph.innerHTML = '';
      for (let i = 0; i < NUM_BARS; i++) {
        const bar = document.createElement('div');
        bar.className = `bar ${gradientClass}`;
        // Staggered optimistic delay
        bar.style.transitionDelay = `${i * 14}ms`;
        graph.appendChild(bar);
      }
    }

    // Apply smooth bouncy transition to every bar
    const bars = Array.from(graph.children);
    bars.forEach((bar, i) => {
      bar.style.height = targetHeight;
    });
  }

  // ================ RESOURCES MONITOR (with /api/v1/resourceMonitor) ================
  async function fetchResources() {
    try {
      const res = await fetch('/api/v1/resourceMonitor');
      const data = await res.json();

      // CPU
      const cpuPercent = Math.round(data.cpu.percent);
      document.getElementById('cpu-text').textContent = cpuPercent + '%';
      document.getElementById('cpu-status').textContent = cpuPercent > 85 ? 'HIGH LOAD ⚠️' : 'Normal';
      updateBarGraph('cpu-graph', cpuPercent, 'from-orange-400 to-red-500 text-orange-400');

      // RAM
      const ramPercent = Math.round(data.ram.percent);
      document.getElementById('ram-text').textContent = ramPercent + '%';
      document.getElementById('ram-used').textContent = data.ram.used.toFixed(1) + ' GB';
      document.getElementById('ram-total').textContent = data.ram.total.toFixed(1) + ' GB';
      updateBarGraph('ram-graph', ramPercent, 'from-blue-400 to-cyan-500 text-blue-400');

      // Disk
      const diskPercent = Math.round(data.disk.percent);
      document.getElementById('disk-text').textContent = diskPercent + '%';
      document.getElementById('disk-used').textContent = data.disk.used.toFixed(1) + ' GB';
      document.getElementById('disk-total').textContent = data.disk.total.toFixed(1) + ' GB';
      updateBarGraph('disk-graph', diskPercent, 'from-emerald-400 to-teal-500 text-emerald-400');

    } catch (e) {
      console.error("Resource monitor failed", e);
    }
  }

  function refreshResources() {
    fetchResources();
  }

  // ================ LIVE LOGS STREAM (unchanged) ================
  let eventSource = null;
  let isStreaming = true;

  function startStream() {
    if (eventSource) eventSource.close();
    eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
    const logsDiv = document.getElementById('logs');

    eventSource.onmessage = (e) => {
      const line = document.createElement('div');
      line.textContent = e.data;
      logsDiv.appendChild(line);
      logsDiv.scrollTop = logsDiv.scrollHeight;
    };

    eventSource.onerror = () => {
      logsDiv.innerHTML += '<span class="text-red-400">[Stream disconnected]</span><br>';
    };
  }

  function toggleStream() {
    const btn = document.getElementById('log-btn');
    if (isStreaming) {
      eventSource.close();
      btn.textContent = '▶️ Resume';
      btn.classList.remove('bg-red-500', 'hover:bg-red-600');
      btn.classList.add('bg-emerald-500', 'hover:bg-emerald-600');
    } else {
      startStream();
      btn.textContent = '⏹️ Stop Stream';
      btn.classList.remove('bg-emerald-500', 'hover:bg-emerald-600');
      btn.classList.add('bg-red-500', 'hover:bg-red-600');
    }
    isStreaming = !isStreaming;
  }

  function clearLogs() {
    document.getElementById('logs').innerHTML = 'Logs cleared.<br>';
  }

  // ================ INIT ================
  window.onload = () => {
    fetchResources();
    setInterval(fetchResources, 3200);   // slightly faster for smoother feel
    startStream();
  };

  window.onbeforeunload = () => {
    if (eventSource) eventSource.close();
  };
</script>
