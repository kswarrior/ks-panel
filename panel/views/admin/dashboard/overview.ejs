<script>
// === DATA HISTORY FOR LINE GRAPHS ===
const history = {
  cpu: Array(20).fill(0),
  ram: Array(20).fill(0),
  disk: Array(20).fill(0),
  net: Array(20).fill(0)
};

// === UPDATE LINE GRAPH (now guaranteed complete with 100% SVG sizing) ===
function updateLineGraph(type, value) {
  history[type].push(value);
  history[type].shift();
  
  const width = 200;
  const height = 60;
  const step = width / (history[type].length - 1);
  
  let pathD = `M 0 ${height - (history[type][0] / 100 * height)}`;
  let areaD = `M 0 ${height} L 0 ${height - (history[type][0] / 100 * height)}`;
  
  history[type].forEach((val, i) => {
    if (i === 0) return;
    const x = i * step;
    const y = height - (val / 100 * height);
    pathD += ` L ${x} ${y}`;
    areaD += ` L ${x} ${y}`;
  });
  
  areaD += ` L ${width} ${height} Z`;
  
  const line = document.getElementById(`${type}-line`);
  const area = document.getElementById(`${type}-area`);
  if (line) {
    line.setAttribute('d', pathD);
    line.style.animation = 'none';
    line.offsetHeight;
    line.style.animation = 'drawLine 0.5s ease-out forwards';
  }
  if (area) area.setAttribute('d', areaD);
}

// === SHOW NOTIFICATION ===
function showNotification(text) {
  const notif = document.getElementById('notification');
  const notifText = document.getElementById('notification-text');
  notifText.textContent = text;
  notif.classList.remove('hidden');
  setTimeout(() => notif.classList.add('hidden'), 3000);
}

// === UPDATE STATS ===
let els = {};
function updateStats(data) {
  if (els.users) els.users.textContent = data.usersTotal;
  if (els.admins) els.admins.textContent = data.adminsTotal;
  if (els.instances) els.instances.textContent = data.instancesTotal;
  if (els.suspended) els.suspended.textContent = data.suspendedTotal;
  if (els.templates) els.templates.textContent = data.templatesTotal;
  if (els.nodes) els.nodes.textContent = data.nodesTotal;
  if (els.online) els.online.textContent = data.onlineNodes;
  if (els.offline) els.offline.textContent = data.offlineNodes;
  if (els.locations) els.locations.textContent = data.locationsTotal;
  if (els.apikeys) els.apikeys.textContent = data.apiKeysTotal;
  if (els.plugins) els.plugins.textContent = data.pluginsTotal;
  if (els.requests) els.requests.textContent = data.totalRequests;
  if (els.visitors) els.visitors.textContent = data.uniqueVisitors;
  if (els.avg) els.avg.textContent = data.avgRequestsPerHour;
  
  // Update pie charts
  const totalInstances = data.instancesTotal || 1;
  const suspended = data.suspendedTotal || 0;
  const running = totalInstances - suspended;
  const instancePie = document.getElementById('instance-pie');
  if (instancePie) {
    const runningPct = (running / totalInstances) * 100;
    const suspendedPct = (suspended / totalInstances) * 100;
    instancePie.style.background = `conic-gradient(var(--color-cpu) 0% ${runningPct}%, var(--color-ram) ${runningPct}% ${runningPct + suspendedPct}%, var(--color-disk) ${runningPct + suspendedPct}% 100%)`;
  }
  document.getElementById('running-count').textContent = running;
  document.getElementById('suspended-count').textContent = suspended;
  
  const totalUsers = data.usersTotal || 1;
  const admins = data.adminsTotal || 0;
  const regular = totalUsers - admins;
  const userPie = document.getElementById('user-pie');
  if (userPie) {
    const regularPct = (regular / totalUsers) * 100;
    userPie.style.background = `conic-gradient(var(--color-cpu) 0% ${regularPct}%, var(--color-disk) ${regularPct}% 100%)`;
  }
  document.getElementById('regular-users').textContent = regular;
  document.getElementById('admin-users').textContent = admins;
  
  // Update heatmap + numerical value
  updateHeatmap(data.totalRequests || 0);
}

// === HEATMAP + NUMERICAL (now shows real number) ===
function updateHeatmap(totalRequests) {
  const container = document.getElementById('request-heatmap');
  if (!container) return;
  
  let html = '';
  for (let i = 0; i < 28; i++) {
    const intensity = Math.random();
    let className = 'heatmap-cell';
    if (intensity > 0.7) className += ' active';
    else if (intensity > 0.4) className += ' medium';
    else className += ' low';
    html += `<div class="${className}" title="Activity level">${Math.floor(intensity * 9) + 1}</div>`;
  }
  container.innerHTML = html;
  
  // Show numerical value
  const totalEl = document.getElementById('heatmap-total-requests');
  if (totalEl) totalEl.textContent = totalRequests.toLocaleString();
}

// === FETCH DASHBOARD STATS ===
async function fetchDashboardStats() {
  try {
    const res = await fetch('/admin/dashboard/api/stats');
    const data = await res.json();
    updateStats(data);
    return true;
  } catch (e) {
    console.error("Stats fetch failed", e);
    return false;
  }
}

// === FETCH RESOURCES ===
async function fetchResources() {
  try {
    const res = await fetch('/resourceMonitor');
    const data = await res.json();
    
    const cpu = Math.round(data.cpu?.percent || 0);
    const ram = Math.round(data.ram?.percent || 0);
    const disk = Math.round(data.disk?.percent || 0);
    const net = Math.round((data.network?.speed || 0) / 10);
    
    document.getElementById('cpu-text').textContent = cpu + '%';
    document.getElementById('ram-text').textContent = ram + '%';
    document.getElementById('disk-text').textContent = disk + '%';
    document.getElementById('net-text').textContent = net + ' MB/s';
    
    document.getElementById('cpu-cores').textContent = `${data.cpu?.cores || 0} cores`;
    document.getElementById('ram-used').textContent = (data.ram?.used || 0).toFixed(1) + ' GB';
    document.getElementById('ram-total').textContent = (data.ram?.total || 0).toFixed(1) + ' GB';
    document.getElementById('disk-used').textContent = (data.disk?.used || 0).toFixed(1) + ' GB';
    document.getElementById('disk-total').textContent = (data.disk?.total || 0).toFixed(1) + ' GB';
    document.getElementById('net-peak').textContent = 'Peak: ' + (data.network?.peak || 0) + ' MB/s';
    
    updateLineGraph('cpu', cpu);
    updateLineGraph('ram', ram);
    updateLineGraph('disk', disk);
    updateLineGraph('net', net);
    
  } catch (e) {
    console.error("Resources fetch failed", e);
  }
}

// === LIVE LOGS ===
let eventSource = null;
let isStreaming = true;
let logBuffer = [];

function createLogEntry(text) {
  const div = document.createElement('div');
  div.className = 'py-0.5 border-l-2 border-transparent hover:border-blue-400 pl-2 transition-colors';
  const time = new Date().toLocaleTimeString('en-US', {hour12:false});
  div.innerHTML = `<span class="text-neutral-500 text-xs">[${time}]</span> <span class="text-neutral-300">${text}</span>`;
  return div;
}

function flushLogs() {
  const container = document.getElementById('logs');
  if (logBuffer.length === 0) return;
  
  if (container.children.length === 1 && container.children[0].classList.contains('italic')) {
    container.innerHTML = '';
  }
  
  const fragment = document.createDocumentFragment();
  logBuffer.forEach(text => fragment.appendChild(createLogEntry(text)));
  container.appendChild(fragment);
  
  if (container.scrollHeight - container.scrollTop < 400) {
    container.scrollTop = container.scrollHeight;
  }
  
  while (container.children.length > 100) {
    container.removeChild(container.firstChild);
  }
  
  logBuffer = [];
}

function startStream() {
  if (eventSource) eventSource.close();
  
  const container = document.getElementById('logs');
  if (container.children.length === 0) {
    container.innerHTML = '<div class="text-neutral-400 italic">Connecting to live logs...</div>';
  }
  
  eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
  eventSource.onmessage = e => logBuffer.push(e.data);
  eventSource.onerror = () => {
    logBuffer.push('<span class="text-red-400">[Stream disconnected – retrying...]</span>');
    setTimeout(startStream, 5000);
  };
}

function toggleStream() {
  const btn = document.getElementById('log-btn');
  if (isStreaming) {
    eventSource?.close();
    btn.textContent = 'Resume';
    btn.classList.remove('bg-red-500/20', 'text-red-400', 'border-red-500/30');
    btn.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/30');
  } else {
    startStream();
    btn.textContent = 'Stop';
    btn.classList.remove('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/30');
    btn.classList.add('bg-red-500/20', 'text-red-400', 'border-red-500/30');
  }
  isStreaming = !isStreaming;
}

function clearLogs() {
  document.getElementById('logs').innerHTML = '<div class="text-neutral-400 italic p-2">Logs cleared • Waiting for new data...</div>';
  logBuffer = [];
}

// === REFRESH ALL ===
async function refreshAll() {
  const btns = document.querySelectorAll('button');
  btns.forEach(b => b.style.opacity = '0.6');
  await Promise.all([fetchDashboardStats(), fetchResources()]);
  btns.forEach(b => b.style.opacity = '1');
  showNotification('Dashboard refreshed');
}

// === INITIALIZATION ===
window.onload = async () => {
  els = {
    users: document.getElementById('users-text'),
    admins: document.getElementById('admins-text'),
    instances: document.getElementById('instances-text'),
    suspended: document.getElementById('suspended-text'),
    templates: document.getElementById('templates-text'),
    nodes: document.getElementById('nodes-text'),
    online: document.getElementById('online-text'),
    offline: document.getElementById('offline-text'),
    locations: document.getElementById('locations-text'),
    apikeys: document.getElementById('apikeys-text'),
    plugins: document.getElementById('plugins-text'),
    requests: document.getElementById('requests-text'),
    visitors: document.getElementById('visitors-text'),
    avg: document.getElementById('avg-text')
  };
  
  await fetchDashboardStats();
  await fetchResources();
  startStream();
  
  setInterval(flushLogs, 100);
  setInterval(fetchDashboardStats, 10000);
  setInterval(fetchResources, 3000);
};
</script>
