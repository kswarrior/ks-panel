<%- include('../../components/template') %>

<style>
.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
  scrollbar-width: thin;
}

/* OPTIMISTIC SMOOTH BAR GRAPH - NO SHADOW + SUPER BOUNCY */
.bar-graph {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 62px;
  background: rgba(255,255,255,0.05);
  border-radius: 14px;
  padding: 7px;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.bar-graph .bar {
  width: 5px;
  background: linear-gradient(to bottom, transparent, currentColor);
  border-radius: 9999px;
  transition: height 520ms cubic-bezier(0.25, 1.8, 0.45, 1.35);
  opacity: 0.95;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-3xl font-semibold text-white tracking-tight">
          Dashboard
        </h1>
        <p class="mt-1 text-sm text-neutral-400">
          Real-time CPU • RAM • Disk + Live logs
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-5 py-2 rounded-[10px] text-sm font-medium">
          <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
          LIVE
        </div>
        <span id="static-version" class="bg-white/5 px-5 py-2 rounded-[10px] text-xs text-neutral-400">v<%= version %></span>
      </div>
    </header>

    <!-- VERSION CONTROL + DYNAMIC ACTION BUTTON -->
    <div class="mt-6 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div>
          <p class="text-xs text-neutral-400">Current Version</p>
          <p id="current-version" class="text-xl font-bold text-white">v<%= version %></p>
        </div>
        <div id="version-badge" class="px-4 py-1.5 rounded-full text-sm font-medium"></div>
      </div>
      
      <div class="flex gap-3">
        <button onclick="checkForUpdate()" 
                id="check-btn"
                class="px-6 py-2.5 bg-white/10 hover:bg-white/20 border border-white/10 rounded-[10px] text-sm font-medium transition-all">
          🔄 Check for Update
        </button>
        
        <button onclick="performAction()" 
                id="action-btn"
                class="px-6 py-2.5 bg-amber-500 hover:bg-amber-600 rounded-[10px] text-sm font-medium transition-all">
          🚀 Reinstall
        </button>
      </div>
    </div>

    <!-- LIVE PM2 LOGS - TOP -->
    <div class="mt-10 bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">KS Panel Log</h2>
        <div class="flex gap-3">
          <button onclick="clearLogs()" 
                  class="px-6 py-2.5 bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 rounded-[10px] text-sm font-medium">
            🗑️ Clear
          </button>
          <button onclick="toggleStream()" id="log-btn"
                  class="px-6 py-2.5 bg-red-500 hover:bg-red-600 rounded-[10px] text-sm font-medium">
            ⏹️ Stop Stream
          </button>
        </div>
      </div>
      
      <div id="logs" class="log-terminal flex-1">
        Connecting to PM2 logs...
      </div>
    </div>

    <!-- RESOURCES MONITOR -->
    <div class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Resources Monitor</h2>
        <button onclick="refreshResources()" 
                class="flex items-center gap-2 text-emerald-400 hover:text-emerald-300 text-sm font-medium transition-all duration-200 disabled:opacity-70 disabled:cursor-wait group"
                id="refreshBtn">
          <span class="inline-block transition-transform group-disabled:rotate-180 duration-700 ease-in-out">↻</span>
          Refresh Now
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- CPU -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">⚡</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">CPU Usage</p>
              <p id="cpu-text" class="text-6xl font-bold text-orange-400">0%</p>
            </div>
          </div>
          <div id="cpu-graph" class="bar-graph"></div>
          <p id="cpu-status" class="text-xs text-neutral-500 mt-4">Normal</p>
        </div>

        <!-- RAM -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">🧠</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">RAM Usage</p>
              <p id="ram-text" class="text-6xl font-bold text-blue-400">0%</p>
            </div>
          </div>
          <div id="ram-graph" class="bar-graph"></div>
          <div class="flex justify-between text-xs text-neutral-400 mt-6">
            <span id="ram-used">0 GB</span>
            <span id="ram-total">0 GB</span>
          </div>
        </div>

        <!-- Disk -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="text-5xl">💾</div>
            <div>
              <p class="text-neutral-400 text-sm font-medium">Disk Usage</p>
              <p id="disk-text" class="text-6xl font-bold text-emerald-400">0%</p>
            </div>
          </div>
          <div id="disk-graph" class="bar-graph"></div>
          <div class="flex justify-between text-xs text-neutral-400 mt-6">
            <span id="disk-used">0 GB</span>
            <span id="disk-total">0 GB</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>

<script>
  // ================ DYNAMIC BAR GRAPH (auto-scales to container width) ================
  function updateBarGraph(graphId, percent, colorClass) {
    const graph = document.getElementById(graphId);
    const targetHeight = Math.max(8, Math.min(100, Math.round(percent || 0))) + '%';

    // Create bars ONLY once (or after resize) – number depends on available space
    if (graph.children.length === 0) {
      graph.innerHTML = '';
      
      const paddingTotal = 14;                    // 7px left + right
      const availableWidth = graph.clientWidth - paddingTotal || 280; // fallback safe value
      const barWidthWithGap = 5 + 2;
      let numBars = Math.floor(availableWidth / barWidthWithGap);
      numBars = Math.max(8, Math.min(50, numBars)); // sensible range for any screen size

      const fragment = document.createDocumentFragment();
      for (let i = 0; i < numBars; i++) {
        const bar = document.createElement('div');
        bar.className = `bar ${colorClass}`;
        bar.style.transitionDelay = `${i * 8}ms`;
        fragment.appendChild(bar);
      }
      graph.appendChild(fragment);
    }

    // Update all bar heights in one pass
    for (let i = 0; i < graph.children.length; i++) {
      graph.children[i].style.height = targetHeight;
    }
  }

  // ================ RESOURCES MONITOR (optimised – fewer DOM reads) ================
  let cpuEl, ramTextEl, ramUsedEl, ramTotalEl, diskTextEl, diskUsedEl, diskTotalEl, cpuStatusEl;

  async function fetchResources() {
    try {
      const res = await fetch('/resourceMonitor');
      const data = await res.json();

      const cpuPercent = Math.round(data.cpu.percent || 0);
      cpuEl.textContent = cpuPercent + '%';
      cpuStatusEl.textContent = cpuPercent > 85 ? 'HIGH LOAD ⚠️' : 'Normal';
      updateBarGraph('cpu-graph', cpuPercent, 'text-orange-400');

      const ramPercent = Math.round(data.ram.percent || 0);
      ramTextEl.textContent = ramPercent + '%';
      ramUsedEl.textContent = (data.ram.used || 0).toFixed(1) + ' GB';
      ramTotalEl.textContent = (data.ram.total || 0).toFixed(1) + ' GB';
      updateBarGraph('ram-graph', ramPercent, 'text-blue-400');

      const diskPercent = Math.round(data.disk.percent || 0);
      diskTextEl.textContent = diskPercent + '%';
      diskUsedEl.textContent = (data.disk.used || 0).toFixed(1) + ' GB';
      diskTotalEl.textContent = (data.disk.total || 0).toFixed(1) + ' GB';
      updateBarGraph('disk-graph', diskPercent, 'text-emerald-400');

    } catch (e) {
      console.error("Resource monitor failed", e);
    }
  }

  function refreshResources() {
    const btn = document.getElementById('refreshBtn');
    btn.disabled = true;
    fetchResources().finally(() => btn.disabled = false);
  }

  // ================ VERSION CHECK + DYNAMIC ACTION BUTTON (optimised) ================
  let isOutdated = false;

  async function checkForUpdate() {
    const checkBtn = document.getElementById('check-btn');
    const originalText = checkBtn.textContent;
    checkBtn.textContent = 'Checking...';
    checkBtn.disabled = true;

    try {
      const res = await fetch('/version');
      const data = await res.json();

      document.getElementById('current-version').textContent = `v${data.currentVersion}`;

      const badge = document.getElementById('version-badge');
      const actionBtn = document.getElementById('action-btn');

      if (data.status === 'outdated') {
        isOutdated = true;
        badge.innerHTML = `Update available <span class="text-amber-400">v${data.latestVersion}</span>`;
        badge.className = 'px-4 py-1.5 rounded-full bg-amber-500/10 text-amber-400 text-sm font-medium';
        actionBtn.textContent = '🚀 Update Now';
        actionBtn.className = 'px-6 py-2.5 bg-emerald-500 hover:bg-emerald-600 rounded-[10px] text-sm font-medium transition-all';
      } else {
        isOutdated = false;
        badge.innerHTML = `✓ Up to date`;
        badge.className = 'px-4 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 text-sm font-medium';
        actionBtn.textContent = '🚀 Reinstall';
        actionBtn.className = 'px-6 py-2.5 bg-amber-500 hover:bg-amber-600 rounded-[10px] text-sm font-medium transition-all';
      }
    } catch (e) {
      console.error("Version check failed", e);
      const badge = document.getElementById('version-badge');
      badge.innerHTML = '❌ Check failed';
      badge.className = 'px-4 py-1.5 rounded-full bg-red-500/10 text-red-400 text-sm font-medium';
    }

    checkBtn.textContent = originalText;
    checkBtn.disabled = false;
  }

  async function performAction() {
    const action = isOutdated ? 'Update' : 'Reinstall';
    if (!confirm(`Start ${action}? This will run the update script and restart services.`)) return;

    const btn = document.getElementById('action-btn');
    const originalText = btn.textContent;
    btn.textContent = `🚀 ${action}ing...`;
    btn.disabled = true;

    try {
      await fetch('/reinstall');
      alert(`✅ ${action} started! Page will auto-reload in 8 seconds...`);
      setTimeout(() => location.reload(true), 8000);
    } catch (e) {
      alert(`${action} trigger failed. Check console.`);
      console.error(e);
    }

    btn.textContent = originalText;
    btn.disabled = false;
  }

  // ================ LIVE LOGS STREAM (unchanged – already efficient) ================
  let eventSource = null;
  let isStreaming = true;

  function startStream() {
    if (eventSource) eventSource.close();
    eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
    const logsDiv = document.getElementById('logs');

    eventSource.onmessage = (e) => {
      const line = document.createElement('div');
      line.textContent = e.data;
      logsDiv.appendChild(line);
      logsDiv.scrollTop = logsDiv.scrollHeight;
    };

    eventSource.onerror = () => {
      logsDiv.innerHTML += '<span class="text-red-400">[Stream disconnected]</span><br>';
    };
  }

  function toggleStream() {
    const btn = document.getElementById('log-btn');
    if (isStreaming) {
      eventSource.close();
      btn.textContent = '▶️ Resume';
      btn.classList.remove('bg-red-500', 'hover:bg-red-600');
      btn.classList.add('bg-emerald-500', 'hover:bg-emerald-600');
    } else {
      startStream();
      btn.textContent = '⏹️ Stop Stream';
      btn.classList.remove('bg-emerald-500', 'hover:bg-emerald-600');
      btn.classList.add('bg-red-500', 'hover:bg-red-600');
    }
    isStreaming = !isStreaming;
  }

  function clearLogs() {
    document.getElementById('logs').innerHTML = 'Logs cleared.<br>';
  }

  // ================ RESPONSIVE BAR GRAPHS (auto-recreate on resize) ================
  function makeGraphsResponsive() {
    const graphs = document.querySelectorAll('.bar-graph');
    graphs.forEach(g => { g.innerHTML = ''; });
    fetchResources(); // recreates bars with new widths
  }

  let resizeTimer;
  function handleResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(makeGraphsResponsive, 150);
  }

  // ================ INIT (optimised – cache elements once) ================
  window.onload = () => {
    // Cache DOM elements
    cpuEl = document.getElementById('cpu-text');
    ramTextEl = document.getElementById('ram-text');
    ramUsedEl = document.getElementById('ram-used');
    ramTotalEl = document.getElementById('ram-total');
    diskTextEl = document.getElementById('disk-text');
    diskUsedEl = document.getElementById('disk-used');
    diskTotalEl = document.getElementById('disk-total');
    cpuStatusEl = document.getElementById('cpu-status');

    fetchResources();
    checkForUpdate();

    setInterval(fetchResources, 2800);
    startStream();

    // Auto-scale bars on window resize
    window.addEventListener('resize', handleResize);
  };

  window.onbeforeunload = () => {
    if (eventSource) eventSource.close();
  };
</script>
