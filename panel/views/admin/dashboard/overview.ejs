<%- include('../../components/template') %>

<style>
.log-terminal {
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 1.25rem;
  font-family: monospace;
  font-size: 0.85rem;
  line-height: 1.5;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
  scrollbar-width: thin;
}

/* Resource icons */
.resource-icon {
  width: 40px;
  height: 40px;
}

/* Dropdown */
#resource-dropdown {
  transition: all 0.3s ease;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-3xl font-semibold text-white tracking-tight">
          System Monitor
        </h1>
        <p class="mt-1 text-sm text-neutral-400">
          Real-time CPU • RAM • Disk + Live PM2 logs
        </p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-5 py-2 rounded-[10px] text-sm font-medium">
          <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
          LIVE
        </div>
        <span class="bg-white/5 px-5 py-2 rounded-[10px] text-xs text-neutral-400">v<%= version %></span>
      </div>
    </header>

    <!-- LIVE PM2 LOGS - TOP (as you requested) -->
    <div class="mt-10 bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-8 flex flex-col">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Live PM2 Logs (kspanel)</h2>
        <div class="flex gap-3">
          <button onclick="clearLogs()" 
                  class="px-6 py-2.5 bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 rounded-[10px] text-sm font-medium">
            🗑️ Clear
          </button>
          <button onclick="toggleStream()" id="log-btn"
                  class="px-6 py-2.5 bg-red-500 hover:bg-red-600 rounded-[10px] text-sm font-medium">
            ⏹️ Stop Stream
          </button>
        </div>
      </div>
      
      <div id="logs" class="log-terminal flex-1">
        Connecting to PM2 logs...
      </div>
    </div>

    <!-- RESOURCES MONITOR - BELOW LOGS (fixed version of your old code) -->
    <div class="mt-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-white">Resources Monitor</h2>
        <button onclick="manualRefresh()" 
                class="flex items-center gap-2 text-emerald-400 hover:text-emerald-300 text-sm font-medium">
          ↻ Refresh Now
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- CPU Icon -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 text-center">
          <div class="flex justify-center mb-3">
            <svg class="resource-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="7" y="2" width="6" height="16" rx="1" fill="#1e2937"/>
              <rect id="cpu-fill" x="7" y="18" width="6" height="0" rx="1" fill="#22c55e"/>
            </svg>
          </div>
          <p class="text-neutral-400 text-sm font-medium">CPU</p>
          <p id="cpu-main-percent" class="text-4xl font-bold text-orange-400">0%</p>
        </div>

        <!-- RAM Icon -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 text-center">
          <div class="flex justify-center mb-3">
            <svg class="resource-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="7" y="2" width="6" height="16" rx="1" fill="#1e2937"/>
              <rect id="ram-fill" x="7" y="18" width="6" height="0" rx="1" fill="#22c55e"/>
            </svg>
          </div>
          <p class="text-neutral-400 text-sm font-medium">RAM</p>
          <p id="ram-main-percent" class="text-4xl font-bold text-blue-400">0%</p>
        </div>

        <!-- Disk Icon -->
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 text-center">
          <div class="flex justify-center mb-3">
            <svg class="resource-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="7" y="2" width="6" height="16" rx="1" fill="#1e2937"/>
              <rect id="disk-fill" x="7" y="18" width="6" height="0" rx="1" fill="#22c55e"/>
            </svg>
          </div>
          <p class="text-neutral-400 text-sm font-medium">Disk</p>
          <p id="disk-main-percent" class="text-4xl font-bold text-emerald-400">0%</p>
        </div>

      </div>

      <!-- Details Button -->
      <div class="mt-6 flex justify-center">
        <button id="resource-link"
                class="px-8 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl text-sm font-medium flex items-center gap-2">
          📊 View Detailed Stats
          <span class="text-xs">↓</span>
        </button>
      </div>

      <!-- Dropdown (your old detailed view) -->
      <div id="resource-dropdown" class="hidden mt-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
        <div class="space-y-8">

          <!-- RAM -->
          <div>
            <div class="flex justify-between text-xs text-neutral-400 mb-2">
              <span>RAM</span>
              <span id="ram-used">0 / 0 GB (0%)</span>
            </div>
            <div class="h-2 bg-white/10 rounded-full overflow-hidden">
              <div id="ram-bar" class="h-full bg-green-500 w-0 transition-all duration-300"></div>
            </div>
          </div>

          <!-- CPU -->
          <div>
            <div class="flex justify-between text-xs text-neutral-400 mb-2">
              <span>CPU</span>
              <span id="cpu-percent">0%</span>
            </div>
            <div class="h-2 bg-white/10 rounded-full overflow-hidden">
              <div id="cpu-bar" class="h-full bg-green-500 w-0 transition-all duration-300"></div>
            </div>
          </div>

          <!-- Disk -->
          <div>
            <div class="flex justify-between text-xs text-neutral-400 mb-2">
              <span>Disk</span>
              <span id="disk-used">0 / 0 GB (0%)</span>
            </div>
            <div class="h-2 bg-white/10 rounded-full overflow-hidden">
              <div id="disk-bar" class="h-full bg-green-500 w-0 transition-all duration-300"></div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</main>

<script>
  // ================ YOUR OLD RESOURCES MONITOR (FIXED + IMPROVED) ================
  let latestData = null;

  function getColor(percent) {
    if (percent > 95) return '#ef4444';
    if (percent > 75) return '#eab308';
    return '#22c55e';
  }

  function getColorClass(percent) {
    if (percent > 95) return 'bg-red-500';
    if (percent > 75) return 'bg-yellow-500';
    return 'bg-green-500';
  }

  async function updateResourceData() {
    try {
      const response = await fetch('/resourceMonitor');
      const data = await response.json();
      latestData = data;

      const maxHeight = 16;

      // CPU
      let cpuHeight = (data.cpu.percent / 100) * maxHeight;
      let cpuY = 2 + (maxHeight - cpuHeight);
      const cpuFill = document.getElementById('cpu-fill');
      cpuFill.setAttribute('y', cpuY);
      cpuFill.setAttribute('height', cpuHeight);
      cpuFill.setAttribute('fill', getColor(data.cpu.percent));
      document.getElementById('cpu-main-percent').textContent = Math.round(data.cpu.percent) + '%';

      // RAM
      let ramHeight = (data.ram.percent / 100) * maxHeight;
      let ramY = 2 + (maxHeight - ramHeight);
      const ramFill = document.getElementById('ram-fill');
      ramFill.setAttribute('y', ramY);
      ramFill.setAttribute('height', ramHeight);
      ramFill.setAttribute('fill', getColor(data.ram.percent));
      document.getElementById('ram-main-percent').textContent = Math.round(data.ram.percent) + '%';

      // Disk
      let diskHeight = (data.disk.percent / 100) * maxHeight;
      let diskY = 2 + (maxHeight - diskHeight);
      const diskFill = document.getElementById('disk-fill');
      diskFill.setAttribute('y', diskY);
      diskFill.setAttribute('height', diskHeight);
      diskFill.setAttribute('fill', getColor(data.disk.percent));
      document.getElementById('disk-main-percent').textContent = Math.round(data.disk.percent) + '%';

    } catch (error) {
      console.error('Resource monitor failed:', error);
    }
  }

  // ================ DROPDOWN LOGIC (fixed - only one listener) ================
  function setupDropdown() {
    const link = document.getElementById('resource-link');
    const dropdown = document.getElementById('resource-dropdown');

    link.addEventListener('click', () => {
      if (!latestData) {
        alert("Waiting for first data update...");
        return;
      }

      // Update dropdown with latest data
      document.getElementById('ram-used').textContent = 
        `${latestData.ram.used.toFixed(1)} / ${latestData.ram.total.toFixed(1)} GB (${latestData.ram.percent.toFixed(0)}%)`;
      document.getElementById('ram-bar').style.width = `${latestData.ram.percent}%`;
      document.getElementById('ram-bar').className = `h-full transition-all duration-300 ${getColorClass(latestData.ram.percent)}`;

      document.getElementById('cpu-percent').textContent = `${latestData.cpu.percent.toFixed(0)}%`;
      document.getElementById('cpu-bar').style.width = `${latestData.cpu.percent}%`;
      document.getElementById('cpu-bar').className = `h-full transition-all duration-300 ${getColorClass(latestData.cpu.percent)}`;

      document.getElementById('disk-used').textContent = 
        `${latestData.disk.used.toFixed(1)} / ${latestData.disk.total.toFixed(1)} GB (${latestData.disk.percent.toFixed(0)}%)`;
      document.getElementById('disk-bar').style.width = `${latestData.disk.percent}%`;
      document.getElementById('disk-bar').className = `h-full transition-all duration-300 ${getColorClass(latestData.disk.percent)}`;

      dropdown.classList.toggle('hidden');
    });
  }

  function manualRefresh() {
    updateResourceData();
  }

  // ================ LIVE PM2 LOGS STREAM (unchanged - works perfectly) ================
  let eventSource = null;
  let isStreaming = true;

  function startStream() {
    if (eventSource) eventSource.close();
    eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
    const logsDiv = document.getElementById('logs');

    eventSource.onmessage = (e) => {
      const line = document.createElement('div');
      line.textContent = e.data;
      logsDiv.appendChild(line);
      logsDiv.scrollTop = logsDiv.scrollHeight;
    };

    eventSource.onerror = () => {
      logsDiv.innerHTML += '<span class="text-red-400">[Stream disconnected]</span><br>';
    };
  }

  function toggleStream() {
    const btn = document.getElementById('log-btn');
    if (isStreaming) {
      eventSource.close();
      btn.textContent = '▶️ Resume';
      btn.classList.remove('bg-red-500', 'hover:bg-red-600');
      btn.classList.add('bg-emerald-500', 'hover:bg-emerald-600');
    } else {
      startStream();
      btn.textContent = '⏹️ Stop Stream';
      btn.classList.remove('bg-emerald-500', 'hover:bg-emerald-600');
      btn.classList.add('bg-red-500', 'hover:bg-red-600');
    }
    isStreaming = !isStreaming;
  }

  function clearLogs() {
    document.getElementById('logs').innerHTML = 'Logs cleared.<br>';
  }

  // ================ INIT (everything starts here) ================
  document.addEventListener('DOMContentLoaded', async () => {
    // Resources (your old code + fixes)
    await updateResourceData();
    setInterval(updateResourceData, 2500);
    setupDropdown();                    // ← fixed: only once

    // Live Logs
    startStream();
  });

  window.onbeforeunload = () => {
    if (eventSource) eventSource.close();
  };
</script>
