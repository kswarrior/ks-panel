<%- include('../../components/template') %>

<style>
/* ============================================
   MODERN DASHBOARD - OPTIMISED STYLES
   Preserving original colors & glassmorphism
   ============================================ */

/* CSS Variables for consistent theming */
:root {
  --glass-bg: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-blur: blur(20px);
  --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-bounce: all 0.5s cubic-bezier(0.25, 1.8, 0.45, 1.35);
  --radius-sm: 10px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-2xl: 24px;
  --shadow-glow: 0 0 20px rgba(255, 255, 255, 0.05);
  --shadow-elevated: 0 20px 40px rgba(0, 0, 0, 0.3);
}

/* Base container refinements */
#content {
  max-width: 1440px;
  margin: 0 auto;
  padding: clamp(0.75rem, 2vw, 2rem);
  padding-bottom: clamp(1.5rem, 4vh, 3rem);
}

/* ============================================
   LOG TERMINAL - ENHANCED
   ============================================ */
.log-terminal {
  background: #0f172a;
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: clamp(0.75rem, 2vw, 1.25rem);
  font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
  font-size: clamp(0.7rem, 1.5vw, 0.85rem);
  line-height: 1.7;
  color: #94a3b8;
  max-height: min(50vh, 420px);
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-word;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.15) transparent;
  position: relative;
}

.log-terminal::-webkit-scrollbar {
  width: 6px;
}

.log-terminal::-webkit-scrollbar-track {
  background: transparent;
}

.log-terminal::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.15);
  border-radius: 3px;
}

.log-terminal::-webkit-scrollbar-thumb:hover {
  background: rgba(255,255,255,0.25);
}

/* Log entry styling */
.log-entry {
  padding: 2px 0;
  border-left: 2px solid transparent;
  padding-left: 8px;
  margin: 2px 0;
  animation: fadeInSlide 0.3s ease forwards;
  opacity: 0;
  transform: translateX(-10px);
}

.log-entry:nth-child(1) { animation-delay: 0ms; }
.log-entry:nth-child(2) { animation-delay: 50ms; }
.log-entry:nth-child(3) { animation-delay: 100ms; }

@keyframes fadeInSlide {
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.log-entry:hover {
  background: rgba(255,255,255,0.03);
  border-left-color: rgba(255,255,255,0.2);
}

/* ============================================
   BAR GRAPH - OPTIMISED ANIMATION
   ============================================ */
.bar-graph {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: clamp(1px, 0.5vw, 3px);
  height: clamp(40px, 8vh, 70px);
  background: rgba(255,255,255,0.03);
  border-radius: var(--radius-md);
  padding: clamp(4px, 1vw, 8px);
  overflow: hidden;
  position: relative;
}

.bar-graph::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.02) 100%);
  pointer-events: none;
  border-radius: inherit;
}

.bar-graph .bar {
  flex: 1;
  min-width: 2px;
  max-width: 12px;
  background: linear-gradient(to bottom, currentColor 0%, rgba(255,255,255,0.1) 100%);
  border-radius: 9999px;
  transition: height 600ms cubic-bezier(0.34, 1.56, 0.64, 1), 
              opacity 300ms ease;
  opacity: 0.9;
  position: relative;
  will-change: height;
}

.bar-graph .bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 30%;
  background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  border-radius: 9999px 9999px 0 0;
}

.bar-graph .bar:hover {
  opacity: 1;
  filter: brightness(1.2);
}

/* ============================================
   GLASS PANEL - ENHANCED
   ============================================ */
.glass-panel {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-glow), 0 4px 24px rgba(0,0,0,0.1);
  transition: var(--transition-smooth);
}

.glass-panel:hover {
  border-color: rgba(255,255,255,0.15);
  box-shadow: var(--shadow-glow), 0 8px 32px rgba(0,0,0,0.15);
}

/* ============================================
   RESOURCE CARDS - MODERNISED
   ============================================ */
.resource-card {
  position: relative;
  overflow: hidden;
  transition: var(--transition-smooth);
}

.resource-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
  transition: left 0.7s ease;
}

.resource-card:hover::before {
  left: 100%;
}

.resource-card:hover {
  transform: translateY(-4px) scale(1.01);
  box-shadow: var(--shadow-elevated);
}

/* Metric value styling */
.metric-value {
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, currentColor 0%, rgba(255,255,255,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ============================================
   BUTTONS - ENHANCED INTERACTIONS
   ============================================ */
.btn {
  position: relative;
  overflow: hidden;
  transition: var(--transition-smooth);
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.btn:active::before {
  width: 300px;
  height: 300px;
}

.btn:active {
  transform: scale(0.96);
}

.btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none !important;
}

/* Button variants */
.btn-primary {
  background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);
  border: 1px solid rgba(255,255,255,0.15);
}

.btn-primary:hover {
  background: linear-gradient(135deg, rgba(255,255,255,0.25) 0%, rgba(255,255,255,0.1) 100%);
  border-color: rgba(255,255,255,0.25);
  transform: translateY(-1px);
}

.btn-action {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  border: none;
  box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
}

.btn-action:hover {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
  transform: translateY(-2px);
}

.btn-success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border: none;
  box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
}

.btn-success:hover {
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
}

.btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  border: none;
  box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
}

.btn-danger:hover {
  background: linear-gradient(135deg, #f87171 0%, #ef4444 100%);
  box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
}

/* ============================================
   LIVE INDICATOR - ENHANCED
   ============================================ */
.live-indicator {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.live-dot {
  width: 8px;
  height: 8px;
  background: #34d399;
  border-radius: 50%;
  position: relative;
  box-shadow: 0 0 10px #34d399;
}

.live-dot::before,
.live-dot::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 2px solid #34d399;
  opacity: 0;
  animation: pulse-ring 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
}

.live-dot::after {
  animation-delay: 0.5s;
}

@keyframes pulse-ring {
  0% { transform: scale(0.5); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* ============================================
   VERSION BADGE - MODERNISED
   ============================================ */
.version-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: clamp(4px, 1vw, 6px) clamp(10px, 2vw, 16px);
  border-radius: 9999px;
  font-size: clamp(0.7rem, 1.5vw, 0.875rem);
  font-weight: 600;
  transition: var(--transition-smooth);
  backdrop-filter: blur(10px);
}

.badge-success {
  background: rgba(16, 185, 129, 0.15);
  color: #34d399;
  border: 1px solid rgba(16, 185, 129, 0.3);
}

.badge-warning {
  background: rgba(245, 158, 11, 0.15);
  color: #fbbf24;
  border: 1px solid rgba(245, 158, 11, 0.3);
}

.badge-error {
  background: rgba(239, 68, 68, 0.15);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

/* ============================================
   SVG ICONS - CONSISTENT SIZING
   ============================================ */
.icon {
  width: 1em;
  height: 1em;
  display: inline-block;
  vertical-align: middle;
  flex-shrink: 0;
}

.icon-lg {
  width: clamp(2rem, 5vw, 3.5rem);
  height: clamp(2rem, 5vw, 3.5rem);
}

.icon-xl {
  width: clamp(2.5rem, 6vw, 4.5rem);
  height: clamp(2.5rem, 6vw, 4.5rem);
}

/* Icon colors matching original emoji colors */
.icon-orange { color: #fb923c; }
.icon-blue { color: #60a5fa; }
.icon-emerald { color: #34d399; }
.icon-amber { color: #fbbf24; }

/* ============================================
   HEADER - RESPONSIVE OPTIMISATIONS
   ============================================ */
.dashboard-header {
  display: flex;
  flex-direction: column;
  gap: clamp(0.75rem, 2vw, 1.5rem);
  padding: clamp(1rem, 3vw, 1.5rem) 0;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

@media (min-width: 640px) {
  .dashboard-header {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.header-title {
  font-size: clamp(1.5rem, 4vw, 2.25rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-subtitle {
  font-size: clamp(0.75rem, 1.5vw, 0.875rem);
  color: #94a3b8;
  margin-top: 0.25rem;
}

/* ============================================
   GRID LAYOUT - MODERN RESPONSIVE
   ============================================ */
.resources-grid {
  display: grid;
  gap: clamp(0.75rem, 2vw, 1.5rem);
  grid-template-columns: 1fr;
}

@media (min-width: 768px) {
  .resources-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .resources-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* ============================================
   STATUS TEXT - ANIMATED
   ============================================ */
.status-text {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: clamp(0.7rem, 1.4vw, 0.8rem);
  font-weight: 500;
  transition: var(--transition-smooth);
}

.status-warning {
  color: #fbbf24;
  animation: pulse-warning 2s ease-in-out infinite;
}

@keyframes pulse-warning {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* ============================================
   SCROLLBAR STYLING FOR WEBKIT
   ============================================ */
* {
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.1) transparent;
}

*::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

*::-webkit-scrollbar-track {
  background: transparent;
}

*::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.1);
  border-radius: 4px;
}

*::-webkit-scrollbar-thumb:hover {
  background: rgba(255,255,255,0.2);
}

/* ============================================
   LOADING SKELETON
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 4px;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ============================================
   FOCUS STATES FOR ACCESSIBILITY
   ============================================ */
button:focus-visible,
.btn:focus-visible {
  outline: 2px solid rgba(255,255,255,0.5);
  outline-offset: 2px;
}

/* ============================================
   REDUCED MOTION SUPPORT
   ============================================ */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* ============================================
   UTILITY CLASSES
   ============================================ */
.text-gradient {
  background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gap-responsive {
  gap: clamp(0.5rem, 1.5vw, 1rem);
}

.p-responsive {
  padding: clamp(0.75rem, 2vw, 1.5rem);
}

.rounded-responsive {
  border-radius: clamp(10px, 2vw, 16px);
}
</style>

<main id="content">
  
  <!-- Header -->
  <header class="dashboard-header">
    <div class="text-center sm:text-left">
      <h1 class="header-title">Dashboard</h1>
      <p class="header-subtitle">
        Real-time CPU • RAM • Disk + Live logs
      </p>
    </div>
    
    <div class="flex items-center justify-center sm:justify-end gap-responsive">
      <div class="glass-panel px-4 py-2 flex items-center gap-2">
        <div class="live-indicator">
          <div class="live-dot"></div>
          <span class="text-xs font-semibold text-emerald-400 tracking-wider">LIVE</span>
        </div>
      </div>
      <span id="static-version" class="glass-panel px-4 py-2 text-xs text-neutral-400 font-mono">
        v<%= version %>
      </span>
    </div>
  </header>

  <!-- VERSION CONTROL + DYNAMIC ACTION BUTTON -->
  <div class="glass-panel p-responsive mt-6 sm:mt-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4 text-center sm:text-left w-full sm:w-auto">
        <div class="p-3 rounded-xl bg-white/5">
          <svg class="icon icon-lg text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-neutral-400 uppercase tracking-wider font-medium">Current Version</p>
          <p id="current-version" class="text-xl sm:text-2xl font-bold text-white font-mono mt-0.5">v<%= version %></p>
        </div>
        <div id="version-badge-container" class="hidden sm:block">
          <div id="version-badge" class="version-badge badge-success">
            <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span>Up to date</span>
          </div>
        </div>
      </div>
      
      <div class="flex gap-2 sm:gap-3 w-full sm:w-auto">
        <button onclick="checkForUpdate()" 
                id="check-btn"
                class="btn btn-primary flex-1 sm:flex-none px-5 py-2.5 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2">
          <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Check</span>
        </button>
        
        <button onclick="performAction()" 
                id="action-btn"
                class="btn btn-action flex-1 sm:flex-none px-5 py-2.5 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white font-medium">
          <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <span>Reinstall</span>
        </button>
      </div>
    </div>
    
    <!-- Mobile version badge (shown only on small screens) -->
    <div id="version-badge-mobile" class="sm:hidden mt-3 flex justify-center">
      <div class="version-badge badge-success">
        <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
        <span>Up to date</span>
      </div>
    </div>
  </div>

  <!-- LIVE PM2 LOGS - TOP -->
  <div class="glass-panel p-responsive mt-6 sm:mt-8 flex flex-col">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 sm:mb-6 gap-3">
      <div class="flex items-center gap-3">
        <div class="p-2 rounded-lg bg-white/5">
          <svg class="icon w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-lg sm:text-xl font-semibold text-white">KS Panel Log</h2>
      </div>
      
      <div class="flex gap-2 sm:gap-3 w-full sm:w-auto">
        <button onclick="clearLogs()" 
                class="btn btn-primary flex-1 sm:flex-none px-4 py-2 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2">
          <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          <span class="hidden sm:inline">Clear</span>
        </button>
        <button onclick="toggleStream()" id="log-btn"
                class="btn btn-danger flex-1 sm:flex-none px-4 py-2 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white">
          <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="6" y="4" width="4" height="16" rx="1"/>
            <rect x="14" y="4" width="4" height="16" rx="1"/>
          </svg>
          <span>Stop</span>
        </button>
      </div>
    </div>
    
    <div id="logs" class="log-terminal flex-1">
      <div class="text-neutral-500 italic flex items-center gap-2">
        <svg class="icon w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        Connecting to PM2 logs...
      </div>
    </div>
  </div>

  <!-- RESOURCES MONITOR -->
  <div class="mt-8 sm:mt-12">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 sm:mb-6 gap-3">
      <div class="flex items-center gap-3">
        <div class="p-2 rounded-lg bg-white/5">
          <svg class="icon w-5 h-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h2 class="text-lg sm:text-xl font-semibold text-white">Resources Monitor</h2>
      </div>
      
      <button onclick="refreshResources()" 
              class="btn btn-primary flex items-center gap-2 text-xs sm:text-sm px-4 py-2 rounded-[10px] disabled:opacity-50 disabled:cursor-not-allowed group"
              id="refreshBtn">
        <svg class="icon w-4 h-4 transition-transform duration-700 ease-in-out group-disabled:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span>Refresh Now</span>
      </button>
    </div>

    <div class="resources-grid">
      
      <!-- CPU Card -->
      <div class="resource-card glass-panel p-responsive lg:p-8">
        <div class="flex items-center gap-4 mb-4 sm:mb-6">
          <div class="p-3 rounded-xl bg-orange-500/10">
            <svg class="icon icon-xl icon-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-neutral-400 text-xs sm:text-sm font-medium uppercase tracking-wider">CPU Usage</p>
            <p id="cpu-text" class="metric-value text-4xl sm:text-5xl lg:text-6xl font-bold text-orange-400 mt-1">0%</p>
          </div>
        </div>
        <div id="cpu-graph" class="bar-graph text-orange-400"></div>
        <div class="flex items-center justify-between mt-4 sm:mt-6">
          <p id="cpu-status" class="status-text text-neutral-500">
            <svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Normal
          </p>
          <span class="text-xs text-neutral-600 font-mono" id="cpu-cores"></span>
        </div>
      </div>

      <!-- RAM Card -->
      <div class="resource-card glass-panel p-responsive lg:p-8">
        <div class="flex items-center gap-4 mb-4 sm:mb-6">
          <div class="p-3 rounded-xl bg-blue-500/10">
            <svg class="icon icon-xl icon-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-neutral-400 text-xs sm:text-sm font-medium uppercase tracking-wider">RAM Usage</p>
            <p id="ram-text" class="metric-value text-4xl sm:text-5xl lg:text-6xl font-bold text-blue-400 mt-1">0%</p>
          </div>
        </div>
        <div id="ram-graph" class="bar-graph text-blue-400"></div>
        <div class="flex justify-between items-center mt-4 sm:mt-6 pt-4 border-t border-white/5">
          <span id="ram-used" class="text-xs sm:text-sm text-neutral-400 font-mono">0 GB</span>
          <div class="h-1 flex-1 mx-3 bg-white/10 rounded-full overflow-hidden">
            <div id="ram-bar" class="h-full bg-blue-400/50 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <span id="ram-total" class="text-xs sm:text-sm text-neutral-400 font-mono">0 GB</span>
        </div>
      </div>

      <!-- Disk Card -->
      <div class="resource-card glass-panel p-responsive lg:p-8 md:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-4 mb-4 sm:mb-6">
          <div class="p-3 rounded-xl bg-emerald-500/10">
            <svg class="icon icon-xl icon-emerald" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-neutral-400 text-xs sm:text-sm font-medium uppercase tracking-wider">Disk Usage</p>
            <p id="disk-text" class="metric-value text-4xl sm:text-5xl lg:text-6xl font-bold text-emerald-400 mt-1">0%</p>
          </div>
        </div>
        <div id="disk-graph" class="bar-graph text-emerald-400"></div>
        <div class="flex justify-between items-center mt-4 sm:mt-6 pt-4 border-t border-white/5">
          <span id="disk-used" class="text-xs sm:text-sm text-neutral-400 font-mono">0 GB</span>
          <div class="h-1 flex-1 mx-3 bg-white/10 rounded-full overflow-hidden">
            <div id="disk-bar" class="h-full bg-emerald-400/50 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <span id="disk-total" class="text-xs sm:text-sm text-neutral-400 font-mono">0 GB</span>
        </div>
      </div>

    </div>
  </div>

</main>

<script>
  // ==========================================
  // SVG ICONS LIBRARY (for dynamic injection)
  // ==========================================
  const Icons = {
    check: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`,
    warning: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
    error: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>`,
    refresh: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
    play: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    stop: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>`,
    trash: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>`,
    rocket: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    update: `<svg class="icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>`
  };

  // ==========================================
  // DYNAMIC BAR GRAPH (Auto-scaling)
  // ==========================================
  function updateBarGraph(graphId, percent, colorClass) {
    const graph = document.getElementById(graphId);
    const targetHeight = Math.max(8, Math.min(100, Math.round(percent || 0))) + '%';
    
    // Calculate optimal bar count based on container width
    const calculateBarCount = () => {
      const paddingTotal = 16;
      const availableWidth = Math.max(200, graph.clientWidth - paddingTotal);
      const barWidthWithGap = 6 + 2; // 6px bar + 2px gap
      let count = Math.floor(availableWidth / barWidthWithGap);
      return Math.max(8, Math.min(50, count));
    };

    // Initialize bars if empty or resize detected
    if (graph.children.length === 0 || graph.dataset.barCount !== String(calculateBarCount())) {
      graph.innerHTML = '';
      graph.dataset.barCount = calculateBarCount();
      const numBars = parseInt(graph.dataset.barCount);
      const fragment = document.createDocumentFragment();
      
      for (let i = 0; i < numBars; i++) {
        const bar = document.createElement('div');
        bar.className = `bar ${colorClass}`;
        // Staggered animation delay for wave effect
        bar.style.transitionDelay = `${i * 15}ms`;
        // Random initial height for visual interest
        bar.style.height = `${Math.random() * 20 + 10}%`;
        fragment.appendChild(bar);
      }
      graph.appendChild(fragment);
      
      // Trigger reflow for animation
      requestAnimationFrame(() => {
        Array.from(graph.children).forEach(bar => {
          bar.style.height = targetHeight;
        });
      });
    } else {
      // Update existing bars with smooth transition
      Array.from(graph.children).forEach(bar => {
        bar.style.height = targetHeight;
      });
    }
  }

  // ==========================================
  // RESOURCES MONITOR (Optimised)
  // ==========================================
  let cpuEl, ramTextEl, ramUsedEl, ramTotalEl, diskTextEl, diskUsedEl, diskTotalEl, cpuStatusEl, ramBar, diskBar;

  async function fetchResources() {
    try {
      const res = await fetch('/resourceMonitor');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      // CPU Update
      const cpuPercent = Math.round(data.cpu?.percent || 0);
      cpuEl.textContent = cpuPercent + '%';
      
      const isHighLoad = cpuPercent > 85;
      cpuStatusEl.className = isHighLoad ? 'status-text status-warning' : 'status-text text-neutral-500';
      cpuStatusEl.innerHTML = isHighLoad ? 
        `${Icons.warning} <span>HIGH LOAD</span>` : 
        `${Icons.check} <span>Normal</span>`;
      
      updateBarGraph('cpu-graph', cpuPercent, 'text-orange-400');
      
      if (data.cpu?.cores) {
        document.getElementById('cpu-cores').textContent = `${data.cpu.cores} Cores`;
      }

      // RAM Update
      const ramPercent = Math.round(data.ram?.percent || 0);
      ramTextEl.textContent = ramPercent + '%';
      ramUsedEl.textContent = (data.ram?.used || 0).toFixed(1) + ' GB';
      ramTotalEl.textContent = (data.ram?.total || 0).toFixed(1) + ' GB';
      if (ramBar) ramBar.style.width = ramPercent + '%';
      updateBarGraph('ram-graph', ramPercent, 'text-blue-400');

      // Disk Update
      const diskPercent = Math.round(data.disk?.percent || 0);
      diskTextEl.textContent = diskPercent + '%';
      diskUsedEl.textContent = (data.disk?.used || 0).toFixed(1) + ' GB';
      diskTotalEl.textContent = (data.disk?.total || 0).toFixed(1) + ' GB';
      if (diskBar) diskBar.style.width = diskPercent + '%';
      updateBarGraph('disk-graph', diskPercent, 'text-emerald-400');

    } catch (e) {
      console.error("Resource monitor failed:", e);
      // Show error state gracefully
      cpuStatusEl.innerHTML = `${Icons.error} <span>Connection Error</span>`;
      cpuStatusEl.className = 'status-text text-red-400';
    }
  }

  function refreshResources() {
    const btn = document.getElementById('refreshBtn');
    btn.disabled = true;
    fetchResources().finally(() => {
      setTimeout(() => btn.disabled = false, 500);
    });
  }

  // ==========================================
  // VERSION CHECK + DYNAMIC ACTION
  // ==========================================
  let isOutdated = false;

  function updateBadge(status, text, version = '') {
    const desktopBadge = document.getElementById('version-badge');
    const mobileBadge = document.getElementById('version-badge-mobile')?.firstElementChild;
    
    const badges = [desktopBadge, mobileBadge].filter(Boolean);
    
    badges.forEach(badge => {
      badge.className = `version-badge badge-${status}`;
      if (status === 'warning' && version) {
        badge.innerHTML = `${Icons.update} <span>Update v${version}</span>`;
      } else if (status === 'success') {
        badge.innerHTML = `${Icons.check} <span>${text}</span>`;
      } else {
        badge.innerHTML = `${Icons.error} <span>${text}</span>`;
      }
    });
  }

  async function checkForUpdate() {
    const checkBtn = document.getElementById('check-btn');
    const originalHTML = checkBtn.innerHTML;
    checkBtn.innerHTML = `<svg class="icon w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> <span>Checking...</span>`;
    checkBtn.disabled = true;

    try {
      const res = await fetch('/version');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      document.getElementById('current-version').textContent = `v${data.currentVersion}`;
      const actionBtn = document.getElementById('action-btn');

      if (data.status === 'outdated') {
        isOutdated = true;
        updateBadge('warning', 'Update', data.latestVersion);
        actionBtn.innerHTML = `${Icons.update} <span>Update</span>`;
        actionBtn.className = 'btn btn-success flex-1 sm:flex-none px-5 py-2.5 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white font-medium';
      } else {
        isOutdated = false;
        updateBadge('success', 'Up to date');
        actionBtn.innerHTML = `${Icons.rocket} <span>Reinstall</span>`;
        actionBtn.className = 'btn btn-action flex-1 sm:flex-none px-5 py-2.5 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white font-medium';
      }
    } catch (e) {
      console.error("Version check failed:", e);
      updateBadge('error', 'Failed');
    }

    checkBtn.innerHTML = originalHTML;
    checkBtn.disabled = false;
  }

  async function performAction() {
    const action = isOutdated ? 'Update' : 'Reinstall';
    if (!confirm(`Start ${action}? This will run the update script and restart services.`)) return;

    const btn = document.getElementById('action-btn');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = `<svg class="icon w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> <span>${action}ing...</span>`;
    btn.disabled = true;

    try {
      const res = await fetch('/reinstall');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      alert(`✅ ${action} started! Page will auto-reload in 8 seconds...`);
      setTimeout(() => location.reload(true), 8000);
    } catch (e) {
      alert(`${action} trigger failed. Check console.`);
      console.error(e);
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    }
  }

  // ==========================================
  // LIVE LOGS STREAM (Enhanced)
  // ==========================================
  let eventSource = null;
  let isStreaming = true;
  let logBuffer = [];
  let flushInterval = null;

  function createLogEntry(text) {
    const entry = document.createElement('div');
    entry.className = 'log-entry';
    
    // Add timestamp
    const time = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    
    // Color coding based on log level
    let colorClass = 'text-neutral-400';
    if (text.includes('ERROR') || text.includes('error')) colorClass = 'text-red-400';
    else if (text.includes('WARN')) colorClass = 'text-amber-400';
    else if (text.includes('INFO')) colorClass = 'text-blue-400';
    else if (text.includes('SUCCESS')) colorClass = 'text-emerald-400';
    
    entry.innerHTML = `<span class="text-neutral-600 text-xs">[${time}]</span> <span class="${colorClass}">${escapeHtml(text)}</span>`;
    return entry;
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function flushLogs() {
    const logsDiv = document.getElementById('logs');
    if (logBuffer.length === 0) return;
    
    const fragment = document.createDocumentFragment();
    logBuffer.forEach(text => {
      fragment.appendChild(createLogEntry(text));
    });
    logBuffer = [];
    
    logsDiv.appendChild(fragment);
    
    // Auto-scroll if near bottom
    const isNearBottom = logsDiv.scrollHeight - logsDiv.scrollTop - logsDiv.clientHeight < 100;
    if (isNearBottom) {
      logsDiv.scrollTop = logsDiv.scrollHeight;
    }
    
    // Limit entries for performance
    while (logsDiv.children.length > 500) {
      logsDiv.removeChild(logsDiv.firstChild);
    }
  }

  function startStream() {
    if (eventSource) eventSource.close();
    
    const logsDiv = document.getElementById('logs');
    if (logsDiv.children.length === 0 || logsDiv.textContent.includes('Connecting')) {
      logsDiv.innerHTML = '';
    }

    eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
    
    eventSource.onmessage = (e) => {
      logBuffer.push(e.data);
    };

    eventSource.onerror = () => {
      logBuffer.push('[Stream disconnected - Retrying...]');
      // Auto-reconnect after 3 seconds
      setTimeout(() => {
        if (isStreaming) startStream();
      }, 3000);
    };

    // Flush buffer every 100ms for smooth rendering
    if (!flushInterval) {
      flushInterval = setInterval(flushLogs, 100);
    }
  }

  function toggleStream() {
    const btn = document.getElementById('log-btn');
    if (isStreaming) {
      eventSource?.close();
      clearInterval(flushInterval);
      flushInterval = null;
      btn.innerHTML = `${Icons.play} <span>Resume</span>`;
      btn.className = 'btn btn-success flex-1 sm:flex-none px-4 py-2 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white';
      logBuffer.push('[Stream paused by user]');
      flushLogs();
    } else {
      startStream();
      btn.innerHTML = `${Icons.stop} <span>Stop</span>`;
      btn.className = 'btn btn-danger flex-1 sm:flex-none px-4 py-2 rounded-[10px] text-xs sm:text-sm flex items-center justify-center gap-2 text-white';
    }
    isStreaming = !isStreaming;
  }

  function clearLogs() {
    const logsDiv = document.getElementById('logs');
    logsDiv.innerHTML = `<div class="log-entry text-neutral-500 italic">Logs cleared. Waiting for new entries...</div>`;
    logBuffer = [];
  }

  // ==========================================
  // RESPONSIVE HANDLING
  // ==========================================
  function handleResize() {
    // Debounced resize handler
    clearTimeout(window.resizeTimer);
    window.resizeTimer = setTimeout(() => {
      // Clear graphs to recalculate bar counts
      ['cpu-graph', 'ram-graph', 'disk-graph'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '';
      });
      fetchResources();
    }, 250);
  }

  // ==========================================
  // INITIALISATION
  // ==========================================
  window.addEventListener('DOMContentLoaded', () => {
    // Cache DOM elements
    cpuEl = document.getElementById('cpu-text');
    ramTextEl = document.getElementById('ram-text');
    ramUsedEl = document.getElementById('ram-used');
    ramTotalEl = document.getElementById('ram-total');
    diskTextEl = document.getElementById('disk-text');
    diskUsedEl = document.getElementById('disk-used');
    diskTotalEl = document.getElementById('disk-total');
    cpuStatusEl = document.getElementById('cpu-status');
    ramBar = document.getElementById('ram-bar');
    diskBar = document.getElementById('disk-bar');

    // Initial data fetch
    fetchResources();
    checkForUpdate();

    // Periodic updates
    setInterval(fetchResources, 2800);

    // Start log stream
    startStream();

    // Responsive handling
    window.addEventListener('resize', handleResize, { passive: true });

    // Visibility API - pause/resume when tab hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        // Reduce update frequency when hidden
        window.slowMode = true;
      } else {
        window.slowMode = false;
        fetchResources(); // Immediate refresh when visible
      }
    });
  });

  // Cleanup
  window.addEventListener('beforeunload', () => {
    if (eventSource) eventSource.close();
    if (flushInterval) clearInterval(flushInterval);
  });
</script>
