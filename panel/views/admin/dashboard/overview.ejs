<%- include('../../components/template') %>

<style>
/* === PREMIUM GLASSMORPHIC CARDS (from Database Overview) === */
.stat-card {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 1.75rem;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 
    0 4px 6px -1px rgba(0, 0, 0, 0.1),
    0 2px 4px -1px rgba(0, 0, 0, 0.06),
    inset 0 1px 0 rgba(255,255,255,0.05);
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
}

.stat-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(255,255,255,0.25);
  box-shadow: 
    0 20px 25px -5px rgba(0, 0, 0, 0.2),
    0 10px 10px -5px rgba(0, 0, 0, 0.1),
    inset 0 1px 0 rgba(255,255,255,0.1);
}

.stat-number {
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-top: 0.75rem;
  word-break: break-word;
  background: linear-gradient(135deg, currentColor 0%, rgba(255,255,255,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-icon {
  width: clamp(2.75rem, 6vw, 3.5rem);
  height: clamp(2.75rem, 6vw, 3.5rem);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.stat-icon::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.15;
  transition: opacity 0.3s ease;
}

.stat-card:hover .stat-icon::before {
  opacity: 0.25;
}

.stat-icon svg {
  width: 55%;
  height: 55%;
  stroke-width: 1.75;
  position: relative;
  z-index: 1;
}

/* === DASHBOARD STYLES (Resources + Logs) === */
:root {
  --glass-bg: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-blur: blur(20px);
}

.glass-panel, .resource-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: 20px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.1);
}

.log-terminal {
  background: #0f172a;
  border: 1px solid var(--glass-border);
  border-radius: 16px;
  padding: 1.25rem;
  font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
  font-size: clamp(0.75rem, 1.5vw, 0.85rem);
  line-height: 1.7;
  color: #94a3b8;
  max-height: 420px;
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-word;
}

.bar-graph {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 3px;
  height: 70px;
  background: rgba(255,255,255,0.03);
  border-radius: 12px;
  padding: 8px;
}

.bar-graph .bar {
  flex: 1;
  background: linear-gradient(to bottom, currentColor, rgba(255,255,255,0.2));
  border-radius: 9999px;
  transition: height 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 12px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: #a1a1aa;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
}

.refresh-btn:hover {
  background: rgba(255,255,255,0.15);
  transform: translateY(-2px);
}

.live-badge {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(16,185,129,0.1);
  color: #10b981;
  padding: 8px 20px;
  border-radius: 9999px;
  font-weight: 600;
}

.live-dot {
  width: 10px;
  height: 10px;
  background: #10b981;
  border-radius: 50%;
  animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* Mobile & Tablet fixes */
@media (max-width: 640px) {
  .stat-card, .resource-card, .glass-panel { padding: 1.25rem; }
  .stat-number { font-size: 1.75rem; }
}
</style>

<main id="content" class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 py-4 sm:py-6 lg:py-8">

  <!-- HEADER (Combined) -->
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-4 sm:py-6 gap-4 border-b border-white/10">
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl sm:text-3xl font-semibold text-white tracking-tight">Dashboard</h1>
      <p class="mt-1 text-xs sm:text-sm text-neutral-400">Users • Instances • Nodes • Database • Resources • Live Logs</p>
    </div>

    <div class="flex items-center gap-3 header-actions">
      <div class="live-badge">
        <div class="live-dot"></div>
        <span>LIVE</span>
      </div>

      <button onclick="refreshAll()" class="refresh-btn">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span>Refresh All</span>
      </button>

      <span class="version-badge bg-white/5 px-3 sm:px-5 py-2 rounded-[10px] text-xs text-neutral-400 whitespace-nowrap border border-white/5">v<%= version %></span>
    </div>
  </header>

  <!-- DATABASE STATISTICS (Exact original 8 cards) -->
  <section class="mt-6 sm:mt-10">
    <div class="flex items-center justify-between mb-4 sm:mb-6">
      <h2 class="text-xl sm:text-2xl font-semibold text-white">Database Statistics</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-4 gap-4 sm:gap-6">
      
      <!-- Users -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Users</p>
            <p id="users-text" class="stat-number text-blue-400"><%= usersTotal %></p>
          </div>
          <div class="stat-icon bg-blue-500/10 text-blue-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
          Admins: <span id="admins-text" class="text-emerald-400 font-semibold"><%= adminsTotal %></span>
        </p>
      </article>

      <!-- Instances -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Instances</p>
            <p id="instances-text" class="stat-number text-purple-400"><%= instancesTotal %></p>
          </div>
          <div class="stat-icon bg-purple-500/10 text-purple-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
          Suspended: <span id="suspended-text" class="text-red-400 font-semibold"><%= suspendedTotal %></span>
        </p>
      </article>

      <!-- Nodes -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Nodes</p>
            <p id="nodes-text" class="stat-number text-orange-400"><%= nodesTotal %></p>
          </div>
          <div class="stat-icon bg-orange-500/10 text-orange-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
          </div>
        </div>
        <div class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 flex flex-col sm:flex-row sm:justify-between gap-2">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Online: <span id="online-text" class="text-emerald-400 font-semibold"><%= onlineNodes %></span></span>
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Offline: <span id="offline-text" class="text-red-400 font-semibold"><%= offlineNodes %></span></span>
        </div>
      </article>

      <!-- Templates -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Templates</p>
            <p id="templates-text" class="stat-number text-cyan-400"><%= templatesTotal %></p>
          </div>
          <div class="stat-icon bg-cyan-500/10 text-cyan-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Available configurations</p>
      </article>

      <!-- Locations -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Locations</p>
            <p id="locations-text" class="stat-number text-amber-400"><%= locationsTotal %></p>
          </div>
          <div class="stat-icon bg-amber-500/10 text-amber-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Global regions</p>
      </article>

      <!-- API Keys -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">API Keys</p>
            <p id="apikeys-text" class="stat-number text-pink-400"><%= apiKeysTotal %></p>
          </div>
          <div class="stat-icon bg-pink-500/10 text-pink-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Active credentials</p>
      </article>

      <!-- Plugins -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Plugins</p>
            <p id="plugins-text" class="stat-number text-violet-400"><%= pluginsTotal %></p>
          </div>
          <div class="stat-icon bg-violet-500/10 text-violet-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Installed modules</p>
      </article>

      <!-- Requests -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Requests</p>
            <p id="requests-text" class="stat-number text-emerald-400"><%= totalRequests %></p>
          </div>
          <div class="stat-icon bg-emerald-500/10 text-emerald-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
        </div>
        <div class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400 space-y-2">
          <div class="flex justify-between items-center">
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-white/50"></span>Visitors:</span>
            <span id="visitors-text" class="text-white font-semibold"><%= uniqueVisitors %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-white/50"></span>Avg/hour:</span>
            <span id="avg-text" class="text-white font-semibold"><%= avgRequestsPerHour %></span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- DATABASE INFORMATION (Exact original 5 cards) -->
  <section class="mt-8 sm:mt-12">
    <h2 class="text-xl sm:text-2xl font-semibold text-white mb-4 sm:mb-6">Database Information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 sm:gap-6">

      <!-- DB Type -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Database Type</p>
            <p id="dbtype-text" class="stat-number text-emerald-400 break-text"><%= dbType %></p>
          </div>
          <div class="stat-icon bg-emerald-500/10 text-emerald-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Storage engine</p>
      </article>

      <!-- Size -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Database Size</p>
            <p id="dbsize-text" class="stat-number text-cyan-400"><%= dbSize %></p>
          </div>
          <div class="stat-icon bg-cyan-500/10 text-cyan-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Storage used</p>
      </article>

      <!-- URL -->
      <article class="stat-card sm:col-span-2 lg:col-span-1 xl:col-span-1">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Connection URL</p>
            <p id="dburl-text" class="mt-2 sm:mt-4 font-mono text-xs sm:text-sm text-amber-400 break-all leading-relaxed bg-black/20 p-2 rounded-lg"><%= dbUrlMasked %></p>
          </div>
          <div class="stat-icon bg-amber-500/10 text-amber-400 flex-shrink-0">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </div>
        </div>
      </article>

      <!-- Table -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Table Name</p>
            <p id="dbtable-text" class="stat-number text-violet-400 break-text"><%= dbTable %></p>
          </div>
          <div class="stat-icon bg-violet-500/10 text-violet-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18m-9-4v8m-7-8h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2v-8a2 2 0 012-2z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Primary collection</p>
      </article>

      <!-- Total Keys -->
      <article class="stat-card">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-neutral-400 truncate">Total Keys</p>
            <p id="dbkeys-text" class="stat-number text-pink-400"><%= totalKeys %></p>
          </div>
          <div class="stat-icon bg-pink-500/10 text-pink-400">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
          </div>
        </div>
        <p class="mt-4 sm:mt-6 text-xs sm:text-sm text-neutral-400">Stored entries</p>
      </article>
    </div>
  </section>

  <!-- RESOURCES MONITOR (Exact original) -->
  <div class="mt-8 sm:mt-12">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 sm:mb-6 gap-3">
      <div class="flex items-center gap-3">
        <div class="p-2 rounded-lg bg-white/5">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h2 class="text-lg sm:text-xl font-semibold text-white">Resources Monitor</h2>
      </div>
      <button onclick="refreshResources()" class="refresh-btn" id="refreshBtn">Refresh Now</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- CPU -->
      <div class="resource-card glass-panel p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="p-3 rounded-xl bg-orange-500/10">
            <svg class="w-9 h-9 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-neutral-400 text-sm">CPU Usage</p>
            <p id="cpu-text" class="text-5xl font-bold text-orange-400">0%</p>
          </div>
        </div>
        <div id="cpu-graph" class="bar-graph text-orange-400"></div>
        <div class="mt-4 flex justify-between text-xs">
          <p id="cpu-status" class="text-neutral-400">Normal</p>
          <span id="cpu-cores" class="font-mono text-neutral-400"></span>
        </div>
      </div>

      <!-- RAM -->
      <div class="resource-card glass-panel p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="p-3 rounded-xl bg-blue-500/10">
            <svg class="w-9 h-9 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-neutral-400 text-sm">RAM Usage</p>
            <p id="ram-text" class="text-5xl font-bold text-blue-400">0%</p>
          </div>
        </div>
        <div id="ram-graph" class="bar-graph text-blue-400"></div>
        <div class="mt-4 flex justify-between text-xs text-neutral-400">
          <span id="ram-used">0 GB</span>
          <div class="flex-1 mx-3 bg-white/10 rounded-full h-1.5"><div id="ram-bar" class="h-full bg-blue-400 rounded-full" style="width:0%"></div></div>
          <span id="ram-total">0 GB</span>
        </div>
      </div>

      <!-- Disk -->
      <div class="resource-card glass-panel p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="p-3 rounded-xl bg-emerald-500/10">
            <svg class="w-9 h-9 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-neutral-400 text-sm">Disk Usage</p>
            <p id="disk-text" class="text-5xl font-bold text-emerald-400">0%</p>
          </div>
        </div>
        <div id="disk-graph" class="bar-graph text-emerald-400"></div>
        <div class="mt-4 flex justify-between text-xs text-neutral-400">
          <span id="disk-used">0 GB</span>
          <div class="flex-1 mx-3 bg-white/10 rounded-full h-1.5"><div id="disk-bar" class="h-full bg-emerald-400 rounded-full" style="width:0%"></div></div>
          <span id="disk-total">0 GB</span>
        </div>
      </div>
    </div>
  </div>

  <!-- LIVE PM2 LOGS (Exact original) -->
  <div class="mt-8 sm:mt-12 glass-panel p-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-3">
      <div class="flex items-center gap-3">
        <div class="p-2 rounded-lg bg-white/5">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <h2 class="text-lg sm:text-xl font-semibold text-white">KS Panel Live Logs</h2>
      </div>
      <div class="flex gap-2">
        <button onclick="clearLogs()" class="refresh-btn text-xs px-4">Clear Logs</button>
        <button onclick="toggleStream()" id="log-btn" class="refresh-btn bg-red-500 text-white text-xs px-4">Stop Stream</button>
      </div>
    </div>
    <div id="logs" class="log-terminal"></div>
  </div>

</main>

<!-- Notification (from original) -->
<div id="notification" class="fixed bottom-4 sm:bottom-6 right-4 sm:right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl shadow-2xl text-xs sm:text-sm font-medium z-50 max-w-[calc(100vw-2rem)] border border-white/10 backdrop-blur-sm">
  <svg id="notification-icon" class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
  <span id="notification-text" class="break-text"></span>
</div>

<script>
// DOM Elements cache
let els = {};

// Update all stats (Database + Dashboard)
function updateStats(data) {
  // Database Statistics
  els.users.textContent = data.usersTotal;
  els.admins.textContent = data.adminsTotal;
  els.instances.textContent = data.instancesTotal;
  els.suspended.textContent = data.suspendedTotal;
  els.templates.textContent = data.templatesTotal;
  els.nodes.textContent = data.nodesTotal;
  els.online.textContent = data.onlineNodes;
  els.offline.textContent = data.offlineNodes;
  els.locations.textContent = data.locationsTotal;
  els.apikeys.textContent = data.apiKeysTotal;
  els.plugins.textContent = data.pluginsTotal;
  els.requests.textContent = data.totalRequests;
  els.visitors.textContent = data.uniqueVisitors;
  els.avg.textContent = data.avgRequestsPerHour;

  // Database Information
  els.dbtype.textContent = data.dbType;
  els.dbsize.textContent = data.dbSize;
  els.dburl.textContent = data.dbUrlMasked;
  els.dbtable.textContent = data.dbTable;
  els.dbkeys.textContent = data.totalKeys;
}

// Fetch full dashboard stats
async function fetchDashboardStats() {
  try {
    const res = await fetch('/admin/dashboard/api/stats');
    const data = await res.json();
    updateStats(data);
    return true;
  } catch (e) {
    console.error("Dashboard stats failed", e);
    return false;
  }
}

// Resources Monitor
async function fetchResources() {
  try {
    const res = await fetch('/resourceMonitor');
    const data = await res.json();

    // CPU
    const cpuPercent = Math.round(data.cpu?.percent || 0);
    document.getElementById('cpu-text').textContent = cpuPercent + '%';
    document.getElementById('cpu-graph').innerHTML = Array(20).fill(`<div class="bar" style="height:${cpuPercent}%"></div>`).join('');
    document.getElementById('cpu-cores').textContent = `${data.cpu?.cores || 0} cores`;

    // RAM
    const ramPercent = Math.round(data.ram?.percent || 0);
    document.getElementById('ram-text').textContent = ramPercent + '%';
    document.getElementById('ram-used').textContent = (data.ram?.used || 0).toFixed(1) + ' GB';
    document.getElementById('ram-total').textContent = (data.ram?.total || 0).toFixed(1) + ' GB';
    document.getElementById('ram-bar').style.width = ramPercent + '%';
    document.getElementById('ram-graph').innerHTML = Array(20).fill(`<div class="bar" style="height:${ramPercent}%"></div>`).join('');

    // Disk
    const diskPercent = Math.round(data.disk?.percent || 0);
    document.getElementById('disk-text').textContent = diskPercent + '%';
    document.getElementById('disk-used').textContent = (data.disk?.used || 0).toFixed(1) + ' GB';
    document.getElementById('disk-total').textContent = (data.disk?.total || 0).toFixed(1) + ' GB';
    document.getElementById('disk-bar').style.width = diskPercent + '%';
    document.getElementById('disk-graph').innerHTML = Array(20).fill(`<div class="bar" style="height:${diskPercent}%"></div>`).join('');
  } catch (e) {
    console.error("Resources failed", e);
  }
}

// Live PM2 Logs
let eventSource = null;
let isStreaming = true;
let logBuffer = [];

function createLogEntry(text) {
  const div = document.createElement('div');
  div.className = 'py-px border-l-2 border-transparent hover:border-blue-400 pl-2';
  const time = new Date().toLocaleTimeString('en-US', {hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit'});
  div.innerHTML = `<span class="text-neutral-500 text-xs">[${time}]</span> ${text}`;
  return div;
}

function flushLogs() {
  const container = document.getElementById('logs');
  logBuffer.forEach(text => container.appendChild(createLogEntry(text)));
  logBuffer = [];
  if (container.scrollHeight - container.scrollTop < 300) container.scrollTop = container.scrollHeight;
}

function startStream() {
  if (eventSource) eventSource.close();
  document.getElementById('logs').innerHTML = '<div class="text-neutral-400 italic">Connecting to live logs...</div>';

  eventSource = new EventSource('/admin/dashboard/api/server-logs/stream');
  eventSource.onmessage = e => logBuffer.push(e.data);
  eventSource.onerror = () => logBuffer.push('<span class="text-red-400">[Stream disconnected – retrying...]</span>');

  setInterval(flushLogs, 80);
}

function toggleStream() {
  const btn = document.getElementById('log-btn');
  if (isStreaming) {
    eventSource?.close();
    btn.textContent = 'Resume Stream';
    btn.classList.remove('bg-red-500');
    btn.classList.add('bg-emerald-500');
  } else {
    startStream();
    btn.textContent = 'Stop Stream';
    btn.classList.remove('bg-emerald-500');
    btn.classList.add('bg-red-500');
  }
  isStreaming = !isStreaming;
}

function clearLogs() {
  document.getElementById('logs').innerHTML = '<div class="text-neutral-400 italic p-2">Logs cleared • Waiting for new data...</div>';
  logBuffer = [];
}

// Full refresh
async function refreshAll() {
  const btns = document.querySelectorAll('button');
  btns.forEach(b => b.style.opacity = '0.6');
  await Promise.all([fetchDashboardStats(), fetchResources()]);
  btns.forEach(b => b.style.opacity = '1');
  showNotification('All data refreshed!', 'success');
}

function showNotification(message, type = 'success') {
  const notif = document.getElementById('notification');
  document.getElementById('notification-text').textContent = message;
  notif.className = type === 'success' 
    ? 'fixed bottom-4 sm:bottom-6 right-4 sm:right-6 flex items-center gap-3 bg-emerald-600 text-white px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl shadow-2xl text-xs sm:text-sm font-medium z-50 max-w-[calc(100vw-2rem)] border border-white/10 backdrop-blur-sm' 
    : 'fixed bottom-4 sm:bottom-6 right-4 sm:right-6 flex items-center gap-3 bg-red-600 text-white px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl shadow-2xl text-xs sm:text-sm font-medium z-50 max-w-[calc(100vw-2rem)] border border-white/10 backdrop-blur-sm';
  notif.classList.remove('hidden');
  setTimeout(() => notif.classList.add('hidden'), 3000);
}

// Init everything
window.onload = async () => {
  // Cache all elements
  els = {
    users: document.getElementById('users-text'),
    admins: document.getElementById('admins-text'),
    instances: document.getElementById('instances-text'),
    suspended: document.getElementById('suspended-text'),
    templates: document.getElementById('templates-text'),
    nodes: document.getElementById('nodes-text'),
    online: document.getElementById('online-text'),
    offline: document.getElementById('offline-text'),
    locations: document.getElementById('locations-text'),
    apikeys: document.getElementById('apikeys-text'),
    plugins: document.getElementById('plugins-text'),
    requests: document.getElementById('requests-text'),
    visitors: document.getElementById('visitors-text'),
    avg: document.getElementById('avg-text'),
    dbtype: document.getElementById('dbtype-text'),
    dbsize: document.getElementById('dbsize-text'),
    dburl: document.getElementById('dburl-text'),
    dbtable: document.getElementById('dbtable-text'),
    dbkeys: document.getElementById('dbkeys-text')
  };

  // Load everything
  await fetchDashboardStats();
  await fetchResources();
  startStream();

  // Fast live updates
  setInterval(fetchDashboardStats, 10000);   // every 10s
  setInterval(fetchResources, 2500);         // every 2.5s (fast resources)
};
</script>

<%- include('../../components/template') %>
