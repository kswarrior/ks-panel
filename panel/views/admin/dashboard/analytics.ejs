<%- include('../../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
  <div class="max-w-[1600px] mx-auto">

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-white/5">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
        <div class="min-w-0">
          <div class="flex items-center gap-3 mb-2 flex-wrap">
            <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight truncate">Analytics</h1>
            <div class="px-2 py-0.5 sm:px-3 sm:py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[9px] sm:text-[10px] font-bold uppercase tracking-widest flex items-center gap-1.5 sm:gap-2 whitespace-nowrap">
              <div class="w-1 h-1 sm:w-1.5 sm:h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
              Live Data
            </div>
          </div>
          <p class="text-xs sm:text-sm text-neutral-400 truncate">Detailed overview of your panel's performance and usage.</p>
        </div>

        <button onclick="refreshAll()" class="w-full md:w-auto px-5 py-2.5 rounded-xl bg-white text-black font-bold text-sm shadow-xl shadow-white/5 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
          Refresh Stats
        </button>
      </div>
      <%- include('../../components/dashboard') %>
    </header>

    <!-- Top Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-10">
      <!-- Total Requests -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:bg-white/[0.08] transition-all group">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Total Requests</span>
          <div class="p-2 rounded-lg bg-emerald-500/10 text-emerald-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white mb-1" id="requests-text">0</p>
        <p class="text-xs text-neutral-500">Across all time</p>
      </div>

      <!-- Unique Visitors -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:bg-white/[0.08] transition-all group">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Unique Visitors</span>
          <div class="p-2 rounded-lg bg-blue-500/10 text-blue-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white mb-1" id="visitors-text">0</p>
        <p class="text-xs text-neutral-500">Based on IP tracking</p>
      </div>

      <!-- Avg Load Time -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:bg-white/[0.08] transition-all group">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Avg Load Time</span>
          <div class="p-2 rounded-lg bg-amber-500/10 text-amber-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white mb-1" id="avg-text">0ms</p>
        <p class="text-xs text-neutral-500">Panel response speed</p>
      </div>

      <!-- Nodes Health -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 hover:bg-white/[0.08] transition-all group">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Nodes Health</span>
          <div class="p-2 rounded-lg bg-purple-500/10 text-purple-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white mb-1"><span id="online-nodes-count">0</span><span class="text-neutral-500 text-lg">/<%= nodesTotal %></span></p>
        <p class="text-xs text-neutral-500">Active server nodes</p>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 mb-10">
      <!-- Instance Distribution -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-6 sm:p-8">
        <h3 class="text-lg font-bold text-white mb-8">Instance Distribution</h3>
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="relative w-40 h-40 sm:w-48 sm:h-48 flex-shrink-0">
            <div id="instance-pie" class="w-full h-full rounded-full" style="background: conic-gradient(#fb923c 0% 0%, #60a5fa 0% 100%);"></div>
            <div class="absolute inset-3 sm:inset-4 bg-[#0a0a0a] rounded-full flex flex-col items-center justify-center border border-white/5">
              <span class="text-2xl sm:text-3xl font-bold text-white" id="instance-pie-value"><%= instancesTotal %></span>
              <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Total</span>
            </div>
          </div>
          <div class="flex-1 space-y-4 w-full">
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-2.5 h-2.5 sm:w-3 h-3 rounded-full bg-orange-400"></div>
                <span class="text-xs sm:text-sm font-medium text-neutral-300">Running</span>
              </div>
              <span class="text-xs sm:text-sm font-bold text-white" id="running-count">0</span>
            </div>
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-2.5 h-2.5 sm:w-3 h-3 rounded-full bg-blue-400"></div>
                <span class="text-xs sm:text-sm font-medium text-neutral-300">Suspended</span>
              </div>
              <span class="text-xs sm:text-sm font-bold text-white" id="suspended-count">0</span>
            </div>
          </div>
        </div>
      </div>

      <!-- User Roles -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-6 sm:p-8">
        <h3 class="text-lg font-bold text-white mb-8">User Roles</h3>
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="relative w-40 h-40 sm:w-48 sm:h-48 flex-shrink-0">
            <div id="user-pie" class="w-full h-full rounded-full" style="background: conic-gradient(#fb923c 0% 0%, #34d399 0% 100%);"></div>
            <div class="absolute inset-3 sm:inset-4 bg-[#0a0a0a] rounded-full flex flex-col items-center justify-center border border-white/5">
              <span class="text-2xl sm:text-3xl font-bold text-white" id="user-pie-value"><%= usersTotal %></span>
              <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Users</span>
            </div>
          </div>
          <div class="flex-1 space-y-4 w-full">
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-2.5 h-2.5 sm:w-3 h-3 rounded-full bg-orange-400"></div>
                <span class="text-xs sm:text-sm font-medium text-neutral-300">Regular Users</span>
              </div>
              <span class="text-xs sm:text-sm font-bold text-white" id="regular-users">0</span>
            </div>
            <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5">
              <div class="flex items-center gap-3">
                <div class="w-2.5 h-2.5 sm:w-3 h-3 rounded-full bg-emerald-400"></div>
                <span class="text-xs sm:text-sm font-medium text-neutral-300">Administrators</span>
              </div>
              <span class="text-xs sm:text-sm font-bold text-white" id="admin-users">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Request Heatmap -->
    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-6 sm:p-8 mb-10">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <h3 class="text-lg font-bold text-white">Request Activity (7 Days)</h3>
        <div class="flex items-center gap-4 flex-wrap">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded bg-emerald-400/20"></div>
            <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase">Low</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded bg-emerald-400/60"></div>
            <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase">Med</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded bg-emerald-400"></div>
            <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase">High</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-7 gap-2 sm:gap-4 mb-4" id="request-heatmap">
        <!-- Generated via JS -->
      </div>
      <div class="grid grid-cols-7 gap-2 sm:gap-4 text-center">
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Mon</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Tue</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Wed</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Thu</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Fri</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Sat</span>
        <span class="text-[9px] sm:text-[10px] font-bold text-neutral-600 uppercase tracking-widest">Sun</span>
      </div>

      <div class="mt-8 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
        <div class="min-w-0">
          <span class="text-[9px] sm:text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Total Weekly Load</span>
          <p class="text-xl sm:text-2xl font-bold text-white mt-1 truncate" id="heatmap-total-requests">0 requests</p>
        </div>
        <div class="px-4 sm:px-6 py-2 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] sm:text-xs font-bold border border-emerald-500/20 whitespace-nowrap">
          Optimal Performance
        </div>
      </div>
    </div>

  </div>
</main>

<script>
let els = {};
function updateStats(data) {
  if (els.requests) els.requests.textContent = data.totalRequests.toLocaleString();
  if (els.visitors) els.visitors.textContent = data.uniqueVisitors.toLocaleString();
  if (els.avg) els.avg.textContent = data.avgRequestsPerHour + 'ms';

  const totalInstances = data.instancesTotal || 1;
  const suspended = data.suspendedTotal || 0;
  const running = totalInstances - suspended;
  const runPct = (running / totalInstances) * 100;

  document.getElementById('instance-pie').style.background = `conic-gradient(#fb923c 0% ${runPct}%, #60a5fa ${runPct}% 100%)`;
  document.getElementById('running-count').textContent = running;
  document.getElementById('suspended-count').textContent = suspended;

  const totalUsers = data.usersTotal || 1;
  const admins = data.adminsTotal || 0;
  const regular = totalUsers - admins;
  const regPct = (regular / totalUsers) * 100;

  document.getElementById('user-pie').style.background = `conic-gradient(#fb923c 0% ${regPct}%, #34d399 ${regPct}% 100%)`;
  document.getElementById('regular-users').textContent = regular;
  document.getElementById('admin-users').textContent = admins;

  document.getElementById('online-nodes-count').textContent = data.onlineNodes;

  updateHeatmap(data.totalRequests || 0);
}

function updateHeatmap(total) {
  const container = document.getElementById('request-heatmap');
  let html = '';
  for(let i=0; i<28; i++) {
    const intensity = Math.random();
    let opacity = 'opacity-20';
    if(intensity > 0.7) opacity = 'opacity-100';
    else if(intensity > 0.4) opacity = 'opacity-60';
    html += `<div class="aspect-square rounded-lg bg-emerald-400 ${opacity} hover:scale-110 transition-transform cursor-pointer" title="Load Intensity: ${Math.round(intensity*100)}%"></div>`;
  }
  container.innerHTML = html;
  document.getElementById('heatmap-total-requests').textContent = total.toLocaleString() + ' requests';
}

async function fetchDashboardStats() {
  try {
    const res = await fetch('/admin/dashboard/api/stats');
    updateStats(await res.json());
  } catch (e) { console.error(e); }
}

function refreshAll() {
  fetchDashboardStats();
}

window.onload = () => {
  els = {
    requests: document.getElementById('requests-text'),
    visitors: document.getElementById('visitors-text'),
    avg: document.getElementById('avg-text')
  };
  fetchDashboardStats();
  setInterval(fetchDashboardStats, 15000);
};
</script>

<%- include('../../components/footer') %>
