<%- include('../../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-[1600px] mx-auto">

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-white/5 space-y-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-black text-white tracking-tight">Visitor Analytics</h1>
          <p class="text-neutral-400 mt-2 font-medium">Monitoring traffic patterns and request volume across the platform.</p>
        </div>
      </div>
      <%- include('../../components/dashboard') %>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Traffic Stats -->
      <div class="lg:col-span-2 space-y-8">
        <div class="glass p-8 rounded-[2.5rem]">
          <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-8">Request Volume</h3>
          <div class="flex items-end gap-2 h-48 mb-6">
            <% [40, 60, 45, 90, 65, 80, 100, 70, 85, 95, 50, 75].forEach(h => { %>
              <div class="flex-1 bg-blue-500/20 rounded-t-lg hover:bg-blue-500/40 transition-all cursor-pointer group relative" style="height: <%= h %>%">
                <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-white text-black text-[10px] font-black px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">
                  <%= Math.round(h * 12.5) %> req
                </div>
              </div>
            <% }) %>
          </div>
          <div class="grid grid-cols-3 gap-4 border-t border-white/5 pt-8">
            <div>
              <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-1">Total Requests</p>
              <h4 class="text-2xl font-black text-white"><%= totalRequests %></h4>
            </div>
            <div>
              <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-1">Unique IPs</p>
              <h4 class="text-2xl font-black text-white"><%= uniqueVisitors %></h4>
            </div>
            <div>
              <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-1">Avg Req/Hour</p>
              <h4 class="text-2xl font-black text-white"><%= avgRequestsPerHour %></h4>
            </div>
          </div>
        </div>

        <div class="glass p-8 rounded-[2.5rem]">
          <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6">Top Routes</h3>
          <div class="space-y-4">
            <% sortedRoutes.forEach(([route, count]) => { %>
              <div class="flex items-center justify-between p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors">
                <span class="text-sm font-mono text-blue-400 font-bold"><%= route %></span>
                <span class="text-xs font-black text-white bg-white/10 px-3 py-1 rounded-full"><%= count %> hits</span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <div class="glass p-8 rounded-[2.5rem] bg-indigo-600/5 border-indigo-500/10">
          <h3 class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-6">Top Traffic Sources</h3>
          <div class="space-y-6">
            <% sortedIPs.forEach(([ip, count]) => { %>
              <div class="flex justify-between items-center">
                <div>
                  <p class="text-sm font-bold text-white"><%= ip %></p>
                  <p class="text-[10px] text-neutral-500 font-black uppercase">Unknown Location</p>
                </div>
                <span class="text-xs font-bold text-indigo-400"><%= count %> req</span>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="glass p-8 rounded-[2.5rem]">
          <h3 class="text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6">Platform Distribution</h3>
          <div class="space-y-4">
            <div class="flex justify-between text-xs mb-1"><span class="text-neutral-400">Desktop (Linux/Windows)</span><span class="text-white font-bold">82%</span></div>
            <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-blue-500 w-[82%]"></div></div>

            <div class="flex justify-between text-xs mb-1 pt-2"><span class="text-neutral-400">Mobile (Android/iOS)</span><span class="text-white font-bold">18%</span></div>
            <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-emerald-500 w-[18%]"></div></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../../components/footer') %>
