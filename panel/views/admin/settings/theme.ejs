<%- include('../../components/template') %>

<main id="content" class="min-h-screen pb-10">
  <div class="px-4 sm:px-6 lg:px-8 pt-6">
    <h1 class="text-3xl font-black text-white tracking-tight">Theme Customization</h1>
    <p class="mt-2 text-sm text-neutral-400">Personalize the panel's visual identity with real-time preview.</p>
  </div>

  <%- include('../../components/settings') %>

  <div class="mx-4 sm:mx-6 lg:mx-8 mt-8">
    <form id="themeForm" action="/admin/theme/save" method="POST" class="space-y-8">

      <!-- Global Colors -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Global Colors</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% const colors = [
            { name: '--bg-color', label: 'Background', default: '#0f172a' },
            { name: '--surface-color', label: 'Surface / Cards', default: '#1e2937' },
            { name: '--text-color', label: 'Text Primary', default: '#e2e8f0' },
            { name: '--muted-text', label: 'Muted Text', default: '#94a3b8' },
            { name: '--border-color', label: 'Border Color', default: '#334155' },
            { name: '--primary-color', label: 'Primary Accent', default: '#3b82f6' }
          ]; %>
          <% colors.forEach(color => { %>
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1"><%= color.label %></label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10 transition-all hover:bg-white/[0.07]">
                <input type="color" name="<%= color.name %>" value="<%= theme[color.name] || color.default %>" oninput="updatePreview(this)"
                       class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <span class="text-xs font-mono text-neutral-400 color-value"><%= theme[color.name] || color.default %></span>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <!-- Advanced UI Elements -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Buttons -->
        <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5">
          <h2 class="text-lg font-bold text-white mb-6">Button Styles</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Background</label>
              <input type="color" name="--button-bg" value="<%= theme['--button-bg'] || '#3b82f6' %>" oninput="updatePreview(this)" class="w-full h-10 rounded-xl bg-white/5 border border-white/10 p-1 cursor-pointer">
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Hover State</label>
              <input type="color" name="--button-hover" value="<%= theme['--button-hover'] || '#2563eb' %>" oninput="updatePreview(this)" class="w-full h-10 rounded-xl bg-white/5 border border-white/10 p-1 cursor-pointer">
            </div>
            <div class="space-y-2 sm:col-span-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Border Radius (rem)</label>
              <input type="number" step="0.05" name="--button-radius" value="<%= parseFloat(theme['--button-radius']) || 0.5 %>" oninput="updatePreview(this)"
                     class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-white focus:outline-none">
            </div>
          </div>
        </section>

        <!-- Cards -->
        <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5">
          <h2 class="text-lg font-bold text-white mb-6">Container Styles</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Card BG</label>
              <input type="color" name="--card-bg" value="<%= theme['--card-bg'] || '#1e2937' %>" oninput="updatePreview(this)" class="w-full h-10 rounded-xl bg-white/5 border border-white/10 p-1 cursor-pointer">
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Card Border</label>
              <input type="color" name="--card-border" value="<%= theme['--card-border'] || '#334155' %>" oninput="updatePreview(this)" class="w-full h-10 rounded-xl bg-white/5 border border-white/10 p-1 cursor-pointer">
            </div>
            <div class="space-y-2 sm:col-span-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Card Radius (rem)</label>
              <input type="number" step="0.05" name="--card-radius" value="<%= parseFloat(theme['--card-radius']) || 0.75 %>" oninput="updatePreview(this)"
                     class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-white focus:outline-none">
            </div>
          </div>
        </section>
      </div>

      <!-- Live Preview Area -->
      <section class="p-8 rounded-[2rem] bg-black/20 border-2 border-dashed border-white/10 relative overflow-hidden">
        <div class="absolute top-4 right-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">Live Preview</span>
        </div>
        
        <div class="max-w-md mx-auto space-y-6 text-center">
          <h3 class="text-3xl font-black text-white" id="preview-h1">Modern Interface</h3>
          <p class="text-sm text-neutral-400" id="preview-text">Experience the future of server management with our sleek, customizable glassmorphic design.</p>
          <div class="flex flex-wrap justify-center gap-3">
            <button type="button" class="px-6 py-2.5 rounded-xl bg-blue-500 text-white font-bold text-sm shadow-xl shadow-blue-500/20" id="preview-btn">Action Button</button>
            <div class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-white text-xs font-medium">Secondary</div>
          </div>
        </div>
      </section>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row justify-end gap-4 pt-6 border-t border-white/5">
        <button type="button" onclick="resetToDefault()" class="px-8 py-3 rounded-2xl bg-red-500/10 text-red-400 font-bold text-sm border border-red-500/20 hover:bg-red-500/20 transition-all">
          Reset to Defaults
        </button>
        <button type="submit" class="px-12 py-3 rounded-2xl bg-white text-black font-black text-sm shadow-2xl shadow-white/10 hover:scale-[1.02] active:scale-[0.98] transition-all">
          Save Theme to Database
        </button>
      </div>
    </form>
  </div>
</main>

<script>
  function updatePreview(input) {
    document.documentElement.style.setProperty(input.name, input.value);
    const wrapper = input.closest('div');
    const valueDisplay = wrapper.querySelector('.color-value');
    if (valueDisplay) valueDisplay.textContent = input.value;

    // Direct preview for specific elements
    if (input.name === '--button-bg') document.getElementById('preview-btn').style.backgroundColor = input.value;
    if (input.name === '--text-color') document.getElementById('preview-h1').style.color = input.value;
    if (input.name === '--muted-text') document.getElementById('preview-text').style.color = input.value;
  }

  function resetToDefault() {
    if (!confirm('Reset all values to system defaults?')) return;
    window.location.reload();
  }

  document.getElementById('themeForm').onsubmit = function() {
    const btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Saving...';
  };
</script>

<%- include('../../components/footer') %>
