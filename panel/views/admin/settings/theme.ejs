<%- include('../../components/template') %>

<main id="content" class="animate-fade-in min-h-screen pb-10">
  <div class="px-4 sm:px-6 lg:px-8 pt-6">
    <div class="flex items-center justify-between">
       <div>
          <h1 class="text-3xl font-black text-white tracking-tight">Interface Studio</h1>
          <p class="mt-2 text-sm text-neutral-400">Total visual control over the panel's glassmorphic architecture.</p>
       </div>
       <div class="flex flex-wrap gap-2 sm:gap-3">
          <div type="button" onclick="document.getElementById('importThemeInput').click()" class="cursor-pointer flex-1 sm:flex-none px-4 sm:px-5 py-2 sm:py-3 rounded-xl sm:rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-[10px] sm:text-xs hover:bg-white/10 transition-all flex items-center justify-center gap-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
             Upload
          </div>
          <input type="file" id="importThemeInput" class="hidden" accept=".json" onchange="importTheme(this)">
          <div type="button" onclick="toggleEditor()" class="cursor-pointer flex-1 sm:flex-none px-4 sm:px-5 py-2 sm:py-3 rounded-xl sm:rounded-2xl bg-blue-500 text-white font-bold text-[10px] sm:text-xs shadow-lg shadow-blue-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
             Create
          </div>
       </div>
    </div>
  </div>

  <div class="mx-2 sm:mx-6 lg:mx-8 mt-4 sm:mt-8">
    <!-- Theme Library -->
    <section class="glass p-4 sm:p-8 rounded-2xl sm:rounded-3xl border border-white/5 shadow-2xl mb-6 sm:mb-8">
       <div class="flex items-center gap-3 mb-4 sm:mb-8">
         <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
           <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
         </div>
         <h2 class="text-lg sm:text-xl font-bold text-white">Architectural Library</h2>
       </div>

       <div id="theme-library-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
          <!-- Dynamic Theme Cards -->
          <% if (typeof themeLibrary !== 'undefined' && themeLibrary.length > 0) { %>
             <% themeLibrary.forEach(t => { %>
                <div class="group relative p-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all cursor-pointer overflow-hidden">
                   <div class="flex items-center justify-between mb-3">
                      <div class="flex items-center gap-2">
                         <h3 class="text-sm font-bold text-white"><%= t.name %></h3>
                         <% if (t.id === 'system-default') { %>
                            <svg class="w-3 h-3 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                         <% } %>
                      </div>
                      <% if (t.active) { %>
                         <span class="px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-400 text-[8px] font-black uppercase tracking-widest border border-blue-500/30">Active</span>
                      <% } %>
                   </div>
                   <div class="flex gap-2">
                      <div onclick="activateTheme('<%= t.id %>')" class="cursor-pointer flex-1 py-2 rounded-lg bg-white/5 text-[10px] font-bold text-neutral-400 hover:text-white hover:bg-white/10 transition-all text-center">Deploy</div>
                      <% if (t.id !== 'system-default') { %>
                        <div onclick="editTheme('<%= t.id %>')" class="cursor-pointer p-2 rounded-lg bg-white/5 text-neutral-400 hover:text-white hover:bg-white/10 transition-all" title="Edit">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        </div>
                      <% } %>
                      <div onclick="exportTheme('<%= t.id %>')" class="cursor-pointer p-2 rounded-lg bg-white/5 text-neutral-400 hover:text-white hover:bg-white/10 transition-all" title="Export">
                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                      </div>
                      <% if (t.id !== 'system-default') { %>
                        <div onclick="deleteTheme('<%= t.id %>')" class="cursor-pointer p-2 rounded-lg bg-red-500/5 text-red-500/50 hover:text-red-500 hover:bg-red-500/10 transition-all" title="Purge">
                           <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </div>
                      <% } %>
                   </div>
                </div>
             <% }) %>
          <% } else { %>
             <div class="col-span-full py-10 text-center glass border-dashed border-white/5 rounded-2xl">
                <p class="text-xs text-neutral-600 font-medium">Your architectural library is empty.</p>
             </div>
          <% } %>
       </div>
    </section>

    <form id="themeForm" action="/admin/settings/theme/save" method="POST" class="space-y-8 hidden">
      <input type="hidden" name="theme_id" id="theme_id" value="">
      <!-- Identity -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Identity</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Theme Name</label>
            <input type="text" name="theme_name" value="<%= theme.theme_name || '' %>" placeholder="e.g. Midnight Onyx" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Type</label>
            <input type="text" name="theme_type" value="<%= theme.theme_type || '' %>" placeholder="e.g. Glassmorphic" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Category</label>
            <input type="text" name="theme_category" value="<%= theme.theme_category || '' %>" placeholder="e.g. Dark, Light, Gaming" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
          </div>
        </div>
      </section>

      <!-- Atmosphere & Core -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Atmosphere & Typography</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Dashboard Background</label>
              <input type="text" name="--bg-url-dashboard" value="<%= theme['--bg-url-dashboard'] || '' %>" placeholder="Image URL..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
           </div>
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Auth Background</label>
              <input type="text" name="--bg-url-auth" value="<%= theme['--bg-url-auth'] || '' %>" placeholder="Image URL..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
           </div>
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Admin Background</label>
              <input type="text" name="--bg-url-admin" value="<%= theme['--bg-url-admin'] || '' %>" placeholder="Image URL..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all">
           </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 pt-8 border-t border-white/5">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Accent Primary</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" name="--accent-color" value="<%= theme['--accent-color'] || '#3b82f6' %>" oninput="updatePreview(this)" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--accent-color'] || '#3b82f6' %></span>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">System Font Family</label>
            <select name="--font-family" onchange="updatePreview(this)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all appearance-none cursor-pointer">
              <option value="'Plus Jakarta Sans', sans-serif" <%= theme['--font-family'] ==="'Plus Jakarta Sans', sans-serif" ? 'selected' : '' %>>Plus Jakarta (Default)</option>
              <option value="Inter, sans-serif" <%= theme['--font-family'] ==="Inter, sans-serif" ? 'selected' : '' %>>Inter</option>
              <option value="'JetBrains Mono', monospace" <%= theme['--font-family'] ==="'JetBrains Mono', monospace" ? 'selected' : '' %>>JetBrains Mono</option>
              <option value="system-ui, sans-serif" <%= theme['--font-family'] ==="system-ui, sans-serif" ? 'selected' : '' %>>System UI</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Header Surface</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" id="header-bg-picker" value="#0a0a0a" oninput="updateAlphaColor(this, '--header-bg')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <input type="hidden" name="--header-bg" value="<%= theme['--header-bg'] || 'rgba(10, 10, 10, 0.4)' %>">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--header-bg'] || 'rgba(10,10,10,0.4)' %></span>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Glow Effect</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
               <input type="text" name="--glow-intensity" value="<%= theme['--glow-intensity'] || '0 0 15px rgba(59, 130, 246, 0.5)' %>" oninput="updatePreview(this)" class="w-full bg-transparent border-none text-xs text-white focus:outline-none">
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Global Transparency</label>
            <input type="range" id="alpha-slider" min="0" max="1" step="0.01" value="0.6" oninput="syncAllAlphas(this.value)" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-blue-500">
          </div>
        </div>
      </section>

      <!-- Sidebar Configuration -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 border border-indigo-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Sidebar Architect</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Surface Color</label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
                <input type="color" id="sidebar-bg-picker" value="#0a0a0a" oninput="updateAlphaColor(this, '--sidebar-bg')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <input type="hidden" name="--sidebar-bg" value="<%= theme['--sidebar-bg'] || 'rgba(10, 10, 10, 0.6)' %>">
                <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--sidebar-bg'] || 'rgba(10,10,10,0.6)' %></span>
              </div>
           </div>
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Text Color</label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
                <input type="color" name="--sidebar-text-color" value="<%= theme['--sidebar-text-color'] || '#9ca3af' %>" oninput="updatePreview(this)" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--sidebar-text-color'] || '#9ca3af' %></span>
              </div>
           </div>
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Active State Color</label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
                <input type="color" name="--sidebar-active-text" value="<%= theme['--sidebar-active-text'] || '#ffffff' %>" oninput="updatePreview(this)" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--sidebar-active-text'] || '#ffffff' %></span>
              </div>
           </div>
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Width</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-width-val"><%= theme['--sidebar-width'] || '16rem' %></span>
              </div>
              <input type="range" min="12" max="24" step="0.5" value="<%= parseFloat(theme['--sidebar-width']) || 16 %>" oninput="updateRangeWithUnit(this, '--sidebar-width', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-width" value="<%= theme['--sidebar-width'] || '16rem' %>">
           </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-8 pt-8 border-t border-white/5">
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Blur Intensity</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-blur-val"><%= theme['--sidebar-blur'] || '16px' %></span>
              </div>
              <input type="range" min="0" max="64" step="1" value="<%= parseInt(theme['--sidebar-blur']) || 16 %>" oninput="updateRangeWithUnit(this, '--sidebar-blur', 'px')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-blur" value="<%= theme['--sidebar-blur'] || '16px' %>">
           </div>
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Sidebar Margin</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-margin-val"><%= theme['--sidebar-margin'] || '0rem' %></span>
              </div>
              <input type="range" min="0" max="4" step="0.25" value="<%= parseFloat(theme['--sidebar-margin']) || 0 %>" oninput="updateRangeWithUnit(this, '--sidebar-margin', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-margin" value="<%= theme['--sidebar-margin'] || '0rem' %>">
           </div>
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Corner Radius</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-radius-val"><%= theme['--sidebar-radius'] || '0rem' %></span>
              </div>
              <input type="range" min="0" max="4" step="0.25" value="<%= parseFloat(theme['--sidebar-radius']) || 0 %>" oninput="updateRangeWithUnit(this, '--sidebar-radius', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-radius" value="<%= theme['--sidebar-radius'] || '0rem' %>">
           </div>
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Inner Padding</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-padding-val"><%= theme['--sidebar-padding'] || '1.5rem' %></span>
              </div>
              <input type="range" min="0" max="4" step="0.25" value="<%= parseFloat(theme['--sidebar-padding']) || 1.5 %>" oninput="updateRangeWithUnit(this, '--sidebar-padding', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-padding" value="<%= theme['--sidebar-padding'] || '1.5rem' %>">
           </div>
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Font Size</label>
                 <span class="text-xs font-mono text-indigo-400" id="sidebar-font-size-val"><%= theme['--sidebar-font-size'] || '0.875rem' %></span>
              </div>
              <input type="range" min="0.5" max="1.5" step="0.125" value="<%= parseFloat(theme['--sidebar-font-size']) || 0.875 %>" oninput="updateRangeWithUnit(this, '--sidebar-font-size', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-indigo-500">
              <input type="hidden" name="--sidebar-font-size" value="<%= theme['--sidebar-font-size'] || '0.875rem' %>">
           </div>
        </div>
      </section>

      <!-- Card Architect -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 border border-purple-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Card Architect</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Surface Background</label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
                <input type="color" id="card-bg-picker" value="#0a0a0a" oninput="updateAlphaColor(this, '--card-bg')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <input type="hidden" name="--card-bg" value="<%= theme['--card-bg'] || 'rgba(10, 10, 10, 0.6)' %>">
                <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--card-bg'] || 'rgba(10,10,10,0.6)' %></span>
              </div>
           </div>
           <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Border Tint</label>
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
                <input type="color" id="border-picker" value="#ffffff" oninput="updateAlphaColor(this, '--card-border')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
                <input type="hidden" name="--card-border" value="<%= theme['--card-border'] || 'rgba(255, 255, 255, 0.08)' %>">
