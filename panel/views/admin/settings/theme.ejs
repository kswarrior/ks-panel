<%- include('../../components/template') %>

<main id="content" class="animate-fade-in min-h-screen pb-10">
  <div class="px-4 sm:px-6 lg:px-8 pt-6">
    <div class="flex items-center justify-between">
       <div>
          <h1 class="text-3xl font-black text-white tracking-tight">Interface Studio</h1>
          <p class="mt-2 text-sm text-neutral-400">Total visual control over the panel's glassmorphic architecture.</p>
       </div>
       <div class="flex flex-wrap gap-2 sm:gap-3">
          <button type="button" onclick="document.getElementById('importThemeInput').click()" class="flex-1 sm:flex-none px-4 sm:px-5 py-2 sm:py-3 rounded-xl sm:rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-[10px] sm:text-xs hover:bg-white/10 transition-all flex items-center justify-center gap-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
             Upload
          </button>
          <input type="file" id="importThemeInput" class="hidden" accept=".json" onchange="importTheme(this)">
          <button type="button" onclick="toggleEditor()" class="flex-1 sm:flex-none px-4 sm:px-5 py-2 sm:py-3 rounded-xl sm:rounded-2xl bg-blue-500 text-white font-bold text-[10px] sm:text-xs shadow-lg shadow-blue-500/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
             Create
          </button>
       </div>
    </div>
  </div>

  <div class="mx-2 sm:mx-6 lg:mx-8 mt-4 sm:mt-8">
    <!-- Theme Library -->
    <section class="glass p-4 sm:p-8 rounded-2xl sm:rounded-3xl border border-white/5 shadow-2xl mb-6 sm:mb-8">
       <div class="flex items-center gap-3 mb-4 sm:mb-8">
         <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
           <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
         </div>
         <h2 class="text-lg sm:text-xl font-bold text-white">Architectural Library</h2>
       </div>

       <div id="theme-library-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
          <!-- Dynamic Theme Cards -->
          <% if (typeof themeLibrary !== 'undefined' && themeLibrary.length > 0) { %>
             <% themeLibrary.forEach(t => { %>
                <div class="group relative p-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all cursor-pointer overflow-hidden">
                   <div class="flex items-center justify-between mb-3">
                      <h3 class="text-sm font-bold text-white"><%= t.name %></h3>
                      <% if (t.active) { %>
                         <span class="px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-400 text-[8px] font-black uppercase tracking-widest border border-blue-500/30">Active</span>
                      <% } %>
                   </div>
                   <div class="flex gap-2">
                      <button onclick="activateTheme('<%= t.id %>')" class="flex-1 py-2 rounded-lg bg-white/5 text-[10px] font-bold text-neutral-400 hover:text-white hover:bg-white/10 transition-all">Deploy</button>
                      <button onclick="exportTheme('<%= t.id %>')" class="p-2 rounded-lg bg-white/5 text-neutral-400 hover:text-white hover:bg-white/10 transition-all" title="Export">
                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                      </button>
                      <button onclick="deleteTheme('<%= t.id %>')" class="p-2 rounded-lg bg-red-500/5 text-red-500/50 hover:text-red-500 hover:bg-red-500/10 transition-all" title="Purge">
                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                      </button>
                   </div>
                </div>
             <% }) %>
          <% } else { %>
             <div class="col-span-full py-10 text-center glass border-dashed border-white/5 rounded-2xl">
                <p class="text-xs text-neutral-600 font-medium">Your architectural library is empty.</p>
             </div>
          <% } %>
       </div>
    </section>

    <form id="themeForm" action="/admin/settings/theme/save" method="POST" class="space-y-8 hidden">

      <!-- Core Atmosphere -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
          </div>
          <h2 class="text-xl font-bold text-white">Atmosphere & Colors</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Accent Primary</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" name="--accent-color" value="<%= theme['--accent-color'] || '#3b82f6' %>" oninput="updatePreview(this)" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--accent-color'] || '#3b82f6' %></span>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Sidebar Surface</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" id="sidebar-bg-picker" value="#0a0a0a" oninput="updateAlphaColor(this, '--sidebar-bg')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <input type="hidden" name="--sidebar-bg" value="<%= theme['--sidebar-bg'] || 'rgba(10, 10, 10, 0.6)' %>">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--sidebar-bg'] || 'rgba(10,10,10,0.6)' %></span>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Header Surface</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" id="header-bg-picker" value="#0a0a0a" oninput="updateAlphaColor(this, '--header-bg')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <input type="hidden" name="--header-bg" value="<%= theme['--header-bg'] || 'rgba(10, 10, 10, 0.4)' %>">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--header-bg'] || 'rgba(10,10,10,0.4)' %></span>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Border Tint</label>
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/10">
              <input type="color" id="border-picker" value="#ffffff" oninput="updateAlphaColor(this, '--glass-border')" class="h-10 w-10 rounded-lg bg-transparent border-none cursor-pointer">
              <input type="hidden" name="--glass-border" value="<%= theme['--glass-border'] || 'rgba(255, 255, 255, 0.08)' %>">
              <span class="text-xs font-mono text-neutral-400 color-value"><%= theme['--glass-border'] || 'rgba(255,255,255,0.08)' %></span>
            </div>
          </div>
        </div>

        <!-- Typography & Layout -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-8 border-t border-white/5">
           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Sidebar Width</label>
                 <span class="text-xs font-mono text-blue-400" id="sidebar-width-val"><%= theme['--sidebar-width'] || '16rem' %></span>
              </div>
              <input type="range" min="12" max="24" step="0.5" value="<%= parseFloat(theme['--sidebar-width']) || 16 %>" oninput="updateRangeWithUnit(this, '--sidebar-width', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-blue-500">
              <input type="hidden" name="--sidebar-width" value="<%= theme['--sidebar-width'] || '16rem' %>">
           </div>

           <div class="space-y-4">
              <div class="flex justify-between items-center">
                 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Card Padding</label>
                 <span class="text-xs font-mono text-blue-400" id="card-padding-val"><%= theme['--card-padding'] || '2rem' %></span>
              </div>
              <input type="range" min="0.5" max="4" step="0.25" value="<%= parseFloat(theme['--card-padding']) || 2 %>" oninput="updateRangeWithUnit(this, '--card-padding', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-blue-500">
              <input type="hidden" name="--card-padding" value="<%= theme['--card-padding'] || '2rem' %>">
           </div>

           <div class="space-y-2">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">System Font Family</label>
              <select name="--font-family" onchange="updatePreview(this)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-xs focus:outline-none transition-all appearance-none cursor-pointer">
                 <option value="'Plus Jakarta Sans', sans-serif" <%= theme['--font-family'] ==="'Plus Jakarta Sans', sans-serif" ? 'selected' : '' %>>Plus Jakarta (Default)</option>
                 <option value="Inter, sans-serif" <%= theme['--font-family'] ==="Inter, sans-serif" ? 'selected' : '' %>>Inter</option>
                 <option value="'JetBrains Mono', monospace" <%= theme['--font-family'] ==="'JetBrains Mono', monospace" ? 'selected' : '' %>>JetBrains Mono</option>
                 <option value="system-ui, sans-serif" <%= theme['--font-family'] ==="system-ui, sans-serif" ? 'selected' : '' %>>System UI</option>
              </select>
           </div>
        </div>
      </section>

      <!-- Geometry & Effects -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Structural Geometry -->
        <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 border border-purple-500/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-white">Structural Geometry</h2>
          </div>

          <div class="space-y-6">
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Glass Corner Radius</label>
                <span class="text-xs font-mono text-blue-400" id="card-radius-val"><%= theme['--card-radius'] || '1.5rem' %></span>
              </div>
              <input type="range" name="--card-radius-val-slider" min="0" max="4" step="0.1" value="<%= parseFloat(theme['--card-radius']) || 1.5 %>" oninput="updateRangeWithUnit(this, '--card-radius', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-blue-500">
              <input type="hidden" name="--card-radius" value="<%= theme['--card-radius'] || '1.5rem' %>">
            </div>

            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Button Corner Radius</label>
                <span class="text-xs font-mono text-blue-400" id="btn-radius-val"><%= theme['--btn-radius'] || '0.75rem' %></span>
              </div>
              <input type="range" name="--btn-radius-val-slider" min="0" max="3" step="0.1" value="<%= parseFloat(theme['--btn-radius']) || 0.75 %>" oninput="updateRangeWithUnit(this, '--btn-radius', 'rem')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-blue-500">
              <input type="hidden" name="--btn-radius" value="<%= theme['--btn-radius'] || '0.75rem' %>">
            </div>
          </div>
        </section>

        <!-- Optical Effects -->
        <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 border border-emerald-500/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-white">Optical Effects</h2>
          </div>

          <div class="space-y-6">
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Backdrop Blur Intensity</label>
                <span class="text-xs font-mono text-emerald-400" id="glass-blur-val"><%= theme['--glass-blur'] || '16px' %></span>
              </div>
              <input type="range" name="--glass-blur-val-slider" min="0" max="64" step="1" value="<%= parseInt(theme['--glass-blur']) || 16 %>" oninput="updateRangeWithUnit(this, '--glass-blur', 'px')" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-emerald-500">
              <input type="hidden" name="--glass-blur" value="<%= theme['--glass-blur'] || '16px' %>">
            </div>

            <div class="space-y-4">
              <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Interface Transparency</label>
              <input type="range" id="alpha-slider" min="0" max="1" step="0.01" value="0.6" oninput="syncAllAlphas(this.value)" class="w-full h-1.5 bg-white/10 rounded-lg appearance-none cursor-pointer accent-emerald-500">
              <p class="text-[9px] text-neutral-500 italic">Adjusts the global opacity of all glass surfaces.</p>
            </div>
          </div>
        </section>
      </div>

      <!-- Raw CSS Injector -->
      <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
         <div class="flex items-center gap-3 mb-8">
           <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 border border-amber-500/20">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
           </div>
           <h2 class="text-xl font-bold text-white">Custom Raw CSS</h2>
         </div>

         <div class="space-y-4">
           <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Global Stylesheet Injection</label>
           <textarea name="custom_css" rows="6" placeholder="/* Custom CSS overrides */"
                     class="w-full rounded-2xl bg-white/5 border border-white/10 text-white px-5 py-4 text-xs font-mono focus:outline-none focus:border-amber-500 transition-all resize-y"><%= theme.custom_css %></textarea>
           <p class="text-[10px] text-neutral-600 italic">This CSS will be injected into a &lt;style&gt; tag on every page in the panel. Use carefully to avoid breaking the UI layout.</p>
         </div>
      </section>

      <!-- Live Simulation -->
      <section class="p-12 rounded-[3rem] bg-black/40 border-2 border-dashed border-white/5 relative overflow-hidden flex items-center justify-center min-h-[400px]">
        <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(var(--accent-color) 1px, transparent 1px); background-size: 30px 30px;"></div>
        
        <div class="absolute top-6 left-6 flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-blue-500 animate-ping"></div>
          <span class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.3em]">Neural Simulation</span>
        </div>

        <div class="relative z-10 w-full max-w-lg">
           <div class="glass p-10 shadow-2xl transition-all duration-500" id="preview-container">
              <div class="flex items-center gap-5 mb-8">
                 <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-white" id="preview-icon-box">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                 </div>
                 <div>
                    <h3 class="text-2xl font-black text-white leading-none mb-1">Quantum Instance</h3>
                    <p class="text-xs text-neutral-400 font-bold uppercase tracking-widest">Active Processing</p>
                 </div>
              </div>

              <div class="space-y-4 mb-10">
                 <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full bg-white/20 transition-all duration-500" style="width: 65%; background-color: var(--accent-color);"></div>
                 </div>
                 <div class="flex justify-between text-[10px] font-black text-neutral-500 uppercase tracking-tighter">
                    <span>Resource Load</span>
                    <span>65% Optimal</span>
                 </div>
              </div>

              <div class="flex gap-4">
                 <button type="button" class="flex-1 py-4 rounded-xl font-black text-xs uppercase tracking-widest transition-all hover:scale-[1.05] active:scale-[0.95]" style="background-color: var(--accent-color); color: white; border-radius: var(--btn-radius);">Execute</button>
                 <button type="button" class="px-8 py-4 rounded-xl border border-white/10 font-black text-xs uppercase tracking-widest text-neutral-400" style="border-radius: var(--btn-radius);">Logs</button>
              </div>
           </div>
        </div>
      </section>

      <!-- Global Actions -->
      <div class="flex flex-col sm:flex-row justify-end gap-4 pt-8 border-t border-white/5">
        <button type="button" onclick="toggleEditor()" class="px-10 py-4 rounded-2xl bg-white/5 text-white font-black text-xs uppercase tracking-widest border border-white/10 hover:bg-white/10 transition-all">
          Discard Changes
        </button>
        <button type="button" onclick="saveAsTheme()" class="px-16 py-4 rounded-2xl bg-blue-500 text-white font-black text-xs uppercase tracking-widest shadow-2xl shadow-blue-500/10 hover:scale-[1.02] active:scale-[0.98] transition-all">
          Create & Save
        </button>
      </div>
    </form>
  </div>
</main>

<script>
  function toggleEditor() {
    const form = document.getElementById('themeForm');
    form.classList.toggle('hidden');
    if (!form.classList.contains('hidden')) {
      form.scrollIntoView({ behavior: 'smooth' });
    }
  }

  function updatePreview(input) {
    document.documentElement.style.setProperty(input.name, input.value);
    const wrapper = input.closest('div');
    const valueDisplay = wrapper.querySelector('.color-value');
    if (valueDisplay) valueDisplay.textContent = input.value;
  }

  function updateRangeWithUnit(input, targetVar, unit) {
    const val = input.value + unit;
    document.documentElement.style.setProperty(targetVar, val);
    document.getElementById(targetVar.substring(2) + '-val').textContent = val;
    document.querySelector(`input[name="${targetVar}"]`).value = val;
  }

  function updateAlphaColor(picker, targetVar) {
    const hex = picker.value;
    const alpha = document.getElementById('alpha-slider').value;
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    const rgba = `rgba(${r}, ${g}, ${b}, ${alpha})`;

    document.documentElement.style.setProperty(targetVar, rgba);
    const hiddenInput = document.querySelector(`input[name="${targetVar}"]`);
    hiddenInput.value = rgba;

    picker.parentElement.querySelector('.color-value').textContent = rgba;
  }

  function syncAllAlphas(alpha) {
    const pickers = [
      { id: 'sidebar-bg-picker', var: '--sidebar-bg' },
      { id: 'header-bg-picker', var: '--header-bg' },
      { id: 'border-picker', var: '--glass-border' }
    ];
    pickers.forEach(p => {
      const picker = document.getElementById(p.id);
      updateAlphaColor(picker, p.var);
    });
  }

  async function resetTheme() {
    if (!confirm('Reset all architectural settings to system defaults?')) return;
    const res = await fetch('/admin/settings/theme/reset', { method: 'POST' });
    if (res.ok) window.location.reload();
  }

  async function saveAsTheme() {
    const name = prompt('Enter a name for this new architecture:');
    if (!name) return;

    // Get current form data
    const formData = new FormData(document.getElementById('themeForm'));
    const themeData = {};
    formData.forEach((value, key) => {
      themeData[key] = value;
    });

    const res = await fetch('/admin/settings/theme/library/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, theme: themeData })
    });

    if (res.ok) window.location.reload();
  }

  async function activateTheme(id) {
    if (!confirm('Deploy this architectural configuration?')) return;

    const res = await fetch('/admin/settings/theme/library/activate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });

    if (res.ok) window.location.reload();
  }

  async function deleteTheme(id) {
    if (!confirm('Purge this theme from the library?')) return;

    const res = await fetch('/admin/settings/theme/library/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });

    if (res.ok) window.location.reload();
  }

  function exportTheme(id) {
    window.location.href = `/admin/settings/theme/export/${id}`;
  }

  async function importTheme(input) {
    if (!input.files || !input.files[0]) return;

    const formData = new FormData();
    formData.append('themeFile', input.files[0]);

    const res = await fetch('/admin/settings/theme/import', {
      method: 'POST',
      body: formData
    });

    if (res.ok) {
       window.location.reload();
    } else {
       const err = await res.json();
       alert('Import failed: ' + err.error);
    }
  }

  document.getElementById('themeForm').onsubmit = function() {
    const btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin h-4 w-4 text-black inline mr-2" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Deploying...';
  };
</script>

