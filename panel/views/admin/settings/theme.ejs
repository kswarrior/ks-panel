                     <div class="flex justify-between items-center">
                        <label class="text-[10px] font-bold text-neutral-500 uppercase">Text Size</label>
                        <span class="text-xs font-mono text-orange-400" id="<%= tag %>-size-val"><%= theme['--' + tag + '-size'] || '1rem' %></span>
                     </div>
                     <input type="range" min="0.5" max="5" step="0.125" value="<%= parseFloat(theme['--' + tag + '-size']) || 1 %>" oninput="updateRangeWithUnit(this, '--<%= tag %>-size', 'rem')" class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-orange-500">
                     <input type="hidden" name="--<%= tag %>-size" value="<%= theme['--' + tag + '-size'] || '1rem' %>">
                  </div>
                  <div class="space-y-4">
                     <div class="flex justify-between items-center">
                        <label class="text-[10px] font-bold text-neutral-500 uppercase">Vertical Margin</label>
                        <span class="text-xs font-mono text-orange-400" id="<%= tag %>-margin-val"><%= theme['--' + tag + '-margin'] || '0rem' %></span>
                     </div>
                     <input type="range" min="0" max="4" step="0.25" value="<%= parseFloat(theme['--' + tag + '-margin']) || 0 %>" oninput="updateRangeWithUnit(this, '--<%= tag %>-margin', 'rem')" class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-orange-500">
                     <input type="hidden" name="--<%= tag %>-margin" value="<%= theme['--' + tag + '-margin'] || '0rem' %>">
                  </div>
                  <div class="space-y-4">
                     <div class="flex justify-between items-center">
                        <label class="text-[10px] font-bold text-neutral-500 uppercase">Padding</label>
                        <span class="text-xs font-mono text-orange-400" id="<%= tag %>-padding-val"><%= theme['--' + tag + '-padding'] || '0rem' %></span>
                     </div>
                     <input type="range" min="0" max="4" step="0.25" value="<%= parseFloat(theme['--' + tag + '-padding']) || 0 %>" oninput="updateRangeWithUnit(this, '--<%= tag %>-padding', 'rem')" class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-orange-500">
                     <input type="hidden" name="--<%= tag %>-padding" value="<%= theme['--' + tag + '-padding'] || '0rem' %>">
                  </div>
               </div>
            </div>
          <% }) %>
        </div>
      </section>

      <!-- Live Simulation -->
      <section class="p-6 sm:p-12 rounded-[3rem] bg-black/40 border-2 border-dashed border-white/5 relative overflow-hidden flex flex-col items-center justify-center min-h-[500px]">
        <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(var(--accent-color) 1px, transparent 1px); background-size: 30px 30px;"></div>
        
        <div class="absolute top-6 left-6 flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-blue-500 animate-ping"></div>
          <span class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.3em]">Neural Simulation</span>
        </div>

        <div class="absolute top-6 right-6 flex bg-white/5 p-1 rounded-xl border border-white/10 z-20">
           <div type="button" onclick="setPreviewSize('desktop')" class="cursor-pointer px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-all" id="btn-desktop">Desktop</div>
           <div type="button" onclick="setPreviewSize('phone')" class="cursor-pointer px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-all" id="btn-phone">Phone</div>
        </div>

        <div class="relative z-10 w-full flex justify-center transition-all duration-500" id="preview-wrapper">
           <div class="glass p-10 shadow-2xl transition-all duration-500 w-full max-w-lg theme-typography" id="preview-container">
              <div class="mb-10 pb-10 border-b border-white/5">
                 <h1 class="mb-4">Quantum Dashboard</h1>
                 <h2 class="mb-3">System Overview</h2>
                 <h3 class="mb-2">Module Stats</h3>
                 <p class="mb-4 text-neutral-400">This is a sample paragraph showing how your typography settings will look in the real dashboard. Text should be legible and well-spaced.</p>
                 <pre class="p-4 rounded-lg bg-black/30 text-emerald-400 text-xs overflow-x-auto">
// Sample Code Output
function initialize() {
  console.log("System Online");
}
                 </pre>
              </div>

              <div class="flex items-center gap-5 mb-8">
                 <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-white" id="preview-icon-box">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                 </div>
                 <div>
                    <h3 class="text-2xl font-black text-white leading-none mb-1">Quantum Instance</h3>
                    <p class="text-xs text-neutral-400 font-bold uppercase tracking-widest">Active Processing</p>
                 </div>
              </div>

              <div class="space-y-4 mb-10">
                 <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full bg-white/20 transition-all duration-500" style="width: 65%; background-color: var(--accent-color);"></div>
                 </div>
                 <div class="flex justify-between text-[10px] font-black text-neutral-500 uppercase tracking-tighter">
                    <span>Resource Load</span>
                    <span>65% Optimal</span>
                 </div>
              </div>

              <div class="flex gap-4">
                 <div type="button" class="cursor-pointer flex-1 py-4 rounded-xl font-black text-xs uppercase tracking-widest transition-all hover:scale-[1.05] active:scale-[0.95]" style="background-color: var(--accent-color); color: white; border-radius: var(--btn-radius);">Execute</div>
                 <div type="button" class="cursor-pointer px-8 py-4 rounded-xl border border-white/10 font-black text-xs uppercase tracking-widest text-neutral-400" style="border-radius: var(--btn-radius);">Logs</div>
              </div>
           </div>
        </div>
      </section>

      <!-- Global Actions -->
      <div class="flex flex-col sm:flex-row justify-end gap-4 pt-8 border-t border-white/5">
        <div type="button" onclick="toggleEditor()" class="cursor-pointer px-10 py-4 rounded-2xl bg-white/5 text-white font-black text-xs uppercase tracking-widest border border-white/10 hover:bg-white/10 transition-all">
          Discard Changes
        </div>
        <div type="button" onclick="saveAsTheme()" id="saveBtn" class="cursor-pointer px-16 py-4 rounded-2xl bg-blue-500 text-white font-black text-xs uppercase tracking-widest shadow-2xl shadow-blue-500/10 hover:scale-[1.02] active:scale-[0.98] transition-all">
          Create & Save
        </div>
      </div>
    </form>
  </div>
</main>

<script>
  function setPreviewSize(size) {
    const wrapper = document.getElementById('preview-wrapper');
    const container = document.getElementById('preview-container');
    const btnDesktop = document.getElementById('btn-desktop');
    const btnPhone = document.getElementById('btn-phone');

    if (size === 'phone') {
       wrapper.classList.add('flex-col', 'items-center');
       container.style.width = '375px';
       container.style.height = '667px';
       container.style.borderRadius = '3rem';
       container.style.border = '8px solid rgba(255,255,255,0.1)';
       container.classList.add('overflow-y-auto');
       btnPhone.classList.add('bg-blue-500', 'text-white');
       btnDesktop.classList.remove('bg-blue-500', 'text-white');
    } else {
       wrapper.classList.remove('flex-col', 'items-center');
       container.style.width = '';
       container.style.height = '';
       container.style.borderRadius = 'var(--card-radius)';
       container.style.border = '';
       container.classList.remove('overflow-y-auto');
       btnDesktop.classList.add('bg-blue-500', 'text-white');
       btnPhone.classList.remove('bg-blue-500', 'text-white');
    }
  }

  // Initialize preview
  setPreviewSize('desktop');

  const themeLibrary = <%- JSON.stringify(themeLibrary || []) %>;

  function toggleEditor(editing = false) {
    const form = document.getElementById('themeForm');
    const saveBtn = document.getElementById('saveBtn');

    if (!editing) {
      document.getElementById('theme_id').value = '';
      saveBtn.textContent = 'Create & Save';
      // Reset form to system defaults if not editing
      // (Optional: implement full form reset logic)
    }

    form.classList.toggle('hidden');
    if (!form.classList.contains('hidden')) {
      form.scrollIntoView({ behavior: 'smooth' });
    }
  }

  function editTheme(id) {
    const theme = themeLibrary.find(t => t.id === id);
    if (!theme) return;

    const form = document.getElementById('themeForm');
    const saveBtn = document.getElementById('saveBtn');

    document.getElementById('theme_id').value = id;
    saveBtn.textContent = 'Update Theme';

    // Populate identity
    form.querySelector('input[name="theme_name"]').value = theme.name;
    form.querySelector('input[name="theme_type"]').value = theme.config.theme_type || '';
    form.querySelector('input[name="theme_category"]').value = theme.config.theme_category || '';
    form.querySelector('textarea[name="custom_css"]').value = theme.config.custom_css || '';

    // Populate variables
    Object.keys(theme.config).forEach(key => {
      if (key.startsWith('--')) {
        const input = form.querySelector(`[name="${key}"]`);
        if (input) {
          input.value = theme.config[key];

          // Update visual displays
          document.documentElement.style.setProperty(key, theme.config[key]);

          const valDisplay = document.getElementById(key.substring(2) + '-val');
          if (valDisplay) valDisplay.textContent = theme.config[key];

          const colorVal = input.closest('div')?.querySelector('.color-value');
          if (colorVal) colorVal.textContent = theme.config[key];

          // Handle range sliders specifically
          const slider = form.querySelector(`input[name="${key}-val-slider"]`) || form.querySelector(`input[oninput*="${key}"]`);
          if (slider && slider.type === 'range') {
             slider.value = parseFloat(theme.config[key]);
          }
        }
      }
    });

    form.classList.remove('hidden');
    form.scrollIntoView({ behavior: 'smooth' });
  }

  function updatePreview(input) {
    document.documentElement.style.setProperty(input.name, input.value);
    const wrapper = input.closest('div');
    const valueDisplay = wrapper.querySelector('.color-value');
    if (valueDisplay) valueDisplay.textContent = input.value;
  }

  function updateRangeWithUnit(input, targetVar, unit) {
    const val = input.value + unit;
    document.documentElement.style.setProperty(targetVar, val);
    document.getElementById(targetVar.substring(2) + '-val').textContent = val;
    document.querySelector(`input[name="${targetVar}"]`).value = val;
  }

  function updateAlphaColor(picker, targetVar) {
    const hex = picker.value;
    const alpha = document.getElementById('alpha-slider').value;
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    const rgba = `rgba(${r}, ${g}, ${b}, ${alpha})`;

    document.documentElement.style.setProperty(targetVar, rgba);
    const hiddenInput = document.querySelector(`input[name="${targetVar}"]`);
    if (hiddenInput) hiddenInput.value = rgba;

    const valDisplay = picker.parentElement.querySelector('.color-value');
    if (valDisplay) valDisplay.textContent = rgba;
  }

  function syncAllAlphas(alpha) {
    const pickers = [
      { id: 'sidebar-bg-picker', var: '--sidebar-bg' },
      { id: 'header-bg-picker', var: '--header-bg' },
      { id: 'border-picker', var: '--card-border' },
      { id: 'card-bg-picker', var: '--card-bg' },
      { id: 'input-bg-picker', var: '--input-bg' },
      { id: 'input-border-picker', var: '--input-border' }
    ];
    pickers.forEach(p => {
      const picker = document.getElementById(p.id);
      if (picker) updateAlphaColor(picker, p.var);
    });
  }

  async function resetTheme() {
    if (!confirm('Reset all architectural settings to system defaults?')) return;
    const res = await fetch('/admin/settings/theme/reset', { method: 'POST' });
    if (res.ok) window.location.reload();
  }

  async function saveAsTheme() {
    const themeId = document.getElementById('theme_id').value;
    let name = document.querySelector('input[name="theme_name"]').value;

    if (!themeId && !name) {
       name = prompt('Enter a name for this new architecture:');
       if (!name) return;
    }

    // Get current form data
    const formData = new FormData(document.getElementById('themeForm'));
    const themeData = {};
    formData.forEach((value, key) => {
      themeData[key] = value;
    });

    const url = themeId ? '/admin/settings/theme/library/update' : '/admin/settings/theme/library/save';

    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: themeId, name, theme: themeData })
    });

    if (res.ok) window.location.reload();
    else {
      const err = await res.json();
      alert('Save failed: ' + err.error);
    }
  }

  async function activateTheme(id) {
    if (id === 'system-default') {
       if (!confirm('Reverting to the System Default will override any unsaved changes to your current architecture. Proceed?')) return;
    } else {
       if (!confirm('Deploy this architectural configuration?')) return;
    }

    const res = await fetch('/admin/settings/theme/library/activate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });

    if (res.ok) window.location.reload();
  }

  async function deleteTheme(id) {
    if (!confirm('Purge this theme from the library?')) return;

    const res = await fetch('/admin/settings/theme/library/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });

    if (res.ok) window.location.reload();
  }

  function exportTheme(id) {
    window.location.href = `/admin/settings/theme/export/${id}`;
  }

  async function importTheme(input) {
    if (!input.files || !input.files[0]) return;

    const formData = new FormData();
    formData.append('themeFile', input.files[0]);

    const res = await fetch('/admin/settings/theme/import', {
      method: 'POST',
      body: formData
    });

    if (res.ok) {
       window.location.reload();
    } else {
       const err = await res.json();
       alert('Import failed: ' + err.error);
    }
  }

  document.getElementById('themeForm').onsubmit = function() {
    const btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin h-4 w-4 text-black inline mr-2" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Deploying...';
  };
</script>

<%- include('../../components/footer') %>
