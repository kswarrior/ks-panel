<%- include('../../components/template') %>

<main id="content" class="min-h-screen pb-10">

  <div class="px-4 sm:px-6 lg:px-8 pt-6">
    <h1 class="text-3xl font-black text-white tracking-tight">General Settings</h1>
    <p class="mt-2 text-sm text-neutral-400">Manage panel identity, branding, and registration behavior.</p>
  </div>

  <%- include('../../components/settings') %>

  <div class="mx-4 sm:mx-6 lg:mx-8 mt-8 grid grid-cols-1 lg:grid-cols-2 gap-8">

    <!-- Branding & Identity -->
    <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl flex flex-col gap-8">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 border border-blue-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        <h2 class="text-xl font-bold text-white">Panel Branding</h2>
      </div>

      <div class="space-y-6">
        <!-- Change Name -->
        <form action="/admin/settings/change/name" method="POST" class="space-y-3">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1"><%= req.translations.panelName %></label>
          <div class="flex gap-3">
            <input name="name" type="text" value="<%= name %>" required
                   class="flex-1 rounded-xl bg-white/5 border border-white/10 text-white px-4 py-3 text-sm focus:outline-none focus:border-blue-500 transition-all">
            <button type="submit" class="px-6 py-3 bg-white text-black font-bold text-sm rounded-xl hover:bg-neutral-200 transition-all">Save</button>
          </div>
        </form>

        <!-- Change Logo -->
        <form action="/admin/settings/change/logo" method="POST" enctype="multipart/form-data" class="space-y-4 pt-6 border-t border-white/5">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1">Panel Logo</label>

          <div class="flex items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/5 group cursor-pointer" onclick="document.getElementById('useImage').click()">
            <div class="relative flex items-center">
              <input id="useImage" name="useImage" type="checkbox" class="peer h-6 w-6 rounded-lg bg-white/10 border-white/10 text-blue-500 focus:ring-0 appearance-none transition-all checked:bg-blue-500">
              <svg class="absolute w-4 h-4 text-white ml-1 pointer-events-none opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-neutral-300">Use custom image instead of text</span>
          </div>

          <div id="imageUploadBox" class="hidden animate-fade-in">
            <input type="file" name="logo" id="logo" accept="image/*"
                   class="block w-full text-xs text-neutral-400 file:mr-4 file:py-2.5 file:px-6 file:rounded-xl file:border-0 file:text-xs file:font-black file:bg-blue-500/10 file:text-blue-400 hover:file:bg-blue-500/20 transition-all">
          </div>

          <input type="hidden" name="type" id="logoType" value="none">
          <button id="logoButton" type="submit" class="w-full py-3 bg-white/5 border border-white/10 text-white font-bold text-sm rounded-xl hover:bg-white/10 transition-all">
            <%= req.translations.removeLogo %>
          </button>
        </form>
      </div>
    </section>

    <!-- System Behavior -->
    <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl flex flex-col gap-8">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 border border-emerald-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h2 class="text-xl font-bold text-white">System Access</h2>
      </div>

      <div class="space-y-8">
        <!-- Toggle Register -->
        <form action="/admin/settings/toggle/register" method="POST" class="space-y-4">
          <div class="flex items-center justify-between">
            <div class="space-y-1">
              <h3 class="text-sm font-bold text-white">User Registration</h3>
              <p class="text-xs text-neutral-500">Allow new visitors to create accounts</p>
            </div>
            <div class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= settings.register ? 'bg-emerald-500/10 text-emerald-500' : 'bg-red-500/10 text-red-500' %>">
              <%= settings.register ? 'Active' : 'Disabled' %>
            </div>
          </div>
          <button type="submit" class="w-full py-3 <%= settings.register ? 'bg-red-500/10 text-red-400 border-red-500/20' : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' %> border font-bold text-sm rounded-xl transition-all hover:bg-opacity-20">
            <%= settings.register ? 'Disable Registration' : 'Enable Registration' %>
          </button>
        </form>

        <!-- Toggle Force Verify -->
        <form action="/admin/settings/toggle/force-verify" method="POST" class="space-y-4 pt-8 border-t border-white/5">
          <div class="flex items-center justify-between">
            <div class="space-y-1">
              <h3 class="text-sm font-bold text-white">Email Verification</h3>
              <p class="text-xs text-neutral-500">Require users to confirm their email before access</p>
            </div>
            <div class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= settings.forceVerify ? 'bg-emerald-500/10 text-emerald-500' : 'bg-red-500/10 text-red-500' %>">
              <%= settings.forceVerify ? 'Enforced' : 'Optional' %>
            </div>
          </div>
          <button type="submit" class="w-full py-3 <%= settings.forceVerify ? 'bg-red-500/10 text-red-400 border-red-500/20' : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' %> border font-bold text-sm rounded-xl transition-all hover:bg-opacity-20">
            <%= settings.forceVerify ? 'Disable Requirement' : 'Enable Requirement' %>
          </button>
        </form>
      </div>
    </section>

    <!-- Backgrounds (Full Width) -->
    <section class="glass p-6 sm:p-8 rounded-3xl border border-white/5 shadow-2xl lg:col-span-2">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 border border-purple-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h2 class="text-xl font-bold text-white">Dynamic Backgrounds</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Upload -->
        <form action="/admin/settings/change/background" method="POST" enctype="multipart/form-data" class="space-y-4">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Local Upload</label>
          <input type="file" name="bg" accept="image/*,video/mp4"
                 class="block w-full text-xs text-neutral-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-white/5 file:text-neutral-300 hover:file:bg-white/10 transition-all">
          <input type="hidden" name="type" value="upload">
          <button type="submit" class="w-full py-2.5 bg-white text-black font-bold text-xs rounded-xl hover:bg-neutral-200 transition-all">Upload & Apply</button>
        </form>

        <!-- URL -->
        <form action="/admin/settings/change/background" method="POST" class="space-y-4">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Remote URL (GIF/Image)</label>
          <input type="text" name="url" placeholder="https://..."
                 class="w-full rounded-xl bg-white/5 border border-white/10 text-white px-4 py-2 text-xs focus:outline-none focus:border-blue-500 transition-all">
          <input type="hidden" name="type" value="url">
          <button type="submit" class="w-full py-2.5 bg-white text-black font-bold text-xs rounded-xl hover:bg-neutral-200 transition-all">Save URL</button>
        </form>

        <!-- Presets -->
        <div class="space-y-4">
          <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest">Quick Presets</label>
          <div class="grid grid-cols-2 gap-2">
            <% [1,2,3,4].forEach(i => { %>
            <form action="/admin/settings/change/background" method="POST">
              <input type="hidden" name="type" value="preset">
              <input type="hidden" name="preset" value="<%= i %>">
              <button type="submit" class="w-full py-2 rounded-lg bg-white/5 border border-white/5 text-[10px] font-bold text-neutral-400 hover:text-white hover:bg-white/10 transition-all">Preset <%= i %></button>
            </form>
            <% }) %>
          </div>
        </div>
      </div>

      <form action="/admin/settings/change/background" method="POST" class="mt-8 pt-6 border-t border-white/5">
        <input type="hidden" name="type" value="none">
        <button type="submit" class="w-full py-3 bg-red-500/10 text-red-400 font-bold text-sm rounded-xl border border-red-500/20 hover:bg-red-500/20 transition-all">Remove Current Background</button>
      </form>
    </section>
  </div>

</main>

<%- include('../../components/footer') %>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const useImage = document.getElementById('useImage');
  const imageUploadBox = document.getElementById('imageUploadBox');
  const logoButton = document.getElementById('logoButton');
  const logoType = document.getElementById('logoType');

  if (useImage) {
    useImage.addEventListener('change', function () {
      if (this.checked) {
        imageUploadBox.classList.remove('hidden');
        logoButton.textContent = '<%= req.translations.saveNewLogo %>';
        logoType.value = 'image';
      } else {
        imageUploadBox.classList.add('hidden');
        logoButton.textContent = '<%= req.translations.removeLogo %>';
        logoType.value = 'none';
      }
    });
  }
});
</script>
