<%- include('../../components/template') %>
<main id="content">
  <style>
.input-error {
    border: 2px solid rgb(255, 69, 69);
}

.error-message {
    color: rgb(255, 69, 69);
    font-size: 0.9rem;
}
  </style>
   <div class="bg-transparent">
      <div class="sm:flex sm:items-center px-8 pt-4">
         <div class="sm:flex-auto">
           <h1 class="text-base font-medium leading-6 text-white"><%= req.translations.instances %></h1>
           <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.instancesText %></p>
         </div>
         <div class="mt-4 sm:ml-8 sm:mt-0 sm:flex-none">
           <a href="/admin/instances" class="block rounded-xl bg-white text-black px-3 py-2 text-center text-sm font-medium shadow-lg transition focus:outline focus:outline-2 focus:outline-offset-2">
            ← Back to Instances
          </a>
         </div>
       </div>

      <div id="instanceForm" class="flex flex-col lg:flex-row gap-6 mt-6 px-4 sm:px-8 w-full">
    <div class="p-4 sm:p-6 lg:p-10 bg-transparent shadow-xl border border-white/5 rounded-xl overflow-hidden w-full lg:max-w-[800px] card">
        <form>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block"><%= req.translations.name %>:</label>
                    <input id="name" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all" placeholder="My instance">
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block"><%= req.translations.user %>:</label>
                    <select id="user" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 border border-white/5 transition-all">
                        <% users.forEach(function(user) { %>
                            <option value="<%= user.userId %>" class="bg-neutral-800 text-white"><%= user.username %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block">Template:</label>
                    <select id="template" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 border border-white/5 transition-all">
                        <option value="" class="bg-neutral-800 text-white">-- Select template --</option>
                        <% templates.forEach(function(template) { %>
                            <option value="<%= template.filename %>" class="bg-neutral-800 text-white" data-variables="<%= JSON.stringify(template.Variables || []) %>"><%= template.Name %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block"><%= req.translations.node %>:</label>
                    <select id="node" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 border border-white/5 transition-all">
                        <option value="" class="bg-neutral-800 text-white">-- Select node --</option>
                        <% nodes.forEach(function(node) { %>
                            <option value="<%= node.id %>" class="bg-neutral-800 text-white"><%= node.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block"><%= req.translations.memory %> (MiB):</label>
                    <input id="memory" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all" placeholder="2048">
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block"><%= req.translations.cpuThreads %>:</label>
                    <input id="cpu" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all" placeholder="1">
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block">Threads:</label>
                    <input id="threads" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all" placeholder="1">
                </div>

                <div>
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block">Disk (MiB):</label>
                    <input id="disk" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all" placeholder="10240">
                </div>

                <div class="sm:col-span-2">
                    <label class="text-neutral-400 text-sm tracking-tight mb-2 block">Select Host Port (Allocation) (IP:Port):</label>
                    <select id="primary" class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-2 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 border border-white/5 transition-all" required>
                        <option value="" class="bg-neutral-800 text-white">-- Select node first --</option>
                    </select>
                    <small class="text-neutral-500 block">Choose an available IP:Port from the selected node</small>
                </div>
            </div>

            <div class="mt-8">
                <button id="createNodeBtn" type="button" class="w-full sm:w-auto block rounded-xl bg-white text-black px-8 py-3 text-center text-sm font-bold shadow-lg hover:bg-neutral-200 active:scale-95 transition-all focus:outline focus:outline-2 focus:outline-offset-2">
                    <%= req.translations.create %>
                </button>
            </div>
        </form>
    </div>

    <div id="secondCard" class="p-4 sm:p-6 lg:p-10 bg-transparent shadow-xl border border-white/5 rounded-xl overflow-hidden w-full lg:max-w-[800px] card hidden">
        <form id="variablesForm" class="space-y-4">
            </form>
    </div>
</div>

</main>

    <!-- FIXED SCRIPT: now handles array format from your template -->
    <script>
  document.getElementById('template').addEventListener('change', function(event) {
      var selectedOption = event.target.options[event.target.selectedIndex];
      var variablesStr = selectedOption.getAttribute('data-variables');
      var secondCard = document.getElementById('secondCard');
      var variablesForm = document.getElementById('variablesForm');

      variablesForm.innerHTML = ''; // clear previous fields

      if (variablesStr && variablesStr !== '[]' && variablesStr !== '{}') {
          secondCard.classList.remove('hidden');
          
          let variables;
          try {
              variables = JSON.parse(variablesStr);
          } catch (e) {
              console.error("Failed to parse variables:", e);
              secondCard.classList.add('hidden');
              return;
          }

          if (Array.isArray(variables)) {
              // Your format: array of objects [{id, name, description, default}, ...]
              variables.forEach(function(variable) {
                  const id = variable.id || 'unknown';
                  const label = variable.name || id;
                  const defaultVal = variable.default || '';
                  const desc = variable.description || '';

                  const fieldHtml = `
                      <div>
                          <label class="text-neutral-400 text-sm tracking-tight mb-2 block">${label}:</label>
                          <input type="text" name="${id}" value="${defaultVal}" 
                                 class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all"
                                 placeholder="${desc}">
                          ${desc ? `<small class="text-neutral-500 block mt-1">${desc}</small>` : ''}
                      </div>
                  `;
                  variablesForm.insertAdjacentHTML('beforeend', fieldHtml);
              });
          } else {
              // Fallback for old object format (if any template still uses it)
              for (var key in variables) {
                  if (variables.hasOwnProperty(key)) {
                      var variable = variables[key];
                      var fieldHtml = `
                          <div>
                              <label class="text-neutral-400 text-sm tracking-tight mb-2 block">${key}:</label>
                              <input type="text" name="${key}" value="${variable.default || ''}" 
                                     class="rounded-xl focus:ring-2 focus:ring-white/10 focus:border-transparent text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-600/20 placeholder:text-white/20 border border-white/5 transition-all">
                          </div>
                      `;
                      variablesForm.insertAdjacentHTML('beforeend', fieldHtml);
                  }
              }
          }
      } else {
          secondCard.classList.add('hidden');
      }
  });
</script>

<script>
  // ────────────────────────────────────────────────
  // Load available allocations when node changes
  // ────────────────────────────────────────────────
  document.getElementById('node')?.addEventListener('change', async (e) => {
    const nodeId = e.target.value;
    const allocSelect = document.getElementById('primary');

    if (!allocSelect) return;

    allocSelect.innerHTML = '<option value="">Loading available ports...</option>';

    if (!nodeId) {
      allocSelect.innerHTML = '<option value="">-- Select node first --</option>';
      return;
    }

    try {
      const response = await fetch(`/admin/nodes/overview/${nodeId}/available-allocations`);
      if (!response.ok) throw new Error('Failed to load ports');

      const allocations = await response.json();

      allocSelect.innerHTML = '<option value="">-- Choose available host port --</option>';

      if (!Array.isArray(allocations) || allocations.length === 0) {
        allocSelect.innerHTML = '<option value="">No available ports on this node</option>';
        return;
      }

      allocations.forEach(alloc => {
        const display = alloc.label.replace(/ \(.+\)$/, '');
        const option = document.createElement('option');
        option.value = display; // full IP:Port
        option.textContent = display;
        allocSelect.appendChild(option);
      });

    } catch (err) {
      console.error(err);
      allocSelect.innerHTML = '<option value="">Error loading ports</option>';
    }
  });
</script>
<script>
document.getElementById('createNodeBtn').addEventListener('click', async function() {
    const createBtn = this;
    createBtn.textContent = 'Working on it...';
    createBtn.disabled = true;

    const name = document.getElementById('name');
    const memory = document.getElementById('memory');
    const cpu = document.getElementById('cpu');
    const threads = document.getElementById('threads');
    const disk = document.getElementById('disk');
    const templateDropdown = document.getElementById('template');
    const primaryAlloc = document.getElementById('primary');
    const selectedTemplate = templateDropdown.options[templateDropdown.selectedIndex];
    const variablesForm = document.getElementById('variablesForm');
    
    const inputs = variablesForm.querySelectorAll('div > input');
    const variables = Array.from(inputs).reduce((acc, input) => {
        if (input.name) {
            acc[input.name] = input.value;
        }
        return acc;
    }, {});

    clearValidationErrors();

    let isValid = true;

    if (name.value.includes(' ')) {
        showError(name, 'Name must not contain spaces.');
        isValid = false;
    }

    if (!isPositiveInteger(memory.value)) {
        showError(memory, 'Memory must be an integer greater than 1.');
        isValid = false;
    }

    if (!isPositiveIntegerCpu(cpu.value)) {
        showError(cpu, 'CPU must be an integer greater than 0.');
        isValid = false;
    }

    if (!isPositiveInteger(threads.value)) {
        showError(threads, 'Threads must be an integer greater than 0.');
        isValid = false;
    }

    if (!isPositiveInteger(disk.value)) {
        showError(disk, 'Disk must be an integer greater than 1.');
        isValid = false;
    }

    if (!primaryAlloc.value.includes(':')) {
        showError(primaryAlloc, 'Please select a valid IP:Port allocation.');
        isValid = false;
    }

    if (!isValid) {
        createBtn.textContent = 'Create';
        createBtn.disabled = false;
        return;
    }

    // Split allocation into IP and Port
    const [allocationIp, allocationPort] = primaryAlloc.value.split(':');

    const deployData = {
        name: name.value,
        user: document.getElementById('user').value,
        templateFilename: templateDropdown.value,
        nodeId: document.getElementById('node').value,
        memory: memory.value,
        cpu: cpu.value,
        threads: threads.value,
        disk: disk.value,
        allocationIp: allocationIp,
        allocationPort: allocationPort,
        variables: variables
    };

    await sendData(deployData, createBtn);
});

function clearValidationErrors() {
    const inputs = document.querySelectorAll('.input-error');
    const messages = document.querySelectorAll('.error-message');
    inputs.forEach(input => input.classList.remove('input-error'));
    messages.forEach(msg => msg.remove());
}
    
function showError(element, message) {
    element.classList.add('input-error');
    const errorDiv = document.createElement('div');
    errorDiv.textContent = message;
    errorDiv.className = 'error-message';
    element.parentNode.insertBefore(errorDiv, element.nextSibling);
}

function isPositiveInteger(value) {
    const num = parseInt(value, 10);
    return Number.isInteger(num) && num > 1;
}

function isPositiveIntegerCpu(value) {
    const num = parseInt(value, 10);
    return Number.isInteger(num) && num > 0;
}

async function sendData(deployData, createBtn) {
    try {
        const response = await fetch('/admin/instances/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(deployData)
        });

        if (response.ok) {
            window.location.href = '../admin/instances/overview?err=CREATED';
        } else {
            const errData = await response.json();
            throw errData;
        }
    } catch (error) {
        console.error('Error creating instance:', error);
        alert(`Error! Instance creation failed. Details: ${error.error || error.message || 'Check server logs'}`);
        createBtn.textContent = 'Create';
        createBtn.disabled = false;
    }
}
</script>
<%- include('../../components/footer') %>
