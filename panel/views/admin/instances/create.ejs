<!-- Template Variables Handler -->
<script>
  document.getElementById('template').addEventListener('change', function(event) {
    const selectedOption = event.target.options[event.target.selectedIndex];
    const variablesStr = selectedOption.getAttribute('data-variables');
    const secondCard = document.getElementById('secondCard');
    const variablesForm = document.getElementById('variablesForm');

    variablesForm.innerHTML = '';

    if (variablesStr && variablesStr !== '[]' && variablesStr !== '{}') {
      secondCard.classList.remove('hidden');
      let variables;
      try { 
        variables = JSON.parse(variablesStr); 
      } catch(e) { 
        console.error(e); 
        secondCard.classList.add('hidden'); 
        return; 
      }

      if (Array.isArray(variables)) {
        variables.forEach(function(variable, index) {
          const id = variable.id || 'unknown';
          const label = variable.name || id;
          const defaultVal = variable.default || '';
          const desc = variable.description || '';
          
          const fieldHtml = `
            <div class="field-group col-12 animate-fade-in" style="animation-delay: ${index * 50}ms">
              <label class="field-label">${label}</label>
              <input type="text" name="${id}" value="${defaultVal}" class="input-field" placeholder="${desc || 'Enter value...'}">
              ${desc ? `<span class="helper-text">${desc}</span>` : ''}
            </div>`;
          
          variablesForm.insertAdjacentHTML('beforeend', fieldHtml);
        });
      }
    } else {
      secondCard.classList.add('hidden');
    }
  });
</script>

<!-- Node Allocation Loader -->
<script>
  document.getElementById('node').addEventListener('change', async (e) => {
    const nodeId = e.target.value;
    const allocSelect = document.getElementById('primary');
    
    // Optimistic loading state
    allocSelect.disabled = true;
    allocSelect.innerHTML = '<option value="">Loading available ports...</option>';
    allocSelect.classList.add('skeleton');

    if (!nodeId) {
      allocSelect.innerHTML = '<option value="">Select a node first...</option>';
      allocSelect.disabled = true;
      allocSelect.classList.remove('skeleton');
      return;
    }

    try {
      // Simulate network delay for better UX (remove in production if too fast)
      await new Promise(r => setTimeout(r, 300));
      
      const response = await fetch(`/admin/nodes/overview/${nodeId}/available-allocations`);
      
      if (!response.ok) throw new Error('Failed to load');
      
      const allocations = await response.json();

      allocSelect.innerHTML = '<option value="">Choose available host port...</option>';
      allocations.forEach(alloc => {
        const display = alloc.label.replace(/ \(.+\)$/, '');
        const option = document.createElement('option');
        option.value = display;
        option.textContent = display;
        option.className = 'bg-[#1c3b54] text-white';
        allocSelect.appendChild(option);
      });
      
      allocSelect.disabled = false;
      showToast('Ports loaded successfully', 'success');
    } catch (err) {
      allocSelect.innerHTML = '<option value="">Error loading ports. Try again.</option>';
      showToast('Failed to load available ports', 'error');
    } finally {
      allocSelect.classList.remove('skeleton');
    }
  });
</script>

<!-- Form Submission Handler -->
<script>
  // Toast notification system
  function showToast(message, type = 'info') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    
    const icon = type === 'success' 
      ? '<svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>'
      : type === 'error'
      ? '<svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>'
      : '<svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
    
    toast.innerHTML = `${icon}<span class="text-white text-sm font-medium">${message}</span>`;
    container.appendChild(toast);
    
    setTimeout(() => {
      toast.style.animation = 'slideInRight 0.3s ease-out reverse forwards';
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  document.getElementById('instanceForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('createInstancesBtn');
    const originalContent = btn.innerHTML;
    
    // Set loading state
    btn.disabled = true;
    btn.classList.add('loading');
    btn.innerHTML = '<span class="opacity-0">Creating...</span>';

    // Get values
    const name = document.getElementById('name').value.trim();
    const user = document.getElementById('user').value;
    const template = document.getElementById('template').value;
    const nodeId = document.getElementById('node').value;
    const memory = document.getElementById('memory').value;
    const cpu = document.getElementById('cpu').value;
    const disk = document.getElementById('disk').value;
    const primary = document.getElementById('primary').value;

    clearValidationErrors();

    let valid = true;
    
    // Validation with visual feedback
    if (!name || name.includes(' ')) { 
      showError(document.getElementById('name'), 'Name is required and cannot contain spaces'); 
      valid = false; 
    }
    if (!template) { 
      showToast('Please select a template', 'error'); 
      valid = false; 
    }
    if (!nodeId) { 
      showToast('Please select a node', 'error'); 
      valid = false; 
    }
    if (!primary || !primary.includes(':')) { 
      showError(document.getElementById('primary'), 'Please select a valid IP:Port allocation'); 
      valid = false; 
    }
    if (!isPositiveInteger(memory)) { 
      showError(document.getElementById('memory'), 'Memory must be an integer greater than 1'); 
      valid = false; 
    }
    if (!isPositiveIntegerCpu(cpu)) { 
      showError(document.getElementById('cpu'), 'CPU must be an integer greater than 0'); 
      valid = false; 
    }
    if (!isPositiveInteger(disk)) { 
      showError(document.getElementById('disk'), 'Disk must be an integer greater than 1'); 
      valid = false; 
    }

    if (!valid) {
      btn.disabled = false;
      btn.classList.remove('loading');
      btn.innerHTML = originalContent;
      showToast('Please fix the errors above', 'error');
      return;
    }

    const [allocationIp, allocationPort] = primary.split(':');
    const variables = {};
    document.querySelectorAll('#variablesForm input').forEach(inp => { 
      if (inp.name) variables[inp.name] = inp.value; 
    });

    const data = {
      name, 
      user, 
      templateFilename: template, 
      nodeId,
      memory: parseInt(memory), 
      cpu: parseInt(cpu), 
      disk: parseInt(disk),
      allocationIp, 
      allocationPort: parseInt(allocationPort), 
      variables
    };

    try {
      const res = await fetch('/admin/instances/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      let result;
      const contentType = res.headers.get('content-type');
      
      if (contentType && contentType.includes('application/json')) {
        result = await res.json();
      } else {
        const text = await res.text();
        result = { 
          error: text.includes('<!DOCTYPE') 
            ? 'Server error occurred. Please check the logs.' 
            : text 
        };
      }

      if (res.ok) {
        showToast('Instance created successfully! Redirecting...', 'success');
        setTimeout(() => {
          window.location.href = '/admin/instances/overview/?err=CREATED';
        }, 1000);
      } else {
        throw new Error(result.error || result.message || 'Unknown error occurred');
      }
    } catch (err) {
      console.error(err);
      showToast(`Creation failed: ${err.message}`, 'error');
      btn.disabled = false;
      btn.classList.remove('loading');
      btn.innerHTML = originalContent;
    }
  });

  function clearValidationErrors() {
    document.querySelectorAll('.input-error').forEach(el => {
      el.classList.remove('input-error');
    });
    document.querySelectorAll('.error-message').forEach(el => el.remove());
  }

  function showError(el, msg) {
    el.classList.add('input-error');
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    
    // Remove existing error
    const existing = el.parentNode.querySelector('.error-message');
    if (existing) existing.remove();
    
    const div = document.createElement('div');
    div.className = 'error-message';
    div.innerHTML = `
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      ${msg}
    `;
    el.parentNode.appendChild(div);
  }

  function isPositiveInteger(v) { 
    const n = parseInt(v, 10); 
    return Number.isInteger(n) && n > 1; 
  }
  
  function isPositiveIntegerCpu(v) { 
    const n = parseInt(v, 10); 
    return Number.isInteger(n) && n > 0; 
  }
</script>

