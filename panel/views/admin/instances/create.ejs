<%- include('../../components/template') %>
<style>
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  placeholder-color: rgba(255, 255, 255, 0.4);
  outline: none;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

.form-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  width: 100%;
}

.field-long,
.field-short {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex-grow: 1;
}

.field-long {
  flex-basis: 420px;
  min-width: 260px;
}

.field-short {
  flex-basis: 180px;
  min-width: 160px;
}

@media (min-width: 1024px) {
  .form-row {
    gap: 2rem;
  }

  .field-long {
    flex: 2 1 420px;
  }

  .field-short {
    flex: 1 1 180px;
  }
}

/* checkbox / radio */
.proxy-checkbox,
.radio-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.proxy-checkbox input[type="checkbox"] {
  accent-color: #3b82f6;
}

.radio-group input[type="radio"] {
  accent-color: #3b82f6;
}

.radio-option {
  display: flex;
  align-items: center;
  padding: 0.75rem;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 0.5rem;
  cursor: pointer;
  transition: background-color 0.2s ease;
  gap: 0.75rem;
}

.radio-option:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

.proxy-checkbox {
  align-items: flex-start;
  padding: 0.75rem;
  background-color: rgba(75, 85, 99, 0.3);
  border-radius: 0.5rem;
  gap: 0.75rem;
}

/* select textarea */
textarea.input-field,
select.input-field {
  resize: vertical;
  min-height: 3rem;
}

/* hidden */
.hidden {
  display: none;
}
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight">Create New Instance</h1>
        <p class="mt-1 text-sm text-neutral-400">Deploy a new server instance using a template with custom resources and port allocation</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/admin/instances'" 
                class="flex items-center gap-2 px-5 py-2.5 rounded-[10px] bg-neutral-900/70 hover:bg-neutral-800 border border-white/10 text-neutral-300 text-sm font-medium transition-all duration-200 active:scale-95 shadow-sm">
          ← Back to Instances
        </button>
      </div>
    </header>

    <section class="mt-12">
      <div class="max-w-5xl mx-auto bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 lg:p-12 shadow-sm">
        <form id="instanceForm">

          <!-- BASIC -->
          <div class="flex items-center gap-4 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">BASIC INFORMATION</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2"><%= req.translations.name %> <span class="text-red-400">*</span></label>
              <input id="name" class="input-field" placeholder="My instance" required>
            </div>
          </div>

          <div class="form-row">
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2"><%= req.translations.user %> <span class="text-red-400">*</span></label>
              <select id="user" class="input-field" required>
                <% users.forEach(function(user) { %>
                  <option value="<%= user.userId %>" class="bg-neutral-800 text-white"><%= user.username %></option>
                <% }); %>
              </select>
            </div>

            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">Template <span class="text-red-400">*</span></label>
              <select id="template" class="input-field" required>
                <option value="" class="bg-neutral-800 text-white">-- Select template --</option>
                <% templates.forEach(function(template) { %>
                  <option value="<%= template.filename %>" class="bg-neutral-800 text-white" data-variables="<%= JSON.stringify(template.Variables || []) %>"><%= template.Name %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2"><%= req.translations.node %> <span class="text-red-400">*</span></label>
              <select id="node" class="input-field" required>
                <option value="" class="bg-neutral-800 text-white">-- Select node --</option>
                <% nodes.forEach(function(node) { %>
                  <option value="<%= node.id %>" class="bg-neutral-800 text-white"><%= node.name %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <!-- RESOURCES -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">RESOURCES</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2"><%= req.translations.memory %> (MiB) <span class="text-red-400">*</span></label>
              <input id="memory" class="input-field" placeholder="2048" required>
            </div>

            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2"><%= req.translations.cpuThreads %> <span class="text-red-400">*</span></label>
              <input id="cpu" class="input-field" placeholder="1" required>
            </div>

            <div class="field-short">
              <label class="text-xs font-medium text-neutral-400 block mb-2">Disk (MiB) <span class="text-red-400">*</span></label>
              <input id="disk" class="input-field" placeholder="10240" required>
            </div>
          </div>

          <!-- ALLOCATION -->
          <div class="flex items-center gap-4 mt-10 mb-6">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            <h2 class="text-lg font-semibold text-white tracking-wide">ALLOCATION (HOST PORT)</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
          </div>

          <div class="form-row">
            <div class="field-long">
              <label class="text-xs font-medium text-neutral-400 block mb-2">Select Host Port (Allocation) (IP:Port) <span class="text-red-400">*</span></label>
              <select id="primary" class="input-field" required>
                <option value="" class="bg-neutral-800 text-white">-- Select node first --</option>
              </select>
              <small class="text-neutral-500 block mt-2">Choose an available IP:Port from the selected node</small>
            </div>
          </div>

          <!-- TEMPLATE VARIABLES (dynamic) -->
          <div id="secondCard" class="hidden mt-10">
            <div class="flex items-center gap-4 mb-6">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
              <h2 class="text-lg font-semibold text-white tracking-wide">TEMPLATE VARIABLES</h2>
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
            </div>
            <div id="variablesForm" class="space-y-6"></div>
          </div>

          <!-- SUBMIT -->
          <div class="mt-10">
            <button id="createInstancesBtn" type="button"
                    class="w-full px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
              <%= req.translations.create %>
            </button>
          </div>

        </form>
      </div>
    </section>

    <div id="notification" 
         class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
      <span id="notification-text"></span>
    </div>
  </div>

  <script>
    // Template variables handler
    document.getElementById('template').addEventListener('change', function(event) {
      var selectedOption = event.target.options[event.target.selectedIndex];
      var variablesStr = selectedOption.getAttribute('data-variables');
      var secondCard = document.getElementById('secondCard');
      var variablesForm = document.getElementById('variablesForm');

      variablesForm.innerHTML = '';

      if (variablesStr && variablesStr !== '[]' && variablesStr !== '{}') {
          secondCard.classList.remove('hidden');
          let variables;
          try { variables = JSON.parse(variablesStr); } catch(e) { console.error(e); secondCard.classList.add('hidden'); return; }

          if (Array.isArray(variables)) {
              variables.forEach(function(variable) {
                  const id = variable.id || 'unknown';
                  const label = variable.name || id;
                  const defaultVal = variable.default || '';
                  const desc = variable.description || '';
                  const fieldHtml = `
                      <div class="form-row">
                          <div class="field-long">
                              <label class="text-xs font-medium text-neutral-400 block mb-2">${label}:</label>
                              <input type="text" name="${id}" value="${defaultVal}" class="input-field" placeholder="${desc}">
                              ${desc ? `<small class="text-neutral-500 block mt-1">${desc}</small>` : ''}
                          </div>
                      </div>`;
                  variablesForm.insertAdjacentHTML('beforeend', fieldHtml);
              });
          }
      } else {
          secondCard.classList.add('hidden');
      }
    });

    // Node allocation loader
    document.getElementById('node').addEventListener('change', async (e) => {
      const nodeId = e.target.value;
      const allocSelect = document.getElementById('primary');
      allocSelect.innerHTML = '<option value="">Loading available ports...</option>';

      if (!nodeId) {
        allocSelect.innerHTML = '<option value="">-- Select node first --</option>';
        return;
      }

      try {
        const response = await fetch(`/admin/nodes/overview/${nodeId}/available-allocations`);
        const allocations = await response.json();

        allocSelect.innerHTML = '<option value="">-- Choose available host port --</option>';
        allocations.forEach(alloc => {
          const display = alloc.label.replace(/ \(.+\)$/, '');
          const option = document.createElement('option');
          option.value = display;
          option.textContent = display;
          allocSelect.appendChild(option);
        });
      } catch (err) {
        allocSelect.innerHTML = '<option value="">Error loading ports</option>';
      }
    });

    // Notification helper (exactly like node create)
    function showNotification(message, type = 'success') {
      const notification = document.getElementById('notification');
      const textEl = document.getElementById('notification-text');
      textEl.textContent = message;
      
      notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
        type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
      }`;
      notification.classList.remove('hidden');
      notification.classList.add('flex');

      setTimeout(() => {
        notification.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => {
          notification.classList.add('hidden');
          notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
        }, 300);
      }, 2800);
    }

    // Create Instance handler (exactly same pattern as node create)
    document.getElementById('createInstancesBtn').addEventListener('click', async () => {
      const btn = document.getElementById('createInstancesBtn');
      const orig = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Creating Instance...';

      try {
        const name = document.getElementById('name').value.trim();
        const user = document.getElementById('user').value;
        const template = document.getElementById('template').value;
        const nodeId = document.getElementById('node').value;
        const memory = document.getElementById('memory').value;
        const cpu = document.getElementById('cpu').value;
        const disk = document.getElementById('disk').value;
        const primary = document.getElementById('primary').value;

        // Validation (same style as node create - simple and clear)
        if (!name || name.includes(' ')) {
          throw new Error('Name is required (no spaces allowed)');
        }
        if (!template) {
          throw new Error('Please select a template');
        }
        if (!nodeId) {
          throw new Error('Please select a node');
        }
        if (!primary || !primary.includes(':')) {
          throw new Error('Please select a valid IP:Port allocation');
        }

        const memNum = parseInt(memory, 10);
        if (!Number.isInteger(memNum) || memNum <= 1) {
          throw new Error('Memory must be an integer greater than 1');
        }
        const cpuNum = parseInt(cpu, 10);
        if (!Number.isInteger(cpuNum) || cpuNum <= 0) {
          throw new Error('CPU must be an integer greater than 0');
        }
        const diskNum = parseInt(disk, 10);
        if (!Number.isInteger(diskNum) || diskNum <= 1) {
          throw new Error('Disk must be an integer greater than 1');
        }

        const [allocationIp, allocationPortStr] = primary.split(':');
        const allocationPort = parseInt(allocationPortStr, 10);
        if (isNaN(allocationPort)) {
          throw new Error('Invalid port number in allocation');
        }

        // Collect template variables
        const variables = {};
        document.querySelectorAll('#variablesForm input').forEach(inp => {
          if (inp.name) variables[inp.name] = inp.value;
        });

        const data = {
          name,
          user,
          templateFilename: template,
          nodeId,
          memory: memNum,
          cpu: cpuNum,
          disk: diskNum,
          allocationIp,
          allocationPort,
          variables
        };

        const res = await fetch('/admin/instances/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (!res.ok) {
          let errData = {};
          try {
            errData = await res.json();
          } catch (_) {}
          throw new Error(errData.error || errData.message || 'Failed to create instance');
        }

        showNotification('Instance created successfully!', 'success');
        setTimeout(() => {
          window.location.href = '/admin/instances/overview/?err=CREATED';
        }, 800);

      } catch (e) {
        showNotification(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = orig;
      }
    });
  </script>
</main>

<%- include('../../components/footer') %>
