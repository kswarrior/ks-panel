<%- include('../../components/template') %>
<style>
    .input-field {
      width: 100%;
      padding: 1rem 1.5rem;
      background-color: #1c3b54;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      color: white;
      placeholder-color: rgba(255, 255, 255, 0.4);
      outline: none;
      transition: all 0.2s ease;
    }

    .input-field:focus {
      border-color: rgba(255, 255, 255, 0.3);
      box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
    }
</style>

<main id="content" class="max-w-screen-2xl mx-auto">
  <div class="bg-transparent px-4 md:px-6 lg:px-8">
    
    <!-- Header Section -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between py-6 gap-4 border-b border-white/10">
      <div>
        <h1 class="text-2xl font-semibold text-white tracking-tight"><%= req.translations.instances %></h1>
        <p class="mt-1 text-sm text-neutral-400"><%= req.translations.instancesText %></p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/admin/instances/create'"
                class="px-6 py-2.5 rounded-[10px] bg-white text-black font-semibold text-sm shadow-lg hover:bg-neutral-100 transition-all duration-200 active:scale-95">
          <%= req.translations.createNewInstance %>
        </button>
      </div>
    </header>

    <!-- Stats Section -->
    <section id="stats" class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <article class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 transition-all duration-200 hover:border-white/20 group shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400">Total Instances</p>
            <p class="text-4xl md:text-5xl font-semibold text-white mt-2"><%= instances.length %></p>
          </div>
          <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center text-3xl">🖥️</div>
        </div>
      </article>

      <article class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg p-6 transition-all duration-200 hover:border-white/20 group shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-neutral-400">Suspended Instances</p>
            <% 
              let suspendedCount = 0;
              instances.forEach(function(instance) {
                if (instance.suspended === true) suspendedCount++;
              });
            %>
            <p class="text-4xl md:text-5xl font-semibold text-white mt-2"><%= suspendedCount %></p>
          </div>
          <div class="w-12 h-12 bg-yellow-500/10 rounded-lg flex items-center justify-center text-3xl">⛔</div>
        </div>
      </article>
    </section>

    <!-- Success Banner -->
    <% if (req.query.err == "CREATED") { %>
    <div class="mt-8 mx-1 bg-emerald-900/30 border border-emerald-500/30 rounded-lg p-5 flex gap-4 items-start">
      <div class="mt-0.5 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7" />
        </svg>
      </div>
      <div class="flex-1">
        <p class="font-medium text-emerald-400">Success!</p>
        <p class="text-sm text-emerald-300/80">The instance was created successfully. Please allow a few minutes for it to finish installing and downloading additional files.</p>
      </div>
    </div>
    <% } %>

    <!-- Table Section -->
    <section class="mt-8">
      <div class="overflow-x-auto rounded-lg border border-white/10 bg-neutral-900/50 shadow-2xl" id="instanceTable">
        <table class="min-w-full text-sm text-left text-white divide-y divide-white/10">
          <thead class="bg-neutral-950/70">
            <tr>
              <th class="py-4 pl-6 pr-2 font-semibold text-neutral-300 text-xs sm:py-5 sm:pl-8"><%= req.translations.name %></th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5">STATE</th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5"><%= req.translations.node %></th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5"><%= req.translations.dockerID %></th>
              <th class="py-4 px-2 font-semibold text-neutral-300 text-xs sm:px-4 sm:py-5"><%= req.translations.volumeANDMount %></th>
              <th class="py-4 pr-2 pl-2 font-semibold text-neutral-300 text-xs sm:pr-6 sm:pl-4 sm:py-5 text-right"><%= req.translations.actions %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% if (instances.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-12">
                <p class="text-sm text-neutral-400"><%= req.translations.noInstancesText %></p>
              </td>
            </tr>
            <% } %>

            <% instances.forEach(function(instance) { %>
            <tr class="hover:bg-white/5 transition-colors duration-200 group cursor-pointer" onclick="location.href='/instance/<%= instance.Id %>'">

              <!-- Name -->
              <td class="pl-6 py-4 sm:pl-8 sm:py-6">
                <div class="flex items-center gap-3">
                  <span class="font-semibold text-white truncate max-w-[180px]"><%= instance.Name %></span>
                </div>
              </td>

              <!-- State -->
              <td class="px-2 py-4 font-mono text-xs text-neutral-400 sm:px-4 sm:py-6">
                <%= instance.InternalState %>
              </td>

              <!-- Node -->
              <td class="px-2 py-4 font-mono text-xs text-neutral-400 sm:px-4 sm:py-6">
                <%= instance.Node.name %>
              </td>

              <!-- Docker ID -->
              <td class="px-2 py-4 font-mono text-xs text-neutral-400 sm:px-4 sm:py-6">
                <%= instance.ContainerId %>
              </td>

              <!-- Volume -->
              <td class="px-2 py-4 font-mono text-xs text-neutral-400 sm:px-4 sm:py-6">
                /volumes/<%= instance.VolumeId %>
              </td>

              <!-- Actions -->
              <td class="pr-2 py-4 text-right sm:pr-6 sm:py-6">
                <div class="flex items-center gap-2 justify-end flex-wrap" onclick="event.stopImmediatePropagation();">

                  <!-- Delete -->
                  <button onclick="location.href='/admin/instance/delete/<%= instance.Id %>'; event.stopImmediatePropagation();" 
                          class="px-3 py-1.5 text-xs font-medium bg-red-600/80 hover:bg-red-600 text-white rounded-[10px] transition-all duration-200 active:scale-95">
                    <%= req.translations.remove %>
                  </button>

                  <!-- Suspend / Unsuspend -->
                  <% if (instance.suspended === true) { %>
                    <% if (instance['suspended-flagg']) { %>
                      <button onclick="openSuspendInfoModal('<%= instance['suspended-flagg'] %>'); event.stopImmediatePropagation();" 
                              class="px-3 py-1.5 text-xs font-medium bg-yellow-600/10 hover:bg-yellow-600/20 text-yellow-400 rounded-[10px] transition-all duration-200 active:scale-95 flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                        </svg>
                      </button>
                    <% } %>
                    <form action="/admin/instances/unsuspend/<%= instance.Id %>" method="POST">
                      <button type="submit" onclick="event.stopImmediatePropagation();" 
                              class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95">
                        <%= req.translations.unsuspend %>
                      </button>
                    </form>
                  <% } else { %>
                    <form action="/admin/instances/suspend/<%= instance.Id %>" method="POST">
                      <button type="submit" onclick="event.stopImmediatePropagation();" 
                              class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95">
                        <%= req.translations.suspend %>
                      </button>
                    </form>
                  <% } %>

                  <!-- Edit -->
                  <button onclick="location.href='/admin/instances/<%= instance.Id %>/edit'; event.stopImmediatePropagation();" 
                          class="px-3 py-1.5 text-xs font-medium bg-white/10 hover:bg-white/20 text-white rounded-[10px] transition-all duration-200 active:scale-95">
                    <%= req.translations.edit %>
                  </button>

                </div>
              </td>

            </tr>
            <% }); %>

          </tbody>
        </table>
      </div>
    </section>

    <%- include('../../components/pagination', { pagination }) %>

    <!-- Notification (ready for future use) -->
    <div id="notification" 
         class="fixed bottom-6 right-6 hidden flex items-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-lg shadow-2xl text-sm font-medium z-50">
      <span id="notification-text"></span>
    </div>

  </div>

  <!-- Suspend Info Modal -->
  <div id="suspendInfoModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-neutral-800 text-white border border-white/5 rounded-xl p-8 max-w-xl w-full transform scale-95 transition-transform duration-300 shadow-lg">
      <h2 class="text-2xl font-semibold mb-2 text-neutral-200">Suspend Reason</h2>
      <p class="mb-6 text-gray-400" id="modalMessage"></p>
      <div class="flex justify-end space-x-4">
        <button onclick="closeSuspendInfoModal()" 
                class="px-5 py-2 bg-gray-200 text-gray-800 rounded-xl hover:bg-gray-300 transition">Close</button>
      </div>
    </div>
  </div>

  <script>
    function openSuspendInfoModal(reason) {
      document.getElementById('modalMessage').textContent = reason;
      const modal = document.getElementById('suspendInfoModal');
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
    }

    function closeSuspendInfoModal() {
      const modal = document.getElementById('suspendInfoModal');
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('opacity-100');
    }

    // Optional notification helper (ready if needed)
    function showNotification(message, type = 'success') {
      const notification = document.getElementById('notification');
      const textEl = document.getElementById('notification-text');
      textEl.textContent = message;
      
      notification.className = `fixed bottom-6 right-6 flex items-center gap-3 px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-300 ${
        type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'
      }`;
      notification.classList.remove('hidden');
      notification.classList.add('flex');

      setTimeout(() => {
        notification.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => {
          notification.classList.add('hidden');
          notification.classList.remove('opacity-0', 'translate-y-2', 'flex');
        }, 300);
      }, 2800);
    }
  </script>
</main>

<%- include('../../components/footer') %>
