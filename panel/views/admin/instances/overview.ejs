<%- include('../components/template') %>
<main id="content">
  <style>
.input-error {
    border: 2px solid rgb(255, 69, 69);
}

.error-message {
    color: rgb(255, 69, 69);
    font-size: 0.9rem;
}
  </style>
   <div class="bg-transparent">
      <div class="sm:flex sm:items-center px-8 pt-4">
         <div class="sm:flex-auto">
           <h1 class="text-base font-medium leading-6 text-white"><%= req.translations.instances %></h1>
           <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.instancesText %></p>
         </div>
         <div class="mt-4 sm:ml-8 sm:mt-0 sm:flex-none">
           <a href="/admin/instances/create" id="createButton" class="block rounded-xl bg-white text-black px-3 py-2 text-center text-sm font-medium shadow-lg transition focus:outline focus:outline-2 focus:outline-offset-2">
            <%= req.translations.createNewInstance %>
          </a>
         </div>
       </div>
 <% if (req.query.err == "CREATED") { %>
      <div class="mt-6 w-full">
        <div class="rounded-xl bg-emerald-800/10 px-4 py-6 mt-8 ml-8 mb-8 mr-8">
          <div class="flex">
             <div class="flex-shrink-0 ml-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mt-2 text-emerald-400">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>                
             </div>
             <div class="ml-5">
                <h3 class="text-sm font-medium text-emerald-400">Action completed!</h3>
                <div class="text-sm text-emerald-400/50">
                   <p>The instance was created successfully. Please allow a few minutes for it to finish installing and downloading additional files. </p>
                </div>
             </div>
          </div>
       </div>
      <% } %>	  
 
      <div style="display: block;" id="instanceTable" class="mt-6 w-full overflow-x-auto">
  <table class="min-w-full text-sm text-left text-white border-collapse">

    <!-- Table Head -->
    <thead class="border-b border-white/10 text-neutral-400">
      <tr>
        <th class="py-3 px-4 font-medium min-w-[180px]"><%= req.translations.name %></th>
        <th class="py-3 px-4 font-medium min-w-[120px]">State</th>
        <th class="py-3 px-4 font-medium min-w-[120px]"><%= req.translations.node %></th>
        <th class="py-3 px-4 font-medium min-w-[200px]"><%= req.translations.dockerID %></th>
        <th class="py-3 px-4 font-medium min-w-[200px]"><%= req.translations.volumeANDMount %></th>
        <th class="py-3 px-4 font-medium min-w-[200px] text-right"><%= req.translations.actions %></th>
      </tr>
    </thead>

    <!-- Table Body -->
    <tbody class="divide-y divide-white/5">
      <% if (instances.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center py-4">
            <p class="text-sm text-neutral-400"><%= req.translations.noInstancesText %></p>
          </td>
        </tr>
      <% } %>

      <% instances.forEach(function(instance) { %>
      <tr class="hover:bg-white/5 transition cursor-pointer" onclick="location.href='/instance/<%= instance.Id %>'">

        <!-- Name -->
        <td class="py-4 px-4 min-w-[200px]">
          <div class="flex items-center gap-3 truncate">
            <span class="font-medium text-sm truncate"><%= instance.Name %></span>
          </div>
        </td>

        <!-- State -->
        <td class="py-4 px-4 min-w-[150px]">
          <div class="font-mono text-sm text-neutral-400 truncate">
            <%= instance.InternalState %>
          </div>
        </td>

        <!-- Node -->
        <td class="py-4 px-4 min-w-[150px]">
          <div class="font-mono text-sm text-neutral-400 truncate">
            <%= instance.Node.name %>
          </div>
        </td>

        <!-- Docker ID -->
        <td class="py-4 px-4 min-w-[250px]">
          <div class="font-mono text-sm text-neutral-400 truncate">
            <%= instance.ContainerId %>
          </div>
        </td>

        <!-- Volume -->
        <td class="py-4 px-4 min-w-[200px]">
          <div class="font-mono text-sm text-neutral-400 truncate">
            /volumes/<%= instance.VolumeId %>
          </div>
        </td>

        <!-- Actions -->
        <td class="py-4 px-4 min-w-[250px] text-right">
          <div class="flex justify-end gap-2">

            <!-- Delete Button -->
            <button onclick="location.href='/admin/instance/delete/<%= instance.Id %>'; event.stopPropagation();" class="rounded-lg bg-red-600 hover:bg-red-500 px-3 py-1.5 text-xs font-medium text-white shadow transition">
              <%= req.translations.remove %>
            </button>

            <!-- Suspend / Unsuspend -->
            <% if (instance.suspended === true) { %>
              <% if (instance['suspended-flagg']) { %>
                <button onclick="openSuspendInfoModal('<%= instance['suspended-flagg'] %>'); event.stopPropagation();" class="rounded-lg bg-yellow-600/5 border border-neutral-200/5 px-3 py-1 text-xs font-medium shadow hover:bg-yellow-400/10 hover:text-white">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 text-yellow-500 mx-auto">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                  </svg>
                </button>
              <% } %>
              <form action="/admin/instances/unsuspend/<%= instance.Id %>" method="POST">
                <button type="submit" onclick="event.stopPropagation();" class="rounded-lg bg-white text-black px-3 py-1.5 text-xs font-medium shadow">
                  <%= req.translations.unsuspend %>
                </button>
              </form>
            <% } else { %>
              <form action="/admin/instances/suspend/<%= instance.Id %>" method="POST">
                <button type="submit" onclick="event.stopPropagation();" class="rounded-lg bg-white text-black px-3 py-1.5 text-xs font-medium shadow">
                  <%= req.translations.suspend %>
                </button>
              </form>
            <% } %>

            <!-- Edit Button -->
            <button onclick="location.href='/admin/instances/<%= instance.Id %>/edit'; event.stopPropagation();" class="rounded-lg bg-white text-black px-3 py-1.5 text-xs font-medium shadow">
              <%= req.translations.edit %>
            </button>

          </div>
        </td>

      </tr>
      <% }); %>

    </tbody>
  </table>
</div>
      <%- include('../components/pagination', { pagination }) %>

</main>

  <div id="suspendInfoModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="bg-neutral-800 text-white border border-white/5 rounded-xl p-8 max-w-xl w-full transform scale-95 transition-transform duration-300 shadow-lg">
            <h2 class="text-2xl font-semibold mb-2 text-neutral-200">Suspend Reason</h2>
            <p class="mb-6 text-gray-700" id="modalMessage"></p>
            <div class="flex justify-end space-x-4">
                <button onclick="closeSuspendInfoModal()" class="px-5 py-2 bg-gray-200 text-gray-800 rounded-xl hover:bg-gray-300 transition">Close</button>
            </div>
        </div>
    </div>

<%- include('../components/footer') %>
