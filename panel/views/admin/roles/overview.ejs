<%- include('../../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-[1600px] mx-auto">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-black text-white tracking-tight">Custom Roles</h1>
        <p class="text-neutral-400 mt-1">Manage discord-like roles and permissions</p>
      </div>
      <a href="/admin/roles/create" class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Create Role
      </a>
    </div>

    <!-- Roles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% if (roles.length === 0) { %>
        <div class="col-span-full glass p-12 rounded-3xl border border-white/5 text-center">
          <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white">No roles created yet</h3>
          <p class="text-neutral-500 text-sm mt-1">Start by creating your first custom role</p>
        </div>
      <% } %>

      <% roles.forEach(role => { %>
        <div class="glass p-6 rounded-3xl border border-white/5 flex flex-col group transition-all hover:translate-y-[-4px]">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full shadow-[0_0_10px_rgba(0,0,0,0.5)]" style="background-color: <%= role.color %>"></div>
              <h3 class="font-bold text-white"><%= role.name %></h3>
            </div>
            <div class="flex items-center gap-2">
              <a href="/admin/roles/edit/<%= role.id %>" class="p-2 rounded-lg hover:bg-white/5 text-neutral-400 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              </a>
              <button onclick="deleteRole('<%= role.id %>')" class="p-2 rounded-lg hover:bg-red-500/10 text-neutral-400 hover:text-red-500 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>

          <div class="flex-1">
            <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-2">Permissions</p>
            <div class="flex flex-wrap gap-1.5">
              <% const activePerms = Object.keys(role.permissions || {}).filter(k => role.permissions[k] === 'true' || role.permissions[k] === true); %>
              <% if (activePerms.length === 0) { %>
                <span class="text-xs text-neutral-600 italic">No permissions assigned</span>
              <% } else { %>
                <% activePerms.forEach(perm => { %>
                  <span class="px-2 py-0.5 rounded-md bg-white/5 text-[10px] text-neutral-400 border border-white/5"><%= perm.replace('_', ' ') %></span>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</main>

<script>
  async function deleteRole(roleId) {
    if (!confirm('Are you sure you want to delete this role? Users assigned to it will lose its permissions.')) return;

    try {
      const response = await fetch('/admin/roles/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ roleId })
      });

      if (response.ok) {
        window.location.reload();
      } else {
        alert('Failed to delete role');
      }
    } catch (err) {
      console.error(err);
      alert('An error occurred');
    }
  }
</script>

<%- include('../components/footer') %>
