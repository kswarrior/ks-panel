<%- include('../components/template') %>
<main id="content">
   <div class="bg-transparent">
      <div class="sm:flex sm:items-center px-8 pt-4">
         <div class="sm:flex-auto">
           <h1 class="text-base font-medium leading-6 text-white"><%= req.translations.nodes %></h1>
           <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.nodesText %></p>
         </div>
         <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <div class="flex gap-2">
            <button onclick="radarcheck()" type="button" class="block rounded-xl bg-neutral-900/20 text-neutral-300 border border-neutral-400/20 px-3 py-2 text-center text-sm font-medium shadow-lg transition focus:outline focus:outline-2 focus:outline-offset-2 flex gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256"><path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"></path></svg>
              Radar Scan
            </button>
            <button id="createButton" type="button" class="block rounded-xl bg-white text-black px-3 py-2 text-center text-sm font-medium shadow-lg transition focus:outline focus:outline-2 focus:outline-offset-2">
              <%= req.translations.createNewNode %>
            </button>
            <button type="button"
              onclick="window.location.href='/admin/localnode'"
              class="block rounded-xl bg-white text-black px-3 py-2 text-center text-sm font-medium shadow-lg transition focus:outline focus:outline-2 focus:outline-offset-2">
              Local Node
            </button>
          </div>
         </div>
       </div>

      <!-- Stats -->
      <div id="stats" class="grid grid-cols-1 md:grid-cols-2 gap-6 m-8">
        <div class="bg-white/5 rounded-xl p-6 shadow-lg">
          <h2 class="text-lg font-semibold text-white mb-2">Total Nodes</h2>
          <p class="text-4xl font-bold text-white"><%= nodes.length %></p>
          <p class="text-sm text-neutral-400 mt-2">Online Nodes: <%= nodes.filter(node => node.status === 'Online').length %></p>
        </div>
        <div class="bg-white/5 rounded-xl p-6 shadow-lg">
          <h2 class="text-lg font-semibold text-white mb-2">Server Count</h2>
          <p class="text-4xl font-bold text-white"><%= Object.values(set).reduce((a, b) => a + b, 0) %></p>
          <% if (nodes.length > 0) { %>
            <p class="text-sm text-neutral-400 mt-2">Average Node Density: <%= (Object.values(set).reduce((a, b) => a + b, 0) / nodes.length).toFixed(2) %></p>
          <% } else { %>
            <p class="text-sm text-neutral-400 mt-2">No nodes available</p>
          <% } %>
        </div>
      </div>

      <% if (req.query.err == "none") { %>
      <div class="mt-6 w-full">
        <div class="rounded-xl bg-emerald-800/10 px-4 py-6 mt-8 ml-8 mb-8 mr-8">
          <div class="flex">
             <div class="flex-shrink-0 ml-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mt-2 text-emerald-400">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>                
             </div>
             <div class="ml-5">
                <h3 class="text-sm font-medium text-emerald-400">Success!</h3>
                <div class="text-sm text-emerald-400/50">
                   <p>The action was successfully completed.</p>
                </div>
             </div>
          </div>
       </div>
      <% } %>
      <% if (req.query.err == "EDITED") { %>
      <div class="mt-6 w-full">
        <div class="rounded-xl bg-emerald-800/10 px-4 py-6 mt-8 ml-8 mb-8 mr-8">
          <div class="flex">
             <div class="flex-shrink-0 ml-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 mt-2 text-emerald-400">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>                
             </div>
             <div class="ml-5">
                <h3 class="text-sm font-medium text-emerald-400">Success!</h3>
                <div class="text-sm text-emerald-400/50">
                   <p>The node was edited successfully.</p>
                </div>
             </div>
          </div>
       </div>	      
      <% } %>

      <!-- Responsive Node Table -->
      <div class="px-4 sm:px-8 mt-8 w-full overflow-x-auto">
        <div class="min-w-full bg-neutral-900/30 shadow ring-1 ring-white/5 rounded-lg" id="nodeTable">
          <table class="min-w-full text-sm text-left text-white border-collapse">
            <!-- Head -->
            <thead class="border-b border-white/10 text-neutral-400">
              <tr>
                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-white sm:pl-6">
                  <%= req.translations.name %>
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white">
                  Connection
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white">
                  Tunnel
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white">
                  <%= req.translations.location %>
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white">
                  Instances
                </th>
                <!-- New Resource Columns -->
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white min-w-[180px]">
                  RAM
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white min-w-[140px]">
                  CPU
                </th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-white min-w-[180px]">
                  Disk
                </th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-white">
                  Upload
                </th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-white">
                  <%= req.translations.actions %>
                </th>
              </tr>
            </thead>

            <!-- Body -->
            <tbody class="divide-y divide-white/5">
              <% nodes.forEach(function(node) { %>
              <tr class="hover:bg-white/[0.05] transition">

                <!-- Name -->
                <td class="py-4 pl-4 pr-3 text-sm sm:pl-6 min-w-[220px]">
                  <div class="flex items-center gap-3">
                    <% if (node.status === "Online") { %>
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                      </span>
                    <% } else if (node.status === "Offline") { %>
                      <span class="relative flex h-2 w-2">
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-neutral-500"></span>
                      </span>
                    <% } else { %>
                      <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-amber-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
                      </span>
                    <% } %>
                    <span class="font-medium text-white truncate">
                      <%= node.name %>
                    </span>
                  </div>
                </td>

                <!-- Connection -->
                <td class="px-3 py-4 text-sm min-w-[260px]">
                  <div class="font-mono text-sm text-neutral-400 truncate">
                    <%= node.address %><span class="text-neutral-500">:<%= node.port %></span>
                    <% if (node.behindProxy) { %><span class="ml-2 text-amber-400 text-xs">(Proxy)</span><% } %>
                  </div>
                </td>

                <!-- Tunnel -->
                <td class="px-3 py-4 text-sm">
                  <% if (node.useCloudflareTunnel) { %>
                    <span class="inline-flex items-center gap-1 text-emerald-400 text-xs font-medium">
                      <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                      CF Tunnel
                    </span>
                  <% } else { %>
                    <span class="text-neutral-500 text-xs">—</span>
                  <% } %>
                </td>

                <!-- Location -->
                <td class="px-3 py-4 text-sm text-neutral-400 min-w-[120px]">
                  <% let locName = 'unknown'; %>
                  <% locations.forEach(function(loc) { %>
                    <% if (loc.id === node.location) locName = loc.name; %>
                  <% }); %>
                  <%= locName %>
                </td>

                <!-- Instances -->
                <td class="px-3 py-4 text-sm text-neutral-400 min-w-[120px]">
                  <div class="bg-neutral-800/40 px-3 py-1 rounded-lg text-xs inline-block">
                    <%= set[node.id] || 0 %>
                  </div>
                </td>

                <!-- RAM -->
                <td class="px-3 py-4 text-sm text-neutral-400 min-w-[180px]">
                  <div class="flex items-center gap-2">
                    <div class="w-20 bg-neutral-700/60 h-2 rounded-full overflow-hidden">
                      <div id="ram-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-500"
                           style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="ram-text-<%= node.id %>" class="text-xs font-mono">-- / -- GB (0%)</span>
                  </div>
                </td>

                <!-- CPU -->
                <td class="px-3 py-4 text-sm text-neutral-400 min-w-[140px]">
                  <div class="flex items-center gap-2">
                    <div class="w-16 bg-neutral-700/60 h-2 rounded-full overflow-hidden">
                      <div id="cpu-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-500"
                           style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="cpu-text-<%= node.id %>" class="text-xs font-mono">0%</span>
                  </div>
                </td>

                <!-- Disk -->
                <td class="px-3 py-4 text-sm text-neutral-400 min-w-[180px]">
                  <div class="flex items-center gap-2">
                    <div class="w-20 bg-neutral-700/60 h-2 rounded-full overflow-hidden">
                      <div id="disk-bar-<%= node.id %>" 
                           class="h-full rounded-full transition-all duration-500"
                           style="width: 0%; background: linear-gradient(to right, #22c55e, #eab308, #ef4444);"></div>
                    </div>
                    <span id="disk-text-<%= node.id %>" class="text-xs font-mono">-- / -- GB (0%)</span>
                  </div>
                </td>

                <!-- Upload Size -->
                <td class="px-3 py-4 text-sm text-neutral-400 text-right">
                  <%= node.uploadSize || 500 %> MB
                </td>

                <!-- Actions -->
                <td class="px-3 py-4 text-sm min-w-[260px]">
                  <div class="flex justify-end gap-2">
                    <button onclick="configure('<%= node.id %>')" 
                            class="rounded-lg bg-white text-black px-3 py-1.5 text-xs font-medium shadow transition">
                      <%= req.translations.configure %>
                    </button>
                    <a href="/admin/node/<%= node.id %>">
                      <button class="rounded-lg bg-white text-black px-3 py-1.5 text-xs font-medium shadow transition">
                        <%= req.translations.edit %>
                      </button>
                    </a>
                    <button onclick="deletenode('<%= node.id %>')" 
                            class="rounded-lg bg-red-600 hover:bg-red-500 px-3 py-1.5 text-xs font-medium text-white shadow transition">
                      <%= req.translations.remove %>
                    </button>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <%- include('../components/pagination', { pagination }) %>

      <div id="notification" class="fixed bottom-5 right-5 bg-white/5 text-white px-4 py-2 rounded-xl shadow-lg transform transition-all duration-300 translate-y-full opacity-0">
        Command copied to clipboard!
      </div>

      <!-- ==================== FULL CREATE FORM (All Pterodactyl + Cloudflare Tunnel fields) ==================== -->
      <div id="nodeForm" class="mt-6 px-4 sm:px-6 w-full hidden">
        <div class="p-6 lg:p-8 bg-neutral-900/30 border border-white/10 rounded-2xl max-w-5xl mx-auto">
          <form id="createNodeForm">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-6">

              <!-- Basic Info -->
              <div class="lg:col-span-2">
                <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                  Basic Information
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                </h3>
              </div>

              <div>
                <label class="text-neutral-400 text-sm block mb-1">Node Name <span class="text-red-400">*</span></label>
                <input id="nodeName" required type="text" class="input-field" placeholder="Main Node">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">FQDN / IP or Tunnel Hostname <span class="text-red-400">*</span></label>
                <input id="nodeAddress" required type="text" class="input-field" placeholder="node1.example.com or 103.XX.XX.XX">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Daemon Port <span class="text-red-400">*</span></label>
                <input id="nodePort" required type="number" value="8080" class="input-field">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">SFTP Port</label>
                <input id="nodeSftpPort" type="number" value="2022" class="input-field">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Location <span class="text-red-400">*</span></label>
                <select id="nodeLocation" required class="input-field">
                  <option value="">Select location...</option>
                  <% locations.forEach(function(loc) { %>
                    <option value="<%= loc.id %>"><%= loc.name %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Category <span class="text-red-400">*</span></label>
                <div class="flex gap-2">
                  <select id="nodeCategory" required class="input-field flex-1">
                    <option value="">Select category...</option>
                  </select>
                  <button type="button" onclick="addNewCategory()" 
                    class="px-5 py-3 bg-neutral-800/70 hover:bg-neutral-700 border border-white/10 rounded-2xl text-white text-sm font-medium transition flex items-center gap-1">
                    <span class="text-lg leading-none">+</span> Add Category
                  </button>
                </div>
              </div>

              <!-- Resources -->
              <div class="lg:col-span-2 mt-8">
                <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                  Resource Limits (Pterodactyl Style)
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                </h3>
              </div>

              <div>
                <label class="text-neutral-400 text-sm block mb-1">Total RAM (MB) <span class="text-red-400">*</span></label>
                <input id="nodeRam" required type="number" class="input-field" placeholder="32768">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Total Disk (GB) <span class="text-red-400">*</span></label>
                <input id="nodeDisk" required type="number" class="input-field" placeholder="500">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Memory Overallocate (%)</label>
                <input id="nodeMemoryOver" type="number" value="0" class="input-field">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Disk Overallocate (%)</label>
                <input id="nodeDiskOver" type="number" value="0" class="input-field">
              </div>
              <div>
                <label class="text-neutral-400 text-sm block mb-1">Max Upload Size (MB)</label>
                <input id="nodeUploadSize" type="number" value="500" class="input-field">
              </div>

              <!-- Tunnel / Proxy -->
              <div class="lg:col-span-2 mt-8">
                <h3 class="text-white text-lg font-semibold mb-4 flex items-center gap-2">
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                  Cloudflare Tunnel &amp; Proxy (Zero Port Forwarding)
                  <span class="w-3 h-px bg-white/30 flex-1"></span>
                </h3>
              </div>

              <div class="flex items-center gap-3">
                <input id="behindProxy" type="checkbox" class="w-5 h-5 accent-white">
                <label for="behindProxy" class="text-white text-sm">Behind Proxy (Nginx / Cloudflare)</label>
              </div>
              <div class="flex items-center gap-3">
                <input id="useCloudflareTunnel" type="checkbox" class="w-5 h-5 accent-emerald-400" onchange="toggleTunnelField()">
                <label for="useCloudflareTunnel" class="text-white text-sm">Use Cloudflare Tunnel (Recommended)</label>
              </div>

              <div id="tunnelHostnameGroup" class="lg:col-span-2 hidden">
                <label class="text-neutral-400 text-sm block mb-1">Tunnel Public Hostname</label>
                <input id="tunnelPublicHostname" type="text" class="input-field" placeholder="yournode.trycloudflare.com">
              </div>

              <div>
                <label class="text-neutral-400 text-sm block mb-1">Connection Type</label>
                <select id="connectionType" class="input-field">
                  <option value="Direct">Direct</option>
                  <option value="Behind Proxy">Behind Proxy</option>
                  <option value="Cloudflare Tunnel" selected>Cloudflare Tunnel</option>
                  <option value="Ngrok">Ngrok</option>
                </select>
              </div>

              <!-- Allocations (your original section) -->
              <div class="lg:col-span-2 mt-10 border-t border-white/10 pt-8">
                <h3 class="text-white text-lg font-semibold mb-4">Initial Allocations (Ports)</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                    <label class="text-neutral-400 text-sm block mb-1">IP for allocations</label>
                    <input id="allocIp" type="text" class="input-field" placeholder="Leave blank = node address">
                  </div>
                  <div>
                    <label class="text-neutral-400 text-sm block mb-1">IP Alias / Label</label>
                    <input id="allocAlias" type="text" class="input-field" placeholder="e.g. Game Servers">
                  </div>
                  <div class="md:col-span-3">
                    <label class="text-neutral-400 text-sm block mb-1">Ports (comma or ranges)</label>
                    <textarea id="allocPorts" rows="3" class="input-field" placeholder="25565,27015-27030"></textarea>
                  </div>
                </div>
              </div>

              <!-- Submit -->
              <div class="lg:col-span-2 mt-8">
                <button id="createNodeBtn" type="button"
                  class="w-full py-4 rounded-2xl bg-white text-black font-semibold text-lg tracking-wide hover:bg-neutral-100 transition">
                  Create Node
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
   </div>

   <script>
   // Input field styling
   document.querySelectorAll('.input-field').forEach(el => {
     el.className = `rounded-2xl text-white text-sm w-full px-5 py-3 bg-neutral-800/50 border border-white/10 focus:border-white/30 outline-none placeholder:text-white/30`;
   });

   function toggleTunnelField() {
     const group = document.getElementById('tunnelHostnameGroup');
     const checked = document.getElementById('useCloudflareTunnel').checked;
     group.classList.toggle('hidden', !checked);
   }

   function addNewCategory() {
     const newCat = prompt('Enter new category name:');
     if (newCat && newCat.trim()) {
       const select = document.getElementById('nodeCategory');
       const optionValue = newCat.trim().toLowerCase().replace(/[^a-z0-9]/g, '-');
       const option = new Option(newCat.trim(), optionValue);
       select.add(option);
       select.value = optionValue;
       showNotification('Category added: ' + newCat, 'success');
     }
   }

   function showNotification(message, type = 'success') {
     const notification = document.getElementById('notification');
     notification.textContent = message;
     notification.className = `fixed bottom-6 right-6 px-6 py-3 rounded-2xl shadow-2xl transform transition-all duration-300 z-50 ${
       type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-500 text-white'
     }`;
     notification.classList.remove('opacity-0', 'translate-y-10');
     notification.classList.add('opacity-100', 'translate-y-0');
     setTimeout(() => {
       notification.classList.add('opacity-0', 'translate-y-10');
     }, 2800);
   }

   function getBarColor(percent) {
     if (percent > 95) return '#ef4444';
     if (percent > 75) return '#eab308';
     return '#22c55e';
   }

   async function updateNodeResources(nodeId) {
     try {
       const res = await fetch(`/admin/node/${nodeId}/resourceMonitor`);
       if (!res.ok) throw new Error();
       const data = await res.json();

       ['ram','cpu','disk'].forEach(key => {
         const bar = document.getElementById(key + '-bar-' + nodeId);
         const text = document.getElementById(key + '-text-' + nodeId);
         if (!bar || !text) return;
         const val = data[key];
         if (!val) return;
         const p = parseFloat(val.percent || val.used / val.total * 100);
         bar.style.width = `${p}%`;
         bar.style.background = `linear-gradient(to right, ${getBarColor(p)}, ${getBarColor(p*1.2)})`;
         text.textContent = key === 'cpu' 
           ? `${val.percent}%` 
           : `${val.used} / ${val.total} GB (${p.toFixed(0)}%)`;
       });
     } catch(e) {
       console.warn(`Resource update failed for ${nodeId}`);
     }
   }

   // Toggle form
   document.getElementById('createButton').addEventListener('click', () => {
     const table = document.getElementById('nodeTable');
     const form = document.getElementById('nodeForm');
     const stats = document.getElementById('stats');
     if (table.classList.contains('hidden')) {
       table.classList.remove('hidden');
       stats.classList.remove('hidden');
       form.classList.add('hidden');
     } else {
       table.classList.add('hidden');
       stats.classList.add('hidden');
       form.classList.remove('hidden');
     }
   });

   // Create Node - ALL fields
   document.getElementById('createNodeBtn').addEventListener('click', async () => {
     const btn = document.getElementById('createNodeBtn');
     const orig = btn.innerHTML;
     btn.disabled = true;
     btn.innerHTML = 'Creating Node...';

     try {
       const data = {
         name: document.getElementById('nodeName').value.trim(),
         address: document.getElementById('nodeAddress').value.trim(),
         port: document.getElementById('nodePort').value,
         sftpPort: document.getElementById('nodeSftpPort').value,
         location: document.getElementById('nodeLocation').value,
         category: document.getElementById('nodeCategory').value,
         ram: document.getElementById('nodeRam').value,
         disk: document.getElementById('nodeDisk').value,
         memoryOverallocate: document.getElementById('nodeMemoryOver').value,
         diskOverallocate: document.getElementById('nodeDiskOver').value,
         uploadSize: document.getElementById('nodeUploadSize').value,
         behindProxy: document.getElementById('behindProxy').checked,
         useCloudflareTunnel: document.getElementById('useCloudflareTunnel').checked,
         tunnelPublicHostname: document.getElementById('tunnelPublicHostname').value.trim(),
         connectionType: document.getElementById('connectionType').value,
         allocIp: document.getElementById('allocIp').value.trim(),
         allocAlias: document.getElementById('allocAlias').value.trim(),
         portsInput: document.getElementById('allocPorts').value.trim()
       };

       const res = await fetch('/nodes/create', {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify(data)
       });

       if (!res.ok) {
         const err = await res.json();
         throw new Error(err.error || 'Failed to create node');
       }

       showNotification('Node created successfully with Cloudflare Tunnel support!', 'success');
       setTimeout(() => window.location.href = '/admin/nodes?err=none', 800);
     } catch (e) {
       showNotification(e.message, 'error');
     } finally {
       btn.disabled = false;
       btn.innerHTML = orig;
     }
   });

   // Existing functions (delete, configure, radar, resource update) - unchanged
   async function deletenode(nodeId) { 
     if (!confirm('Delete this node?')) return;
     try {
       const res = await fetch('/nodes/delete', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({nodeId}) });
       if (res.ok) { showNotification('Node deleted', 'success'); location.reload(); }
       else throw new Error('Failed');
     } catch(e) { showNotification('Delete failed', 'error'); }
   }

   async function configure(nodeId) {
     try {
       const res = await fetch(`/admin/node/${nodeId}/configure-command`);
       const { configureCommand } = await res.json();
       await navigator.clipboard.writeText(configureCommand);
       showNotification('Configure command copied!', 'success');
     } catch(e) { showNotification('Failed to copy command', 'error'); }
   }

   async function radarcheck() {
     await fetch('/admin/nodes/radar/check', { method: 'POST' });
     showNotification('Radar check started', 'success');
   }

   // Init
   document.addEventListener('DOMContentLoaded', () => {
     <% nodes.forEach(node => { %>
       updateNodeResources('<%= node.id %>');
     <% }); %>
     setInterval(() => {
       <% nodes.forEach(node => { %>
         updateNodeResources('<%= node.id %>');
       <% }); %>
     }, 15000);
   });
   </script>
</main>
