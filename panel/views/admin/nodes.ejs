<%- include('../components/template') %>

<style>
/* ==================================================
   CLEAN SEMANTIC STYLES - ZERO TAILWIND
   Uses only the exact CSS variables provided
   Responsive via media queries + var(--card-padding-mobile)
   ================================================== */

.page-content {
  max-width: 100%;
  margin: 0 auto;
  padding: 0 var(--margin-body);
  background: transparent;
}

@media (max-width: 768px) {
  .page-content {
    padding: 0 16px;
  }
}

.admin-header {
  display: flex;
  flex-direction: column;
  gap: var(--gap);
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
}

@media (min-width: 640px) {
  .admin-header {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.header-title h1 {
  font-size: var(--h1-size);
  font-weight: 600;
  color: var(--text);
  letter-spacing: -0.025em;
}

.header-subtitle {
  margin-top: 4px;
  font-size: var(--small-size);
  color: var(--text-muted);
}

.header-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: var(--btn-padding);
  border-radius: var(--btn-radius);
  font-size: 14px;
  font-weight: var(--btn-font-weight);
  transition: var(--transition);
  border: 1px solid var(--btn-border);
  background: var(--btn-bg);
  color: var(--btn-text);
  cursor: pointer;
  text-decoration: none;
}

.btn:hover {
  background: var(--btn-hover);
}

.btn:active {
  transform: scale(0.95);
}

.btn-primary {
  background: var(--btn-primary-bg);
  color: var(--btn-primary-text);
  border: none;
  box-shadow: var(--btn-shadow);
  font-weight: 700;
}

.btn-danger {
  background: var(--btn-danger-bg);
  color: var(--btn-danger-text);
  border: none;
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--gap-large);
  margin-top: 32px;
}

@media (min-width: 768px) {
  .stat-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.stat-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--card-radius);
  padding: var(--card-padding);
  transition: var(--transition);
  backdrop-filter: blur(var(--backdrop-blur));
}

.stat-card:hover {
  border-color: rgba(255,255,255,0.2);
  background: var(--hover-card);
}

.stat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-value {
  font-size: 48px;
  font-weight: 600;
  color: var(--text);
  margin-top: 8px;
}

.stat-icon {
  width: 48px;
  height: 48px;
  background: rgba(16,185,129,0.1);
  border-radius: var(--card-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.stat-info {
  margin-top: 24px;
  font-size: var(--small-size);
  color: var(--text-muted);
}

.alert {
  margin-top: 32px;
  margin-inline: 4px;
  background: rgba(16,185,129,0.3);
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: var(--card-radius);
  padding: 20px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.alert svg {
  width: 24px;
  height: 24px;
  color: var(--success);
  margin-top: 2px;
}

.alert-title {
  font-weight: 500;
  color: var(--success);
}

.alert-text {
  font-size: 14px;
  color: rgba(134,239,172,0.8);
}

.table-wrapper {
  margin-top: 32px;
  overflow-x: auto;
  background: var(--table-bg);
  border: 1px solid var(--table-border);
  border-radius: var(--table-radius);
  box-shadow: var(--table-shadow);
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--table-font-size);
  color: var(--text);
}

.data-table thead {
  background: var(--table-head-bg);
}

.data-table th {
  padding: 20px 16px;
  font-weight: 600;
  color: var(--table-head-text);
  text-align: left;
  font-size: 13px;
  letter-spacing: 0.5px;
}

.data-table th:first-child { padding-left: 32px; }
.data-table th:last-child { padding-right: 32px; text-align: right; }

.data-table td {
  padding: 24px 16px;
  vertical-align: middle;
}

.data-table tr {
  transition: background 0.2s ease;
}

.data-table tr:hover {
  background: var(--table-hover);
}

.status-dot {
  position: relative;
  display: inline-flex;
  width: 12px;
  height: 12px;
}

.status-dot.online::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--success);
  border-radius: 50%;
  animation: ping 2s infinite;
  opacity: 0.75;
}

.status-dot.online span,
.status-dot.warning span,
.status-dot.offline span {
  position: relative;
  display: block;
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.status-dot.online span { background: var(--success); }
.status-dot.offline span { background: #6b7280; }
.status-dot.warning span { background: var(--warning); }

.node-name {
  font-weight: 600;
  color: var(--text);
  max-width: 180px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.connection-info {
  font-family: monospace;
  font-size: 12px;
  color: var(--text-muted);
}

.tunnel-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--success);
  font-size: 12px;
  font-weight: 500;
}

.progress-track {
  flex: 1;
  height: 8px;
  background: var(--progress-bg);
  border-radius: 9999px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 9999px;
  transition: width 700ms ease;
  background: linear-gradient(to right, var(--progress-success), var(--warning), var(--danger));
}

.resource-value {
  font-family: monospace;
  font-size: 12px;
  color: var(--text-muted);
  width: 80px;
  text-align: right;
}

.instance-badge {
  display: inline-block;
  background: var(--badge-bg);
  color: var(--badge-text);
  padding: 4px 16px;
  border-radius: var(--badge-radius);
  font-size: 12px;
  font-weight: 500;
}

.action-group {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
}

.btn-small {
  padding: 8px 16px;
  font-size: 12px;
  border-radius: var(--btn-radius);
  background: rgba(255,255,255,0.1);
  color: var(--text);
  border: none;
}

.btn-small:hover {
  background: rgba(255,255,255,0.2);
}

.notification {
  position: fixed;
  bottom: 24px;
  right: 24px;
  display: none;
  align-items: center;
  gap: 12px;
  padding: 16px 24px;
  border-radius: 9999px;
  box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
  font-size: 14px;
  font-weight: 500;
  z-index: 10000;
  transition: all 0.3s ease;
}

.notification.show {
  display: flex;
}

.notification.success { background: var(--success); color: white; }
.notification.error { background: var(--danger); color: white; }

.form-panel {
  margin-top: 48px;
  max-width: 1100px;
  margin-left: auto;
  margin-right: auto;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--card-radius);
  padding: 48px;
  backdrop-filter: blur(var(--backdrop-blur));
}

@media (max-width: 1024px) {
  .form-panel {
    padding: 32px;
  }
}

.form-section {
  margin-bottom: 40px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
}

.section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(255,255,255,0.3), transparent);
}

.section-title {
  font-size: var(--h3-size);
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.5px;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
}

@media (min-width: 1024px) {
  .form-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.form-group label {
  display: block;
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: var(--label-font-weight);
  color: var(--text-muted);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.input-field,
.form-select,
.form-textarea {
  width: 100%;
  padding: var(--input-padding);
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: var(--input-radius);
  color: var(--text);
  font-size: 15px;
  transition: var(--transition);
}

.input-field:focus,
.form-select:focus {
  border-color: var(--input-focus-border);
  box-shadow: 0 0 0 3px rgba(255,255,255,0.1);
}

.input-field::placeholder {
  color: var(--input-placeholder);
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
  color: var(--text);
}

.checkbox-wrapper input[type="checkbox"] {
  width: 20px;
  height: 20px;
  accent-color: var(--accent);
}

.hidden { display: none !important; }

@keyframes ping {
  75%, 100% { transform: scale(2); opacity: 0; }
}
</style>

<main id="content" class="page-content">
   <div class="page-content">
      
      <!-- HEADER -->
      <header class="admin-header">
         <div class="header-title">
           <h1><%= req.translations.nodes %></h1>
           <p class="header-subtitle"><%= req.translations.nodesText %></p>
         </div>

         <div class="header-actions">
            <button onclick="radarcheck()" 
                    class="btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256"><path d="M240,128a15.74,15.74,0,0,1-7.6,13.51L88.32,229.65a16,16,0,0,1-16.2.3A15.86,15.86,0,0,1,64,216.13V39.87a15.86,15.86,0,0,1,8.12-13.82,16,16,0,0,1,16.2.3L232.4,114.49A15.74,15.74,0,0,1,240,128Z"></path></svg>
              Radar Scan
            </button>
            
            <button id="createButton" 
                    class="btn btn-primary">
              <%= req.translations.createNewNode %>
            </button>

            <button onclick="window.location.href='/admin/localnode'"
                    class="btn btn-primary">
              Local Node
            </button>
         </div>
      </header>

      <!-- STATS -->
      <div id="stats" class="stat-grid">
        <div class="stat-card">
          <div class="stat-header">
            <div>
              <p class="text-sm font-medium" style="color:var(--text-muted)">Total Nodes</p>
              <p class="stat-value"><%= nodes.length %></p>
            </div>
            <div class="stat-icon">📡</div>
          </div>
          <p class="stat-info">
            Online: <span style="color:var(--success);font-weight:500"><%= nodes.filter(node => node.status === 'Online').length %></span>
          </p>
        </div>

        <div class="stat-card">
          <div class="stat-header">
            <div>
              <p class="text-sm font-medium" style="color:var(--text-muted)">Server Count</p>
              <p class="stat-value"><%= Object.values(set).reduce((a, b) => a + b, 0) %></p>
            </div>
            <div class="stat-icon" style="background:rgba(59,130,246,0.1)">🖥️</div>
          </div>
          <% if (nodes.length > 0) { %>
            <p class="stat-info">
              Avg. Density: <span style="font-family:monospace"><%= (Object.values(set).reduce((a, b) => a + b, 0) / nodes.length).toFixed(2) %></span>
            </p>
          <% } else { %>
            <p class="stat-info">No nodes yet</p>
          <% } %>
        </div>
      </div>

      <!-- SUCCESS BANNERS -->
      <% if (req.query.err == "none") { %>
      <div class="alert">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7" />
          </svg>
        </div>
        <div>
          <p class="alert-title">Success!</p>
          <p class="alert-text">The action was successfully completed.</p>
        </div>
      </div>
      <% } %>

      <% if (req.query.err == "EDITED") { %>
      <div class="alert">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7" />
          </svg>
        </div>
        <div>
          <p class="alert-title">Success!</p>
          <p class="alert-text">The node was edited successfully.</p>
        </div>
      </div>
      <% } %>

      <!-- TABLE CONTAINER -->
      <div class="table-wrapper" id="nodeTable">
        <table class="data-table">
          <thead>
            <tr>
              <th>NODE</th>
              <th>CONNECTION</th>
              <th>TUNNEL</th>
              <th>LOCATION</th>
              <th style="text-align:center">INSTANCES</th>
              <th>RAM</th>
              <th>CPU</th>
              <th>DISK</th>
              <th style="text-align:right">UPLOAD</th>
              <th style="text-align:right">ACTIONS</th>
            </tr>
          </thead>
          <tbody>
            <% nodes.forEach(function(node) { %>
            <tr class="table-row">
              <!-- Name -->
              <td style="padding-left:32px">
                <div style="display:flex;align-items:center;gap:12px">
                  <% if (node.status === "Online") { %>
                    <span class="status-dot online">
                      <span></span>
                    </span>
                  <% } else if (node.status === "Offline") { %>
                    <span class="status-dot offline">
                      <span></span>
                    </span>
                  <% } else { %>
                    <span class="status-dot warning">
                      <span></span>
                    </span>
                  <% } %>
                  <span class="node-name"><%= node.name %></span>
                </div>
              </td>

              <!-- Connection -->
              <td>
                <span class="connection-info"><%= node.address %><span style="color:#6b7280">:</span><%= node.port %></span>
                <% if (node.behindProxy) { %><span style="margin-left:8px;color:#f59e0b;font-size:10px">(proxy)</span><% } %>
              </td>

              <!-- Tunnel -->
              <td>
                <% if (node.useCloudflareTunnel) { %>
                  <span class="tunnel-badge">
                    <span style="width:8px;height:8px;background:var(--success);border-radius:50%;animation:pulse 2s infinite"></span>
                    CF TUNNEL
                  </span>
                <% } else { %>
                  <span style="color:#6b7280;font-size:13px">—</span>
                <% } %>
              </td>

              <!-- Location -->
              <td style="color:var(--text-muted);font-size:14px">
                <% let locName = 'unknown'; %>
                <% locations.forEach(function(loc) { %>
                  <% if (loc.id === node.location) locName = loc.name; %>
                <% }); %>
                <%= locName %>
              </td>

              <!-- Instances -->
              <td style="text-align:center">
                <span class="instance-badge"><%= set[node.id] || 0 %></span>
              </td>

              <!-- RAM -->
              <td>
                <div style="display:flex;align-items:center;gap:12px">
                  <div class="progress-track">
                    <div id="ram-bar-<%= node.id %>" class="progress-fill" style="width:0%"></div>
                  </div>
                  <span id="ram-text-<%= node.id %>" class="resource-value">--</span>
                </div>
              </td>

              <!-- CPU -->
              <td>
                <div style="display:flex;align-items:center;gap:12px">
                  <div class="progress-track">
                    <div id="cpu-bar-<%= node.id %>" class="progress-fill" style="width:0%"></div>
                  </div>
                  <span id="cpu-text-<%= node.id %>" class="resource-value">0%</span>
                </div>
              </td>

              <!-- Disk -->
              <td>
                <div style="display:flex;align-items:center;gap:12px">
                  <div class="progress-track">
                    <div id="disk-bar-<%= node.id %>" class="progress-fill" style="width:0%"></div>
                  </div>
                  <span id="disk-text-<%= node.id %>" class="resource-value">--</span>
                </div>
              </td>

              <!-- Upload -->
              <td style="text-align:right;font-size:14px;color:var(--text-muted);font-weight:500">
                <%= node.uploadSize || 500 %> MB
              </td>

              <!-- Actions -->
              <td style="padding-right:32px;text-align:right">
                <div class="action-group">
                  <button onclick="configure('<%= node.id %>')" 
                          class="btn-small">CONFIGURE</button>
                  <a href="/admin/node/<%= node.id %>">
                    <button class="btn-small">EDIT</button>
                  </a>
                  <button onclick="deletenode('<%= node.id %>')" 
                          class="btn-small btn-danger">DELETE</button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <%- include('../components/pagination', { pagination }) %>

      <!-- NOTIFICATION -->
      <div id="notification" class="notification">
        <span id="notification-text"></span>
      </div>

      <!-- CREATE FORM -->
      <div id="nodeForm" class="form-panel hidden">
        <form id="createNodeForm">
          <div class="form-grid">

            <!-- BASIC INFO -->
            <div class="form-section" style="grid-column:1/-1">
              <div class="section-header">
                <div class="section-line"></div>
                <h3 class="section-title">BASIC INFORMATION</h3>
                <div class="section-line"></div>
              </div>
            </div>

            <div class="form-group">
              <label>NODE NAME <span style="color:var(--danger)">*</span></label>
              <input id="nodeName" required type="text" class="input-field" placeholder="Main Node">
            </div>

            <div class="form-group">
              <label>FQDN / IP OR TUNNEL HOSTNAME <span style="color:var(--danger)">*</span></label>
              <input id="nodeAddress" required type="text" class="input-field" placeholder="node1.example.com">
            </div>

            <div class="form-group">
              <label>DAEMON PORT <span style="color:var(--danger)">*</span></label>
              <input id="nodePort" required type="number" value="2022" class="input-field">
            </div>

            <div class="form-group">
              <label>SFTP PORT</label>
              <input id="nodeSftpPort" type="number" value="2022" class="input-field">
            </div>

            <div class="form-group">
              <label>LOCATION <span style="color:var(--danger)">*</span></label>
              <select id="nodeLocation" required class="form-select">
                <option value="">Select location...</option>
                <% locations.forEach(function(loc) { %>
                  <option value="<%= loc.id %>"><%= loc.name %></option>
                <% }); %>
              </select>
            </div>

            <div class="form-group">
              <label>CATEGORY <span style="color:var(--danger)">*</span></label>
              <div style="display:flex;gap:12px">
                <select id="nodeCategory" required class="form-select" style="flex:1"></select>
                <button type="button" onclick="addNewCategory()" 
                        class="btn" style="padding:0 24px">+ ADD</button>
              </div>
            </div>

            <!-- RESOURCES -->
            <div class="form-section" style="grid-column:1/-1">
              <div class="section-header">
                <div class="section-line"></div>
                <h3 class="section-title">RESOURCE LIMITS</h3>
                <div class="section-line"></div>
              </div>
            </div>

            <div class="form-group">
              <label>TOTAL RAM (MB) <span style="color:var(--danger)">*</span></label>
              <input id="nodeRam" required type="number" class="input-field" placeholder="32768">
            </div>
            <div class="form-group">
              <label>TOTAL DISK (GB) <span style="color:var(--danger)">*</span></label>
              <input id="nodeDisk" required type="number" class="input-field" placeholder="500">
            </div>
            <div class="form-group">
              <label>MEMORY OVERALLOCATE (%)</label>
              <input id="nodeMemoryOver" type="number" value="0" class="input-field">
            </div>
            <div class="form-group">
              <label>DISK OVERALLOCATE (%)</label>
              <input id="nodeDiskOver" type="number" value="0" class="input-field">
            </div>
            <div class="form-group">
              <label>MAX UPLOAD SIZE (MB)</label>
              <input id="nodeUploadSize" type="number" value="500" class="input-field">
            </div>

            <!-- TUNNEL SECTION -->
            <div class="form-section" style="grid-column:1/-1">
              <div class="section-header">
                <div class="section-line"></div>
                <h3 class="section-title">CLOUDFLARE TUNNEL &amp; PROXY</h3>
                <div class="section-line"></div>
              </div>
            </div>

            <div class="checkbox-wrapper">
              <input id="behindProxy" type="checkbox">
              <label for="behindProxy">Behind Proxy (Nginx / Cloudflare)</label>
            </div>
            <div class="checkbox-wrapper">
              <input id="useCloudflareTunnel" type="checkbox" onchange="toggleTunnelField()">
              <label for="useCloudflareTunnel">Use Cloudflare Tunnel (Recommended)</label>
            </div>

            <div id="tunnelHostnameGroup" class="form-group hidden" style="grid-column:1/-1">
              <label>TUNNEL PUBLIC HOSTNAME</label>
              <input id="tunnelPublicHostname" type="text" class="input-field" placeholder="yournode.trycloudflare.com">
            </div>

            <div class="form-group">
              <label>CONNECTION TYPE</label>
              <select id="connectionType" class="form-select">
                <option value="Direct">Direct</option>
                <option value="Behind Proxy">Behind Proxy</option>
                <option value="Cloudflare Tunnel" selected>Cloudflare Tunnel</option>
                <option value="Ngrok">Ngrok</option>
              </select>
            </div>

            <!-- ALLOCATIONS -->
            <div class="form-section" style="grid-column:1/-1;border-top:1px solid var(--border);padding-top:32px">
              <h3 class="section-title" style="margin-bottom:24px">INITIAL ALLOCATIONS (PORTS)</h3>
              <div style="display:grid;grid-template-columns:1fr;gap:24px">
                <div class="form-group">
                  <label>IP FOR ALLOCATIONS</label>
                  <input id="allocIp" type="text" class="input-field" placeholder="Leave blank = node address">
                </div>
                <div class="form-group">
                  <label>IP ALIAS / LABEL</label>
                  <input id="allocAlias" type="text" class="input-field" placeholder="e.g. Game Servers">
                </div>
                <div class="form-group" style="grid-column:1/-1">
                  <label>PORTS (COMMA OR RANGES)</label>
                  <textarea id="allocPorts" rows="3" class="input-field" placeholder="25565,27015-27030"></textarea>
                </div>
              </div>
            </div>

            <!-- SUBMIT -->
            <div style="grid-column:1/-1;margin-top:24px">
              <button id="createNodeBtn" type="button"
                      class="btn btn-primary" style="width:100%;padding:18px;font-size:18px">
                CREATE NODE
              </button>
            </div>
          </div>
        </form>
      </div>
   </div>

   <script>
   // Inputs are now styled via CSS variables (no dynamic Tailwind needed)
   function toggleTunnelField() {
     const group = document.getElementById('tunnelHostnameGroup');
     const checked = document.getElementById('useCloudflareTunnel').checked;
     group.classList.toggle('hidden', !checked);
   }

   function addNewCategory() {
     const newCat = prompt('Enter new category name:');
     if (newCat && newCat.trim()) {
       const select = document.getElementById('nodeCategory');
       const optionValue = newCat.trim().toLowerCase().replace(/[^a-z0-9]/g, '-');
       const option = new Option(newCat.trim(), optionValue);
       select.add(option);
       select.value = optionValue;
       showNotification('Category added: ' + newCat, 'success');
     }
   }

   function showNotification(message, type = 'success') {
     const notification = document.getElementById('notification');
     const textEl = document.getElementById('notification-text');
     textEl.textContent = message;
     
     notification.className = `notification ${type === 'error' ? 'error' : 'success'} show`;
     
     setTimeout(() => {
       notification.classList.add('opacity-0', 'translate-y-2');
       setTimeout(() => {
         notification.classList.remove('show', 'opacity-0', 'translate-y-2');
       }, 300);
     }, 2800);
   }

   function getBarColor(percent) {
     if (percent > 95) return '#ef4444';
     if (percent > 75) return '#eab308';
     return '#22c55e';
   }

   async function updateNodeResources(nodeId) {
     try {
       const res = await fetch(`/admin/node/${nodeId}/resourceMonitor`);
       if (!res.ok) throw new Error();
       const data = await res.json();

       ['ram','cpu','disk'].forEach(key => {
         const bar = document.getElementById(key + '-bar-' + nodeId);
         const text = document.getElementById(key + '-text-' + nodeId);
         if (!bar || !text) return;
         const val = data[key];
         if (!val) return;
         const p = parseFloat(val.percent || val.used / val.total * 100);
         bar.style.width = `${p}%`;
         text.textContent = key === 'cpu' 
           ? `${val.percent}%` 
           : `${val.used} / \( {val.total} GB ( \){p.toFixed(0)}%)`;
       });
     } catch(e) {
       console.warn(`Resource update failed for ${nodeId}`);
     }
   }

   // Toggle form
   document.getElementById('createButton').addEventListener('click', () => {
     const table = document.getElementById('nodeTable');
     const form = document.getElementById('nodeForm');
     const stats = document.getElementById('stats');
     if (table.classList.contains('hidden')) {
       table.classList.remove('hidden');
       stats.classList.remove('hidden');
       form.classList.add('hidden');
     } else {
       table.classList.add('hidden');
       stats.classList.add('hidden');
       form.classList.remove('hidden');
     }
   });

   // Create Node handler
   document.getElementById('createNodeBtn').addEventListener('click', async () => {
     const btn = document.getElementById('createNodeBtn');
     const orig = btn.innerHTML;
     btn.disabled = true;
     btn.innerHTML = 'Creating Node...';

     try {
       const data = {
         name: document.getElementById('nodeName').value.trim(),
         address: document.getElementById('nodeAddress').value.trim(),
         port: document.getElementById('nodePort').value,
         sftpPort: document.getElementById('nodeSftpPort').value,
         location: document.getElementById('nodeLocation').value,
         category: document.getElementById('nodeCategory').value,
         ram: document.getElementById('nodeRam').value,
         disk: document.getElementById('nodeDisk').value,
         memoryOverallocate: document.getElementById('nodeMemoryOver').value,
         diskOverallocate: document.getElementById('nodeDiskOver').value,
         uploadSize: document.getElementById('nodeUploadSize').value,
         behindProxy: document.getElementById('behindProxy').checked,
         useCloudflareTunnel: document.getElementById('useCloudflareTunnel').checked,
         tunnelPublicHostname: document.getElementById('tunnelPublicHostname').value.trim(),
         connectionType: document.getElementById('connectionType').value,
         allocIp: document.getElementById('allocIp').value.trim(),
         allocAlias: document.getElementById('allocAlias').value.trim(),
         portsInput: document.getElementById('allocPorts').value.trim()
       };

       const res = await fetch('/nodes/create', {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify(data)
       });

       if (!res.ok) {
         const err = await res.json();
         throw new Error(err.error || 'Failed to create node');
       }

       showNotification('Node created successfully with Cloudflare Tunnel support!', 'success');
       setTimeout(() => window.location.href = '/admin/nodes?err=none', 800);
     } catch (e) {
       showNotification(e.message, 'error');
     } finally {
       btn.disabled = false;
       btn.innerHTML = orig;
     }
   });

   // Unchanged helper functions
   async function deletenode(nodeId) { 
     if (!confirm('Delete this node?')) return;
     try {
       const res = await fetch('/nodes/delete', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({nodeId}) });
       if (res.ok) { showNotification('Node deleted', 'success'); location.reload(); }
       else throw new Error('Failed');
     } catch(e) { showNotification('Delete failed', 'error'); }
   }

   async function configure(nodeId) {
     try {
       const res = await fetch(`/admin/node/${nodeId}/configure-command`);
       const { configureCommand } = await res.json();
       await navigator.clipboard.writeText(configureCommand);
       showNotification('Configure command copied!', 'success');
     } catch(e) { showNotification('Failed to copy command', 'error'); }
   }

   async function radarcheck() {
     await fetch('/admin/nodes/radar/check', { method: 'POST' });
     showNotification('Radar check started', 'success');
   }

   // Init resources
   document.addEventListener('DOMContentLoaded', () => {
     <% nodes.forEach(node => { %>
       updateNodeResources('<%= node.id %>');
     <% }); %>
     setInterval(() => {
       <% nodes.forEach(node => { %>
         updateNodeResources('<%= node.id %>');
       <% }); %>
     }, 15000);
   });
   </script>
</main>
