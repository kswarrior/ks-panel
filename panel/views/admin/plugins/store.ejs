<%- include('../../components/template') %>

<div id="content">
  <div class="bg-transparent">

    <!-- Header -->
    <div class="sm:flex sm:items-center px-6 md:px-8 pt-6 pb-4">
      <div class="sm:flex-auto">
        <h1 class="text-2xl font-bold text-white tracking-tight">Plugin Store</h1>
        <p class="mt-2 text-sm text-neutral-400">
          Discover, filter and install powerful extensions for your KS Panel.
        </p>
      </div>
    </div>

    <!-- Filters -->
    <div class="px-6 md:px-8 pb-6">
      <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl p-6 shadow-2xl ring-1 ring-white/10 border border-neutral-800/60">
        <form action="/admin/plugins/store" method="get" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

          <!-- Search -->
          <div class="col-span-1 lg:col-span-2">
            <input 
              type="text" 
              name="search" 
              placeholder="Search plugins, authors, categories..." 
              value="<%= currentFilters?.search || '' %>"
              class="w-full bg-neutral-800/80 border border-neutral-700 rounded-xl px-4 py-3 text-white placeholder-neutral-500 focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/30 outline-none transition-all"
            >
          </div>

          <!-- Category -->
          <select 
            name="category"
            class="bg-neutral-800/80 border border-neutral-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/30 outline-none transition-all"
          >
            <option value="">All Categories</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= currentFilters?.category === cat ? 'selected' : '' %>>
                <%= cat %>
              </option>
            <% }) %>
          </select>

          <!-- Min Version -->
          <input 
            type="text" 
            name="min_version" 
            placeholder="Min Version (e.g. 1.2.0)" 
            value="<%= currentFilters?.min_version || '' %>"
            class="bg-neutral-800/80 border border-neutral-700 rounded-xl px-4 py-3 text-white placeholder-neutral-500 focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/30 outline-none transition-all"
          >

          <!-- Price Type -->
          <select 
            name="price_filter" 
            id="priceFilter"
            class="bg-neutral-800/80 border border-neutral-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/30 outline-none transition-all"
          >
            <option value="all"    <%= currentFilters?.price_filter === 'all'    ? 'selected' : '' %>>All Prices</option>
            <option value="free"   <%= currentFilters?.price_filter === 'free'   ? 'selected' : '' %>>Free Only</option>
            <option value="paid"   <%= currentFilters?.price_filter === 'paid'   ? 'selected' : '' %>>Paid Only</option>
            <option value="limit"  <%= currentFilters?.price_filter === 'limit'  ? 'selected' : '' %>>Min Price</option>
          </select>

          <!-- Min Price (shown only when limit selected) -->
          <div id="minPriceContainer" class="<%= currentFilters?.price_filter === 'limit' ? '' : 'hidden' %>">
            <input 
              type="number" 
              name="min_price" 
              id="minPrice"
              step="0.01"
              min="0"
              placeholder="Min price ($)" 
              value="<%= currentFilters?.min_price || '' %>"
              class="w-full bg-neutral-800/80 border border-neutral-700 rounded-xl px-4 py-3 text-white placeholder-neutral-500 focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/30 outline-none transition-all"
            >
          </div>

          <!-- Submit -->
          <div class="lg:col-span-4 flex justify-end mt-2">
            <button 
              type="submit"
              class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-400 text-white font-medium rounded-xl shadow-lg shadow-indigo-500/20 transition-all duration-200 flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4 4m0-4l-4-4" />
              </svg>
              Apply Filters
            </button>
          </div>

        </form>
      </div>
    </div>

    <!-- Plugin Grid -->
    <div class="px-6 md:px-8">
      <% if (!plugins || plugins.length === 0) { %>
        <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl p-10 text-center border border-neutral-800/60">
          <div class="text-neutral-400 text-lg mb-2">No plugins found</div>
          <p class="text-neutral-500">Try adjusting your filters</p>
        </div>
      <% } else { %>

        <div id="pluginGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-6 pb-12">

          <% plugins.forEach(p => { %>
            <div class="plugin-card group bg-neutral-900/60 backdrop-blur-lg rounded-2xl overflow-hidden border border-neutral-800/70 hover:border-indigo-500/40 transition-all duration-300 shadow-xl hover:shadow-2xl hover:shadow-indigo-500/10">

              <div class="p-5">
                <div class="flex items-center gap-4">
                  <div class="w-14 h-14 rounded-xl overflow-hidden bg-neutral-800 flex-shrink-0 ring-1 ring-neutral-700">
                    <img src="<%= p.icon || '/img/placeholder-plugin.png' %>" alt="<%= p.name %>" class="w-full h-full object-cover">
                  </div>
                  <div class="min-w-0 flex-1">
                    <h3 class="text-white font-semibold text-base truncate group-hover:text-indigo-400 transition-colors">
                      <%= p.name %>
                    </h3>
                    <p class="text-xs text-neutral-400 truncate"><%= p.author || 'Unknown' %></p>
                  </div>
                </div>

                <div class="mt-4 grid grid-cols-2 gap-2 text-xs text-neutral-300">
                  <div>Version <span class="text-white font-medium"><%= p.version || '?' %></span></div>
                  <div class="text-right">
                    <% if (p.price === 'free' || p.price == 0) { %>
                      <span class="text-emerald-400 font-semibold">Free</span>
                    <% } else { %>
                      <span class="text-amber-400 font-semibold">$<%= p.price %></span>
                    <% } %>
                  </div>
                </div>

                <div class="mt-5 flex items-center justify-between gap-3">
                  <% if (installedNames.includes(p.name)) { %>
                    <span class="px-4 py-1.5 bg-emerald-900/40 text-emerald-300 rounded-lg text-xs font-medium ring-1 ring-emerald-800/50">
                      Installed
                    </span>
                  <% } else { %>
                    <form action="/admin/plugins/store/install" method="post" class="inline">
                      <input type="hidden" name="download_url" value="<%= p.download %>">
                      <input type="hidden" name="plugin_name" value="<%= p.name %>">
                      <button 
                        type="submit"
                        class="px-4 py-1.5 bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-400 text-white text-xs font-medium rounded-lg shadow-md hover:shadow-lg transition-all"
                      >
                        Install
                      </button>
                    </form>
                  <% } %>

                  <a 
                    href="<%= p.more || '#' %>" 
                    target="_blank" 
                    class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1"
                  >
                    Details →
                  </a>
                </div>
              </div>
            </div>
          <% }) %>

        </div>

        <% if (hasMore) { %>
          <div id="loading" class="text-center py-12 text-neutral-500 hidden">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-500 mx-auto mb-3"></div>
            Loading more plugins...
          </div>
        <% } %>

      <% } %>
    </div>

  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // Show/hide min price field
  const priceFilter = document.getElementById("priceFilter");
  const minPriceContainer = document.getElementById("minPriceContainer");

  priceFilter.addEventListener("change", () => {
    minPriceContainer.classList.toggle("hidden", priceFilter.value !== "limit");
  });

  // Infinite scroll (client fallback + server pagination)
  let page = 2;
  let loading = false;
  const grid = document.getElementById("pluginGrid");
  const loadingIndicator = document.getElementById("loading");

  const loadMore = async () => {
    if (loading || !loadingIndicator) return;
    if (window.innerHeight + window.scrollY < document.body.offsetHeight - 400) return;

    loading = true;
    loadingIndicator.classList.remove("hidden");

    try {
      const params = new URLSearchParams(window.location.search);
      params.set("page", page);

      const res = await fetch(`/admin/plugins/store?${params.toString()}`, {
        headers: { "X-Requested-With": "XMLHttpRequest" }
      });

      if (!res.ok) throw new Error("Network error");

      const html = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");
      const newCards = doc.querySelectorAll(".plugin-card");

      if (newCards.length === 0) {
        window.removeEventListener("scroll", onScroll);
        loadingIndicator.remove();
        return;
      }

      newCards.forEach(card => grid.appendChild(card));
      page++;
    } catch (err) {
      console.error("Load more failed:", err);
    } finally {
      loading = false;
      loadingIndicator.classList.add("hidden");
    }
  };

  const onScroll = () => {
    requestAnimationFrame(loadMore);
  };

  if (loadingIndicator) {
    window.addEventListener("scroll", onScroll);
    // Trigger initial check in case content is already short
    setTimeout(loadMore, 300);
  }
});
</script>
