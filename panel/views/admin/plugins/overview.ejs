<%- include('../../components/template') %>
<main id="content" class="px-4 sm:px-6 lg:px-8 pt-4 pb-8">
  <div class="bg-transparent max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-8 pb-8 border-b border-white/5">
      <div class="flex-grow">
        <h1 class="text-3xl font-bold text-white tracking-tight">Plugins Overview</h1>
        <p class="mt-2 text-neutral-400">Manage and configure your installed extensions.</p>
      </div>
      
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
        <%- include('../../components/plugins') %>

        <button 
          id="reload" 
          type="button" 
          class="flex items-center justify-center rounded-xl bg-white px-6 py-2.5 text-sm font-bold text-black shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all whitespace-nowrap"
          onclick="fetch('/admin/plugins/reload', {method: 'POST'}), location.reload()"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
          Reload Plugins
        </button>
      </div>
    </div>
        
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
      <div class="glass p-6 rounded-3xl border border-white/10">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-1">Installed</p>
        <p class="text-3xl font-bold text-white"><%= plugins.length %></p>
      </div>
      <div class="glass p-6 rounded-3xl border border-white/10">
        <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest mb-1">Active</p>
        <p class="text-3xl font-bold text-emerald-400"><%= enabledPlugins.length %></p>
      </div>
    </div>

    <!-- Plugin List -->
    <div class="grid grid-cols-1 gap-4">
      <% if (plugins.length === 0) { %>
        <div class="glass p-20 text-center rounded-3xl border border-white/10 italic text-neutral-500">
          No plugins installed. Visit the Store to get started.
        </div>
      <% } else { %>
        <% plugins.forEach(function(plugin) {
          const isActive = enabledPlugins.some(p => p.name === plugin.name);
        %>
          <div class="glass p-6 rounded-3xl border border-white/10 flex flex-col md:flex-row md:items-center justify-between gap-6 hover:border-white/20 transition-all">
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl shadow-inner">
                🔌
              </div>
              <div class="min-w-0">
                <h3 class="text-lg font-bold text-white truncate"><%= plugin.name %></h3>
                <p class="text-xs text-neutral-500 font-mono"><%= plugin.directoryname %></p>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= isActive ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-white/5 text-neutral-500 border border-white/5' %>">
                <span class="w-1.5 h-1.5 rounded-full <%= isActive ? 'bg-emerald-400 animate-pulse' : 'bg-neutral-600' %> mr-2"></span>
                <%= isActive ? 'Active' : 'Disabled' %>
              </span>

              <div class="flex items-center gap-2">
                <a href="/admin/plugins/<%= plugin.directoryname %>/edit"
                   class="px-4 py-2 bg-white/5 text-white text-xs font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all">
                  Configure
                </a>
                <button onclick="fetch('/admin/plugins/<%= plugin.name %>/toggle', {method: 'POST'}).then(() => location.reload())"
                        class="px-4 py-2 rounded-xl text-xs font-bold shadow-lg transition-all <%= isActive ? 'bg-red-500/10 text-red-400 border border-red-500/20 hover:bg-red-500/20' : 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20' %>">
                  <%= isActive ? 'Disable' : 'Enable' %>
                </button>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</main>
<%- include('../../components/footer') %>
