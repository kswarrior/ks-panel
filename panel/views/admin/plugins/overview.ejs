<%- include('../../components/template') %>
<main id="content" class="px-4 sm:px-6 lg:px-8 pt-4 pb-8">
  <div class="bg-transparent max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div class="flex-grow">
        <h1 class="text-base font-medium leading-6 text-white">Plugins Overview</h1>
        <p class="mt-1 tracking-tight text-sm text-neutral-500">A list of all the Plugins installed on the panel.</p>
      </div>
      
      <%- include('../../components/plugins') %>
      
      <div class="flex items-center gap-3">
        <button 
          id="reload" 
          type="button" 
          class="flex items-center justify-center rounded-xl bg-green-500 px-4 py-2 text-sm font-medium text-white shadow-lg hover:bg-green-600 transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 active:scale-95 w-full sm:w-auto"
          onclick="fetch('/admin/plugins/reload', {method: 'POST'}), location.reload()"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
          <span class="hidden sm:inline">Reload Plugins</span>
          <span class="sm:hidden">Reload</span>
        </button>
      </div>
    </div>
        
    <!-- Stats Cards Grid -->
    <div class="mt-6">
      <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        
        <!-- Card 1: Plugins Installed -->
        <div class="bg-white/5 rounded-xl p-5 shadow-lg hover:bg-white/[0.08] transition-all duration-300 hover:scale-[1.02] border border-white/5 group cursor-default">
          <div class="flex items-center justify-between">
            <div class="flex-grow">
              <dt class="truncate text-sm font-medium text-neutral-400">Plugins Installed</dt>
              <dd class="mt-2 text-2xl sm:text-3xl font-bold tracking-tight text-white">
                <%= plugins.length %>
              </dd>
            </div>
            <div class="ml-4 shadow-lg border border-white/10 rounded-xl p-3 bg-white/5 group-hover:bg-white/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
              </svg>                                         
            </div>
          </div>
          <div class="mt-3 flex items-center text-xs text-neutral-500">
            <span class="inline-flex items-center rounded-full bg-white/5 px-2 py-1">
              Total available
            </span>
          </div>
        </div>
         
        <!-- Card 2: Plugins Enabled -->
        <div class="bg-white/5 rounded-xl p-5 shadow-lg hover:bg-white/[0.08] transition-all duration-300 hover:scale-[1.02] border border-white/5 group cursor-default">
          <div class="flex items-center justify-between">
            <div class="flex-grow">
              <dt class="truncate text-sm font-medium text-neutral-400">Plugins Enabled</dt>
              <dd class="mt-2 text-2xl sm:text-3xl font-bold tracking-tight text-white">
                <%= enabledPlugins.length %>
              </dd>
            </div>
            <div class="ml-4 shadow-lg border border-white/10 rounded-xl p-3 bg-white/5 group-hover:bg-white/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-emerald-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>                   
            </div>
          </div>
          <div class="mt-3 flex items-center text-xs text-neutral-500">
            <span class="inline-flex items-center rounded-full bg-emerald-500/10 text-emerald-400 px-2 py-1">
              <%= Math.round((enabledPlugins.length / (plugins.length || 1)) * 100) %>% active
            </span>
          </div>
        </div>

      </dl>
    </div>

    <!-- Plugins List Section -->
    <div class="mt-8">
      <h3 class="text-lg font-medium leading-6 text-white mb-4">Installed Plugins</h3>
      
      <!-- Mobile Card View / Desktop List -->
      <div class="space-y-3 sm:space-y-4">
        <% plugins.forEach(function(plugin) { %>
          <div class="bg-white/5 rounded-xl border border-white/10 hover:bg-white/[0.08] transition-all duration-300 hover:shadow-lg group">
            
            <!-- Mobile Layout (Vertical) -->
            <div class="sm:hidden p-4">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-3 flex-grow min-w-0">
                  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-white">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-grow">
                    <h4 class="text-sm font-medium text-white truncate"><%= plugin.name %></h4>
                    <p class="text-xs text-neutral-500 truncate"><%= plugin.directoryname %></p>
                  </div>
                </div>
                <button 
                  onclick="event.stopPropagation(); fetch('/admin/plugins/<%= plugin.name %>/toggle', {method: 'POST'}).then((res) => { if (res.ok) location.reload() })"
                  class="flex-shrink-0 ml-2"
                >
                  <% if (enabledPlugins.some(pluginObj => pluginObj.name === plugin.name)) { %>
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white transition-all duration-300">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1 0 12.728 0M12 3v9" />
                      </svg>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-emerald-600/20 text-emerald-400 hover:bg-emerald-600 hover:text-white transition-all duration-300">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 0 1 12.728 0M12 3v9m0 0 3-3m-3 3-3-3" />
                      </svg>
                    </span>
                  <% } %>
                </button>
              </div>
              
              <div class="flex items-center justify-between pt-3 border-t border-white/5">
                <button 
                  onclick="location.href='/admin/plugins/<%= plugin.directoryname %>/edit'"
                  class="flex items-center text-sm text-neutral-400 hover:text-white transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                  Edit Plugin
                </button>
                
                <span class="text-xs text-neutral-500">
                  <% if (enabledPlugins.some(pluginObj => pluginObj.name === plugin.name)) { %>
                    <span class="inline-flex items-center gap-1 text-emerald-400">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                      Active
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 text-neutral-500">
                      <span class="w-1.5 h-1.5 rounded-full bg-neutral-500"></span>
                      Disabled
                    </span>
                  <% } %>
                </span>
              </div>
            </div>

            <!-- Desktop Layout (Horizontal) -->
            <div class="hidden sm:flex sm:items-center sm:justify-between p-5">
              <div class="flex items-center gap-4 flex-grow min-w-0 cursor-pointer" onclick="location.href='/admin/plugins/<%= plugin.directoryname %>/edit'">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
                  </svg>
                </div>
                
                <div class="min-w-0 flex-grow">
                  <div class="flex items-center gap-2">
                    <h4 class="text-base font-medium text-white group-hover:text-neutral-300 transition-colors truncate"><%= plugin.name %></h4>
                    <% if (enabledPlugins.some(pluginObj => pluginObj.name === plugin.name)) { %>
                      <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-400 border border-emerald-500/20">
                        Enabled
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center rounded-full bg-neutral-500/10 px-2 py-0.5 text-xs font-medium text-neutral-400 border border-neutral-500/20">
                        Disabled
                      </span>
                    <% } %>
                  </div>
                  <p class="text-sm text-neutral-500 truncate mt-0.5"><%= plugin.directoryname %></p>
                </div>
              </div>

              <div class="flex items-center gap-3 ml-4 flex-shrink-0">
                <button 
                  onclick="location.href='/admin/plugins/<%= plugin.directoryname %>/edit'"
                  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-neutral-400 hover:text-white hover:bg-white/10 transition-all duration-300"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                  Edit
                </button>

                <button 
                  onclick="fetch('/admin/plugins/<%= plugin.name %>/toggle', {method: 'POST'}).then((res) => { if (res.ok) location.reload() })"
                  class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium shadow-lg transition-all duration-300 active:scale-95 <%= enabledPlugins.some(pluginObj => pluginObj.name === plugin.name) ? 'bg-red-600 hover:bg-red-500 text-white' : 'bg-emerald-600 hover:bg-emerald-500 text-white' %>"
                >
                  <% if (enabledPlugins.some(pluginObj => pluginObj.name === plugin.name)) { %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1 0 12.728 0M12 3v9" />
                    </svg>
                    Disable
                  <% } else { %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 0 1 12.728 0M12 3v9m0 0 3-3m-3 3-3-3" />
                    </svg>
                    Enable
                  <% } %>
                </button>
              </div>
            </div>

          </div>
        <% }); %>
      </div>
      
      <% if (plugins.length === 0) { %>
        <div class="text-center py-16 bg-white/5 rounded-xl border border-white/10 border-dashed">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-neutral-500 mx-auto mb-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
          </svg>
          <h3 class="text-sm font-medium text-white">No plugins installed</h3>
          <p class="mt-1 text-sm text-neutral-500">Get started by installing your first plugin.</p>
        </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../../components/footer') %>

<style>
  /* Mobile-first responsive improvements */
  @media (max-width: 640px) {
    .group:active {
      transform: scale(0.98);
    }
  }

  /* Smooth transitions for all interactive elements */
  button, a {
    transition: all 0.3s ease;
  }

  /* Touch-friendly improvements */
  @media (hover: none) and (pointer: coarse) {
    button {
      min-height: 44px;
      min-width: 44px;
    }
  }

  /* Safe area support for notched phones */
  @supports (padding: max(0px)) {
    #content {
      padding-left: max(1rem, env(safe-area-inset-left));
      padding-right: max(1rem, env(safe-area-inset-right));
      padding-bottom: max(2rem, env(safe-area-inset-bottom));
    }
  }

  /* Custom scrollbar for webkit browsers */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>
