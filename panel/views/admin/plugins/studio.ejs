<%- include('../../components/template') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.34.0/min/vs/loader.js"></script>

<main id="content" class="animate-fade-in min-h-screen pb-24">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Header -->
    <header class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-4xl font-black text-white tracking-tight">Plugin Studio</h1>
        <p class="text-neutral-400 mt-2">Design and scaffold advanced extensions for KS Panel.</p>
      </div>
      <a href="/admin/plugins/overview" class="px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-white hover:bg-white/10 transition-all">
        Back to Overview
      </a>
    </header>

    <form action="/admin/plugins/studio/create" method="POST" id="studioForm" enctype="multipart/form-data">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Architecture Stack (Left) -->
        <div class="lg:col-span-1 space-y-6">
          <!-- Sidebar -->
          <section class="glass p-6 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xs font-black text-neutral-400 uppercase tracking-widest">Sidebar</h2>
              <button type="button" onclick="addSidebarItem()" class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase">Add</button>
            </div>
            <div id="sidebarItems" class="space-y-2"></div>
          </section>

          <!-- Frontend -->
          <section class="glass p-6 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xs font-black text-neutral-400 uppercase tracking-widest">Frontend</h2>
              <div class="flex gap-1">
                <button type="button" onclick="addFile('fe')" class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase">Add</button>
                <button type="button" onclick="triggerImport('fe')" class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase">Import</button>
                <label class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase cursor-pointer">
                  Upload
                  <input type="file" multiple class="hidden" onchange="handleUpload(this, 'fe')">
                </label>
              </div>
            </div>
            <div id="feFiles" class="space-y-2"></div>
          </section>

          <!-- Backend -->
          <section class="glass p-6 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xs font-black text-neutral-400 uppercase tracking-widest">Backend</h2>
              <div class="flex gap-1">
                <button type="button" onclick="addFile('be')" class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase">Add</button>
                <button type="button" onclick="triggerImport('be')" class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase">Import</button>
                <label class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[9px] font-black text-white hover:bg-white/10 transition-all uppercase cursor-pointer">
                  Upload
                  <input type="file" multiple class="hidden" onchange="handleUpload(this, 'be')">
                </label>
              </div>
            </div>
            <div id="beFiles" class="space-y-2"></div>
          </section>

          <!-- Page Registry -->
          <section class="glass p-6 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Page Registry</h2>
              <input type="text" id="registrySearch" placeholder="Filter..." class="w-20 bg-white/5 border border-white/10 rounded-lg px-2 py-1 text-[9px] text-white focus:outline-none focus:border-amber-500 transition-all">
            </div>
            <div id="pageRegistry" class="space-y-2 max-h-[200px] overflow-y-auto custom-scrollbar pr-1"></div>
          </section>
        </div>

        <!-- Extension Core & IDE (Right) -->
        <div class="lg:col-span-3 space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
             <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl">
               <h2 class="text-xl font-bold text-white mb-8">Metadata</h2>
               <div class="grid grid-cols-2 gap-6">
                 <div><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Name</label><input type="text" name="name" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></div>
                 <div><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Version</label><input type="text" name="version" value="1.0.0" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></div>
               </div>
               <div class="mt-4"><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Description</label><textarea name="description" rows="2" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea></div>
             </section>

             <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl">
               <h2 class="text-xl font-bold text-white mb-8">Required Permissions</h2>
               <div class="grid grid-cols-2 gap-2">
                 <% [
                   {id: 'db:read', label: 'Database R/O'},
                   {id: 'db:write', label: 'Database R/W'},
                   {id: 'terminal:exec', label: 'Terminal Exec (VPS/apt)'},
                   {id: 'users:manage', label: 'User Mgmt'},
                   {id: 'servers:manage', label: 'Server Mgmt'},
                   {id: 'system:power', label: 'System Control'}
                 ].forEach(perm => { %>
                   <label class="flex items-center gap-2 p-2.5 rounded-xl bg-white/5 border border-white/5 cursor-pointer hover:bg-white/10 transition-all group">
                     <input type="checkbox" name="permissions[]" value="<%= perm.id %>" class="rounded border-white/20 bg-white/5 text-blue-500 focus:ring-0">
                     <span class="text-[10px] text-neutral-400 font-bold uppercase group-hover:text-white"><%= perm.label %></span>
                   </label>
                 <% }) %>
               </div>
             </section>
          </div>

          <!-- IDE Interface -->
          <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl overflow-hidden">
            <div class="flex items-center justify-between mb-8">
              <div class="flex items-center gap-4">
                <h2 class="text-xl font-bold text-white">Logic Laboratory</h2>
                <div id="fileTabs" class="flex gap-2">
                   <!-- Dynamically populated file tabs -->
                </div>
              </div>
              <div class="flex gap-2">
                 <button type="button" id="saveActiveFile" class="px-3 py-1.5 rounded-lg bg-emerald-500 text-white text-[10px] font-black uppercase">Sync to Stack</button>
              </div>
            </div>

            <div id="editor" class="w-full h-[600px] rounded-2xl border border-white/10 bg-black/40 overflow-hidden"></div>
          </section>

          <!-- Advanced Configuration -->
          <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl">
          <!-- Dependency Cloner (Dynamic Importer Modal) -->
          <div id="importModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4">
            <div class="absolute inset-0 bg-black/80 backdrop-blur-xl" onclick="this.parentElement.classList.add('hidden')"></div>
            <div class="glass relative w-full max-w-2xl p-8 rounded-[2rem] border border-white/10 shadow-2xl">
              <h2 class="text-2xl font-black text-white mb-8">Import Source Component</h2>
              <div class="grid grid-cols-2 gap-8 h-96">
                <div class="space-y-4">
                  <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Views (Frontend)</h3>
                  <div class="space-y-1 max-h-80 overflow-y-auto custom-scrollbar">
                    <% views.forEach(v => { %>
                      <div onclick="selectForImport('fe', '<%= v %>')" class="p-3 rounded-xl bg-white/5 border border-white/5 text-xs text-neutral-400 hover:text-white hover:bg-blue-500/10 hover:border-blue-500/20 cursor-pointer transition-all truncate"><%= v %></div>
                    <% }) %>
                  </div>
                </div>
                <div class="space-y-4">
                  <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Routes (Backend)</h3>
                  <div class="space-y-1 max-h-80 overflow-y-auto custom-scrollbar">
                    <% routes.forEach(r => { %>
                      <div onclick="selectForImport('be', '<%= r %>')" class="p-3 rounded-xl bg-white/5 border border-white/5 text-xs text-neutral-400 hover:text-white hover:bg-purple-500/10 hover:border-purple-500/20 cursor-pointer transition-all truncate"><%= r %></div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit & Live Manifest -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
            <div class="glass p-6 rounded-3xl border border-white/5 overflow-hidden">
               <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest mb-4 flex items-center justify-between">
                 Live manifest.json Preview
                 <span class="text-blue-400">Read Only</span>
               </h3>
               <pre id="manifestPreview" class="text-[10px] text-neutral-400 font-mono bg-black/20 p-4 rounded-xl overflow-x-auto">{}</pre>
            </div>

            <div class="flex flex-col gap-4">
              <button type="submit" class="w-full py-6 rounded-3xl bg-blue-500 text-white font-black text-sm hover:bg-blue-600 transition-all shadow-2xl shadow-blue-500/20 uppercase tracking-[0.3em]">
                Initialize Plugin Core
              </button>
              <button type="reset" class="w-full py-3 rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-[10px] hover:bg-white/10 transition-all uppercase tracking-widest">
                Discard Changes
              </button>
            </div>
          </div>
        </div>
      </div>
    </form>

  </div>
</main>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
</style>

<script>
let architectureStack = {
  fe: [{ name: 'index.ejs', content: '<h1>Hello Plugin</h1>' }],
  be: [{ name: 'index.js', content: 'const express = require("express");\nconst router = express.Router();\n\nrouter.get("/", (req, res) => { res.render("../views/index"); });\n\nmodule.exports = router;' }]
};
let activeFile = { type: 'be', index: 0 };

require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.34.0/min/vs' }});
require(['vs/editor/editor.main'], function() {
    window.editor = monaco.editor.create(document.getElementById('editor'), {
        value: architectureStack.be[0].content,
        language: 'javascript',
        theme: 'vs-dark',
        automaticLayout: true,
        fontSize: 13,
        minimap: { enabled: false },
        padding: { top: 20 }
    });
    renderStack();
});

function renderStack() {
  ['fe', 'be'].forEach(type => {
    const container = document.getElementById(type + 'Files');
    container.innerHTML = architectureStack[type].map((f, i) => `
      <div onclick="switchFile('${type}', ${i})" class="group flex items-center justify-between p-3 rounded-2xl border transition-all cursor-pointer ${activeFile.type === type && activeFile.index === i ? 'bg-blue-500/10 border-blue-500/30' : 'bg-white/5 border-transparent hover:border-white/10'}">
        <span class="text-xs ${activeFile.type === type && activeFile.index === i ? 'text-blue-400 font-bold' : 'text-neutral-400'} truncate">${f.name}</span>
        <button type="button" onclick="event.stopPropagation(); removeFile('${type}', ${i})" class="opacity-0 group-hover:opacity-100 text-red-500"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg></button>
      </div>
    `).join('');
  });
  renderTabs();
  syncPagesFromLogic();
  updateManifestPreview();
}

function switchFile(type, index) {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  activeFile = { type, index };
  const file = architectureStack[type][index];
  window.editor.setValue(file.content);
  monaco.editor.setModelLanguage(window.editor.getModel(), type === 'fe' ? 'html' : 'javascript');
  renderStack();
}

function addFile(type) {
  const name = prompt("Enter filename (without extension):");
  if (!name) return;
  architectureStack[type].push({ name: name + (type === 'fe' ? '.ejs' : '.js'), content: '' });
  renderStack();
}

function triggerImport(type) {
  window.importTargetType = type;
  document.getElementById('importModal').classList.remove('hidden');
}

async function selectForImport(type, file) {
  try {
    const res = await fetch(`/admin/plugins/studio/src?type=${type === 'fe' ? 'view' : 'route'}&file=${file}`);
    const data = await res.json();
    architectureStack[window.importTargetType].push({ name: path.basename(file), content: data.content });
    document.getElementById('importModal').classList.add('hidden');
    renderStack();
  } catch (e) { alert("Import failed."); }
}

function handleUpload(input, type) {
  Array.from(input.files).forEach(f => {
    const reader = new FileReader();
    reader.onload = (e) => {
      architectureStack[type].push({ name: f.name, content: e.target.result });
      renderStack();
    };
    reader.readAsText(f);
  });
}

function removeFile(type, index) {
  if (architectureStack[type].length <= 1) return alert("Must have at least one file.");
  architectureStack[type].splice(index, 1);
  if (activeFile.type === type && activeFile.index >= architectureStack[type].length) activeFile.index = 0;
  renderStack();
}

document.getElementById('studioForm').addEventListener('submit', (e) => {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  const form = e.target;

  architectureStack.fe.forEach(f => {
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="fe_filenames[]" value="${f.name}">`);
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="fe_contents[]" value="${f.content.replace(/"/g, '&quot;')}">`);
  });

  architectureStack.be.forEach(f => {
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="be_filenames[]" value="${f.name}">`);
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="be_contents[]" value="${f.content.replace(/"/g, '&quot;')}">`);
  });
});

document.getElementById('saveActiveFile').addEventListener('click', () => {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  syncPagesFromLogic();
  updateManifestPreview();
  alert("Synced to memory.");
});

function renderTabs() {
  const tabs = document.getElementById('fileTabs');
  const file = architectureStack[activeFile.type][activeFile.index];
  tabs.innerHTML = `<div class="px-4 py-1.5 rounded-full bg-blue-500/20 text-blue-400 text-[10px] font-black uppercase tracking-widest border border-blue-500/30">Editing: ${file.name}</div>`;
}

function updateManifestPreview() {
  const form = document.getElementById('studioForm');
  const formData = new FormData(form);

  const adminsidebar = {};
  const sCats = formData.getAll('sidebar_category[]');
  const sNames = formData.getAll('sidebar_name[]');
  const sRoutes = formData.getAll('sidebar_route[]');
  const sIcons = formData.getAll('sidebar_icon[]');

  sNames.forEach((name, i) => {
    if (!name) return;
    const cat = sCats[i] || 'Plugins';
    if (!adminsidebar[cat]) adminsidebar[cat] = [];
    adminsidebar[cat].push({
      name,
      icon: sIcons[i] || 'puzzle-piece',
      link: `/plugins/${sRoutes[i] || 'index'}`
    });
  });

  const manifest = {
    name: formData.get('name') || 'Unnamed Plugin',
    version: formData.get('version'),
    description: formData.get('description'),
    main: 'router/index.js',
    adminsidebar,
    dependencies: formData.getAll('dependencies[]').filter(d => d),
    hooks: formData.getAll('hooks[]'),
    permissions: formData.getAll('permissions[]')
  };

  document.getElementById('manifestPreview').textContent = JSON.stringify(manifest, null, 2);
}

document.getElementById('studioForm').addEventListener('input', updateManifestPreview);

document.getElementById('registrySearch').addEventListener('input', (e) => {
  const term = e.target.value.toLowerCase();
  document.querySelectorAll('#pageRegistry > div').forEach(el => {
    const text = el.textContent.toLowerCase();
    el.style.display = text.includes(term) ? 'flex' : 'none';
  });
});

function syncPagesFromLogic() {
  const registry = document.getElementById('pageRegistry');
  registry.innerHTML = '';

  architectureStack.be.forEach(file => {
    const routeRegex = /router\.(get|post|put|delete)\(['"]\/([^'"]*)['"]/g;
    let match;
    while ((match = routeRegex.exec(file.content)) !== null) {
      const path = match[2] || 'index';
      const div = document.createElement('div');
      div.className = 'flex items-center justify-between p-3 rounded-xl bg-white/[0.03] border border-white/5 animate-fade-in hover:border-blue-500/30 transition-all';
      div.innerHTML = `
        <div class="flex flex-col">
          <span class="text-[9px] font-black text-blue-400 uppercase">${match[1]}</span>
          <span class="text-[10px] text-white font-mono truncate max-w-[80px]">/${path}</span>
        </div>
        <button type="button" onclick="addSidebarRegistration('${path}')" class="px-2 py-1 rounded-lg bg-white/5 border border-white/10 text-[8px] font-black text-neutral-400 hover:text-white transition-all uppercase">Add</button>
      `;
      registry.appendChild(div);
    }
  });
}

function addSidebarRegistration(path) {
  addSidebarItem();
  const lastItem = document.getElementById('sidebarItems').lastElementChild;
  lastItem.querySelector('input[name="sidebar_route[]"]').value = path;
  lastItem.querySelector('input[name="sidebar_name[]"]').value = path.charAt(0).toUpperCase() + path.slice(1);
  updateManifestPreview();
}

// Attach listener to editor
require(['vs/editor/editor.main'], function() {
    window.editor.onDidChangeModelContent(() => {
       syncPagesFromLogic();
       updateManifestPreview();
    });
    syncPagesFromLogic();
    updateManifestPreview();
});

function addDependency() {
  const container = document.getElementById('dependencyList');
  const div = document.createElement('div');
  div.className = 'flex gap-2 animate-fade-in';
  div.innerHTML = `
    <input type="text" name="dependencies[]" placeholder="e.g., axios" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-white text-xs focus:outline-none focus:border-blue-500 transition-all">
    <button type="button" onclick="this.parentElement.remove()" class="px-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-500 hover:bg-red-500/20">x</button>
  `;
  container.appendChild(div);
}

function addSidebarItem() {
  const container = document.getElementById('sidebarItems');
  const div = document.createElement('div');
  div.className = 'sidebar-item p-4 rounded-2xl bg-white/[0.03] border border-white/5 relative group animate-fade-in hover:border-white/10 transition-all';
  div.innerHTML = `
    <button type="button" onclick="this.parentElement.remove()" class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-red-500/20 border border-red-500/20 text-red-500 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all hover:bg-red-500 hover:text-white">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div class="grid grid-cols-1 gap-3">
      <div>
        <label class="text-[9px] font-black text-neutral-500 uppercase tracking-[0.2em] block mb-1">Category</label>
        <input type="text" name="sidebar_category[]" placeholder="Plugins" class="w-full bg-black/20 border border-white/10 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-blue-500">
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="text-[9px] font-black text-neutral-500 uppercase tracking-[0.2em] block mb-1">Name</label>
          <input type="text" name="sidebar_name[]" placeholder="Overview" class="w-full bg-black/20 border border-white/10 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="text-[9px] font-black text-neutral-500 uppercase tracking-[0.2em] block mb-1">Route</label>
          <input type="text" name="sidebar_route[]" placeholder="index" class="w-full bg-black/20 border border-white/10 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-blue-500">
        </div>
      </div>
      <div>
        <label class="text-[9px] font-black text-neutral-500 uppercase tracking-[0.2em] block mb-1">Icon (Heroicon name or RAW SVG)</label>
        <input type="text" name="sidebar_icon[]" placeholder="puzzle-piece or <svg>...</svg>" class="w-full bg-black/20 border border-white/10 rounded-lg px-3 py-2 text-[10px] text-white focus:outline-none focus:border-blue-500 font-mono">
      </div>
    </div>
  `;
  container.appendChild(div);
}
</script>

<%- include('../../components/footer') %>
