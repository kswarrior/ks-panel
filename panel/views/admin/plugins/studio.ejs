<%- include('../../components/template') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.34.0/min/vs/loader.js"></script>

<main id="content" class="animate-fade-in min-h-screen pb-24">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Header -->
    <header class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-4xl font-black text-white tracking-tight">Plugin Studio</h1>
        <p class="text-neutral-400 mt-2">Design and scaffold advanced extensions for KS Panel.</p>
      </div>
      <a href="/admin/plugins/overview" class="px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-white hover:bg-white/10 transition-all">
        Back to Overview
      </a>
    </header>

    <form action="/admin/plugins/studio/create" method="POST" id="studioForm" enctype="multipart/form-data" class="w-full overflow-x-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-8">

        <!-- Architecture Stack (Left) -->
        <div class="lg:col-span-1 space-y-4">
          <!-- Sidebar -->
          <section class="glass p-5 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.2em]">Sidebar.</h2>
              <button type="button" onclick="addSidebarItem()" class="px-2 py-1 rounded-lg bg-blue-500 text-white text-[10px] font-black uppercase shadow-lg shadow-blue-500/20 hover:scale-105 active:scale-95 transition-all">Add</button>
            </div>
            <div id="sidebarItems" class="space-y-2 max-h-40 overflow-y-auto no-scrollbar"></div>
          </section>

          <!-- Frontend -->
          <section class="glass p-5 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.2em]">Frontend.</h2>
              <div class="flex gap-2">
                <button type="button" onclick="addFile('fe')" class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all" title="Add"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg></button>
                <button type="button" onclick="triggerImport('fe')" class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all" title="Import"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h10a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg></button>
                <label class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all cursor-pointer" title="Upload">
                  <input type="file" multiple class="hidden" onchange="handleUpload(this, 'fe')">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                </label>
              </div>
            </div>
            <div id="feFiles" class="space-y-1 max-h-40 overflow-y-auto no-scrollbar"></div>
          </section>

          <!-- Backend -->
          <section class="glass p-5 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-[0.2em]">Backend.</h2>
              <div class="flex gap-2">
                <button type="button" onclick="addFile('be')" class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all" title="Add"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg></button>
                <button type="button" onclick="triggerImport('be')" class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all" title="Import"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h10a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg></button>
                <label class="p-1.5 rounded-lg bg-white/5 text-white hover:bg-white/10 transition-all cursor-pointer" title="Upload">
                  <input type="file" multiple class="hidden" onchange="handleUpload(this, 'be')">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                </label>
              </div>
            </div>
            <div id="beFiles" class="space-y-1 max-h-40 overflow-y-auto no-scrollbar"></div>
          </section>

          <!-- Page Registry -->
          <section class="glass p-6 rounded-3xl border border-white/5 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Page Registry</h2>
              <input type="text" id="registrySearch" placeholder="Filter..." class="w-20 bg-white/5 border border-white/10 rounded-lg px-2 py-1 text-[9px] text-white focus:outline-none focus:border-amber-500 transition-all">
            </div>
            <div id="pageRegistry" class="space-y-2 max-h-[200px] overflow-y-auto custom-scrollbar pr-1"></div>
          </section>
        </div>

        <!-- Extension Core & IDE (Right) -->
        <div class="lg:col-span-3 space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
             <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl">
               <h2 class="text-xl font-bold text-white mb-8">Metadata</h2>
               <div class="grid grid-cols-2 gap-6">
                 <div><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Name</label><input type="text" name="name" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></div>
                 <div><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Version</label><input type="text" name="version" value="1.0.0" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></div>
               </div>
               <div class="mt-4"><label class="text-[10px] font-black text-neutral-500 uppercase block mb-1">Description</label><textarea name="description" rows="2" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm"></textarea></div>
             </section>

             <section class="glass p-4 sm:p-8 rounded-3xl border border-white/5 shadow-2xl">
               <h2 class="text-xl font-bold text-white mb-8">Required Permissions</h2>
               <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                 <% [
                   {id: 'db:read', label: 'Database R/O'},
                   {id: 'db:write', label: 'Database R/W'},
                   {id: 'terminal:exec', label: 'Terminal Exec (VPS/apt)'},
                   {id: 'users:manage', label: 'User Mgmt'},
                   {id: 'servers:manage', label: 'Server Mgmt'},
                   {id: 'system:power', label: 'System Control'}
                 ].forEach(perm => { %>
                   <label class="flex items-center gap-2 p-2.5 rounded-xl bg-white/5 border border-white/5 cursor-pointer hover:bg-white/10 transition-all group">
                     <input type="checkbox" name="permissions[]" value="<%= perm.id %>" class="rounded border-white/20 bg-white/5 text-blue-500 focus:ring-0">
                     <span class="text-[10px] text-neutral-400 font-bold uppercase group-hover:text-white"><%= perm.label %></span>
                   </label>
                 <% }) %>
               </div>
             </section>
          </div>

          <!-- IDE & Testing Laboratory -->
          <div class="space-y-6">
            <div class="flex gap-2">
               <button type="button" onclick="setStudioView('editor')" id="viewBtnEditor" class="flex-1 py-3 rounded-2xl bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest transition-all">IDE Editor</button>
               <button type="button" onclick="setStudioView('tester')" id="viewBtnTester" class="flex-1 py-3 rounded-2xl bg-white/5 border border-white/10 text-neutral-400 text-[10px] font-black uppercase tracking-widest transition-all">Testing Lab</button>
            </div>

            <section id="studioEditor" class="glass p-4 sm:p-8 rounded-3xl border border-white/5 shadow-2xl overflow-hidden">
              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
                <div class="flex items-center gap-4">
                  <h2 class="text-xl font-bold text-white">Logic Laboratory</h2>
                  <div id="fileTabs" class="flex gap-2 overflow-x-auto max-w-[200px] sm:max-w-none no-scrollbar"></div>
                </div>
                <div class="flex gap-2 w-full sm:w-auto">
                   <button type="button" id="saveActiveFile" class="flex-1 sm:flex-none px-4 py-2 rounded-xl bg-emerald-500 text-white text-[10px] font-black uppercase shadow-lg shadow-emerald-500/20" title="Sync to Memory">
                      <span class="sm:hidden"><svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg></span>
                      <span class="hidden sm:inline">Sync to Memory</span>
                   </button>
                </div>
              </div>
              <div id="editor" class="w-full h-[400px] sm:h-[600px] rounded-2xl border border-white/10 bg-black/40 overflow-hidden"></div>
            </section>

            <section id="studioTester" class="hidden glass p-4 sm:p-8 rounded-3xl border border-white/5 shadow-2xl space-y-8">
               <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                  <!-- Frontend Simulator -->
                  <div class="space-y-4">
                     <h3 class="text-xs font-black text-white uppercase tracking-[0.2em]">HTML Simulator</h3>
                     <div class="p-4 rounded-2xl bg-white/5 border border-white/5 space-y-4">
                        <button type="button" onclick="simulateFrontend()" class="w-full py-3 rounded-xl bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] font-black uppercase">Render Active View</button>
                        <div id="simPreview" class="w-full h-80 bg-white rounded-xl overflow-auto p-4 text-black text-sm">
                           <p class="text-neutral-500 italic text-center mt-20">Click render to simulate view...</p>
                        </div>
                     </div>
                  </div>

                  <!-- Route Tester -->
                  <div class="space-y-4">
                     <h3 class="text-xs font-black text-white uppercase tracking-[0.2em]">Route Tester</h3>
                     <div class="p-4 rounded-2xl bg-white/5 border border-white/5 space-y-4">
                        <div class="flex gap-2">
                           <input type="text" id="testRoutePath" placeholder="/index" class="flex-1 bg-black/20 border border-white/10 rounded-xl px-4 py-2 text-xs text-white">
                           <button type="button" onclick="testRoute()" class="px-4 py-2 rounded-xl bg-purple-500 text-white text-[10px] font-black uppercase">Run</button>
                        </div>
                        <pre id="testResponse" class="w-full h-40 bg-black/40 rounded-xl p-4 text-[10px] text-emerald-400 font-mono overflow-auto border border-white/5">Waiting for request...</pre>

                        <div class="pt-4 border-t border-white/5">
                           <h4 class="text-[9px] font-black text-neutral-500 uppercase mb-2">Security Audit (Simulated)</h4>
                           <div id="securityAudit" class="space-y-1">
                              <p class="text-[10px] text-neutral-600 italic">No sensitive calls detected.</p>
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
            </section>
          </div>

          <!-- Advanced Configuration -->
          <section class="glass p-8 rounded-3xl border border-white/5 shadow-2xl">
          <!-- Dependency Cloner (Dynamic Importer Modal) -->
          <div id="importModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4">
            <div class="absolute inset-0 bg-black/80 backdrop-blur-xl" onclick="this.parentElement.classList.add('hidden')"></div>
            <div class="glass relative w-full max-w-2xl p-8 rounded-[2rem] border border-white/10 shadow-2xl">
              <h2 class="text-2xl font-black text-white mb-8">Import Source Component</h2>
              <div class="grid grid-cols-2 gap-8 h-96">
                <div class="space-y-4">
                  <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Views (Frontend)</h3>
                  <div class="space-y-1 max-h-80 overflow-y-auto custom-scrollbar">
                    <% views.forEach(v => { %>
                      <div onclick="selectForImport('fe', '<%= v %>')" class="p-3 rounded-xl bg-white/5 border border-white/5 text-xs text-neutral-400 hover:text-white hover:bg-blue-500/10 hover:border-blue-500/20 cursor-pointer transition-all truncate"><%= v %></div>
                    <% }) %>
                  </div>
                </div>
                <div class="space-y-4">
                  <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Routes (Backend)</h3>
                  <div class="space-y-1 max-h-80 overflow-y-auto custom-scrollbar">
                    <% routes.forEach(r => { %>
                      <div onclick="selectForImport('be', '<%= r %>')" class="p-3 rounded-xl bg-white/5 border border-white/5 text-xs text-neutral-400 hover:text-white hover:bg-purple-500/10 hover:border-purple-500/20 cursor-pointer transition-all truncate"><%= r %></div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Submit & Live Manifest -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
            <div class="glass p-6 rounded-3xl border border-white/5 overflow-hidden">
               <h3 class="text-[10px] font-black text-neutral-500 uppercase tracking-widest mb-4 flex items-center justify-between">
                 Live manifest.json Preview
                 <span class="text-blue-400">Read Only</span>
               </h3>
               <pre id="manifestPreview" class="text-[10px] text-neutral-400 font-mono bg-black/20 p-4 rounded-xl overflow-x-auto">{}</pre>
            </div>

            <div class="flex flex-col gap-4">
              <button type="submit" class="w-full py-6 rounded-3xl bg-blue-500 text-white font-black text-sm hover:bg-blue-600 transition-all shadow-2xl shadow-blue-500/20 uppercase tracking-[0.3em]">
                Initialize Plugin Core
              </button>
              <button type="reset" class="w-full py-3 rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-[10px] hover:bg-white/10 transition-all uppercase tracking-widest">
                Discard Changes
              </button>
            </div>
          </div>
        </div>
      </div>
    </form>

  </div>
</main>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
</style>

<script>
let architectureStack = {
  fe: [{ name: 'index.ejs', content: '<h1>Hello Plugin</h1>' }],
  be: [{ name: 'index.js', content: 'const express = require("express");\nconst router = express.Router();\n\nrouter.get("/", (req, res) => { res.render("../views/index"); });\n\nmodule.exports = router;' }]
};
let activeFile = { type: 'be', index: 0 };

require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.34.0/min/vs' }});
require(['vs/editor/editor.main'], function() {
    window.editor = monaco.editor.create(document.getElementById('editor'), {
        value: architectureStack.be[0].content,
        language: 'javascript',
        theme: 'vs-dark',
        automaticLayout: true,
        fontSize: 13,
        minimap: { enabled: false },
        padding: { top: 20 }
    });
    renderStack();
});

function renderStack() {
  ['fe', 'be'].forEach(type => {
    const container = document.getElementById(type + 'Files');
    container.innerHTML = architectureStack[type].map((f, i) => `
      <div onclick="switchFile('${type}', ${i})" class="group flex items-center justify-between p-3 rounded-2xl border transition-all cursor-pointer ${activeFile.type === type && activeFile.index === i ? 'bg-blue-500/10 border-blue-500/30' : 'bg-white/5 border-transparent hover:border-white/10'}">
        <span class="text-[10px] sm:text-xs ${activeFile.type === type && activeFile.index === i ? 'text-blue-400 font-bold' : 'text-neutral-400'} truncate max-w-[100px] sm:max-w-none">${f.name}</span>
        <button type="button" onclick="event.stopPropagation(); removeFile('${type}', ${i})" class="opacity-100 sm:opacity-0 sm:group-hover:opacity-100 text-red-500 transition-opacity"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg></button>
      </div>
    `).join('');
  });
  renderTabs();
  syncPagesFromLogic();
  updateManifestPreview();
}

function switchFile(type, index) {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  activeFile = { type, index };
  const file = architectureStack[type][index];
  window.editor.setValue(file.content);
  monaco.editor.setModelLanguage(window.editor.getModel(), type === 'fe' ? 'html' : 'javascript');
  renderStack();
}

function addFile(type) {
  const name = prompt("Enter filename (without extension):");
  if (!name) return;
  architectureStack[type].push({ name: name + (type === 'fe' ? '.ejs' : '.js'), content: '' });
  renderStack();
}

function triggerImport(type) {
  window.importTargetType = type;
  document.getElementById('importModal').classList.remove('hidden');
}

async function selectForImport(type, file) {
  try {
    const res = await fetch(`/admin/plugins/studio/src?type=${type === 'fe' ? 'view' : 'route'}&file=${file}`);
    const data = await res.json();
    architectureStack[window.importTargetType].push({ name: path.basename(file), content: data.content });
    document.getElementById('importModal').classList.add('hidden');
    renderStack();
  } catch (e) { alert("Import failed."); }
}

function handleUpload(input, type) {
  Array.from(input.files).forEach(f => {
    const reader = new FileReader();
    reader.onload = (e) => {
      architectureStack[type].push({ name: f.name, content: e.target.result });
      renderStack();
    };
    reader.readAsText(f);
  });
}

function removeFile(type, index) {
  if (architectureStack[type].length <= 1) return alert("Must have at least one file.");
  architectureStack[type].splice(index, 1);
  if (activeFile.type === type && activeFile.index >= architectureStack[type].length) activeFile.index = 0;
  renderStack();
}

document.getElementById('studioForm').addEventListener('submit', (e) => {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  const form = e.target;

  architectureStack.fe.forEach(f => {
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="fe_filenames[]" value="${f.name}">`);
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="fe_contents[]" value="${f.content.replace(/"/g, '&quot;')}">`);
  });

  architectureStack.be.forEach(f => {
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="be_filenames[]" value="${f.name}">`);
    form.insertAdjacentHTML('beforeend', `<input type="hidden" name="be_contents[]" value="${f.content.replace(/"/g, '&quot;')}">`);
  });
});

document.getElementById('saveActiveFile').addEventListener('click', () => {
  architectureStack[activeFile.type][activeFile.index].content = window.editor.getValue();
  syncPagesFromLogic();
  updateManifestPreview();
  alert("Synced to memory.");
});

function renderTabs() {
  const tabs = document.getElementById('fileTabs');
  const file = architectureStack[activeFile.type][activeFile.index];
  tabs.innerHTML = `<div class="px-4 py-1.5 rounded-full bg-blue-500/20 text-blue-400 text-[10px] font-black uppercase tracking-widest border border-blue-500/30">Editing: ${file.name}</div>`;
}

function updateManifestPreview() {
  const form = document.getElementById('studioForm');
  const formData = new FormData(form);

  const adminsidebar = {};
  const sCats = formData.getAll('sidebar_category[]');
  const sNames = formData.getAll('sidebar_name[]');
  const sRoutes = formData.getAll('sidebar_route[]');
  const sIcons = formData.getAll('sidebar_icon[]');

  sNames.forEach((name, i) => {
    if (!name) return;
    const cat = sCats[i] || 'Plugins';
    if (!adminsidebar[cat]) adminsidebar[cat] = [];
    adminsidebar[cat].push({
      name,
      icon: sIcons[i] || 'puzzle-piece',
      link: `/plugins/${sRoutes[i] || 'index'}`
    });
  });

  const manifest = {
    name: formData.get('name') || 'Unnamed Plugin',
    version: formData.get('version'),
    description: formData.get('description'),
    main: 'router/index.js',
    adminsidebar,
    dependencies: formData.getAll('dependencies[]').filter(d => d),
    hooks: formData.getAll('hooks[]'),
    permissions: formData.getAll('permissions[]')
  };

  document.getElementById('manifestPreview').textContent = JSON.stringify(manifest, null, 2);
}

document.getElementById('studioForm').addEventListener('input', updateManifestPreview);

document.getElementById('registrySearch').addEventListener('input', (e) => {
  const term = e.target.value.toLowerCase();
  document.querySelectorAll('#pageRegistry > div').forEach(el => {
    const text = el.textContent.toLowerCase();
    el.style.display = text.includes(term) ? 'flex' : 'none';
  });
});

function syncPagesFromLogic() {
  const registry = document.getElementById('pageRegistry');
  registry.innerHTML = '';

  architectureStack.be.forEach(file => {
    const routeRegex = /router\.(get|post|put|delete)\(['"]\/([^'"]*)['"]/g;
    let match;
    while ((match = routeRegex.exec(file.content)) !== null) {
      const path = match[2] || 'index';
      const div = document.createElement('div');
      div.className = 'flex items-center justify-between p-3 rounded-xl bg-white/[0.03] border border-white/5 animate-fade-in hover:border-blue-500/30 transition-all';
      div.innerHTML = `
        <div class="flex flex-col">
          <span class="text-[9px] font-black text-blue-400 uppercase">${match[1]}</span>
          <span class="text-[10px] text-white font-mono truncate max-w-[80px]">/${path}</span>
        </div>
        <button type="button" onclick="addSidebarRegistration('${path}')" class="px-2 py-1 rounded-lg bg-white/5 border border-white/10 text-[8px] font-black text-neutral-400 hover:text-white transition-all uppercase">Add</button>
      `;
      registry.appendChild(div);
    }
  });
}

function setStudioView(view) {
  const e = document.getElementById('studioEditor');
  const t = document.getElementById('studioTester');
  const be = document.getElementById('viewBtnEditor');
  const bt = document.getElementById('viewBtnTester');

  if (view === 'editor') {
    e.classList.remove('hidden');
    t.classList.add('hidden');
    be.classList.add('bg-blue-500', 'text-white');
    be.classList.remove('bg-white/5', 'text-neutral-400');
    bt.classList.add('bg-white/5', 'text-neutral-400');
    bt.classList.remove('bg-blue-500', 'text-white');
  } else {
    e.classList.add('hidden');
    t.classList.remove('hidden');
    bt.classList.add('bg-blue-500', 'text-white');
    bt.classList.remove('bg-white/5', 'text-neutral-400');
    be.classList.add('bg-white/5', 'text-neutral-400');
    be.classList.remove('bg-blue-500', 'text-white');
  }
}

function updateSecurityAudit() {
  const code = architectureStack.be.map(f => f.content).join('\n');
  const audit = document.getElementById('securityAudit');
  const detections = [];

  if (code.includes('executeCommand')) detections.push({ id: 'terminal:exec', label: 'Terminal Command Execution' });
  if (code.includes('db.get') || code.includes('db.set')) detections.push({ id: 'db:*', label: 'Database Access' });

  if (detections.length === 0) {
    audit.innerHTML = '<p class="text-[10px] text-neutral-600 italic">No sensitive calls detected.</p>';
  } else {
    audit.innerHTML = detections.map(d => `
      <div class="flex items-center gap-2 text-amber-500/80">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        <span class="text-[10px] font-bold uppercase">${d.label}</span>
      </div>
    `).join('');
  }
}

function simulateFrontend() {
  if (activeFile.type !== 'fe') return alert("Select a Frontend (.ejs) file first.");
  const code = window.editor.getValue();
  const sim = document.getElementById('simPreview');

  // Mock data for simulator
  const mockData = {
    user: { username: 'AdminUser', admin: true, owner: true, userId: '1' },
    req: { path: '/plugins/test', query: {} },
    notifications: [],
    name: 'KS Panel Simulator',
    theme: { '--accent-color': '#3b82f6' }
  };

  try {
    // Simple EJS tag replacement logic for the client-side simulator
    let clean = code.replace(/<%%[=-]?([\s\S]*?)%>/g, (match, inner) => {
      const key = inner.trim();
      if (key === 'user.username') return mockData.user.username;
      if (key === 'name') return mockData.name;
      if (key.includes('req.path')) return mockData.req.path;
      return `[${key}]`;
    });

    // Remove any remaining raw <%% ... %> blocks
    clean = clean.replace(/<%%[\s\S]*?%>/g, '');

    sim.innerHTML = `<div style="all: initial; font-family: sans-serif;">${clean}</div>`;
  } catch (err) {
    sim.innerHTML = `<div class="text-red-500 font-mono">Render Error: ${err.message}</div>`;
  }
}

async function testRoute() {
  const path = document.getElementById('testRoutePath').value;
  const resp = document.getElementById('testResponse');
  resp.textContent = `[SIMULATING GET ${path}]...\n\nChecking logic stack...`;

  // Basic mock matcher
  const file = architectureStack.be.find(f => f.content.includes(`'${path}'`) || f.content.includes(`"${path}"`));
  if (file) {
    resp.textContent = `[MATCH FOUND in ${file.name}]\n\nStatus: 200 OK\nContent-Type: text/html\n\n[MOCKED RESPONSE: Renders correctly]`;
  } else {
    resp.textContent = `[ERROR]\n\nStatus: 404 Not Found\nRoute ${path} not defined in any Backend files.`;
  }
}

function addSidebarRegistration(path) {
  addSidebarItem();
  const lastItem = document.getElementById('sidebarItems').lastElementChild;
  lastItem.querySelector('input[name="sidebar_route[]"]').value = path;
  lastItem.querySelector('input[name="sidebar_name[]"]').value = path.charAt(0).toUpperCase() + path.slice(1);
  updateManifestPreview();
}

// Attach listener to editor
require(['vs/editor/editor.main'], function() {
    window.editor.onDidChangeModelContent(() => {
       syncPagesFromLogic();
       updateManifestPreview();
       updateSecurityAudit();
    });
    syncPagesFromLogic();
    updateManifestPreview();
});

