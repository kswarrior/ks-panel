<%- include('../components/template') %>

<main id="content" class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-[1600px] mx-auto">
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
      <div class="w-24 h-24 rounded-3xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-8 border border-blue-500/20 shadow-2xl">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
      </div>
      <h1 class="text-4xl font-black text-white tracking-tight mb-4">Admin Control Center</h1>
      <p class="text-neutral-400 max-w-md mx-auto mb-10 leading-relaxed">Welcome back, <%= user.username %>. Use the sidebar or the quick links below to manage your infrastructure.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-5xl">
        <a href="/admin/dashboard/console" class="glass p-6 rounded-3xl border border-white/10 hover:bg-white/[0.08] transition-all group">
          <div class="text-2xl mb-4 group-hover:scale-110 transition-transform">📊</div>
          <h3 class="font-bold text-white mb-1">System Health</h3>
          <p class="text-xs text-neutral-500">Live logs and resource monitoring</p>
        </a>
        <a href="/admin/instances/overview" class="glass p-6 rounded-3xl border border-white/10 hover:bg-white/[0.08] transition-all group">
          <div class="text-2xl mb-4 group-hover:scale-110 transition-transform">🖥️</div>
          <h3 class="font-bold text-white mb-1">Instances</h3>
          <p class="text-xs text-neutral-500">Deploy and scale containers</p>
        </a>
        <a href="/admin/nodes/overview" class="glass p-6 rounded-3xl border border-white/10 hover:bg-white/[0.08] transition-all group">
          <div class="text-2xl mb-4 group-hover:scale-110 transition-transform">📡</div>
          <h3 class="font-bold text-white mb-1">Nodes</h3>
          <p class="text-xs text-neutral-500">Infrastructure management</p>
        </a>
        <a href="/admin/users" class="glass p-6 rounded-3xl border border-white/10 hover:bg-white/[0.08] transition-all group">
          <div class="text-2xl mb-4 group-hover:scale-110 transition-transform">👥</div>
          <h3 class="font-bold text-white mb-1">Users</h3>
          <p class="text-xs text-neutral-500">RBAC and access control</p>
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('../components/footer') %>
