<%- include('../components/template') %>

<style>
/* Base styles - preserving your exact colors */
.input-field {
  width: 100%;
  padding: 1rem 1.5rem;
  background-color: #1c3b54;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
  color: white;
  outline: none;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.1);
}

/* Smooth scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Prevent iOS zoom */
@supports (-webkit-touch-callout: none) {
  input, select, textarea {
    font-size: 16px;
  }
}

/* View visibility controls */
.mobile-view {
  display: block;
}

.desktop-view {
  display: none;
}

@media (min-width: 640px) {
  .mobile-view {
    display: none;
  }
  .desktop-view {
    display: block;
  }
}

/* Animations */
@keyframes slideIn {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-slide-in {
  animation: slideIn 0.3s ease-out;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* Glassmorphism enhancement */
.glass-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.glass-card:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.15);
}
</style>

<main id="content" class="min-h-screen pb-20">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    
    <!-- Header Section -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pb-6 sm:pb-8 border-b border-white/10">
      <div class="space-y-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= req.translations.locations %></h1>
        <p class="text-sm text-neutral-400 max-w-xl"><%= req.translations.locationsText %></p>
      </div>
      
      <div class="flex-shrink-0">
        <button id="createButton" type="button" 
                class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl bg-white text-black font-semibold text-sm shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          <span class="hidden sm:inline"><%= req.translations.createNewLocation %></span>
          <span class="sm:hidden">Create</span>
        </button>
      </div>
    </header>

    <!-- Stats Section -->
    <section id="stats" class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mt-6 sm:mt-8">
      <!-- Total Locations -->
      <article class="relative overflow-hidden rounded-2xl glass-card p-5 sm:p-6 transition-all duration-300 hover:border-white/20 shadow-lg group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-blue-500/20 transition-all duration-500"></div>
        <div class="relative">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-medium text-neutral-400 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-blue-500"></span>
              <%= req.translations.totalLocations || 'Total Locations' %>
            </p>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-xl sm:text-2xl border border-blue-500/20 group-hover:scale-110 transition-transform duration-300">📍</div>
          </div>
          <p class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight"><%= locations.length %></p>
          <p class="mt-2 text-xs sm:text-sm text-neutral-500">Active deployment zones</p>
        </div>
      </article>

      <!-- Node Count -->
      <article class="relative overflow-hidden rounded-2xl glass-card p-5 sm:p-6 transition-all duration-300 hover:border-white/20 shadow-lg group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-emerald-500/20 transition-all duration-500"></div>
        <div class="relative">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-medium text-neutral-400 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              <%= req.translations.nodeCount || 'Node Count' %>
            </p>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center text-xl sm:text-2xl border border-emerald-500/20 group-hover:scale-110 transition-transform duration-300">🖥️</div>
          </div>
          <p class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight"><%= Object.values(nodeSet).reduce((a, b) => a + b, 0) %></p>
          <% if (locations.length > 0) { %>
            <p class="mt-2 text-xs sm:text-sm text-neutral-400">
              Avg: <span class="text-white font-semibold"><%= (Object.values(nodeSet).reduce((a, b) => a + b, 0) / locations.length).toFixed(2) %></span> nodes/location
            </p>
          <% } else { %>
            <p class="mt-2 text-xs sm:text-sm text-neutral-500">No locations configured</p>
          <% } %>
        </div>
      </article>
    </section>

    <!-- Success Notifications -->
    <% if (req.query.err == "none") { %>
    <div class="mt-6 sm:mt-8 bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 sm:p-5 flex gap-3 sm:gap-4 items-start shadow-lg backdrop-blur-sm animate-slide-in">
      <div class="flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-emerald-400 text-sm sm:text-base">Success!</p>
        <p class="text-sm text-emerald-300/80 mt-1">The action was successfully completed.</p>
      </div>
      <button onclick="this.parentElement.remove()" class="flex-shrink-0 text-emerald-400/60 hover:text-emerald-400 transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <% } %>

    <% if (req.query.err == "EDITED") { %>
    <div class="mt-6 sm:mt-8 bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 sm:p-5 flex gap-3 sm:gap-4 items-start shadow-lg backdrop-blur-sm animate-slide-in">
      <div class="flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-emerald-400 text-sm sm:text-base">Changes Saved!</p>
        <p class="text-sm text-emerald-300/80 mt-1">The location was edited successfully.</p>
      </div>
      <button onclick="this.parentElement.remove()" class="flex-shrink-0 text-emerald-400/60 hover:text-emerald-400 transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <% } %>

    <!-- DESKTOP VIEW - Table -->
    <section id="locationTable" class="mt-6 sm:mt-8 desktop-view">
      <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left text-white">
            <thead class="bg-neutral-950/80 text-neutral-400 text-xs uppercase tracking-wider">
              <tr>
                <th scope="col" class="py-4 px-4 sm:py-5 sm:px-6 font-semibold"><%= req.translations.name %></th>
                <th scope="col" class="py-4 px-4 sm:py-5 sm:px-6 font-semibold text-center"><%= req.translations.nodes %></th>
                <th scope="col" class="py-4 px-4 sm:py-5 sm:px-6 font-semibold text-right"><%= req.translations.actions %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% locations.forEach(function(location) { %>
              <tr class="hover:bg-white/[0.03] transition-colors duration-200 group">
                <!-- Name -->
                <td class="py-4 px-4 sm:py-5 sm:px-6">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-white/10 transition-colors">
                      <svg class="w-4 h-4 sm:w-5 sm:h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                    </div>
                    <span class="font-medium text-white truncate max-w-[200px] sm:max-w-[300px]"><%= location.name %></span>
                  </div>
                </td>

                <!-- Nodes -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 text-center">
                  <span class="inline-flex items-center justify-center min-w-[3rem] bg-neutral-800 px-3 py-1.5 rounded-lg text-xs font-semibold text-white border border-white/10 shadow-sm">
                    <%= nodeSet[location.id] || 0 %>
                  </span>
                </td>

                <!-- Actions -->
                <td class="py-4 px-4 sm:py-5 sm:px-6 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/admin/location/<%= location.id %>">
                      <button type="button" class="px-4 py-2 text-xs font-medium bg-white text-black rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                        <%= req.translations.edit %>
                      </button>
                    </a>
                    <button onclick="deletelocation('<%= location.id %>')" type="button" class="px-4 py-2 text-xs font-medium bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-xl border border-red-500/20 hover:border-red-500/30 transition-all duration-200 active:scale-95 flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                      <%= req.translations.remove %>
                    </button>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- MOBILE VIEW - Cards -->
    <section id="locationCards" class="mt-6 mobile-view">
      <div class="space-y-3">
        <% locations.forEach(function(location) { %>
        <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl border border-white/10 shadow-lg overflow-hidden hover:border-white/20 transition-all duration-300">
          <!-- Card Header -->
          <div class="p-4 border-b border-white/5 bg-white/[0.02]">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold text-white truncate"><%= location.name %></h3>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs text-neutral-400"><%= nodeSet[location.id] || 0 %> nodes</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Card Actions -->
          <div class="p-4 grid grid-cols-2 gap-3">
            <a href="/admin/location/<%= location.id %>" class="block">
              <button type="button" class="w-full py-2.5 bg-white text-black text-xs font-semibold rounded-xl shadow-lg hover:shadow-xl active:scale-95 transition-all duration-200 flex items-center justify-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                <%= req.translations.edit %>
              </button>
            </a>
            <button onclick="deletelocation('<%= location.id %>')" type="button" class="w-full py-2.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-semibold rounded-xl border border-red-500/20 hover:border-red-500/30 active:scale-95 transition-all duration-200 flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
              <%= req.translations.remove %>
            </button>
          </div>
        </div>
        <% }); %>
      </div>
    </section>

    <%- include('../components/pagination', { pagination }) %>

    <!-- Create Location Form -->
    <div id="locationForm" class="mt-6 hidden w-full max-w-2xl mx-auto animate-slide-in">
      <div class="bg-neutral-900/50 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
        <!-- Form Header -->
        <div class="px-4 sm:px-6 py-4 border-b border-white/10 bg-white/[0.02] flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
            </div>
            <h2 class="text-lg font-semibold text-white"><%= req.translations.createNewLocation || 'Create New Location' %></h2>
          </div>
          <button onclick="toggleForm()" class="text-neutral-400 hover:text-white transition-colors p-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Form Body -->
        <div class="p-4 sm:p-6 space-y-4">
          <div>
            <label for="locationName" class="block text-sm font-medium text-neutral-300 mb-2">
              <%= req.translations.name %> <span class="text-red-400">*</span>
            </label>
            <input id="locationName" type="text"
                   class="w-full px-4 py-3 rounded-xl bg-neutral-800/50 border border-white/10 text-white placeholder-neutral-500 focus:outline-none focus:border-white/30 focus:ring-2 focus:ring-white/10 transition-all text-sm sm:text-base"
                   placeholder="e.g., Guwahati, Assam, IN">
            <p class="mt-1 text-xs text-neutral-500">Enter a descriptive name for this location</p>
          </div>

          <div class="pt-2">
            <button id="createLocationBtn" type="button" 
                    class="w-full sm:w-auto px-6 py-3 bg-white text-black font-semibold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <%= req.translations.create %>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Notification Toast -->
    <div id="notification" 
         class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 hidden items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 rounded-xl shadow-2xl text-sm font-medium z-50 transition-all duration-300 transform translate-y-2 opacity-0 bg-white/10 backdrop-blur-xl border border-white/20 text-white">
      <span id="notification-icon">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </span>
      <span id="notification-text">Command copied to clipboard!</span>
    </div>

  </div>
</main>

<script>
// Toggle form visibility
function toggleForm() {
  const table = document.getElementById('locationTable') || document.getElementById('locationCards');
  const stats = document.getElementById('stats');
  const form = document.getElementById('locationForm');
  
  if (!form) return;

  if (form.classList.contains('hidden')) {
    // Show form, hide table/cards and stats
    stats?.classList.add('hidden');
    table?.classList.add('hidden');
    form.classList.remove('hidden');
    // Scroll to form on mobile
    if (window.innerWidth < 640) {
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  } else {
    // Hide form, show table/cards and stats
    stats?.classList.remove('hidden');
    table?.classList.remove('hidden');
    form.classList.add('hidden');
  }
}

// Update create button to use toggleForm
document.getElementById('createButton')?.addEventListener('click', toggleForm);

// Delete location with improved error handling
async function deletelocation(locationId) {
  if (!confirm('Are you sure you want to delete this location?')) return;
  
  try {
    const response = await fetch('/locations/delete', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ locationId })
    });

    const result = await response.json();

    if (response.ok) {
      showNotification('Location successfully deleted', 'success');
      setTimeout(() => window.location.reload(), 1000);
    } else if (result.error === "There are nodes in the location") {
      showNotification('Cannot delete: There are still nodes in this location', 'error');
    } else {
      throw new Error(result.error || 'Delete failed');
    }
  } catch (error) {
    console.error('Request failed:', error);
    showNotification(error.message || 'Failed to delete location', 'error');
  }
}

// Show notification with type support
function showNotification(message, type = 'success') {
  const notification = document.getElementById('notification');
  const textEl = document.getElementById('notification-text');
  const iconEl = document.getElementById('notification-icon');
  
  if (!notification || !textEl || !iconEl) return;
  
  textEl.textContent = message;
  
  // Set icon based on type
  if (type === 'error') {
    iconEl.innerHTML = `<svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>`;
    notification.classList.remove('border-white/20');
    notification.classList.add('border-red-500/30', 'bg-red-500/10');
  } else {
    iconEl.innerHTML = `<svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
    </svg>`;
    notification.classList.remove('border-red-500/30', 'bg-red-500/10');
    notification.classList.add('border-white/20');
  }
  
  notification.classList.remove('hidden');
  notification.classList.add('flex');
  
  requestAnimationFrame(() => {
    notification.classList.remove('translate-y-2', 'opacity-0');
  });

  setTimeout(() => {
    notification.classList.add('translate-y-2', 'opacity-0');
    setTimeout(() => {
      notification.classList.add('hidden');
      notification.classList.remove('flex');
    }, 300);
  }, 3000);
}

// Create location with validation
document.getElementById('createLocationBtn')?.addEventListener('click', function() {
  const nameInput = document.getElementById('locationName');
  const name = nameInput?.value?.trim();

  if (!name) {
    showNotification('Please enter a location name', 'error');
    nameInput?.focus();
    return;
  }

  const locationData = { name };

  fetch('/locations/create', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(locationData)
  })
  .then(response => {
    if (response.ok) {
      return response.json();
    }
    throw new Error('Failed to create location');
  })
  .then(data => {
    showNotification('Location created successfully!', 'success');
    setTimeout(() => {
      window.location.href = '/admin/locations?err=none';
    }, 500);
  })
  .catch(error => {
    console.error(error);
    showNotification('Error creating location: ' + error.message, 'error');
  });
});

// Enter key support for form
document.getElementById('locationName')?.addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    document.getElementById('createLocationBtn')?.click();
  }
});
</script>
