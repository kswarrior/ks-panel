{
  "name": "ks-panel",
  "version": "1.0.0",
  "description": "KS Panel is an open-source web panel for managing game servers and applications built with Node.js, Express, and Docker.",
  "main": "index.js",
  "bin": {
    "ks-panel": "./exec/bin/index.js"
  },
  "scripts": {
    "start": "npx pm2 start index.js --name ks-panel",
    "update": "kspanel update",
    "local:node": "node exec/localnode.js",
    "dev": "nodemon index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run watch\"",
    "watch": "browser-sync start --config bs-config.js",
    "seed": "node exec/seed.js",
    "create:user": "node exec/createUser.js",
    "build:css": "npx @tailwindcss/cli -i ./public/tw.conf -o ./public/assets/tailwind.css --watch",
    "build": "pkg .",
    "build:linux": "pkg . --targets linux-x64,linux-arm64"
  },
  "author": "ks-panel",
  "license": "MIT",
  "dependencies": {
    "@keyvhq/core": "^2.1.7",
    "@keyvhq/postgres": "^2.1.7",
    "@tailwindcss/cli": "^4.1.17",
    "adm-zip": "^0.5.12",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "cat-loggr": "^1.2.2",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "concurrently": "^8.2.2",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "eventemitter3": "^5.0.1",
    "express": "^4.19.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.2",
    "express-ws": "^5.0.2",
    "form-data": "^4.0.4",
    "http-proxy-middleware": "^2.0.6",
    "keyv": "^4.5.4",
    "multer": "^2.0.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "readline": "^1.3.0",
    "sanitize-filename": "^1.6.3",
    "sequelize": "^6.37.3",
    "speakeasy": "^2.0.0",
    "tailwindcss": "^4.1.17",
    "uuid": "^10.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "browser-sync": "^2.26.2",
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "scripts": [
      "./**/*.js"
    ],
    "assets": [
      "./**/*.ejs",
      "./**/*.css",
      "./**/*.json",
      "./**/*.txt",
      "./**/*.html",
      "./**/*.md",
      "./public/**/*",
      "./views/**/*",
      "./handlers/**/*",
      "./lang/**/*",
      "./storage/**/*",
      "./plugins/**/*",
      "./lib/**/*",
      "./utils/**/*",
      "./routes/**/*",
      "./exec/**/*",
      "./*.env",
      "./config.json",
      "./LICENSE",
      "./README.md",
      "./kspanel.sh"
    ],
    "targets": [
      "linux-x64",
      "linux-arm64"
    ]
  }
}
