#!/bin/bash

APP_NAME="kspanel"
PANEL_DIR="$HOME/.kspanel/panel"
LAUNCHER_DIR="$HOME/.kspanel/launcher"
DATABASE_DIR="$HOME/.kspanel/database"
DOWNLOAD_URL="https://github.com/kswarrior/ks-panel/releases/latest/download"
DOCKER_DIR="$HOME/.kspanel/docker"

USE_DOCKER_DB=false
if [ -f "$DOCKER_DIR/.env" ] && [ -f "$DOCKER_DIR/docker-compose.yml" ]; then
    if docker-compose -f "$DOCKER_DIR/docker-compose.yml" ps db | grep -q "Up"; then
        USE_DOCKER_DB=true
    fi
fi

case "$1" in

install)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Initializing installation...\033[0m"

# Check and install Node.js
if ! command -v node >/dev/null 2>&1; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing Node.js...\033[0m"
    sudo apt update >/dev/null 2>&1
    sudo apt install -y nodejs npm >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] Node.js installation failed.\033[0m"
        exit 1
    }
fi

# Check and install unzip
if ! command -v unzip >/dev/null 2>&1; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing unzip...\033[0m"
    sudo apt update >/dev/null 2>&1
    sudo apt install -y unzip >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] unzip installation failed.\033[0m"
        exit 1
    }
fi

# Check and install wget
if ! command -v wget >/dev/null 2>&1; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing wget...\033[0m"
    sudo apt update >/dev/null 2>&1
    sudo apt install -y wget >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] wget installation failed.\033[0m"
        exit 1
    }
fi

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;32m✔ Node.js, unzip, and wget are installed.\033[0m"

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Setting up directories...\033[0m"
mkdir -p "$LAUNCHER_DIR" "$PANEL_DIR" "$DATABASE_DIR" || {
echo -e "\033[1;31m[✗] Failed to create directories.\033[0m"
exit 1
}

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Downloading launcher...\033[0m"
cd "$LAUNCHER_DIR" || exit 1

wget -q https://raw.githubusercontent.com/kswarrior/ks-panel/refs/heads/main/launcher/index.js -O index.js || {
echo -e "\033[1;31m[✗] Failed to download launcher.\033[0m"
exit 1
}

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Preparing database directories...\033[0m"
cd "$DATABASE_DIR" || exit 1
mkdir -p templates plugins

cd plugins || exit 1
wget -q https://raw.githubusercontent.com/kswarrior/ks-panel/refs/heads/main/database/plugins/plugins.json -O plugins.json || {
echo -e "\033[1;31m[✗] Failed to download plugins.json.\033[0m"
exit 1
}

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Downloading latest panel release...\033[0m"
cd "$PANEL_DIR" || {
echo -e "\033[1;31m[✗] Failed to access panel directory.\033[0m"
exit 1
}

wget -q "$DOWNLOAD_URL/panel.zip" -O panel.zip || {
echo -e "\033[1;31m[✗] Failed to download panel release.\033[0m"
exit 1
}

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Extracting files...\033[0m"
unzip -qq -o panel.zip || {
echo -e "\033[1;31m[✗] Extraction failed.\033[0m"
exit 1
}

rm -f panel.zip

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing dependencies...\033[0m"
npm install --prefix "$PANEL_DIR" --production --no-audit --no-fund >/dev/null 2>&1 || {
echo -e "\033[1;31m[✗] Dependency installation failed.\033[0m"
exit 1
}

npm link >/dev/null 2>&1

if [ "$USE_DOCKER_DB" = true ]; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Using Docker PostgreSQL...\033[0m"
    DB_PASS=$(grep DB_PASS "$DOCKER_DIR/.env" | cut -d= -f2-)
    DB_USER="ksuser"
    DB_NAME="kspanel"
    DB_URL="postgres://$DB_USER:$DB_PASS@localhost:5432/$DB_NAME"
else
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing PostgreSQL...\033[0m"

    if ! command -v psql >/dev/null 2>&1; then
    sudo apt update -y >/dev/null 2>&1
    sudo apt install -y postgresql postgresql-contrib >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] PostgreSQL installation failed.\033[0m"
        exit 1
    }
    fi

    sudo systemctl start postgresql >/dev/null 2>&1
    sudo systemctl enable postgresql >/dev/null 2>&1

    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Generating secure database credentials...\033[0m"

    echo -ne "\033[1;36m[KS Panel]\033[0m \033[1;34m» Enter database password: \033[0m"
    read -s DB_PASS
    echo ""

    echo -ne "\033[1;36m[KS Panel]\033[0m \033[1;34m» Confirm password: \033[0m"
    read -s DB_PASS_CONFIRM
    echo ""

    if [ "$DB_PASS" != "$DB_PASS_CONFIRM" ]; then
      echo -e "\033[1;31m[✗] Passwords do not match.\033[0m"
      exit 1
    fi

    DB_USER="ksuser"
    DB_NAME="kspanel"

    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Configuring PostgreSQL database...\033[0m"

    ROLE_SQL=$(cat <<'EOSQL'
DO $$
BEGIN
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE  rolname = '%s') THEN
      CREATE ROLE %s LOGIN PASSWORD '%s';
   END IF;
END
$$;
EOSQL
)

    DB_SQL=$(cat <<'EOSQL'
DO $$
BEGIN
   IF NOT EXISTS (SELECT FROM pg_database WHERE  datname = '%s') THEN
      CREATE DATABASE %s OWNER %s;
   END IF;
END
$$;
EOSQL
)

    GRANT_SQL="GRANT ALL PRIVILEGES ON DATABASE %s TO %s;"

    FULL_SQL=$(printf "${ROLE_SQL}\n${DB_SQL}\n${GRANT_SQL}\n" "$DB_USER" "$DB_USER" "$DB_PASS" "$DB_NAME" "$DB_NAME" "$DB_USER" "$DB_NAME" "$DB_USER")

    sudo -u postgres psql <<< "$FULL_SQL" || {
        echo -e "\033[1;31m[✗] PostgreSQL configuration failed.\033[0m"
        exit 1
    }

    DB_URL="postgres://$DB_USER:$DB_PASS@localhost:5432/$DB_NAME"
fi

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Updating panel configuration...\033[0m"

cd "$PANEL_DIR" || exit 1

if [ -f config.json ]; then
sed -i "s|\"databaseURL\": \".*\"|\"databaseURL\": \"$DB_URL\"|g" config.json
fi

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Creating environment file...\033[0m"

cat > .env <<ENDF
DB_URL=$DB_URL
SESSION_SECRET=$(openssl rand -base64 32)
ENDF

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Seeding database...\033[0m"
npm run seed >/dev/null 2>&1

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Creating admin user...\033[0m"
npm run create:user

echo ""
echo -e "\033[1;32m[✓] KS Panel installed successfully.\033[0m"
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Run panel using: kspanel start\033[0m"
echo ""

;;

update)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Updating panel...\033[0m"
cd "$PANEL_DIR" || {
echo -e "\033[1;31m[✗] Panel directory not found\033[0m"
exit 1
}

backup_dir="$HOME/.kspanel/update_backup"
mkdir -p "$backup_dir"
cp .env "$backup_dir/" 2>/dev/null || true
cp config.json "$backup_dir/" 2>/dev/null || true
mv node_modules .node_modules 2>/dev/null || true
rm -rf *

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Downloading latest release...\033[0m"
wget -q "$DOWNLOAD_URL/panel.zip" -O panel.zip || {
echo -e "\033[1;31m[✗] Failed to download panel release.\033[0m"
exit 1
}

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Extracting files...\033[0m"
unzip -qq -o panel.zip || {
echo -e "\033[1;31m[✗] Extraction failed.\033[0m"
exit 1
}
rm -f panel.zip

mv .node_modules node_modules 2>/dev/null || true

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing dependencies...\033[0m"
npm install --prefix "$PANEL_DIR" --production --no-audit --no-fund >/dev/null 2>&1
npm link >/dev/null 2>&1

cp "$backup_dir/.env" .env 2>/dev/null || true
cp "$backup_dir/config.json" config.json 2>/dev/null || true
rm -rf "$backup_dir"

echo -e "\033[1;32m[✓] KS Panel updated successfully.\033[0m"
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Restarting service...\033[0m"

kspanel restart

echo -e "\033[1;32m[✓] KS Panel restarted successfully.\033[0m"

;;

uninstall)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Stopping service...\033[0m"
npx pm2 delete "$APP_NAME" >/dev/null 2>&1 || true

if [ "$USE_DOCKER_DB" = true ]; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Stopping Docker DB...\033[0m"
    docker-compose -f "$DOCKER_DIR/docker-compose.yml" down >/dev/null 2>&1 || true
fi

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;31m» Removing all files...\033[0m"

rm -rf "$HOME/.kspanel"

# Attempt to remove global binary (correction)
if [ -f /usr/local/bin/kspanel ]; then
    if [ "$EUID" -eq 0 ] || command -v sudo >/dev/null 2>&1; then
        if [ "$EUID" -eq 0 ]; then
            rm -f /usr/local/bin/kspanel
        else
            sudo rm -f /usr/local/bin/kspanel
        fi
        echo -e "\033[1;32m[✓] Global binary removed.\033[0m"
    else
        echo -e "\033[1;33m[!] Run as root to remove /usr/local/bin/kspanel\033[0m"
    fi
fi

# Note: Database remains; manual cleanup needed for PostgreSQL
echo -e "\033[1;32m[✓] KS Panel removed successfully.\033[0m"

;;

create:user)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Creating new user...\033[0m"

cd "$PANEL_DIR" || {
echo -e "\033[1;31m[✗] Panel directory not found\033[0m"
exit 1
}

npm run create:user

echo -e "\033[1;32m[✓] User created successfully.\033[0m"

;;

database)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Setting up Docker database only...\033[0m"

# Check and install Docker
if ! command -v docker >/dev/null 2>&1; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing Docker...\033[0m"
    sudo apt update >/dev/null 2>&1
    sudo apt install -y docker.io >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] Docker installation failed.\033[0m"
        exit 1
    }
    sudo systemctl start docker >/dev/null 2>&1
    sudo systemctl enable docker >/dev/null 2>&1
fi

# Check and install Docker Compose
if ! command -v docker-compose >/dev/null 2>&1; then
    echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Installing Docker Compose...\033[0m"
    sudo apt update >/dev/null 2>&1
    sudo apt install -y docker-compose >/dev/null 2>&1 || {
        echo -e "\033[1;31m[✗] Docker Compose installation failed.\033[0m"
        exit 1
    }
fi

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;32m✔ Docker and Docker Compose are installed.\033[0m"

mkdir -p "$DOCKER_DIR"

cd "$DOCKER_DIR" || exit 1

# Write docker-compose.yml for database only
cat > docker-compose.yml <<'EOF'
version: '3.8'

services:
  db:
    image: postgres:14
    container_name: kspanel_postgres
    restart: always
    environment:
      POSTGRES_DB: kspanel
      POSTGRES_USER: ksuser
      POSTGRES_PASSWORD: ${DB_PASS}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

volumes:
  postgres_data:
EOF

echo -ne "\033[1;36m[KS Panel]\033[0m \033[1;34m» Enter database password: \033[0m"
read -s DB_PASS
echo ""

echo -ne "\033[1;36m[KS Panel]\033[0m \033[1;34m» Confirm password: \033[0m"
read -s DB_PASS_CONFIRM
echo ""

if [ "$DB_PASS" != "$DB_PASS_CONFIRM" ]; then
  echo -e "\033[1;31m[✗] Passwords do not match.\033[0m"
  exit 1
fi

# Create .env for compose
cat > .env <<ENDF
DB_PASS=$DB_PASS
ENDF

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Starting database service...\033[0m"
docker-compose up -d

# Wait for DB to be ready
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Waiting for database to initialize...\033[0m"
sleep 10

echo -e "\033[1;32m[✓] KS Panel Database Docker setup completed.\033[0m"
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Database running on localhost:5432\033[0m"
echo ""
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Connection String:\033[0m"
echo -e "\033[1;37mpostgres://ksuser:${DB_PASS}@localhost:5432/kspanel\033[0m"
echo ""
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» To connect panel:\033[0m"
echo -e "  1. Run: kspanel install"
echo ""
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Manage: cd $DOCKER_DIR && docker-compose logs -f db\033[0m"
echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Stop: docker-compose down\033[0m"

;;

start)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;34m» Starting service...\033[0m"

if [[ -f "$PANEL_DIR/index.js" ]]; then

npx --yes pm2 start "$PANEL_DIR/index.js" --name "$APP_NAME" --cwd "$PANEL_DIR" >/dev/null 2>&1

if [[ $? -eq 0 ]]; then
echo -e "\033[1;32m[✓] KS Panel started successfully.\033[0m"
else
echo -e "\033[1;31m[✗] Failed to start via pm2.\033[0m"
echo -e "\033[1;37m[!] Manual: cd $PANEL_DIR && npx pm2 start index.js --name $APP_NAME\033[0m"
fi

else

echo -e "\033[1;31m[✗] Panel not installed. Run 'kspanel install'.\033[0m"

fi

;;

stop)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Stopping service...\033[0m"

npx pm2 stop "$APP_NAME" >/dev/null 2>&1

echo -e "\033[1;32m[✓] KS Panel stopped successfully.\033[0m"

;;

restart)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;33m» Restarting service...\033[0m"

npx pm2 restart "$APP_NAME" >/dev/null 2>&1

echo -e "\033[1;32m[✓] KS Panel restarted successfully.\033[0m"

;;

log)

echo -e "\033[1;36m[KS Panel]\033[0m \033[1;35m» Showing logs...\033[0m"

npx pm2 log "$APP_NAME"

;;

*)

RED="\033[1;31m"
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
WHITE="\033[1;37m"
MAGENTA="\033[1;35m"
RESET="\033[0m"

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║                  [KS Panel]                 ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e ""
echo -e "${YELLOW}Available Commands:${RESET}"
echo -e "  ${GREEN}kspanel install${RESET}      ${WHITE}→ Install KS Panel${RESET}"
echo -e "  ${GREEN}kspanel update${RESET}       ${WHITE}→ Update KS Panel${RESET}"
echo -e "  ${GREEN}kspanel uninstall${RESET}    ${WHITE}→ Remove KS Panel${RESET}"
echo -e "  ${GREEN}kspanel create:user${RESET}  ${WHITE}→ Create a new panel user${RESET}"
echo -e "  ${GREEN}kspanel database${RESET}     ${WHITE}→ Setup Database with Docker${RESET}"
echo -e "  ${GREEN}kspanel start${RESET}        ${WHITE}→ Start KS Panel${RESET}"
echo -e "  ${GREEN}kspanel stop${RESET}         ${WHITE}→ Stop KS Panel${RESET}"
echo -e "  ${GREEN}kspanel restart${RESET}      ${WHITE}→ Restart KS Panel${RESET}"
echo -e "  ${GREEN}kspanel log${RESET}          ${WHITE}→ Show logs${RESET}"
echo -e ""

;;

esac
