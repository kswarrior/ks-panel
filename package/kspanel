#!/bin/bash

APP_NAME="kspanel"
PANEL_DIR="$HOME/.kspanel/panel"
LAUNCHER_DIR="$HOME/.kspanel/launcher"
DATABASE_DIR="$HOME/.kspanel/database"
DOWNLOAD_URL="https://github.com/kswarrior/ks-panel/releases/latest/download"

# === Stylish UI Colors & Symbols ===
RESET="\033[0m"
CYAN="\033[1;36m"
BLUE="\033[1;34m"
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
MAGENTA="\033[1;35m"
WHITE="\033[1;37m"
SUCCESS="${GREEN}[✓]${RESET}"
ERROR="${RED}[✗]${RESET}"
INFO="${CYAN}[i]${RESET}"
ARROW="${BLUE}➤${RESET}"
SEP="${BLUE}──────────────────────────────────────────────${RESET}"

USE_DOCKER_DB=false
if [ -f "$DATABASE_DIR/.env" ] && [ -f "$DATABASE_DIR/docker-compose.yml" ]; then
    if docker-compose -f "$DATABASE_DIR/docker-compose.yml" ps db | grep -q "Up"; then
        USE_DOCKER_DB=true
    fi
fi

case "$1" in

install)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║           KS Panel Installation             ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Initializing installation..."
echo -e "${SEP}"

# Check and install Node.js
if ! command -v node >/dev/null 2>&1; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing Node.js..."
    sudo apt update >/dev/null 2>&1
    sudo apt install -y nodejs npm >/dev/null 2>&1 || {
        echo -e "${ERROR} Node.js installation failed."
        exit 1
    }
fi

# Check and install unzip
if ! command -v unzip >/dev/null 2>&1; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing unzip..."
    sudo apt update >/dev/null 2>&1
    sudo apt install -y unzip >/dev/null 2>&1 || {
        echo -e "${ERROR} unzip installation failed."
        exit 1
    }
fi

# Check and install wget
if ! command -v wget >/dev/null 2>&1; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing wget..."
    sudo apt update >/dev/null 2>&1
    sudo apt install -y wget >/dev/null 2>&1 || {
        echo -e "${ERROR} wget installation failed."
        exit 1
    }
fi

echo -e "${SUCCESS} Node.js, unzip, and wget are installed."
echo -e "${SEP}"

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Setting up directories..."
mkdir -p "$LAUNCHER_DIR" "$PANEL_DIR" "$DATABASE_DIR" || {
echo -e "${ERROR} Failed to create directories."
exit 1
}

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Downloading launcher..."
cd "$LAUNCHER_DIR" || exit 1

wget -q https://raw.githubusercontent.com/kswarrior/ks-panel/refs/heads/main/launcher/index.js -O index.js || {
echo -e "${ERROR} Failed to download launcher."
exit 1
}

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Preparing database directories..."
cd "$DATABASE_DIR" || exit 1
mkdir -p templates plugins

cd plugins || exit 1
wget -q https://raw.githubusercontent.com/kswarrior/ks-panel/refs/heads/main/database/plugins/plugins.json -O plugins.json || {
echo -e "${ERROR} Failed to download plugins.json."
exit 1
}

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Downloading latest panel release..."
cd "$PANEL_DIR" || {
echo -e "${ERROR} Failed to access panel directory."
exit 1
}

wget -q "$DOWNLOAD_URL/panel.zip" -O panel.zip || {
echo -e "${ERROR} Failed to download panel release."
exit 1
}

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Extracting files..."
unzip -qq -o panel.zip || {
echo -e "${ERROR} Extraction failed."
exit 1
}

rm -f panel.zip

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing dependencies..."
npm install --prefix "$PANEL_DIR" --production --no-audit --no-fund >/dev/null 2>&1 || {
echo -e "${ERROR} Dependency installation failed."
exit 1
}

npm link >/dev/null 2>&1

if [ "$USE_DOCKER_DB" = true ]; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Using Docker PostgreSQL..."
    DB_PASS=$(grep DB_PASS "$DATABASE_DIR/.env" | cut -d= -f2-)
    DB_USER="ksuser"
    DB_NAME="kspanel"
    DB_URL="postgres://$DB_USER:$DB_PASS@localhost:5432/$DB_NAME"
else
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing PostgreSQL..."

    if ! command -v psql >/dev/null 2>&1; then
    sudo apt update -y >/dev/null 2>&1
    sudo apt install -y postgresql postgresql-contrib >/dev/null 2>&1 || {
        echo -e "${ERROR} PostgreSQL installation failed."
        exit 1
    }
    fi

    sudo systemctl start postgresql >/dev/null 2>&1
    sudo systemctl enable postgresql >/dev/null 2>&1

    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Generating secure database credentials..."

    echo -ne "${CYAN}[KS Panel]${RESET} ${YELLOW}» Enter database password: ${RESET}"
    read -s DB_PASS
    echo ""

    echo -ne "${CYAN}[KS Panel]${RESET} ${YELLOW}» Confirm password: ${RESET}"
    read -s DB_PASS_CONFIRM
    echo ""

    if [ "$DB_PASS" != "$DB_PASS_CONFIRM" ]; then
      echo -e "${ERROR} Passwords do not match."
      exit 1
    fi

    DB_USER="ksuser"
    DB_NAME="kspanel"

    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Configuring PostgreSQL database..."

    ROLE_SQL=$(cat <<'EOSQL'
DO $$
BEGIN
   IF NOT EXISTS (SELECT FROM pg_catalog.pg_roles WHERE  rolname = '%s') THEN
      CREATE ROLE %s LOGIN PASSWORD '%s';
   END IF;
END
$$;
EOSQL
)

    DB_SQL=$(cat <<'EOSQL'
DO $$
BEGIN
   IF NOT EXISTS (SELECT FROM pg_database WHERE  datname = '%s') THEN
      CREATE DATABASE %s OWNER %s;
   END IF;
END
$$;
EOSQL
)

    GRANT_SQL="GRANT ALL PRIVILEGES ON DATABASE %s TO %s;"

    FULL_SQL=$(printf "${ROLE_SQL}\n${DB_SQL}\n${GRANT_SQL}\n" "$DB_USER" "$DB_USER" "$DB_PASS" "$DB_NAME" "$DB_NAME" "$DB_USER" "$DB_NAME" "$DB_USER")

    sudo -u postgres psql <<< "$FULL_SQL" || {
        echo -e "${ERROR} PostgreSQL configuration failed."
        exit 1
    }

    DB_URL="postgres://$DB_USER:$DB_PASS@localhost:5432/$DB_NAME"
fi

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Updating panel configuration..."

cd "$PANEL_DIR" || exit 1

if [ -f config.json ]; then
sed -i "s|\"databaseURL\": \".*\"|\"databaseURL\": \"$DB_URL\"|g" config.json
fi

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Creating environment file..."

cat > .env <<ENDF
DB_URL=$DB_URL
SESSION_SECRET=$(openssl rand -base64 32)
ENDF

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Seeding database..."
npm run seed >/dev/null 2>&1

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Creating admin user..."
npm run create:user

echo ""
echo -e "${SUCCESS} KS Panel installed successfully."
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Run panel using: ${GREEN}kspanel start${RESET}"
echo -e "${SEP}"

;;

update)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║              KS Panel Updater               ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Updating panel..."
echo -e "${SEP}"
cd "$PANEL_DIR" || {
echo -e "${ERROR} Panel directory not found"
exit 1
}

backup_dir="$HOME/.kspanel/update_backup"
mkdir -p "$backup_dir"
cp .env "$backup_dir/" 2>/dev/null || true
cp config.json "$backup_dir/" 2>/dev/null || true
mv node_modules .node_modules 2>/dev/null || true
rm -rf *

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Downloading latest release..."
wget -q "$DOWNLOAD_URL/panel.zip" -O panel.zip || {
echo -e "${ERROR} Failed to download panel release."
exit 1
}

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Extracting files..."
unzip -qq -o panel.zip || {
echo -e "${ERROR} Extraction failed."
exit 1
}
rm -f panel.zip

mv .node_modules node_modules 2>/dev/null || true

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing dependencies..."
npm install --prefix "$PANEL_DIR" --production --no-audit --no-fund >/dev/null 2>&1
npm link >/dev/null 2>&1

cp "$backup_dir/.env" .env 2>/dev/null || true
cp "$backup_dir/config.json" config.json 2>/dev/null || true
rm -rf "$backup_dir"

echo -e "${SUCCESS} KS Panel updated successfully."
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Restarting service..."
echo -e "${SEP}"

kspanel restart

echo -e "${SUCCESS} KS Panel restarted successfully."
echo -e "${SEP}"

;;

uninstall)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║             KS Panel Uninstaller            ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Stopping service..."
npx pm2 delete "$APP_NAME" >/dev/null 2>&1 || true

if [ "$USE_DOCKER_DB" = true ]; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Stopping Docker DB..."
    docker-compose -f "$DATABASE_DIR/docker-compose.yml" down >/dev/null 2>&1 || true
fi

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Removing all files..."
echo -e "${SEP}"

rm -rf "$HOME/.kspanel"

# Attempt to remove global binary (correction)
if [ -f /usr/local/bin/kspanel ]; then
    if [ "$EUID" -eq 0 ] || command -v sudo >/dev/null 2>&1; then
        if [ "$EUID" -eq 0 ]; then
            rm -f /usr/local/bin/kspanel
        else
            sudo rm -f /usr/local/bin/kspanel
        fi
        echo -e "${SUCCESS} Global binary removed."
    else
        echo -e "${YELLOW}[!] Run as root to remove /usr/local/bin/kspanel${RESET}"
    fi
fi

# Note: Database remains; manual cleanup needed for PostgreSQL
echo -e "${SUCCESS} KS Panel removed successfully."
echo -e "${SEP}"

;;

create:user)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║             Create New User                 ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Creating new user..."
echo -e "${SEP}"

cd "$PANEL_DIR" || {
echo -e "${ERROR} Panel directory not found"
exit 1
}

npm run create:user

echo -e "${SUCCESS} User created successfully."
echo -e "${SEP}"

;;

database)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║          KS Panel Docker Database           ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Setting up Docker database only..."
echo -e "${SEP}"

# Check and install Docker
if ! command -v docker >/dev/null 2>&1; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing Docker..."
    sudo apt update >/dev/null 2>&1
    sudo apt install -y docker.io >/dev/null 2>&1 || {
        echo -e "${ERROR} Docker installation failed."
        exit 1
    }
    sudo systemctl start docker >/dev/null 2>&1
    sudo systemctl enable docker >/dev/null 2>&1
fi

# Check and install Docker Compose
if ! command -v docker-compose >/dev/null 2>&1; then
    echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Installing Docker Compose..."
    sudo apt update >/dev/null 2>&1
    sudo apt install -y docker-compose >/dev/null 2>&1 || {
        echo -e "${ERROR} Docker Compose installation failed."
        exit 1
    }
fi

echo -e "${SUCCESS} Docker and Docker Compose are installed."
echo -e "${SEP}"

mkdir -p "$DATABASE_DIR"

cd "$DATABASE_DIR" || exit 1

# Write docker-compose.yml for database only
cat > docker-compose.yml <<'EOF'
version: '3.8'

services:
  db:
    container_name: kspanel-db
    image: postgres:14
    restart: always
    environment:
      POSTGRES_DB: kspanel
      POSTGRES_USER: ksuser
      POSTGRES_PASSWORD: ${DB_PASS}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

volumes:
  postgres_data:
EOF

echo -ne "${CYAN}[KS Panel]${RESET} ${YELLOW}» Enter database password: ${RESET}"
read -s DB_PASS
echo ""

echo -ne "${CYAN}[KS Panel]${RESET} ${YELLOW}» Confirm password: ${RESET}"
read -s DB_PASS_CONFIRM
echo ""

if [ "$DB_PASS" != "$DB_PASS_CONFIRM" ]; then
  echo -e "${ERROR} Passwords do not match."
  exit 1
fi

# Create .env for compose
cat > .env <<ENDF
DB_PASS=$DB_PASS
ENDF

echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Starting database service..."
docker-compose up -d

# Wait for DB to be ready
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Waiting for database to initialize..."
sleep 10

echo -e "${SUCCESS} KS Panel Database Docker setup completed."
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Database running on localhost:5432"
echo ""
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Connection String:"
echo -e "${WHITE}postgres://ksuser:${DB_PASS}@localhost:5432/kspanel${RESET}"
echo ""
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» To connect panel:"
echo -e "  1. Run: ${GREEN}kspanel install${RESET}"
echo ""
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Manage: cd $DATABASE_DIR && docker-compose logs -f db"
echo -e "${CYAN}[KS Panel]${RESET} ${YELLOW}» Stop: docker-compose down"
echo -e "${SEP}"

;;

start)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║               Starting KS Panel             ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Starting service..."
echo -e "${SEP}"

if [[ -f "$PANEL_DIR/index.js" ]]; then

npx --yes pm2 start "$PANEL_DIR/index.js" --name "$APP_NAME" --cwd "$PANEL_DIR" >/dev/null 2>&1

if [[ $? -eq 0 ]]; then
echo -e "${SUCCESS} KS Panel started successfully."
else
echo -e "${ERROR} Failed to start via pm2."
echo -e "${YELLOW}[!] Manual: cd $PANEL_DIR && npx pm2 start index.js --name $APP_NAME${RESET}"
fi

else

echo -e "${ERROR} Panel not installed. Run 'kspanel install'."

fi

echo -e "${SEP}"

;;

stop)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║                Stopping KS Panel            ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Stopping service..."
npx pm2 stop "$APP_NAME" >/dev/null 2>&1
echo -e "${SUCCESS} KS Panel stopped successfully."
echo -e "${SEP}"

;;

restart)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║               Restarting KS Panel           ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Restarting service..."
npx pm2 restart "$APP_NAME" >/dev/null 2>&1
echo -e "${SUCCESS} KS Panel restarted successfully."
echo -e "${SEP}"

;;

log)

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║                  KS Panel Logs              ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${CYAN}[KS Panel]${RESET} ${ARROW} Showing logs..."
echo -e "${SEP}"
npx pm2 log "$APP_NAME"

;;

*)

RED="\033[1;31m"
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
WHITE="\033[1;37m"
MAGENTA="\033[1;35m"
RESET="\033[0m"

echo -e "${BLUE}╔══════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║                  [KS Panel]                 ║${RESET}"
echo -e "${BLUE}╚══════════════════════════════════════════════╝${RESET}"
echo -e "${SEP}"
echo -e "${YELLOW}Available Commands:${RESET}"
echo -e "  ${GREEN}kspanel install${RESET}      ${BLUE}➤${RESET} ${WHITE}Install KS Panel${RESET}"
echo -e "  ${GREEN}kspanel update${RESET}       ${BLUE}➤${RESET} ${WHITE}Update KS Panel${RESET}"
echo -e "  ${GREEN}kspanel uninstall${RESET}    ${BLUE}➤${RESET} ${WHITE}Remove KS Panel${RESET}"
echo -e "  ${GREEN}kspanel create:user${RESET}  ${BLUE}➤${RESET} ${WHITE}Create a new panel user${RESET}"
echo -e "  ${GREEN}kspanel database${RESET}     ${BLUE}➤${RESET} ${WHITE}Setup Database with Docker${RESET}"
echo -e "  ${GREEN}kspanel start${RESET}        ${BLUE}➤${RESET} ${WHITE}Start KS Panel${RESET}"
echo -e "  ${GREEN}kspanel stop${RESET}         ${BLUE}➤${RESET} ${WHITE}Stop KS Panel${RESET}"
echo -e "  ${GREEN}kspanel restart${RESET}      ${BLUE}➤${RESET} ${WHITE}Restart KS Panel${RESET}"
echo -e "  ${GREEN}kspanel log${RESET}          ${BLUE}➤${RESET} ${WHITE}Show logs${RESET}"
echo -e "${SEP}"

;;

esac
