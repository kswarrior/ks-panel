<%- include('../../components/template') %>
<main id="content" class="p-4 sm:p-6 lg:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-white tracking-tight">Localization</h1>
            <p class="text-neutral-400 text-sm font-medium mt-1">Manage panel languages and translations.</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="javascript:void(0)" onclick="document.getElementById('uploadModal').classList.remove('hidden')" class="px-5 py-2.5 bg-white/5 hover:bg-white/10 text-white text-xs font-bold rounded-xl transition-all border border-white/5 cursor-pointer">
                Upload JSON
            </a>
            <a href="javascript:void(0)" onclick="document.getElementById('createModal').classList.remove('hidden')" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20 cursor-pointer">
                Add Language
            </a>
        </div>
    </div>

    <% if (req.query.msg) { %>
        <div class="mb-6 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
            <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest"><%= req.query.msg %></p>
        </div>
    <% } %>

    <% if (req.query.err) { %>
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-2xl flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
            <p class="text-red-400 text-xs font-bold uppercase tracking-widest"><%= req.query.err %></p>
        </div>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% languages.forEach(lang => { %>
            <div class="glass p-6 group transition-all hover:scale-[1.02]">
                <div class="flex items-start justify-between mb-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center text-xl font-black text-white border border-white/5 group-hover:border-blue-500/50 transition-colors">
                            <%= lang.code.toUpperCase() %>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white"><%= lang.name %></h3>
                            <p class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest"><%= lang.code %></p>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-2">
                    <a href="/admin/languages/edit/<%= lang.code %>" class="flex-1 py-3 bg-white/5 hover:bg-white/10 text-white text-[10px] font-bold rounded-xl text-center transition-all uppercase tracking-widest border border-white/5">
                        Edit Phrases
                    </a>
                    <% if (lang.code !== 'en') { %>
                        <form id="delete-form-<%= lang.code %>" action="/admin/languages/delete/<%= lang.code %>" method="POST" class="flex-shrink-0">
                            <a href="javascript:void(0)" onclick="if(confirm('Are you sure you want to delete this language?')) document.getElementById('delete-form-<%= lang.code %>').submit()" class="p-3 bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white rounded-xl transition-all border border-red-500/20 inline-flex items-center justify-center cursor-pointer">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </a>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- Create Modal -->
    <div id="createModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm hidden">
        <div class="glass max-w-md w-full p-8 relative overflow-hidden">
            <h2 class="text-2xl font-bold text-white mb-2">Add Language</h2>
            <p class="text-neutral-400 text-sm mb-6 font-medium leading-relaxed">Enter a 2-character ISO code (e.g., 'fr', 'es').</p>

            <form action="/admin/languages/create" method="POST" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1 mb-2 block">Language Code</label>
                    <input type="text" name="code" maxlength="2" placeholder="e.g. jp" required class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3.5 text-white placeholder-neutral-600 focus:outline-none focus:border-blue-500 transition-all font-medium">
                </div>
                <div class="flex gap-3 pt-2">
                    <a href="javascript:void(0)" onclick="document.getElementById('createModal').classList.add('hidden')" class="cursor-pointer flex-1 py-4 bg-white/5 hover:bg-white/10 text-white font-bold rounded-2xl text-center transition-all text-xs uppercase tracking-widest border border-white/5">
                        Cancel
                    </a>
                    <button type="submit" class="flex-1 py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-2xl text-center transition-all text-xs uppercase tracking-widest shadow-lg shadow-blue-600/20 border-none">
                        Create
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Upload Modal -->
    <div id="uploadModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm hidden">
        <div class="glass max-w-md w-full p-8 relative overflow-hidden">
            <h2 class="text-2xl font-bold text-white mb-2">Upload JSON</h2>
            <p class="text-neutral-400 text-sm mb-6 font-medium leading-relaxed">Upload a lang.json file for a specific code.</p>

            <form action="/admin/languages/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1 mb-2 block">Language Code</label>
                    <input type="text" name="code" maxlength="2" placeholder="e.g. it" required class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3.5 text-white placeholder-neutral-600 focus:outline-none focus:border-blue-500 transition-all font-medium">
                </div>
                <div>
                    <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-widest ml-1 mb-2 block">Select File</label>
                    <input type="file" name="langFile" accept=".json" required class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-3.5 text-white file:hidden cursor-pointer hover:bg-white/10 transition-all font-medium">
                </div>
                <div class="flex gap-3 pt-2">
                    <a href="javascript:void(0)" onclick="document.getElementById('uploadModal').classList.add('hidden')" class="cursor-pointer flex-1 py-4 bg-white/5 hover:bg-white/10 text-white font-bold rounded-2xl text-center transition-all text-xs uppercase tracking-widest border border-white/5">
                        Cancel
                    </a>
                    <button type="submit" class="flex-1 py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-2xl text-center transition-all text-xs uppercase tracking-widest shadow-lg shadow-blue-600/20 border-none">
                        Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>
<%- include('../../components/footer') %>
