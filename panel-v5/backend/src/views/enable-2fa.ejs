<%- include('components/template') %>

<main id="content" class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="max-w-md w-full glass rounded-3xl shadow-2xl overflow-hidden border border-white/10 animate-scale-in">
    <!-- Header Decor -->
    <div class="h-2 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500"></div>

    <div class="p-8 sm:p-10">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/5 border border-white/10 mb-6 shadow-xl">
           <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
           </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= req.translations.enable2FATitle %></h1>
        <p class="text-sm text-neutral-400 mt-3 leading-relaxed"><%= req.translations.enable2FADescription %></p>
      </div>

      <div class="flex justify-center mb-10">
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-purple-500 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative bg-white p-4 rounded-2xl shadow-2xl">
            <img src="<%= qrCode %>" alt="QR Code for 2FA" class="w-48 h-48 sm:w-56 sm:h-56 object-contain">
          </div>
        </div>
      </div>

      <form action="/verify-2fa" method="POST" class="space-y-6">
        <div class="space-y-2">
          <label for="token" class="block text-xs font-bold text-neutral-500 uppercase tracking-widest ml-1">
            <%= req.translations.authCode %>
          </label>
          <input
            type="text"
            id="token"
            name="token"
            required
            placeholder="000000"
            class="block w-full px-5 py-4 bg-white/5 border border-white/10 rounded-2xl text-white text-center text-2xl font-mono tracking-[0.5em] focus:outline-none focus:ring-2 focus:ring-white/10 focus:border-white/20 transition-all duration-200 placeholder-neutral-700"
          >
        </div>

        <button
          type="submit"
          class="w-full py-4 px-6 bg-white text-black font-bold rounded-2xl shadow-xl shadow-white/5 hover:shadow-white/10 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
        >
          <%= req.translations.verifyCode %>
        </button>
      </form>

      <p class="text-center text-[10px] text-neutral-500 mt-8 uppercase tracking-widest">
        <%= req.translations.poweredBy || 'Secured by' %> KS Panel
      </p>
    </div>
  </div>
</main>

<style>
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-scale-in {
    animation: scaleIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
</style>

<%- include('components/footer') %>
