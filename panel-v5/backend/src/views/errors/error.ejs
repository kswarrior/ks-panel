<%- include('../components/template') %>
<main id="content" class="flex items-center justify-center min-h-[60vh] p-4">
  <div class="glass rounded-[3rem] p-12 md:p-20 shadow-2xl text-center max-w-xl border border-white/10">
    <div class="mb-8 flex justify-center">
      <div class="w-20 h-20 bg-red-500/10 rounded-3xl flex items-center justify-center text-red-500 border border-red-500/20">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>
    <h1 class="text-3xl font-black text-white mb-4">Request Blocked</h1>
    <p class="text-neutral-400 font-medium mb-10"><%= typeof error !== 'undefined' ? error : 'An unexpected security or policy error has occurred.' %></p>
    <a href="/instances" class="inline-flex items-center gap-2 bg-white text-black font-black px-10 py-4 rounded-2xl hover:bg-neutral-200 transition-all uppercase tracking-widest text-xs">
      Return to Dashboard
    </a>
  </div>
</main>
