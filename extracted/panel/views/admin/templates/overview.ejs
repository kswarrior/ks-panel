<%- include('../../components/template') %>

<main id="content">
  <div class="bg-transparent">
    <!-- Header -->
    <div class="sm:flex sm:items-center px-6 sm:px-8 pt-6 pb-4">
      <div class="sm:flex-auto">
        <h1 class="text-xl sm:text-2xl font-semibold leading-7 text-white">Server Templates</h1>
        <p class="mt-2 text-sm text-neutral-400">Manage egg-style server templates (Pterodactyl / PufferPanel like)</p>
      </div>
      <div class="mt-4 sm:mt-0 sm:ml-6 flex flex-wrap gap-3">
        <button id="btnNewTemplate" class="rounded-xl bg-indigo-600/90 hover:bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-lg transition">+ New Template</button>
        <button id="btnImportJson" class="rounded-xl bg-neutral-700/80 hover:bg-neutral-600 px-4 py-2.5 text-sm font-medium text-neutral-200 shadow transition">Import JSON</button>
      </div>
    </div>

    <!-- Table -->
    <div class="px-4 sm:px-8 pb-8">
      <div class="overflow-x-auto rounded-xl bg-neutral-900/30 shadow-lg ring-1 ring-white/5">
        <table class="min-w-full divide-y divide-white/5 text-sm text-left text-neutral-200">
          <thead class="bg-neutral-800/40">
            <tr>
              <th class="py-4 pl-6 pr-3 font-semibold text-neutral-300 uppercase tracking-wide">Name</th>
              <th class="py-4 px-3 font-semibold text-neutral-300 uppercase tracking-wide">Category</th>
              <th class="py-4 px-3 font-semibold text-neutral-300 uppercase tracking-wide">Docker Image</th>
              <th class="py-4 pr-6 pl-3 text-right font-semibold text-neutral-300 uppercase tracking-wide">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% if (templates.length === 0) { %>
              <tr><td colspan="4" class="py-16 text-center text-neutral-500">No templates created yet.</td></tr>
            <% } else { %>
              <% templates.forEach(t => { %>
                <tr class="hover:bg-white/[0.04]">
                  <td class="py-4 pl-6 pr-3">
                    <div class="font-medium text-white"><%= t.meta.display_name || t.meta.name %></div>
                    <div class="text-xs text-neutral-500"><%= t.meta.name %></div>
                  </td>
                  <td class="py-4 px-3 text-neutral-300"><%= t.category || '—' %></td>
                  <td class="py-4 px-3 font-mono text-neutral-400 truncate"><%= t.environment?.docker_image || '—' %></td>
                  <td class="py-4 pr-6 pl-3 text-right whitespace-nowrap">
                    <a href="/admin/templates/download/<%= t.filename %>" class="inline-block px-3 py-1.5 rounded-lg bg-emerald-600/80 hover:bg-emerald-600 text-white mr-2">Download</a>
                    <button class="btnEdit px-3 py-1.5 rounded-lg bg-indigo-600/80 hover:bg-indigo-600 text-white mr-2"
                      data-filename="<%= t.filename %>" data-template='<%= JSON.stringify(t).replace(/'/g, "&apos;") %>'>Edit</button>
                    <button class="btnDelete px-3 py-1.5 rounded-lg bg-red-600/80 hover:bg-red-600 text-white"
                      data-filename="<%= t.filename %>">Delete</button>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div id="templateFormSection" class="hidden px-4 sm:px-8 pb-8">
    <div class="rounded-xl bg-neutral-900/30 shadow-lg ring-1 ring-white/5 overflow-hidden">
      <div class="p-6 border-b border-white/10 bg-neutral-800/40 flex justify-between items-center">
        <h5 id="formTitle" class="text-lg font-semibold text-white">Create New Template</h5>
        <div class="flex items-center gap-4">
          <span class="text-sm text-neutral-400">Mode:</span>
          <select id="modeSelect" class="bg-neutral-800 border border-white/20 rounded px-3 py-1.5 text-sm text-white">
            <option value="form">Form</option>
            <option value="json">Raw JSON</option>
          </select>
        </div>
      </div>

      <form id="templateForm" class="p-6 space-y-8">
        <input type="hidden" id="hiddenFilename">

        <!-- FORM MODE -->
        <div id="formArea">
          <!-- General -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-neutral-300 mb-2">Template Name <span class="text-red-400">*</span></label>
              <input type="text" name="meta.name" required class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white">
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-300 mb-2">Display Name</label>
              <input type="text" name="meta.display_name" class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-neutral-300 mb-2">Description</label>
            <textarea name="meta.description" rows="3" class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white"></textarea>
          </div>

          <!-- Category + Docker -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-neutral-300 mb-2">Category <span class="text-red-400">*</span></label>
              <div class="flex gap-3">
                <select name="category" required class="flex-1 bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white">
                  <% categories.forEach(cat => { %><option value="<%= cat %>"><%= cat %></option><% }) %>
                </select>
                <button type="button" id="btnAddCategory" class="bg-emerald-600 hover:bg-emerald-500 px-6 py-3 rounded-xl text-white text-sm font-medium">+ Add</button>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-300 mb-2">Docker Image <span class="text-red-400">*</span></label>
              <input type="text" name="environment.docker_image" required placeholder="itzg/minecraft-server:latest" class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white">
            </div>
          </div>

          <!-- Variables -->
          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <h3 class="text-lg font-semibold text-white">Variables</h3>
              <button type="button" id="btnAddVar" class="bg-indigo-600 hover:bg-indigo-500 px-5 py-2 rounded-xl text-white text-sm">+ Add Custom Variable</button>
            </div>
            <div id="variablesContainer" class="space-y-4"></div>
          </div>

          <!-- Actions -->
          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <h3 class="text-lg font-semibold text-white">Actions</h3>
              <button type="button" id="btnAddAction" class="bg-indigo-600 hover:bg-indigo-500 px-5 py-2 rounded-xl text-white text-sm">+ Add Action</button>
            </div>
            <div id="actionsContainer" class="space-y-4"></div>
          </div>

          <!-- Install Script -->
          <div>
            <label class="block text-sm font-medium text-neutral-300 mb-2">Install Script</label>
            <textarea name="environment.install_script" rows="10" class="w-full bg-neutral-800 border border-neutral-700 rounded-xl p-4 text-white font-mono"></textarea>
          </div>
        </div>

        <!-- JSON MODE -->
        <div id="jsonArea" class="hidden">
          <textarea id="jsonEditor" class="w-full h-[75vh] bg-neutral-800 border border-neutral-700 rounded-xl p-5 font-mono text-white"></textarea>
        </div>
      </form>

      <div class="p-6 border-t border-white/10 bg-neutral-800/40 flex justify-end gap-4">
        <button id="btnCancelForm" class="px-6 py-2.5 bg-neutral-700 hover:bg-neutral-600 rounded-xl text-sm">Cancel</button>
        <button id="btnSaveTemplate" class="px-8 py-2.5 bg-indigo-600 hover:bg-indigo-500 rounded-xl text-white font-medium shadow-lg">Save Template</button>
      </div>
    </div>
  </div>
</main>

<script>
// ====================== CONFIG ======================
let varIndex = 0, actionIndex = 0;

// ====================== SHOW/HIDE ======================
function showForm(title) {
  document.getElementById("formTitle").textContent = title;
  document.getElementById("btnSaveTemplate").textContent = title.includes("Edit") ? "Update Template" : "Save Template";
  document.getElementById("templateFormSection").classList.remove("hidden");
}
function hideForm() {
  document.getElementById("templateFormSection").classList.add("hidden");
}

// ====================== MODE SWITCH ======================
const modeSelect = document.getElementById("modeSelect");
const formArea = document.getElementById("formArea");
const jsonArea = document.getElementById("jsonArea");
const jsonEditor = document.getElementById("jsonEditor");

modeSelect.onchange = () => {
  const isJson = modeSelect.value === "json";
  formArea.classList.toggle("hidden", isJson);
  jsonArea.classList.toggle("hidden", !isJson);
  if (isJson) jsonEditor.value = JSON.stringify(collectFormData(), null, 2);
};

// ====================== VARIABLES ======================
function addVariable(v = {}) {
  const idx = varIndex++;
  const div = document.createElement("div");
  div.className = "grid grid-cols-1 md:grid-cols-12 gap-4 p-5 rounded-2xl border border-white/10 bg-neutral-800/60 relative";
  div.innerHTML = `
    <div class="md:col-span-2">
      <label class="text-xs text-neutral-400">ID <span class="text-rose-400">*</span></label>
      <input type="text" name="variables[${idx}].id" value="${v.id||''}" required class="w-full bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white font-mono">
    </div>
    <div class="md:col-span-2">
      <label class="text-xs text-neutral-400">Name</label>
      <input type="text" name="variables[${idx}].name" value="${v.name||''}" required class="w-full bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white">
    </div>
    <div class="md:col-span-4">
      <label class="text-xs text-neutral-400">Description</label>
      <input type="text" name="variables[${idx}].description" value="${v.description||''}" class="w-full bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white">
    </div>
    <div class="md:col-span-3">
      <label class="text-xs text-neutral-400">Default Value</label>
      <input type="text" name="variables[${idx}].default" value="${v.default||''}" class="w-full bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white">
    </div>
    <button type="button" onclick="this.closest('div').remove()" class="absolute top-6 right-6 text-3xl text-red-400 hover:text-red-300">×</button>
  `;
  document.getElementById("variablesContainer").appendChild(div);
}

// ====================== ACTIONS ======================
function addAction(a = {}) {
  const idx = actionIndex++;
  const div = document.createElement("div");
  div.className = "grid grid-cols-1 sm:grid-cols-5 gap-4 p-4 bg-neutral-800/50 rounded-xl border border-white/10 relative";
  div.innerHTML = `
    <input type="text" name="actions[${idx}].name" value="${a.name||''}" required placeholder="Name" class="bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white">
    <input type="text" name="actions[${idx}].command" value="${a.command||''}" required placeholder="Command" class="bg-neutral-900 border border-neutral-700 rounded-xl px-4 py-3 text-white sm:col-span-4">
    <button type="button" onclick="this.closest('div').remove()" class="absolute top-4 right-4 text-red-400 text-2xl">×</button>
  `;
  document.getElementById("actionsContainer").appendChild(div);
}

// ====================== COLLECT DATA ======================
function collectFormData() {
  const fd = new FormData(document.getElementById("templateForm"));
  const data = { meta: {}, environment: {}, variables: [], actions: [], category: "" };

  for (let [key, value] of fd) {
    if (key.startsWith("meta.")) data.meta[key.split(".")[1]] = value;
    else if (key.startsWith("environment.")) data.environment[key.split(".")[1]] = value;
    else if (key === "category") data.category = value;
    else if (key.startsWith("variables[")) {
      const match = key.match(/variables\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.variables[i]) data.variables[i] = {};
        data.variables[i][match[2]] = value;
      }
    } else if (key.startsWith("actions[")) {
      const match = key.match(/actions\[(\d+)\]\.(.+)/);
      if (match) {
        const i = parseInt(match[1]);
        if (!data.actions[i]) data.actions[i] = {};
        data.actions[i][match[2]] = value;
      }
    }
  }
  data.variables = data.variables.filter(Boolean);
  data.actions = data.actions.filter(Boolean);
  return data;
}

// ====================== FILL FORM ======================
function fillForm(data) {
  document.querySelector('[name="meta.name"]').value = data.meta?.name || "";
  document.querySelector('[name="meta.display_name"]').value = data.meta?.display_name || "";
  document.querySelector('[name="meta.description"]').value = data.meta?.description || "";
  document.querySelector('[name="category"]').value = data.category || "";
  document.querySelector('[name="environment.docker_image"]').value = data.environment?.docker_image || "";
  document.querySelector('[name="environment.install_script"]').value = data.environment?.install_script || "";

  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;
  (data.variables || []).forEach(v => addVariable(v));

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  (data.actions || []).forEach(addAction);

  jsonEditor.value = JSON.stringify(data, null, 2);
}

function loadDefaultForm() {
  document.getElementById("variablesContainer").innerHTML = "";
  varIndex = 0;

  document.getElementById("actionsContainer").innerHTML = "";
  actionIndex = 0;
  [{name:"start",command:"docker start {{container_name}}"},
   {name:"stop",command:"docker stop {{container_name}}"},
   {name:"restart",command:"docker restart {{container_name}}"}].forEach(addAction);
}

// ====================== SAVE ======================
document.getElementById("btnSaveTemplate").onclick = async () => {
  let payload = modeSelect.value === "json" ? JSON.parse(jsonEditor.value) : collectFormData();

  const filename = document.getElementById("hiddenFilename").value;
  const url = filename ? `/admin/templates/${filename}` : "/admin/templates";
  const method = filename ? "PUT" : "POST";

  const res = await fetch(url, {
    method,
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(payload)
  });

  if (res.ok) {
    alert("✅ Template saved!");
    hideForm();
    location.reload();
  } else {
    const err = await res.text();
    alert("❌ Error: " + err.substring(0, 150));
  }
};

// ====================== BUTTONS ======================
document.getElementById("btnNewTemplate").onclick = () => {
  document.getElementById("hiddenFilename").value = "";
  document.getElementById("templateForm").reset();
  modeSelect.value = "form";
  modeSelect.onchange();
  loadDefaultForm();
  showForm("Create New Template");
};

document.getElementById("btnImportJson").onclick = () => {
  const input = document.createElement("input");
  input.type = "file"; input.accept = ".json";
  input.onchange = e => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const data = JSON.parse(ev.target.result);
        document.getElementById("hiddenFilename").value = "";
        modeSelect.value = "json";
        modeSelect.onchange();
        jsonEditor.value = JSON.stringify(data, null, 2);
        showForm("Import Template");
      } catch { alert("Invalid JSON"); }
    };
    reader.readAsText(file);
  };
  input.click();
};

document.getElementById("btnAddCategory").onclick = async () => {
  const name = prompt("New category name:");
  if (!name?.trim()) return;
  const res = await fetch("/admin/templates/category", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({name: name.trim()})
  });
  if (res.ok) {
    const {categories} = await res.json();
    const select = document.querySelector('[name="category"]');
    select.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join("");
    select.value = name.trim();
  } else alert("Failed to add category");
};

document.getElementById("btnCancelForm").onclick = hideForm;
document.getElementById("btnAddVar").onclick = () => addVariable({}, false);
document.getElementById("btnAddAction").onclick = () => addAction();

// ====================== EDIT / DELETE ======================
document.querySelectorAll(".btnEdit").forEach(btn => {
  btn.onclick = () => {
    const data = JSON.parse(btn.dataset.template);
    document.getElementById("hiddenFilename").value = btn.dataset.filename;
    fillForm(data);
    modeSelect.value = "form";
    modeSelect.onchange();
    showForm(`Edit: ${data.meta.name}`);
  };
});

document.querySelectorAll(".btnDelete").forEach(btn => {
  btn.onclick = async () => {
    if (!confirm("Delete this template permanently?")) return;
    await fetch(`/admin/templates/${btn.dataset.filename}`, {method: "DELETE"});
    location.reload();
  };
});
</script>
