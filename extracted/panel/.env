# ===============================
# KS Panel Environment Settings
# ===============================

# PostgreSQL full connection URL
DB_URL=postgres://ksuser:your_secure_password@localhost:5432/kspanel

# Session secret for express-session (use a long random string in production)
SESSION_SECRET=your_random_secret

# ===============================
# Database Configuration
# ===============================

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kspanel
DB_USER=ksuser
DB_PASS=your_secure_password
DB_LOG=false
